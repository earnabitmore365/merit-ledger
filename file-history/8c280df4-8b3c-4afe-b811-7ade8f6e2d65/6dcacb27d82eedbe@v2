#!/usr/bin/env python3
"""
通用 AI 调用模块 — 替代 subprocess.run(["claude", ...])

SDK 直接调用，不启动进程、不加载 hooks。亚秒级到几秒。
本地用 MiniMax M2.7-highspeed（零 Anthropic 配额），推 GitHub 改回 Haiku。

用法：
    from ai_call import ai_call
    result = ai_call("你是审查员。判断是否批准。输出JSON。")
    # result = '{"approved": true, "reason": "xxx"}'
"""

import json
import os

# MiniMax 配置
_MINIMAX_KEY_PATH = os.path.expanduser("~/.claude/.minimax_key")
_MINIMAX_BASE_URL = "https://api.minimax.io/anthropic"
_MINIMAX_MODEL = "MiniMax-M2.7-highspeed"

# Haiku fallback（无 MiniMax key 时用）
_HAIKU_MODEL = "claude-haiku-4-5-20251001"


def ai_call(prompt, system=None, max_tokens=300, timeout=15):
    """
    调用 AI 获取文本回复。

    优先用 MiniMax（零 Anthropic 配额），无 key 则 fallback 到 Haiku。
    返回纯文本字符串。超时或失败返回空字符串。
    """
    try:
        import anthropic
    except ImportError:
        return ""

    try:
        # 优先 MiniMax
        if os.path.exists(_MINIMAX_KEY_PATH):
            key = open(_MINIMAX_KEY_PATH).read().strip()
            client = anthropic.Anthropic(
                api_key=key,
                base_url=_MINIMAX_BASE_URL,
                timeout=timeout,
            )
            model = _MINIMAX_MODEL
        else:
            # Fallback: Haiku（需要 ANTHROPIC_API_KEY 环境变量）
            api_key = os.environ.get("ANTHROPIC_API_KEY", "")
            if not api_key:
                return ""
            client = anthropic.Anthropic(
                api_key=api_key,
                timeout=timeout,
            )
            model = _HAIKU_MODEL

        kwargs = {
            "model": model,
            "max_tokens": max_tokens,
            "messages": [{"role": "user", "content": prompt}],
        }
        if system:
            kwargs["system"] = system

        resp = client.messages.create(**kwargs)

        # 提取 text block（MiniMax 可能返回 thinking + text）
        for block in resp.content:
            if getattr(block, "type", "") == "text":
                return block.text.strip()

        # 没有 text block，尝试从 thinking 提取
        for block in resp.content:
            if getattr(block, "type", "") == "thinking":
                thinking = getattr(block, "thinking", "")
                # 尝试从 thinking 里找 JSON
                start = thinking.find("{")
                end = thinking.rfind("}") + 1
                if start >= 0 and end > start:
                    return thinking[start:end]

        return ""
    except Exception:
        return ""


def ai_call_json(prompt, system=None, max_tokens=300, timeout=15):
    """
    调用 AI 获取 JSON 回复。自动解析，失败返回空 dict。
    """
    text = ai_call(prompt, system=system, max_tokens=max_tokens, timeout=timeout)
    if not text:
        return {}
    try:
        start = text.find("{")
        end = text.rfind("}") + 1
        if start >= 0 and end > start:
            return json.loads(text[start:end])
    except (json.JSONDecodeError, Exception):
        pass
    return {}
