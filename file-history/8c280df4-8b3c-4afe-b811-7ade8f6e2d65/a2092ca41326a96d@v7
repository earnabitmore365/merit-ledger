### 2b. 计划内放行：精确路径匹配

```python
def is_planned_action(mission, tool_name, data):
    """精确匹配，不用子串"""
    file_path = os.path.abspath(data.get("tool_input", {}).get("file_path", ""))
    cmd = data.get("tool_input", {}).get("command", "")
    for item in mission.get("items", []):
        planned = os.path.abspath(os.path.expanduser(item.get("file", "")))
        if item["type"] == "modify" and tool_name in ("Write", "Edit"):
            if planned == file_path:
                return True
        if item["type"] == "delete":
            # 完整路径（目录+文件名）都要命中
            if planned and os.path.basename(planned) in cmd and os.path.dirname(planned) in cmd:
                return True
        if item["type"] == "create" and tool_name == "Write":
            if planned == file_path:
                return True
    return False
```

