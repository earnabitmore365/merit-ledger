_MINIMAX_MODEL = "MiniMax-M2.7-highspeed"
_HAIKU_MODEL = "claude-haiku-4-5-20251001"


def ai_call(prompt, system=None, max_tokens=300, timeout=15):
    """SDK 直调 AI，零 hook 开销。优先 MiniMax，fallback Haiku。"""
    try:
        import anthropic
    except ImportError:
        return ""
    try:
        if os.path.exists(_MINIMAX_KEY_PATH):
            key = open(_MINIMAX_KEY_PATH).read().strip()
            client = anthropic.Anthropic(api_key=key, base_url=_MINIMAX_BASE_URL, timeout=timeout)
            model = _MINIMAX_MODEL
        else:
            api_key = os.environ.get("ANTHROPIC_API_KEY", "")
            if not api_key:
                return ""
            client = anthropic.Anthropic(api_key=api_key, timeout=timeout)
            model = _HAIKU_MODEL
        kwargs = {"model": model, "max_tokens": max_tokens, "messages": [{"role": "user", "content": prompt}]}
        if system:
            kwargs["system"] = system
        resp = client.messages.create(**kwargs)
        for block in resp.content:
            if getattr(block, "type", "") == "text":
                return block.text.strip()
        for block in resp.content:
            if getattr(block, "type", "") == "thinking":
                thinking = getattr(block, "thinking", "")
                start = thinking.find("{")
                end = thinking.rfind("}") + 1
                if start >= 0 and end > start:
                    return thinking[start:end]
        return ""
    except Exception:
        return ""


def ai_call_json(prompt, system=None, max_tokens=300, timeout=15):
    """调 AI 获取 JSON，自动解析。"""
    text = ai_call(prompt, system=system, max_tokens=max_tokens, timeout=timeout)
    if not text:
        return {}
    try:
        start = text.find("{")
        end = text.rfind("}") + 1
        if start >= 0 and end > start:
            return json.loads(text[start:end])
    except (json.JSONDecodeError, Exception):
        pass
    return {}


