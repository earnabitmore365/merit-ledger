#!/usr/bin/env python3
"""
gp_scheduler.py 补丁：
1. 修正 MEMORY_ESTIMATES（基于压力测试实测数据）
2. 每个 worker 启动时用 resource.setrlimit 限制 RSS
3. 加 WORKER_MEM_LIMIT_MB 常量
"""

SCHEDULER_PATH = '/home/pc_heisi_claude/trading/gp_engine/gp_scheduler.py'
with open(SCHEDULER_PATH) as f:
    content = f.read()

# === 1. 修正 MEMORY_ESTIMATES ===
old_estimates = """# 每个周期的预估内存用量 (MB)
MEMORY_ESTIMATES = {
    '1m': 800, '5m': 250, '15m': 120, '30m': 100,
    '1h': 80, '2h': 60, '4h': 50, '8h': 40, '12h': 40, '1d': 30,
}

TOTAL_MEMORY_MB = 22000   # 可用内存上限 (24GB - OS/哨兵开销)"""

new_estimates = """# 每个周期的预估内存用量 (MB) — 基于 2026-04-02 压力测试实测 RSS
# 测试方法：4 workers × 1m 周期，无限制，观察峰值 RSS
# 结果：1m 峰值 5-7.5GB/worker，4个同时跑会 OOM
MEMORY_ESTIMATES = {
    '1m': 5500, '5m': 2000, '15m': 1200, '30m': 1200,
    '1h': 1600, '2h': 600, '4h': 300, '8h': 200, '12h': 200, '1d': 100,
}

TOTAL_MEMORY_MB = 22000   # 可用内存上限 (24GB - OS/哨兵开销)
WORKER_MEM_LIMIT_MB = 5500  # 单 worker RSS 硬上限（超过则被 OS kill，防止 OOM 拖垮全局）"""

if 'WORKER_MEM_LIMIT_MB' in content:
    print("WORKER_MEM_LIMIT_MB 已存在，跳过预估修正")
else:
    content = content.replace(old_estimates, new_estimates)
    print("✅ MEMORY_ESTIMATES 修正完成 + WORKER_MEM_LIMIT_MB 添加")

# === 2. 在 import 区加 resource ===
if 'import resource' not in content:
    content = content.replace(
        'from collections import Counter',
        'from collections import Counter\nimport resource'
    )
    print("✅ import resource 添加")

# === 3. 在 subprocess.Popen 前加 preexec_fn 限制内存 ===
old_popen = """        proc = subprocess.Popen(
            cmd, stdout=log_f, stderr=subprocess.STDOUT,
            cwd=BASE_DIR
        )"""

new_popen = """        # 内存限制：每个 worker 硬上限 WORKER_MEM_LIMIT_MB（防 OOM 拖垮系统）
        def _set_mem_limit():
            mem_bytes = WORKER_MEM_LIMIT_MB * 1024 * 1024
            resource.setrlimit(resource.RLIMIT_AS, (mem_bytes, mem_bytes))

        proc = subprocess.Popen(
            cmd, stdout=log_f, stderr=subprocess.STDOUT,
            cwd=BASE_DIR, preexec_fn=_set_mem_limit
        )"""

if 'preexec_fn=_set_mem_limit' in content:
    print("preexec_fn 已存在，跳过")
else:
    content = content.replace(old_popen, new_popen)
    print("✅ worker 内存限制（preexec_fn）添加")

# === 4. 更新文档注释 ===
old_doc = """硬件参考（24GB RAM）:
  1m 数据 ~4.5GB/进程，30m ~4GB，1h ~3GB，其余 ≤250MB"""

new_doc = """硬件参考（24GB RAM，2026-04-02 压力测试实测）:
  1m: 5-7.5GB/worker（4个同跑会OOM），建议最多3个
  5m: 1.5-2GB/worker，1h: 1.1-1.6GB/worker
  4 workers 安全上限: WORKER_MEM_LIMIT_MB=5500（超过被 kill，不拖垮系统）"""

content = content.replace(old_doc, new_doc)

with open(SCHEDULER_PATH, 'w') as f:
    f.write(content)

print("✅ gp_scheduler.py 全部补丁完成")
