#!/usr/bin/env python3
"""
PreToolUse hook — 门卫系统（信用积分联动）
Write/Edit 前根据角色信用等级执行对应检查。
积分高→查得少，积分低→全查或要老板签字。
"""

import json
import os
import sys

CREDIT_PATH = os.path.expanduser("~/.claude/credit.json")

# 等级定义：score 阈值 → (level, title)
LEVEL_THRESHOLDS = [
    (95, 5, "化神"),
    (80, 4, "元婴"),
    (50, 3, "金丹"),
    (20, 2, "筑基"),
    (0,  1, "锁灵"),
]

# 数据文件后缀 / 路径模式 — 破坏性写入拦截
PROTECTED_EXTENSIONS = {".db", ".sqlite", ".sqlite3", ".parquet"}
PROTECTED_PATH_PARTS = {"/data/", "/reports/", "/seed_"}


def get_level(score):
    for threshold, level, title in LEVEL_THRESHOLDS:
        if score >= threshold:
            return level, title
    return 1, "锁灵"


def determine_agent(data):
    """从 hook 数据判断当前角色"""
    cwd = data.get("cwd", "")
    agent_id = data.get("agent_id", "")
    home = os.path.expanduser("~")

    # subagent → 白纱
    if agent_id:
        return "白纱"

    # auto-trading 项目 → 黑丝
    if "auto-trading" in cwd:
        return "黑丝"

    # home 目录或其他 → 太极
    return "太极"


def load_credit(agent_name):
    """读取角色积分，文件不存在返回默认值"""
    if not os.path.exists(CREDIT_PATH):
        defaults = {"黑丝": 10, "白纱": 40, "太极": 60}
        return defaults.get(agent_name, 50)
    try:
        with open(CREDIT_PATH) as f:
            credit_data = json.load(f)
        agent_info = credit_data.get("agents", {}).get(agent_name, {})
        return agent_info.get("score", 50)
    except Exception:
        return 50


def output_deny(reason):
    print(json.dumps({
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "permissionDecision": "deny",
            "permissionDecisionReason": reason,
        }
    }))


def output_ask(reason):
    print(json.dumps({
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "permissionDecision": "ask",
            "permissionDecisionReason": reason,
        }
    }))


# ── 检查函数 ─────────────────────────────────────────

def check_destructive(data):
    """检查 A：是否写入受保护的数据文件"""
    file_path = data.get("tool_input", {}).get("file_path", "")
    if not file_path:
        return None

    _, ext = os.path.splitext(file_path)
    if ext.lower() in PROTECTED_EXTENSIONS:
        return f"门卫拦截：禁止直接写入数据文件 [{os.path.basename(file_path)}]。G-003 铁律。"

    for pattern in PROTECTED_PATH_PARTS:
        if pattern in file_path:
            return f"门卫拦截：文件路径含受保护目录 [{pattern}]。G-003 铁律。"

    return None


def check_read_before_write(data):
    """检查 B：Write/Edit 前是否 Read 过该文件"""
    file_path = data.get("tool_input", {}).get("file_path", "")
    if not file_path:
        return None

    # 新文件豁免（文件不存在 = 创建，不需要先 Read）
    if not os.path.exists(file_path):
        return None

    transcript_path = data.get("transcript_path", "")
    if not transcript_path or not os.path.exists(transcript_path):
        return None

    # 解析 transcript 找 Read 调用
    read_files = set()
    try:
        with open(transcript_path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                    # tool_use 类型的条目，name=Read
                    if entry.get("type") == "tool_use" and entry.get("name") == "Read":
                        read_path = entry.get("input", {}).get("file_path", "")
                        if read_path:
                            read_files.add(read_path)
                    # 也检查 content 数组中的 tool_use
                    msg = entry.get("message", {})
                    content = msg.get("content", [])
                    if isinstance(content, list):
                        for block in content:
                            if isinstance(block, dict):
                                if block.get("type") == "tool_use" and block.get("name") == "Read":
                                    read_path = block.get("input", {}).get("file_path", "")
                                    if read_path:
                                        read_files.add(read_path)
                except (json.JSONDecodeError, AttributeError):
                    continue
    except Exception:
        # transcript 读取失败不应阻塞操作
        return None

    if file_path not in read_files:
        return (
            f"门卫拦截：文件 [{os.path.basename(file_path)}] 本次会话未 Read 过。"
            f"先读再改（完整性-1）。"
        )

    return None


def check_grep_before_edit(data):
    """检查 C：Edit 前是否 Grep/Glob 过（搜索引用）"""
    tool_name = data.get("tool_name", "")
    if tool_name != "Edit":
        return None

    transcript_path = data.get("transcript_path", "")
    if not transcript_path or not os.path.exists(transcript_path):
        return None

    has_search = False
    try:
        with open(transcript_path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                    if entry.get("type") == "tool_use" and entry.get("name") in ("Grep", "Glob"):
                        has_search = True
                        break
                    msg = entry.get("message", {})
                    content = msg.get("content", [])
                    if isinstance(content, list):
                        for block in content:
                            if isinstance(block, dict):
                                if block.get("type") == "tool_use" and block.get("name") in ("Grep", "Glob"):
                                    has_search = True
                                    break
                    if has_search:
                        break
                except (json.JSONDecodeError, AttributeError):
                    continue
    except Exception:
        return None

    if not has_search:
        return (
            "门卫拦截：本次会话未执行 Grep/Glob 搜索。"
            "改代码前先查影响链路（完整性-1）。"
        )

    return None


def check_plan_format(data):
    """检查 D：Write plan 文件时内容是否包含三准则"""
    tool_name = data.get("tool_name", "")
    if tool_name != "Write":
        return None

    file_path = data.get("tool_input", {}).get("file_path", "")
    if not file_path:
        return None

    # 只检查 plan 目录下的文件
    if "/plans/" not in file_path and "/plan" not in os.path.basename(file_path).lower():
        return None

    content = data.get("tool_input", {}).get("content", "")
    required = ["完整性", "真实性", "有效性"]
    missing = [r for r in required if r not in content]

    if missing:
        return (
            f"门卫拦截：方案文件缺少三准则评估 [{', '.join(missing)}]。"
            f"方案必须按三准则评估（有效性-1）。"
        )

    return None


def check_new_file(data):
    """检查 E：创建新文件需确认必要性"""
    tool_name = data.get("tool_name", "")
    if tool_name != "Write":
        return None

    file_path = data.get("tool_input", {}).get("file_path", "")
    if not file_path:
        return None

    if not os.path.exists(file_path):
        # 豁免：plan 文件、临时文件
        if "/plans/" in file_path or file_path.startswith("/tmp/"):
            return None
        return (
            f"门卫拦截：即将创建新文件 [{os.path.basename(file_path)}]。"
            f"确认有必要再创建，做完不留残（完整性-2）。"
        )

    return None


# ── 主逻辑 ────────────────────────────────────────────

def main():
    try:
        data = json.load(sys.stdin)
    except (json.JSONDecodeError, Exception):
        return

    tool_name = data.get("tool_name", "")
    if tool_name not in ("Write", "Edit"):
        return

    agent_name = determine_agent(data)
    score = load_credit(agent_name)
    level, title = get_level(score)

    # Lv.1 锁灵：所有 Write/Edit → ask 老板
    if level == 1:
        output_ask(
            f"{agent_name}（Lv.1 锁灵 · {score}分）信用不足，"
            f"所有写入操作需老板批准。"
        )
        return

    # Lv.2+ 按等级执行检查
    checks = []

    # A. 破坏性操作 — 所有等级都查（G-003 铁律）
    checks.append(check_destructive)

    if level <= 3:
        # B. Read-before-Write — Lv.2 和 Lv.3
        checks.append(check_read_before_write)

    if level <= 2:
        # C. Grep-before-Edit — 仅 Lv.2
        checks.append(check_grep_before_edit)
        # D. 方案格式 — 仅 Lv.2
        checks.append(check_plan_format)
        # E. 新文件创建 — 仅 Lv.2
        checks.append(check_new_file)

    for check_fn in checks:
        reason = check_fn(data)
        if reason:
            output_deny(f"[{agent_name} Lv.{level} {title}] {reason}")
            return

    # 全部通过，不输出 = 默认放行


if __name__ == "__main__":
    main()
