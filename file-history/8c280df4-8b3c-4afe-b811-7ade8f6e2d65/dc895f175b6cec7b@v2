#!/usr/bin/env python3
"""
影太极 — GP 进化树自动监控 + 干预
系统 crontab 每 15 分钟执行，零 Anthropic 配额消耗。

功能：
1. SSH 检查 Nitro 上 GP 调度器状态
2. 自动干预：进程挂了重启、内存超限减 worker
3. 滚动更新 log，老板醒来看 log 就知道全部情况
"""

import json
import os
import subprocess
import sys
from datetime import datetime

LOG_PATH = os.path.expanduser("~/.claude/gp_monitor.log")
STATE_PATH = os.path.expanduser("~/.claude/gp_monitor_state.json")
SSH_KEY = os.path.expanduser("~/.ssh/id_ed25519")
NITRO_HOST = "pc_heisi_claude@100.88.115.98"
SSH_CMD = f"ssh -i {SSH_KEY} -o ConnectTimeout=10 -o StrictHostKeyChecking=no {NITRO_HOST}"

GP_DIR = "~/trading/gp_engine"
MAX_MEMORY_GB = 21  # 超过 21GB 减 worker
DEFAULT_WORKERS = 4
REDUCED_WORKERS = 2
DEFAULT_ROUNDS = 3


def log(msg):
    ts = datetime.now().strftime("%Y-%m-%d %H:%M")
    line = f"[{ts}] {msg}"
    print(line)
    with open(LOG_PATH, "a") as f:
        f.write(line + "\n")
    # 保留最近 500 行
    try:
        with open(LOG_PATH) as f:
            lines = f.readlines()
        if len(lines) > 500:
            with open(LOG_PATH, "w") as f:
                f.writelines(lines[-500:])
    except Exception:
        pass


def ssh_run(cmd):
    """SSH 到 Nitro 执行命令，返回 stdout"""
    try:
        result = subprocess.run(
            f'{SSH_CMD} "{cmd}"',
            shell=True, capture_output=True, text=True, timeout=30,
        )
        return result.stdout.strip(), result.returncode
    except subprocess.TimeoutExpired:
        return "SSH超时", -1
    except Exception as e:
        return str(e), -1


def load_state():
    if os.path.exists(STATE_PATH):
        try:
            with open(STATE_PATH) as f:
                return json.load(f)
        except Exception:
            pass
    return {"last_grad_count": 0, "restarts": 0, "total_checks": 0}


def save_state(state):
    with open(STATE_PATH, "w") as f:
        json.dump(state, f, ensure_ascii=False, indent=2)


def check_processes():
    """检查 gp_scheduler 和 gp_evolve 进程"""
    out, rc = ssh_run("ps aux | grep -E 'gp_scheduler|gp_evolve' | grep -v grep")
    if rc != 0:
        return None, None, "SSH连接失败"

    lines = [l for l in out.split("\n") if l.strip()]
    scheduler_alive = any("gp_scheduler" in l for l in lines)
    workers = [l for l in lines if "gp_evolve" in l]

    # 解析当前跑的币种/周期
    current_jobs = []
    for w in workers:
        parts = w.split()
        coin = interval = "?"
        for i, p in enumerate(parts):
            if p == "--coin" and i + 1 < len(parts):
                coin = parts[i + 1]
            if p == "--interval" and i + 1 < len(parts):
                interval = parts[i + 1]
        current_jobs.append(f"{coin}/{interval}")

    return scheduler_alive, current_jobs, None


def check_memory():
    """检查内存使用"""
    out, _ = ssh_run("free -m | grep Mem")
    try:
        # free -m 格式: Mem: total used free shared buff/cache available
        parts = out.split()
        total = int(parts[1]) / 1024
        used = int(parts[2]) / 1024
        available = int(parts[-1]) / 1024
        return total, used, available
    except Exception:
        return 24, 0, 24


def check_graduates():
    """检查毕业生数量"""
    out, _ = ssh_run(f"find {GP_DIR}/graduates/ -name '*.json' -type f 2>/dev/null | wc -l")
    try:
        return int(out.strip())
    except Exception:
        return 0


def check_new_graduates(last_count):
    """检查新毕业生详情"""
    current = check_graduates()
    if current <= last_count:
        return current, []

    out, _ = ssh_run(
        f"find {GP_DIR}/graduates/ -name '*.json' -type f -printf '%T+ %p\\n' 2>/dev/null | sort -r | head -5"
    )
    new_grads = []
    for line in out.split("\n"):
        line = line.strip()
        if line:
            new_grads.append(line.split("/")[-1] if "/" in line else line)
    return current, new_grads


def check_errors():
    """检查最新日志错误"""
    out, _ = ssh_run(
        f"grep -i 'error\\|traceback\\|killed\\|oom' {GP_DIR}/scheduler_output.log 2>/dev/null | tail -3"
    )
    return out.strip() if out.strip() else None


def check_latest_progress():
    """检查最新几个组合的进度"""
    out, _ = ssh_run(
        f"for f in $(ls -t {GP_DIR}/results/scheduler_logs/*.log 2>/dev/null | head -3); do "
        f"echo $(basename $f .log): $(grep -c '第.*轮' $f 2>/dev/null)轮 "
        f"$(grep -c '毕业' $f 2>/dev/null)毕业; done"
    )
    return out.strip() if out.strip() else "无进度"


def restart_scheduler(workers=DEFAULT_WORKERS):
    """重启 GP 调度器"""
    # 先确保旧进程停了
    ssh_run(f"pkill -f gp_scheduler; sleep 2")
    ssh_run(f"pkill -f gp_evolve; sleep 2")
    # 启动
    out, rc = ssh_run(
        f"cd {GP_DIR} && nohup python3 gp_scheduler.py --workers {workers} --rounds {DEFAULT_ROUNDS} "
        f"> scheduler_output.log 2>&1 & echo $!"
    )
    return out.strip()


def main():
    state = load_state()
    state["total_checks"] = state.get("total_checks", 0) + 1

    # 1. 连接检查
    scheduler_alive, current_jobs, error = check_processes()
    if error:
        log(f"❌ {error}")
        save_state(state)
        return

    # 2. 内存检查
    total, used, available = check_memory()

    # 3. 毕业生检查
    grad_count, new_grads = check_new_graduates(state.get("last_grad_count", 0))

    # 4. 错误检查
    errors = check_errors()

    # 5. 进度
    progress = check_latest_progress()

    # ── 自动干预逻辑 ──

    intervention = None

    # 干预1：进程挂了 → 重启
    if not scheduler_alive:
        log(f"⚠️ 调度器挂了！自动重启...")
        pid = restart_scheduler()
        state["restarts"] = state.get("restarts", 0) + 1
        intervention = f"自动重启，新PID={pid}，累计重启{state['restarts']}次"

    # 干预2：内存超限 → 减 worker 重启
    elif used > MAX_MEMORY_GB and len(current_jobs) > REDUCED_WORKERS:
        log(f"⚠️ 内存 {used:.1f}/{total:.1f}GB 超限！减 worker 到 {REDUCED_WORKERS} 重启...")
        pid = restart_scheduler(workers=REDUCED_WORKERS)
        intervention = f"内存超限减worker，新PID={pid}"

    # ── 写 log ──

    jobs_str = ", ".join(current_jobs) if current_jobs else "无"
    status = "✅" if scheduler_alive and not errors else "⚠️"

    parts = [
        f"{status} 第{state['total_checks']}次检查",
        f"{len(current_jobs)}工位: {jobs_str}",
        f"内存: {used:.1f}/{total:.1f}GB",
        f"毕业生: {grad_count}个",
    ]

    if new_grads:
        parts.append(f"🎓 新毕业: {', '.join(new_grads[:3])}")

    if intervention:
        parts.append(f"🔧 干预: {intervention}")

    if errors:
        parts.append(f"❗ 错误: {errors[:100]}")

    parts.append(f"进度: {progress[:100]}")

    log(" | ".join(parts))

    # 更新状态
    state["last_grad_count"] = grad_count
    state["last_jobs"] = current_jobs
    state["last_memory_gb"] = round(used, 1)
    save_state(state)


if __name__ == "__main__":
    main()
