#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
太极审查引擎 — 从 conversations.db 拉取黑丝记录并输出结构化 JSON。

用法：
  python3 audit_engine.py                    # 最近 8 小时
  python3 audit_engine.py --hours 24         # 最近 24 小时
  python3 audit_engine.py --session SID      # 指定会话
  python3 audit_engine.py --all-today        # 今天全部
"""

import argparse
import json
import os
import sqlite3
import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path


DB_PATH = Path.home() / ".claude" / "conversations.db"
MEMSEARCH_DIR = Path("/Users/allenbot/project/auto-trading/.memsearch/memory")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="太极审查引擎")
    group = parser.add_mutually_exclusive_group()
    group.add_argument(
        "--hours",
        type=int,
        default=8,
        help="拉最近 N 小时的记录（默认 8）",
    )
    group.add_argument(
        "--session",
        type=str,
        default=None,
        help="拉指定 session_id 的记录",
    )
    group.add_argument(
        "--all-today",
        action="store_true",
        help="拉今天全部记录",
    )
    return parser.parse_args()


def get_time_threshold(args: argparse.Namespace) -> tuple[str | None, str | None]:
    """
    返回 (start_time_iso, label)。
    start_time_iso 为 None 表示用 session 模式，无时间过滤。
    """
    now = datetime.now()

    if args.all_today:
        start = now.replace(hour=0, minute=0, second=0, microsecond=0)
        return start.isoformat(sep=" ", timespec="seconds"), "今天全部"

    if args.session:
        return None, f"会话 {args.session}"

    hours = args.hours
    start = now - timedelta(hours=hours)
    return start.isoformat(sep=" ", timespec="seconds"), f"最近 {hours} 小时"


def fetch_messages(
    conn: sqlite3.Connection,
    start_time: str | None,
    session_id: str | None,
) -> list[dict]:
    """从 conversations.db 拉取 auto-trading 项目的消息。"""
    cursor = conn.cursor()

    if session_id:
        cursor.execute(
            """
            SELECT time, speaker, content, tags, session_id
            FROM messages
            WHERE session_id = ?
            ORDER BY id
            """,
            (session_id,),
        )
    else:
        cursor.execute(
            """
            SELECT time, speaker, content, tags, session_id
            FROM messages
            WHERE project LIKE '%auto-trading%'
              AND time >= ?
            ORDER BY id
            """,
            (start_time,),
        )

    rows = cursor.fetchall()
    return [
        {
            "time": row[0],
            "speaker": row[1],
            "content": row[2],
            "tags": row[3],
            "session_id": row[4],
        }
        for row in rows
    ]


def get_unique_sessions(messages: list[dict]) -> list[str]:
    seen: list[str] = []
    for m in messages:
        sid = m.get("session_id") or ""
        if sid and sid not in seen:
            seen.append(sid)
    return seen


def get_time_range(messages: list[dict]) -> dict:
    if not messages:
        return {"start": None, "end": None}
    times = [m["time"] for m in messages if m.get("time")]
    if not times:
        return {"start": None, "end": None}
    return {"start": min(times), "end": max(times)}


def read_memsearch_summary() -> str:
    """读取 memsearch 目录下最新 .md 文件的前 500 字作为摘要。"""
    if not MEMSEARCH_DIR.exists():
        return "(memsearch 目录不存在)"

    md_files = sorted(
        MEMSEARCH_DIR.glob("*.md"),
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )

    if not md_files:
        return "(memsearch 目录无 .md 文件)"

    latest = md_files[0]
    try:
        text = latest.read_text(encoding="utf-8")
        snippet = text[:500]
        return f"[最新文件: {latest.name}]\n{snippet}{'...' if len(text) > 500 else ''}"
    except Exception as exc:
        return f"(读取失败: {exc})"


def main() -> None:
    args = parse_args()
    start_time, label = get_time_threshold(args)

    # 检查数据库是否存在
    if not DB_PATH.exists():
        result = {
            "error": f"数据库不存在: {DB_PATH}",
            "messages": [],
            "memsearch_summary": read_memsearch_summary(),
            "session_count": 0,
            "message_count": 0,
            "time_range": {"start": None, "end": None},
            "label": label,
        }
        print(json.dumps(result, ensure_ascii=False, indent=2))
        sys.exit(0)

    try:
        conn = sqlite3.connect(str(DB_PATH))
        messages = fetch_messages(conn, start_time, args.session)
        conn.close()
    except sqlite3.Error as exc:
        result = {
            "error": f"数据库查询失败: {exc}",
            "messages": [],
            "memsearch_summary": read_memsearch_summary(),
            "session_count": 0,
            "message_count": 0,
            "time_range": {"start": None, "end": None},
            "label": label,
        }
        print(json.dumps(result, ensure_ascii=False, indent=2))
        sys.exit(0)

    sessions = get_unique_sessions(messages)
    time_range = get_time_range(messages)
    memsearch_summary = read_memsearch_summary()

    result = {
        "messages": messages,
        "memsearch_summary": memsearch_summary,
        "session_count": len(sessions),
        "message_count": len(messages),
        "time_range": time_range,
        "label": label,
        "sessions": sessions,
    }

    print(json.dumps(result, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    main()
