#!/usr/bin/env python3
"""批处理 pending_ai_tasks.jsonl — 逐条调 MiniMax 处理"""
import sys, os, json, time

sys.path.insert(0, os.path.expanduser("~/.claude/merit"))
from merit_gate import (
    ai_call, ai_call_json, update_credit, record_learning,
    log_shiwei_action, auto_reflect_and_evolve, SCORING_TABLE,
    PENDING_AI_TASKS_PATH
)

def process_stop_eval(task):
    """处理 stop_eval 类型：调 MiniMax 评分"""
    agent = task.get("agent", "太极")
    prompt = task.get("prompt", "")
    if not prompt:
        return None

    raw_text = ai_call(prompt, timeout=30)
    if not raw_text:
        return {"status": "minimax_failed"}

    # 解析 JSON
    parsed = {}
    try:
        start = raw_text.find("{")
        end = raw_text.rfind("}") + 1
        if start >= 0 and end > start:
            parsed = json.loads(raw_text[start:end])
    except Exception:
        pass

    if not parsed:
        return {"status": "parse_failed", "raw": raw_text[:200]}

    behavior = parsed.get("behavior", "none")
    delta = parsed.get("delta", 0)
    note = parsed.get("note", "")

    if behavior in SCORING_TABLE:
        delta = SCORING_TABLE[behavior]
    delta = max(-20, min(8, delta))

    if delta != 0:
        update_credit(agent, delta, f"[补评]{task['ts']} 石卫评估[{behavior}]: {note}")
        auto_reflect_and_evolve(agent, delta, behavior, note)
        log_shiwei_action("Stop-补评", agent, "AI评分",
                          f"[{behavior}] {delta:+d}", "SCORE",
                          detail=note, ai_raw=raw_text[:300])

    return {"status": "ok", "behavior": behavior, "delta": delta, "note": note}


def process_rule_proposal(task):
    """处理 rule_proposal 类型：调 MiniMax 生成规则提案"""
    prompt = task.get("prompt", "")
    if not prompt:
        return None

    raw_text = ai_call(prompt, max_tokens=16384, timeout=60)
    if not raw_text:
        return {"status": "minimax_failed"}

    # 规则提案存到 rule_proposals.json
    proposals_path = os.path.join(os.path.expanduser("~/.claude/merit"), "rule_proposals.json")
    try:
        proposals = []
        if os.path.exists(proposals_path):
            with open(proposals_path) as f:
                proposals = json.load(f)
        proposals.append({
            "ts": task.get("ts", ""),
            "source": "pending_batch",
            "raw": raw_text[:2000],
        })
        with open(proposals_path, "w") as f:
            json.dump(proposals, f, ensure_ascii=False, indent=2)
    except Exception as e:
        return {"status": "save_failed", "error": str(e)}

    return {"status": "ok", "preview": raw_text[:200]}


def main():
    if not os.path.exists(PENDING_AI_TASKS_PATH):
        print("没有 pending 任务")
        return

    with open(PENDING_AI_TASKS_PATH) as f:
        tasks = [json.loads(line.strip()) for line in f if line.strip()]

    total = len(tasks)
    print(f"共 {total} 条待处理")

    failed = []
    stats = {"stop_eval_ok": 0, "stop_eval_fail": 0,
             "rule_ok": 0, "rule_fail": 0,
             "score_total": 0}

    for i, task in enumerate(tasks):
        task_type = task.get("type", "unknown")
        ts = task.get("ts", "?")
        print(f"\n[{i+1}/{total}] {task_type} @ {ts} ...", end=" ", flush=True)

        try:
            if task_type == "stop_eval":
                result = process_stop_eval(task)
                if result and result["status"] == "ok":
                    stats["stop_eval_ok"] += 1
                    stats["score_total"] += result.get("delta", 0)
                    print(f"✅ [{result['behavior']}] {result['delta']:+d}")
                else:
                    stats["stop_eval_fail"] += 1
                    failed.append(task)
                    print(f"❌ {result}")
            elif task_type == "rule_proposal":
                result = process_rule_proposal(task)
                if result and result["status"] == "ok":
                    stats["rule_ok"] += 1
                    print(f"✅ {result['preview'][:80]}")
                else:
                    stats["rule_fail"] += 1
                    failed.append(task)
                    print(f"❌ {result}")
            else:
                print(f"⚠️ 未知类型 {task_type}")
                failed.append(task)
        except Exception as e:
            print(f"❌ 异常: {e}")
            failed.append(task)

        # 防止 rate limit
        time.sleep(1)

    # 处理完毕，清空原文件（失败的写回）
    if failed:
        with open(PENDING_AI_TASKS_PATH, "w") as f:
            for t in failed:
                f.write(json.dumps(t, ensure_ascii=False) + "\n")
        print(f"\n⚠️ {len(failed)} 条失败，已写回 pending")
    else:
        with open(PENDING_AI_TASKS_PATH, "w") as f:
            f.write("")
        print("\n✅ 全部处理完毕，pending 已清空")

    print(f"\n=== 统计 ===")
    print(f"stop_eval: {stats['stop_eval_ok']} 成功 / {stats['stop_eval_fail']} 失败")
    print(f"rule_proposal: {stats['rule_ok']} 成功 / {stats['rule_fail']} 失败")
    print(f"积分净变化: {stats['score_total']:+d}")


if __name__ == "__main__":
    main()
