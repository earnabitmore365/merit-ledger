#!/usr/bin/env python3
"""
实盘监控 Bot — Mac Mini 上运行

SSH 读 Nitro 日志 → 解析关键事件 → Telegram 推送
独立于交易进程，交易崩了监控还能报警。

用法:
  export TELEGRAM_BOT_TOKEN="8626060346:AAFnkP2V7avxpmnFsO8DUsHEDB7SmqtMJhg"
  export TELEGRAM_CHAT_ID="6506412244"
  python3 monitor_bot.py
"""

import os
import re
import json
import time
import subprocess
import urllib.request

# ==================== 配置 ====================

SSH_CMD = "ssh -p 2222 -o ConnectTimeout=10 -o StrictHostKeyChecking=no pc_heisi_claude@localhost"
NITRO_DIR = "/home/pc_heisi_claude/trading"
LOG_FILES = ['sol_1m_live', 'eth_1m_live', 'xrp_5m_live', 'gateway']
COIN_MAP = {'sol_1m_live': 'SOL', 'eth_1m_live': 'ETH',
            'xrp_5m_live': 'XRP', 'gateway': 'GW'}

CHECK_INTERVAL = 30     # 轮询间隔（秒）
SUMMARY_INTERVAL = 3600 # 每小时摘要

TOKEN = os.getenv('TELEGRAM_BOT_TOKEN', '8626060346:AAFnkP2V7avxpmnFsO8DUsHEDB7SmqtMJhg')
CHAT_ID = os.getenv('TELEGRAM_CHAT_ID', '6506412244')


# ==================== Telegram ====================

def send_telegram(message):
    """纯 urllib 推送，零依赖，纯文本"""
    if not TOKEN or not CHAT_ID:
        return
    try:
        url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
        data = json.dumps({'chat_id': CHAT_ID, 'text': message}).encode()
        req = urllib.request.Request(
            url, data=data, headers={'Content-Type': 'application/json'})
        urllib.request.urlopen(req, timeout=5)
    except Exception:
        pass  # 推送失败静默，绝不能影响监控循环


# ==================== SSH ====================

def ssh_exec(cmd):
    """SSH 执行命令，返回 stdout"""
    full = f"{SSH_CMD} '{cmd}'"
    try:
        result = subprocess.run(
            full, shell=True, capture_output=True, text=True, timeout=20)
        return result.stdout.strip()
    except subprocess.TimeoutExpired:
        return None
    except Exception:
        return None


def poll_once():
    """一次 SSH 获取全部数据（进程数 + 4 个日志文件）"""
    cmd = (
        f'cd {NITRO_DIR} && '
        'echo "===PROC==="; '
        'ps aux | grep -E "feed_gateway|bitmex_race" | grep -v grep | wc -l; '
        'echo "===SOL==="; tail -50 logs/sol_1m_live.log 2>/dev/null; '
        'echo "===ETH==="; tail -50 logs/eth_1m_live.log 2>/dev/null; '
        'echo "===XRP==="; tail -50 logs/xrp_5m_live.log 2>/dev/null; '
        'echo "===GW==="; tail -50 logs/gateway.log 2>/dev/null'
    )
    out = ssh_exec(cmd)
    if out is None:
        return None

    sections = {}
    current = None
    for line in out.split('\n'):
        if line.startswith('===') and line.endswith('==='):
            current = line.strip('=')
            sections[current] = []
        elif current is not None:
            sections[current].append(line)
    return sections


# ==================== 事件解析 ====================

def parse_events(lines, coin):
    """解析日志行，提取关键事件"""
    events = []
    for line in lines:
        # 实际交易（操作 != NONE）
        m = re.search(r'操作=(\w+).*持仓=(\w+).*余额=\$(\S+)', line)
        if m and m.group(1) != 'NONE':
            regime_m = re.search(r'regime=(\S+)', line)
            regime = regime_m.group(1) if regime_m else ''
            events.append(
                f"🔵 {coin} {m.group(1)} | 持仓={m.group(2)} | "
                f"余额=${m.group(3)} | {regime}")

        # Regime 变盘
        if '⚡变盘' in line:
            detail = line.split('⚡')[1].strip()[:60] if '⚡' in line else ''
            events.append(f"⚡ {coin} {detail}")

        # 智能平仓
        if '[Regime]' in line and ('平多仓' in line or '平空仓' in line):
            detail = line.split('[Regime]')[1].strip()[:80]
            events.append(f"🟡 {coin} {detail}")

        # TTP 触发
        if 'TTP tick触发' in line or 'TTP触发' in line:
            events.append(f"📊 {coin} TTP触发!")

        # TTP 探针
        if '[TTP Probe] 🔥利润新高' in line:
            m2 = re.search(r'profit=(\S+)', line)
            profit = m2.group(1) if m2 else ''
            events.append(f"🔥 {coin} 利润新高 {profit}")

        if '[TTP Probe] 首次激活' in line:
            events.append(f"🎯 {coin} TTP 首次激活!")

        if '[TTP Probe] TTP上移' in line or '[TTP Probe] TTP下移' in line:
            events.append(f"📈 {coin} TTP level 变化")

        # HALT 熔断
        if 'HALT' in line and '熔断' in line:
            events.append(f"🚨 {coin} HALT 熔断!")

        # 严重错误
        if coin == 'GW' and ('ERROR' in line or 'corrupted' in line):
            events.append(f"⚠️ Gateway ERROR: {line[-60:]}")

    return events


# ==================== 主循环 ====================

def main():
    print(f"Monitor Bot 启动: 每 {CHECK_INTERVAL}s 轮询, Telegram @{CHAT_ID}")

    # 去重：初始化为当前时间（跳过历史）
    now_str = time.strftime('%Y-%m-%d %H:%M:%S')
    last_seen = {f: now_str for f in LOG_FILES}

    last_summary = time.time()
    last_proc_alert = 0

    # 启动确认
    send_telegram("✅ 监控已启动\nMac Mini → Nitro SSH 轮询\n每30s检查 | 每小时摘要")

    while True:
        try:
            sections = poll_once()

            if sections is None:
                # SSH 失败
                if time.time() - last_proc_alert > 300:
                    send_telegram("⚠️ SSH 隧道断了！无法连接 Nitro")
                    last_proc_alert = time.time()
                time.sleep(CHECK_INTERVAL)
                continue

            # 1. 进程存活检测
            proc_lines = sections.get('PROC', ['0'])
            try:
                proc_count = int(proc_lines[0].strip())
            except (ValueError, IndexError):
                proc_count = 0

            if proc_count < 8:
                if time.time() - last_proc_alert > 60:
                    send_telegram(f"🚨 进程异常: {proc_count}/8 存活!")
                    last_proc_alert = time.time()

            # 2. 读日志找新事件
            section_map = {'SOL': 'sol_1m_live', 'ETH': 'eth_1m_live',
                           'XRP': 'xrp_5m_live', 'GW': 'gateway'}

            for section_key, log_name in section_map.items():
                lines = sections.get(section_key, [])
                coin = COIN_MAP[log_name]
                new_lines = []
                for line in lines:
                    ts = re.match(r'(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})', line)
                    if ts and ts.group(1) > last_seen[log_name]:
                        new_lines.append(line)

                if new_lines:
                    # 更新 last_seen
                    last_ts = re.match(
                        r'(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})', new_lines[-1])
                    if last_ts:
                        last_seen[log_name] = last_ts.group(1)

                    events = parse_events(new_lines, coin)
                    for event in events:
                        send_telegram(event)

            # 3. 每小时摘要
            if time.time() - last_summary > SUMMARY_INTERVAL:
                # 从最新日志提取余额和 regime
                summary_parts = [f"📊 每小时状态 | 进程: {proc_count}/8"]

                for section_key, log_name in section_map.items():
                    if log_name == 'gateway':
                        continue
                    lines = sections.get(section_key, [])
                    coin = COIN_MAP[log_name]
                    # 从最后几行找余额和 regime
                    bal = '?'
                    regime = '?'
                    position = '?'
                    for line in reversed(lines):
                        if '余额=' in line:
                            bm = re.search(r'余额=\$(\S+)', line)
                            if bm:
                                bal = bm.group(1)
                            rm = re.search(r'regime=(\S+)', line)
                            if rm:
                                regime = rm.group(1)
                            pm = re.search(r'持仓=(\S+)', line)
                            if pm:
                                position = pm.group(1)
                            break
                    summary_parts.append(f"{coin} {position} | ${bal} | {regime}")

                send_telegram('\n'.join(summary_parts))
                last_summary = time.time()

        except Exception as e:
            # 整体异常静默
            print(f"监控异常: {e}")

        time.sleep(CHECK_INTERVAL)


if __name__ == '__main__':
    main()
