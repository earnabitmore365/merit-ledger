## 重启命令（进程死了用这个）

```bash
# 1. 杀旧进程
ssh -p 2222 pc_heisi_claude@localhost "pkill -f 'feed_gateway\|bitmex_race'"

# 2. 启动 Gateway（等10秒）
ssh -p 2222 -f pc_heisi_claude@localhost "cd /home/pc_heisi_claude/trading && nohup python3 src/data/feed_gateway.py --coins SOL,ETH,XRP --intervals 1m,1m,5m >> logs/gateway.log 2>&1 &"
sleep 10

# 3. 启动 3 策略（间隔 5 秒）
ssh -p 2222 -f pc_heisi_claude@localhost "cd /home/pc_heisi_claude/trading && nohup python3 bitmex_race.py --feed --mirror --strategy mean_reversion --coin SOL --interval 1m --min-bet 100 >> logs/sol_1m_live.log 2>&1 &"
sleep 5
ssh -p 2222 -f pc_heisi_claude@localhost "cd /home/pc_heisi_claude/trading && nohup python3 bitmex_race.py --feed --mirror --strategy mean_reversion --coin ETH --interval 1m --min-bet 100 >> logs/eth_1m_live.log 2>&1 &"
sleep 5
ssh -p 2222 -f pc_heisi_claude@localhost "cd /home/pc_heisi_claude/trading && nohup python3 bitmex_race.py --feed --mirror --strategy mean_reversion --coin XRP --interval 5m --min-bet 80 >> logs/xrp_5m_live.log 2>&1 &"
