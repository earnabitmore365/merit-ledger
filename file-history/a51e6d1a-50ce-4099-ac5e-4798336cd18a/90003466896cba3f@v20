## 反向合约公式（完整代码）

```python
# sim_coin_margin.py

INITIAL_USD = 500.0   # 等值美元，按首笔交易价格换算成币
LEVERAGE = 10
BET_PCT = 0.10        # 10% 余额
MIN_BET_USD = 100.0   # 最低开仓等值 $100

def simulate_coin_margin(trades, use_2yr=False):
    first_price = trades[0][0]
    initial_coins = INITIAL_USD / first_price  # $500 → 币
    balance = initial_coins
    peak = balance
    max_dd = 0.0

    for entry_p, exit_p, direction, fee_usd, fund_usd, slip_usd, open_time in trades:
        # 下注：余额的 10%，不低于 $100 等值的币
        min_bet_coins = MIN_BET_USD / entry_p
        bet = max(balance * BET_PCT, min_bet_coins)

        if bet > balance:
            return {'busted': True, ...}

        # ===== 反向合约 PnL（分母 = exit） =====
        if direction == 'long':
            raw_pnl = bet * LEVERAGE * (exit_p - entry_p) / exit_p
        else:
            raw_pnl = bet * LEVERAGE * (entry_p - exit_p) / exit_p

        # ===== 费用缩放 =====
        # 种子里的费用基于 $1 × 10x = $10 名义价值
        # 缩放到实际仓位
        scale = bet * entry_p
        cost_usd = (fee_usd + fund_usd + slip_usd) * scale
        cost_coins = cost_usd / exit_p  # 按 exit_price 结算为币

        pnl = raw_pnl - cost_coins

        # 逐仓爆仓 = 最多亏保证金
        if pnl < -bet:
            pnl = -bet

        balance += pnl
        if balance <= 0:
            return {'busted': True, ...}

        if balance > peak:
            peak = balance
        dd = (peak - balance) / peak * 100
        if dd > max_dd:
            max_dd = dd
```

