```python
#!/usr/bin/env python3
"""
通讯部总机 — Feed Gateway

单 WebSocket 连 BitMEX → ZMQ PUB 广播给所有策略进程。
策略进程零 REST 调用（除下单外）。
"""

import os, sys, json, time, logging, threading, argparse
from datetime import datetime, timezone
from typing import Dict, List, Optional
from collections import deque

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..'))

import zmq
from exchange.bitmex.adapter import BitMEXAdapter, SYMBOL_MAP, API_BASE
from exchange.bitmex.websocket import BitMEXWebSocket

logger = logging.getLogger('FeedGateway')

def parse_ts(iso_str: str) -> int:
    dt = datetime.fromisoformat(iso_str.replace('Z', '+00:00'))
    return int(dt.timestamp() * 1000)

def normalize_kline(row: dict) -> dict:
    ts_ms = parse_ts(row['timestamp'])
    return {
        'timestamp': ts_ms, 'time': ts_ms,
        'open': float(row.get('open', 0)),
        'high': float(row.get('high', 0)),
        'low': float(row.get('low', 0)),
        'close': float(row.get('close', 0)),
        'volume': float(row.get('volume', 0)),
    }

_REVERSE_SYMBOL_MAP = {v: k for k, v in SYMBOL_MAP.items()}

def symbol_to_coin(symbol: str) -> Optional[str]:
    return _REVERSE_SYMBOL_MAP.get(symbol)

class FeedGateway:
    def __init__(self, coins, intervals, zmq_port=5555):
        self.coins = coins
        self.intervals = intervals
        self.zmq_port = zmq_port
        self._kline_windows = {}
        for coin in coins:
            key = f"{coin}_{intervals[coin]}"
            self._kline_windows[key] = deque(maxlen=250)
        self._last_price = {}
        self._positions = {}
        self._margin = {}
        self._lock = threading.Lock()
        self._ctx = zmq.Context()
        self._pub = None
        self._rep = None
        self._ws = None
        self._running = False

    def start(self, api_key, api_secret, testnet=False):
        self._running = True
        self._load_history(api_key, api_secret, testnet)

        self._ws = BitMEXWebSocket(testnet=testnet)
        # 【Gemini终极补丁】重连时全量覆盖K线
        self._ws._on_reconnect_callback = lambda: self._load_history(api_key, api_secret, testnet)
        ok = self._ws.connect(api_key=api_key, api_secret=api_secret)
        if not ok:
            return

        self._ws._on_table_callback = self._on_ws_table

        # ZMQ（先HWM再bind）
        self._pub = self._ctx.socket(zmq.PUB)
        self._pub.setsockopt(zmq.SNDHWM, 1000)
        self._pub.setsockopt(zmq.RCVHWM, 1000)
        self._pub.bind(f"tcp://127.0.0.1:{self.zmq_port}")
        self._rep = self._ctx.socket(zmq.REP)
        self._rep.bind(f"tcp://127.0.0.1:{self.zmq_port + 1}")

        # 订阅
        topics = []
        for coin in self.coins:
            sym = SYMBOL_MAP.get(coin, f"{coin}USDT")
            topics.append(f'tradeBin{self.intervals[coin]}:{sym}')
            topics.append(f'trade:{sym}')
        self._ws.subscribe_private()
        self._ws.subscribe(topics)

        threading.Thread(target=self._rep_loop, daemon=True).start()
        threading.Thread(target=self._heartbeat_loop, daemon=True).start()

        while self._running:
            time.sleep(1)

    def _load_history(self, api_key, api_secret, testnet):
        """全量覆盖K线窗口（= 赋值，不extend）"""
        adapter = BitMEXAdapter({'api_key': api_key, 'api_secret': api_secret, 'testnet': testnet})
        adapter._ws = None
        adapter._connected = True
        for coin in self.coins:
            interval = self.intervals[coin]
            key = f"{coin}_{interval}"
            klines = adapter.get_klines(coin, interval, limit=250)
            if klines:
                self._kline_windows[key] = deque(klines, maxlen=250)  # = 赋值，不extend！

    def _on_ws_table(self, table, action, rows):
        if not self._pub:
            return
        if table.startswith('tradeBin'):
            interval = table.replace('tradeBin', '')
            for row in rows:
                coin = symbol_to_coin(row.get('symbol', ''))
                if not coin: continue
                kline = normalize_kline(row)
                key = f"{coin}_{interval}"
                with self._lock:
                    w = self._kline_windows.get(key)
                    if w is not None and (not w or w[-1]['timestamp'] != kline['timestamp']):
                        w.append(kline)
                self._pub.send_string(f"KLINE.{coin}.{interval} {json.dumps(kline)}")
        elif table == 'trade':
            for row in rows:
                coin = symbol_to_coin(row.get('symbol', ''))
                price = row.get('price', 0)
                if coin and price > 0:
                    with self._lock: self._last_price[coin] = price
                    self._pub.send_string(f"TICK.{coin} {price}")
        elif table == 'position':
            for row in rows:
                coin = symbol_to_coin(row.get('symbol', ''))
                if coin:
                    with self._lock:
                        if action in ('partial','insert'): self._positions[coin] = row
                        elif action == 'update': self._positions.setdefault(coin,{}).update(row)
                        elif action == 'delete': self._positions.pop(coin, None)
                    self._pub.send_string(f"POS.{coin} {json.dumps(row)}")
        elif table == 'margin':
            for row in rows:
                with self._lock: self._margin.update(row)
                self._pub.send_string(f"BALANCE {json.dumps(row)}")

    def _rep_loop(self):
        """REQ/REP: 策略启动时请求历史K线"""
        poller = zmq.Poller()
        poller.register(self._rep, zmq.POLLIN)
        while self._running:
            if self._rep in dict(poller.poll(1000)):
                msg = self._rep.recv_string()
                parts = msg.split()
                if len(parts)==3 and parts[0]=='KLINES':
                    key = f"{parts[1]}_{parts[2]}"
                    with self._lock:
                        data = list(self._kline_windows.get(key, deque()))
                    self._rep.send_string(json.dumps(data))
                else:
                    self._rep.send_string("[]")

    def _heartbeat_loop(self):
        while self._running:
            if self._pub: self._pub.send_string(f"HEARTBEAT {time.time():.3f}")
            time.sleep(10)
```

### feed_client.py（224行）

```python
#!/usr/bin/env python3
"""通讯部客户端 — 线程安全 ZMQ 订阅"""

import json, time, threading, logging
from typing import Dict, List, Optional
from collections import deque
import zmq

logger = logging.getLogger('FeedClient')

class FeedClient:
    def __init__(self, pub_endpoint='tcp://127.0.0.1:5555',
                 req_endpoint='tcp://127.0.0.1:5556'):
        self._ctx = zmq.Context()
        self._sub = self._ctx.socket(zmq.SUB)
        self._sub.connect(pub_endpoint)
        self._req = self._ctx.socket(zmq.REQ)
        self._req.connect(req_endpoint)
        self._req.setsockopt(zmq.RCVTIMEO, 10000)
        self._lock = threading.Lock()
        self._kline_windows = {}
        self._last_price = {}
        self._positions = {}
        self._balance = {}
        self._last_heartbeat = time.time()
        self._kline_event = threading.Event()
        self._running = True
        threading.Thread(target=self._recv_loop, daemon=True).start()

    def subscribe(self, coin, interval):
        self._sub.setsockopt_string(zmq.SUBSCRIBE, f'KLINE.{coin}.{interval}')
        self._sub.setsockopt_string(zmq.SUBSCRIBE, f'TICK.{coin}')
        self._sub.setsockopt_string(zmq.SUBSCRIBE, f'POS.{coin}')
        self._sub.setsockopt_string(zmq.SUBSCRIBE, 'BALANCE')
        self._sub.setsockopt_string(zmq.SUBSCRIBE, 'HEARTBEAT')
        with self._lock:
            self._kline_windows.setdefault(f"{coin}_{interval}", deque(maxlen=250))

    def request_history(self, coin, interval):
        try:
            self._req.send_string(f"KLINES {coin} {interval}")
            klines = json.loads(self._req.recv_string())
            with self._lock:
                self._kline_windows[f"{coin}_{interval}"] = deque(klines, maxlen=250)
            return klines
        except zmq.Again:
            return []

    def wait_for_kline(self, timeout=120):
        got = self._kline_event.wait(timeout=timeout)
        self._kline_event.clear()
        return got

    def get_klines(self, coin, interval):
        with self._lock: return list(self._kline_windows.get(f"{coin}_{interval}", deque()))

    def get_price(self, coin):
        with self._lock: return self._last_price.get(coin, 0.0)

    def get_position(self, coin):
        with self._lock: return self._positions.get(coin)

    def get_balance(self):
        with self._lock: return dict(self._balance)

    def is_gateway_alive(self):
        return (time.time() - self._last_heartbeat) < 30

    def _recv_loop(self):
        poller = zmq.Poller()
        poller.register(self._sub, zmq.POLLIN)
        while self._running:
            if self._sub not in dict(poller.poll(1000)): continue
            msg = self._sub.recv_string()
            sp = msg.index(' ')
            topic, payload = msg[:sp], msg[sp+1:]
            if topic.startswith('KLINE.'):
                parts = topic.split('.')
                kline = json.loads(payload)
                key = f"{parts[1]}_{parts[2]}"
                with self._lock:
                    w = self._kline_windows.get(key)
                    if w is not None and (not w or w[-1]['timestamp']!=kline['timestamp']):
                        w.append(kline)
                self._kline_event.set()
            elif topic.startswith('TICK.'):
                with self._lock: self._last_price[topic.split('.')[1]] = float(payload)
            elif topic.startswith('POS.'):
                with self._lock: self._positions[topic.split('.')[1]] = json.loads(payload)
            elif topic == 'BALANCE':
                with self._lock: self._balance.update(json.loads(payload))
            elif topic == 'HEARTBEAT':
                self._last_heartbeat = float(payload)
