```python
# __init__ 新增:
self._on_table_callback = None      # 泛用回调：(table, action, rows)
self._on_reconnect_callback = None  # 重连成功回调（Gateway 用于全量覆盖 K 线）
self._kline_data = {}   # "{symbol}_{interval}" → latest kline dict
self._margin_data = {}  # 最新余额

# _on_message 末尾新增（在现有 4 个 elif 之后）:
elif table.startswith('tradeBin'):
    self._handle_tradebin(table, action, rows)
elif table == 'margin':
    self._handle_margin(action, rows)
# 泛用回调
if self._on_table_callback:
    try:
        self._on_table_callback(table, action, rows)
    except Exception as e:
        logger.error(f"Table callback 错误: {e}")

def _handle_tradebin(self, table: str, action: str, rows: list):
    """处理 tradeBin1m/tradeBin5m K线数据"""
    with self._lock:
        for row in rows:
            symbol = row.get('symbol', '')
            # table = "tradeBin1m" or "tradeBin5m"
            interval = table.replace('tradeBin', '')  # "1m" or "5m"
            key = f"{symbol}_{interval}"
            self._kline_data[key] = row

def _handle_margin(self, action: str, rows: list):
    """处理 margin 余额更新"""
    with self._lock:
        for row in rows:
            self._margin_data.update(row)

def get_kline(self, symbol: str, interval: str) -> Optional[Dict]:
    """获取最新K线"""
    with self._lock:
        return self._kline_data.get(f"{symbol}_{interval}")

def get_margin(self) -> Dict:
    """获取最新余额"""
    with self._lock:
        return dict(self._margin_data)
