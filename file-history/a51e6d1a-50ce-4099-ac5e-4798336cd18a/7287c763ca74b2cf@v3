### 步骤 3：新建 `lab/src/data/feed_client.py`（约 200 行）

**核心代码框架：**

```python
#!/usr/bin/env python3
"""
通讯部客户端 — 策略进程用来接收 Gateway 推送
"""

import json, time, threading, logging
from typing import Dict, List, Optional
from collections import deque

import zmq

logger = logging.getLogger('FeedClient')


class FeedClient:
    """ZMQ 订阅客户端 — 线程安全"""

    def __init__(self, pub_endpoint='tcp://127.0.0.1:5555',
                 req_endpoint='tcp://127.0.0.1:5556'):
        self._ctx = zmq.Context()

        # SUB socket (接收实时推送)
        self._sub = self._ctx.socket(zmq.SUB)
        self._sub.connect(pub_endpoint)

        # REQ socket (启动时请求历史 K 线)
        self._req = self._ctx.socket(zmq.REQ)
        self._req.connect(req_endpoint)
        self._req.setsockopt(zmq.RCVTIMEO, 10000)  # 10s 超时

        # 内部缓存（线程安全）
        self._lock = threading.Lock()
        self._kline_windows: Dict[str, deque] = {}   # "{coin}_{interval}" → deque
        self._last_price: Dict[str, float] = {}       # coin → price
        self._positions: Dict[str, dict] = {}          # coin → position dict
        self._balance: dict = {}                       # 最新余额
        self._last_heartbeat: float = time.time()

        # K 线事件信号（用于事件驱动主循环）
        self._kline_event = threading.Event()

        # 后台接收线程
        self._running = True
        self._recv_thread = threading.Thread(target=self._recv_loop, daemon=True)
        self._recv_thread.start()

    def subscribe(self, coin: str, interval: str):
        """订阅指定 coin 的所有频道"""
        self._sub.setsockopt_string(zmq.SUBSCRIBE, f'KLINE.{coin}.{interval}')
        self._sub.setsockopt_string(zmq.SUBSCRIBE, f'TICK.{coin}')
        self._sub.setsockopt_string(zmq.SUBSCRIBE, f'POS.{coin}')
        self._sub.setsockopt_string(zmq.SUBSCRIBE, 'BALANCE')
        self._sub.setsockopt_string(zmq.SUBSCRIBE, 'HEARTBEAT')

        key = f"{coin}_{interval}"
        with self._lock:
            if key not in self._kline_windows:
                self._kline_windows[key] = deque(maxlen=250)

        logger.info(f"已订阅: {coin}/{interval}")

    def request_history(self, coin: str, interval: str) -> List[Dict]:
        """向 Gateway 请求历史 K 线（启动时一次性调用）"""
        try:
            self._req.send_string(f"KLINES {coin} {interval}")
            reply = self._req.recv_string()
            klines = json.loads(reply)
            key = f"{coin}_{interval}"
            with self._lock:
                self._kline_windows[key] = deque(klines, maxlen=250)
            logger.info(f"历史 K 线: {coin}/{interval} = {len(klines)} 根")
            return klines
        except zmq.Again:
            logger.error("请求历史 K 线超时（Gateway 无响应）")
            return []

    def wait_for_kline(self, timeout: float = 120) -> bool:
        """阻塞等待 K 线事件（事件驱动主循环用）"""
        got = self._kline_event.wait(timeout=timeout)
        self._kline_event.clear()
        return got

    # ---- 缓存读取（线程安全） ----

    def get_klines(self, coin: str, interval: str) -> List[Dict]:
        """获取 K 线窗口（200 根）"""
        key = f"{coin}_{interval}"
        with self._lock:
            window = self._kline_windows.get(key, deque())
            return list(window)

    def get_price(self, coin: str) -> float:
        with self._lock:
            return self._last_price.get(coin, 0.0)

    def get_position(self, coin: str) -> Optional[dict]:
        with self._lock:
            return self._positions.get(coin)

    def get_balance(self) -> dict:
        with self._lock:
            return dict(self._balance)

    def is_gateway_alive(self) -> bool:
        """Gateway 心跳是否正常（30 秒内）"""
        return (time.time() - self._last_heartbeat) < 30

    # ---- 后台接收 ----

    def _recv_loop(self):
        """后台线程：持续接收 ZMQ 消息并更新缓存"""
        poller = zmq.Poller()
        poller.register(self._sub, zmq.POLLIN)

        while self._running:
            socks = dict(poller.poll(1000))
            if self._sub not in socks:
                continue

            msg = self._sub.recv_string()
            space = msg.index(' ')
            topic = msg[:space]
            payload = msg[space+1:]

            if topic.startswith('KLINE.'):
                # KLINE.SOL.1m {json}
                parts = topic.split('.')
                coin, interval = parts[1], parts[2]
                kline = json.loads(payload)
                key = f"{coin}_{interval}"
                with self._lock:
                    window = self._kline_windows.get(key)
                    if window is not None:
                        if not window or window[-1]['timestamp'] != kline['timestamp']:
                            window.append(kline)
                self._kline_event.set()  # 通知主循环

            elif topic.startswith('TICK.'):
                coin = topic.split('.')[1]
                price = float(payload)
                with self._lock:
                    self._last_price[coin] = price

            elif topic.startswith('POS.'):
                coin = topic.split('.')[1]
                data = json.loads(payload)
                with self._lock:
                    self._positions[coin] = data

            elif topic == 'BALANCE':
                data = json.loads(payload)
                with self._lock:
                    self._balance.update(data)

            elif topic == 'HEARTBEAT':
                self._last_heartbeat = float(payload)

    def close(self):
        self._running = False
        self._sub.close()
        self._req.close()
        self._ctx.term()
