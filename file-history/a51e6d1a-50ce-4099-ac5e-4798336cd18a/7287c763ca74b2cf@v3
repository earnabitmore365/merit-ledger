### 步骤 2：新建 `lab/src/data/feed_gateway.py`（约 350 行）

**核心代码框架：**

```python
#!/usr/bin/env python3
"""
通讯部总机 — Feed Gateway

单 WebSocket 连 BitMEX → ZMQ PUB 广播给所有策略进程。
策略进程零 REST 调用（除下单外）。

用法:
  python3 feed_gateway.py
  python3 feed_gateway.py --coins SOL,ETH,XRP --port 5555
"""

import os, sys, json, time, logging, threading, argparse
from datetime import datetime, timezone
from typing import Dict, List, Optional
from collections import deque

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..'))

import zmq
from exchange.bitmex.adapter import BitMEXAdapter, SYMBOL_MAP, API_BASE
from exchange.bitmex.websocket import BitMEXWebSocket

logger = logging.getLogger('FeedGateway')

# BitMEX WS timestamp (ISO) → 毫秒时间戳
def parse_ts(iso_str: str) -> int:
    dt = datetime.fromisoformat(iso_str.replace('Z', '+00:00'))
    return int(dt.timestamp() * 1000)

# WS tradeBin 行 → 标准 K 线 dict（与 adapter.get_klines 格式一致）
def normalize_kline(row: dict) -> dict:
    ts_ms = parse_ts(row['timestamp'])
    return {
        'timestamp': ts_ms, 'time': ts_ms,
        'open': float(row.get('open', 0)),
        'high': float(row.get('high', 0)),
        'low': float(row.get('low', 0)),
        'close': float(row.get('close', 0)),
        'volume': float(row.get('volume', 0)),
    }


class FeedGateway:
    """通讯部总机"""

    def __init__(self, coins: List[str], intervals: Dict[str, str],
                 zmq_port: int = 5555):
        """
        Args:
            coins: 币种列表 ['SOL', 'ETH', 'XRP']
            intervals: 币种→周期映射 {'SOL': '1m', 'ETH': '1m', 'XRP': '5m'}
            zmq_port: ZMQ PUB 端口
        """
        self.coins = coins
        self.intervals = intervals  # coin → interval
        self.zmq_port = zmq_port

        # K 线滑动窗口：{coin}_{interval} → deque(maxlen=250)
        self._kline_windows: Dict[str, deque] = {}
        for coin in coins:
            interval = intervals[coin]
            key = f"{coin}_{interval}"
            self._kline_windows[key] = deque(maxlen=250)

        # 最新 tick 价格
        self._last_price: Dict[str, float] = {}

        # 持仓/余额缓存
        self._positions: Dict[str, dict] = {}  # symbol → position data
        self._margin: dict = {}

        # 线程锁
        self._lock = threading.Lock()

        # ZMQ（socket 创建在 start() 中，先设 HWM 再 bind）
        self._ctx = zmq.Context()
        self._pub = None
        self._rep = None

        # WebSocket
        self._ws: Optional[BitMEXWebSocket] = None
        self._running = False

    def start(self, api_key: str, api_secret: str, testnet: bool = False):
        """启动 Gateway"""
        self._running = True

        # 1. 先 REST 拉历史 K 线填充窗口
        logger.info("正在加载历史 K 线...")
        self._load_history(api_key, api_secret, testnet)

        # 2. 连接 WebSocket
        self._ws = BitMEXWebSocket(testnet=testnet)

        # 【Gemini 终极补丁】重连时全量覆盖 K 线（不 extend！）
        self._ws._on_reconnect_callback = lambda: self._load_history(
            api_key, api_secret, testnet)

        ok = self._ws.connect(api_key=api_key, api_secret=api_secret)
        if not ok:
            logger.error("WebSocket 连接失败")
            return

        # 注册泛用回调（处理 tradeBin/margin）
        self._ws._on_table_callback = self._on_ws_table

        # 3. ZMQ 绑定（先设 HWM 再 bind）
        self._pub = self._ctx.socket(zmq.PUB)
        self._pub.setsockopt(zmq.SNDHWM, 1000)
        self._pub.setsockopt(zmq.RCVHWM, 1000)
        self._pub.bind(f"tcp://127.0.0.1:{self.zmq_port}")

        self._rep = self._ctx.socket(zmq.REP)
        self._rep.bind(f"tcp://127.0.0.1:{self.zmq_port + 1}")

        # 4. 订阅频道
        topics = []
        for coin in self.coins:
            symbol = SYMBOL_MAP.get(coin, f"{coin}USDT")
            interval = self.intervals[coin]
            topics.append(f'tradeBin{interval}:{symbol}')  # K 线
            topics.append(f'trade:{symbol}')                # Tick 价格
        topics.extend(['position', 'margin'])               # 私有
        self._ws.subscribe_private()
        self._ws.subscribe(topics)

        logger.info(f"Gateway 启动: ZMQ PUB={self.zmq_port} REP={self.zmq_port+1}")
        logger.info(f"订阅: {topics}")

        # 5. 启动 REQ/REP 服务线程（响应历史 K 线请求）
        threading.Thread(target=self._rep_loop, daemon=True).start()

        # 6. 心跳线程
        threading.Thread(target=self._heartbeat_loop, daemon=True).start()

        # 7. 主循环（阻塞）
        try:
            while self._running:
                time.sleep(1)
        except KeyboardInterrupt:
            logger.info("收到停止信号")
        finally:
            self.stop()

    def stop(self):
        self._running = False
        if self._ws:
            self._ws.disconnect()
        if self._pub:
            self._pub.close()
        if self._rep:
            self._rep.close()
        self._ctx.term()

    def _load_history(self, api_key, api_secret, testnet):
        """REST 拉历史 K 线填充滑动窗口（仅启动时一次）"""
        from exchange.bitmex.adapter import BitMEXAdapter
        config = {'api_key': api_key, 'api_secret': api_secret,
                  'testnet': testnet}
        adapter = BitMEXAdapter(config)
        # 不连 WS，只用 REST
        adapter._ws = None
        adapter._connected = True

        for coin in self.coins:
            interval = self.intervals[coin]
            key = f"{coin}_{interval}"
            klines = adapter.get_klines(coin, interval, limit=250)
            if klines:
                self._kline_windows[key] = deque(klines, maxlen=250)
                logger.info(f"  {key}: 加载 {len(klines)} 根 K 线")
            else:
                logger.warning(f"  {key}: 加载失败")

    def _on_ws_table(self, table: str, action: str, rows: list):
        """WebSocket 消息 → 更新缓存 + ZMQ 广播"""

        # --- tradeBin ---
        if table.startswith('tradeBin'):
            interval = table.replace('tradeBin', '')  # "1m" / "5m"
            for row in rows:
                symbol = row.get('symbol', '')
                coin = self._symbol_to_coin(symbol)
                if not coin:
                    continue

                kline = normalize_kline(row)
                key = f"{coin}_{interval}"

                with self._lock:
                    window = self._kline_windows.get(key)
                    if window is not None:
                        # 防重复：检查时间戳
                        if not window or window[-1]['timestamp'] != kline['timestamp']:
                            window.append(kline)

                # ZMQ 广播新 K 线
                topic = f"KLINE.{coin}.{interval}"
                self._pub.send_string(f"{topic} {json.dumps(kline)}")
                logger.debug(f"[PUB] {topic}")

        # --- trade (tick 价格) ---
        elif table == 'trade':
            for row in rows:
                symbol = row.get('symbol', '')
                price = row.get('price', 0)
                coin = self._symbol_to_coin(symbol)
                if coin and price > 0:
                    with self._lock:
                        self._last_price[coin] = price
                    self._pub.send_string(f"TICK.{coin} {price}")

        # --- position ---
        elif table == 'position':
            for row in rows:
                symbol = row.get('symbol', '')
                coin = self._symbol_to_coin(symbol)
                if coin:
                    with self._lock:
                        if action in ('partial', 'insert'):
                            self._positions[coin] = row
                        elif action == 'update':
                            self._positions.setdefault(coin, {}).update(row)
                        elif action == 'delete':
                            self._positions.pop(coin, None)
                    self._pub.send_string(
                        f"POS.{coin} {json.dumps(row)}")

        # --- margin ---
        elif table == 'margin':
            for row in rows:
                with self._lock:
                    self._margin.update(row)
                self._pub.send_string(f"BALANCE {json.dumps(row)}")

    def _rep_loop(self):
        """REQ/REP 服务：响应策略进程的历史 K 线请求"""
        poller = zmq.Poller()
        poller.register(self._rep, zmq.POLLIN)
        while self._running:
            socks = dict(poller.poll(1000))
            if self._rep in socks:
                msg = self._rep.recv_string()
                # 格式: "KLINES {coin} {interval}"
                parts = msg.split()
                if len(parts) == 3 and parts[0] == 'KLINES':
                    coin, interval = parts[1], parts[2]
                    key = f"{coin}_{interval}"
                    with self._lock:
                        window = self._kline_windows.get(key, deque())
                        data = list(window)
                    self._rep.send_string(json.dumps(data))
                else:
                    self._rep.send_string("[]")

    def _heartbeat_loop(self):
        """每 10 秒发心跳"""
        while self._running:
            self._pub.send_string(f"HEARTBEAT {time.time():.3f}")
            time.sleep(10)

    @staticmethod
    def _symbol_to_coin(symbol: str) -> Optional[str]:
        """BitMEX symbol → coin（反查 SYMBOL_MAP）"""
        for coin, sym in SYMBOL_MAP.items():
            if sym == symbol:
                return coin
        return None


def main():
    parser = argparse.ArgumentParser(description='通讯部总机 Feed Gateway')
    parser.add_argument('--coins', default='SOL,ETH,XRP', help='币种')
    parser.add_argument('--intervals', default='1m,1m,5m',
                        help='对应币种的 K 线周期')
    parser.add_argument('--port', type=int, default=5555, help='ZMQ PUB 端口')
    args = parser.parse_args()

    logging.basicConfig(level=logging.INFO,
                        format='%(asctime)s [%(name)s] %(levelname)s %(message)s')

    coins = args.coins.split(',')
    intervals_list = args.intervals.split(',')
    intervals = dict(zip(coins, intervals_list))

    from dotenv import load_dotenv
    load_dotenv(os.path.join(os.path.dirname(__file__), '..', '..', '.env'))

    gateway = FeedGateway(coins=coins, intervals=intervals, zmq_port=args.port)
    gateway.start(
        api_key=os.getenv('BITMEX_API_KEY'),
        api_secret=os.getenv('BITMEX_API_SECRET'),
        testnet=os.getenv('BITMEX_TESTNET', 'false').lower() == 'true',
    )

if __name__ == '__main__':
    main()
```

