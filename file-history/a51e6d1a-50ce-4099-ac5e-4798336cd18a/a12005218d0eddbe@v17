### 3. monitor_bot.py — 加 BitMEX 持仓查询 + 盈亏推送

**新增功能：每 30 秒 SSH 查一次 BitMEX 真实持仓数据**

```python
def get_positions_via_ssh():
    """通过 SSH 到 Nitro 调 BitMEX API 获取真实持仓"""
    cmd = (
        f'cd {NITRO_DIR} && PYTHONPATH=src python3 -c "'
        'from exchange.bitmex.adapter import BitMEXAdapter;'
        'from dotenv import load_dotenv;'
        'import os,json;'
        'load_dotenv(\".env\");'
        'a=BitMEXAdapter({\"api_key\":os.getenv(\"BITMEX_API_KEY\"),'
        '\"api_secret\":os.getenv(\"BITMEX_API_SECRET\"),\"testnet\":False});'
        'a._ws=None;a._connected=True;'
        'b=a.get_balance();'
        'positions=[{\"coin\":p.coin,\"side\":p.side,\"entry\":p.entry_price,'
        '\"pnl\":p.unrealized_pnl,\"size\":p.size} for p in a.get_positions()];'
        'print(json.dumps({\"balance\":b.get(\"usdc\",0),\"positions\":positions}))'
        '"'
    )
    out = ssh_exec(cmd)
    if out:
        return json.loads(out)
    return None
```

**盈亏里程碑推送（替代 TTP 探针）：**
```python
# 记录每个币种的上次推送百分比
last_pushed_pct = {}  # coin → last milestone %

def check_pnl_milestones(positions_data):
    """检查持仓盈亏是否跨过 5% 里程碑（杠杆后）"""
    for pos in positions_data['positions']:
        coin = pos['coin']
        entry = pos['entry']
        pnl = pos['pnl']  # BitMEX unrealisedPnl，真实美元

        # 杠杆后百分比 = pnl / margin × 100
        # margin ≈ notional / leverage（从 entry × size / leverage）
        side = pos['side']
        size = pos['size']
        notional = entry * size
        margin = notional / 10  # 10x 杠杆
        if margin > 0:
            pct = pnl / margin * 100  # 杠杆后百分比

        # 每 5% 推一次
        milestone = int(pct / 5) * 5
        last = last_pushed_pct.get(coin, 0)
        if milestone != last and abs(pct) >= 5:
            last_pushed_pct[coin] = milestone
            emoji = "🔥" if pct > 0 else "🔻"
            send_telegram(f"{emoji} {coin} {side} {pct:+.1f}% (${pnl:+.2f})")
```

