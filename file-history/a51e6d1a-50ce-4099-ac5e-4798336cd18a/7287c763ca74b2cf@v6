#### 主循环改造（feed 模式内）
```python
# 在创建 TradingSystem 后、主循环前：
bridge = None
normal_strategy = None  # 保存原版策略引用
mirror_strategy = None  # 保存 mirror 策略引用

if args.regime_bridge:
    # 保存两版策略
    if args.mirror:
        mirror_strategy = strategy  # 当前已是 mirror
        normal_strategy = strategy._inner if hasattr(strategy, '_inner') else get_strategy(args.strategy)
    else:
        normal_strategy = strategy
        from core.strategy.mirror import MirrorStrategy
        mirror_strategy = MirrorStrategy(get_strategy(args.strategy), interval=args.interval)

    bridge = RegimeBridge(args.coin, adapter, logger)
    bridge.warmup()

    # 根据预热结果设置初始模式
    if bridge.mode == 'mirror':
        system.strategy = mirror_strategy
    else:
        system.strategy = normal_strategy
    system.signal_filter = bridge.signal_filter
    logger.info(f"[Regime Bridge] 初始: {bridge.regime} mode={bridge.mode} filter={bridge.signal_filter}")

# 主循环（feed 模式）内，在 run_once 之前：
if bridge:
    switched = bridge.check_update()
    if switched:
        # 变盘强制清仓
        if system.position != 'NO_POSITION':
            logger.info(f"[Regime] 变盘清仓: {system.position} → 市价平仓")
            result = adapter.close_position(args.coin)
            if result.success:
                system.position = 'NO_POSITION'
                system.entry_price = 0
                logger.info("[Regime] 清仓成功")
            else:
                logger.error(f"[Regime] 清仓失败: {result.message}")
                # 失败也继续，下次 _sync_position 会纠正

        # 切策略
        if bridge.mode == 'mirror':
            system.strategy = mirror_strategy
        else:
            system.strategy = normal_strategy
        system.signal_filter = bridge.signal_filter

        # 动态阈值重新设置（切策略后 inner 引用变了）
        inner = system.strategy._inner if hasattr(system.strategy, '_inner') else system.strategy
        if hasattr(inner, 'config') and args.coin in coin_thresholds:
            buy_th, sell_th = coin_thresholds[args.coin]
            inner.config.buy_threshold = buy_th
            inner.config.sell_threshold = sell_th

        logger.info(f"[Regime] 切换完成: {bridge.regime} mode={bridge.mode} filter={bridge.signal_filter}")
```

