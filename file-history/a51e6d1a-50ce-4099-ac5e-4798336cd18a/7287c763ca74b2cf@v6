#### RegimeBridge 类
```python
class RegimeBridge:
    """Regime 动态桥接：1h Regime 指挥 1m/5m 策略"""

    REGIME_MAP = {
        '牛':   {'mode': 'mirror', 'filter': 'BUY_ONLY'},
        '初牛': {'mode': 'mirror', 'filter': 'BUY_ONLY'},
        '熊':   {'mode': 'mirror', 'filter': 'SELL_ONLY'},
        '初熊': {'mode': 'mirror', 'filter': 'SELL_ONLY'},
        '盘整': {'mode': 'normal', 'filter': None},
    }

    def __init__(self, coin, adapter, logger):
        from live_regime.regime_detector import RegimeDetector
        self.coin = coin
        self.adapter = adapter  # REST 用（拉 1h K线）
        self.logger = logger
        self._detector = RegimeDetector(
            initial_regime='盘整',
            state_file=f'regime_state_{coin}.json'
        )
        self._last_1h_ts = 0       # 上次拉 1h 的时间戳
        self._regime = '盘整'
        self._prev_regime = '盘整'
        self._warmup_done = False

    def warmup(self):
        """冷启动预热：REST 拉 250 根 1h 历史 K 线喂饱 Detector"""
        self.logger.info("[Regime] 预热中：拉取 250 根 1h K线...")
        klines = self.adapter.get_klines(self.coin, '1h', limit=250)
        if not klines:
            self.logger.error("[Regime] 预热失败：无法获取 1h K线")
            return
        for i, k in enumerate(klines):
            self._detector.update_with_aggregation(
                i, k['high'], k['low'], k['close'],
                k.get('volume', 0), k.get('time', k.get('timestamp', 0)),
                large_tf_bars=4)
        self._regime = self._detector.regime
        self._prev_regime = self._regime
        self._last_1h_ts = klines[-1].get('time', klines[-1].get('timestamp', 0))
        self._warmup_done = True
        self.logger.info(f"[Regime] 预热完成: {self._regime} (喂了{len(klines)}根1h)")

    def check_update(self) -> bool:
        """每次 K 线事件时调用，检查是否该拉新 1h bar
        Returns: True = regime 发生切换
        """
        import time
        now_ms = int(time.time() * 1000)
        # 每小时拉一次（3600秒 = 3,600,000毫秒）
        if now_ms - self._last_1h_ts < 3_540_000:  # 59分钟，留1分钟余量
            return False

        # 拉最新 1 根 1h K线
        klines = self.adapter.get_klines(self.coin, '1h', limit=2)
        if not klines or len(klines) < 2:
            return False

        latest = klines[-1]  # 最新闭合的 1h bar
        latest_ts = latest.get('time', latest.get('timestamp', 0))

        # 防重复：同一根不喂两次
        if latest_ts <= self._last_1h_ts:
            return False

        self._last_1h_ts = latest_ts
        self._prev_regime = self._regime

        result = self._detector.update_with_aggregation(
            0, latest['high'], latest['low'], latest['close'],
            latest.get('volume', 0), latest_ts,
            large_tf_bars=4)

        self._regime = result['regime']

        if self._regime != self._prev_regime:
            self.logger.info(
                f"[Regime] ⚡变盘！{self._prev_regime} → {self._regime}")
            return True

        self.logger.info(
            f"[Regime] 1h更新: {self._regime} "
            f"valid={result['valid']} warning={result.get('warning')}")
        return False

    @property
    def regime(self): return self._regime

    @property
    def mode(self): return self.REGIME_MAP.get(self._regime, {}).get('mode', 'normal')

    @property
    def signal_filter(self): return self.REGIME_MAP.get(self._regime, {}).get('filter')

    @property
    def switched(self): return self._regime != self._prev_regime
```

