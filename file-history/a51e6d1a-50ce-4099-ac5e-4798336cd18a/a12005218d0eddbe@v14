# strategy_mean_reversion.py — 完整代码
class MeanReversion(Strategy):
    REQUIRES = ['sma']

    def __init__(self, exchange=None, config=None):
        self.config = config or MeanReversionConfig()
        # config.period = 20, buy_threshold = 0.995, sell_threshold = 1.005

    def generate_signal(self, coin, klines=None):
        current = klines[-1]["close"]
        sma_series = get_indicator('sma', period=self.config.period)
        ma = sma_series[self.current_idx]

        if current < ma * self.config.buy_threshold:    # 价格低于SMA×0.995
            signal = Signal.BUY
        elif current > ma * self.config.sell_threshold:  # 价格高于SMA×1.005
            signal = Signal.SELL
        else:
            signal = Signal.HOLD
        return TradingSignal(signal=signal, ...)
