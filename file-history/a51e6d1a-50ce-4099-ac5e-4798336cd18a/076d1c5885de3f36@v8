#!/usr/bin/env python3
"""
实盘监控 Bot — Mac Mini 上运行

SSH 读 Nitro 日志 + SSH 查 BitMEX API → Telegram 推送
独立于交易进程，交易崩了监控还能报警。

功能：
1. [TRADE] 事件推送（开仓/平仓/反手）
2. 盈亏里程碑推送（每 5% 杠杆后，用 BitMEX 真实数据）
3. Regime 变盘 / TTP 触发 / HALT 熔断推送
4. 进程存活检测
5. 每小时摘要（真实余额+持仓+PnL）

用法:
  python3 monitor_bot.py
"""

import os
import re
import json
import time
import subprocess
import urllib.request

# ==================== 配置 ====================

SSH_CMD = "ssh -p 2222 -o ConnectTimeout=10 -o StrictHostKeyChecking=no pc_heisi_claude@localhost"
NITRO_DIR = "/home/pc_heisi_claude/trading"
LOG_FILES = ['sol_1m_live', 'eth_1m_live', 'xrp_5m_live', 'gateway']
COIN_MAP = {'sol_1m_live': 'SOL', 'eth_1m_live': 'ETH',
            'xrp_5m_live': 'XRP', 'gateway': 'GW'}

CHECK_INTERVAL = 30      # 日志轮询间隔（秒）
PNL_CHECK_INTERVAL = 60  # 盈亏查询间隔（秒，不用太频繁）
SUMMARY_INTERVAL = 3600  # 每小时摘要
PNL_MILESTONE = 5.0      # 杠杆后每 5% 推一次

TOKEN = os.getenv('TELEGRAM_BOT_TOKEN', '8626060346:AAFnkP2V7avxpmnFsO8DUsHEDB7SmqtMJhg')
CHAT_ID = os.getenv('TELEGRAM_CHAT_ID', '6506412244')


# ==================== Telegram ====================

def send_telegram(message):
    """纯 urllib 推送，零依赖，纯文本"""
    if not TOKEN or not CHAT_ID:
        return
    try:
        url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
        data = json.dumps({'chat_id': CHAT_ID, 'text': message}).encode()
        req = urllib.request.Request(
            url, data=data, headers={'Content-Type': 'application/json'})
        urllib.request.urlopen(req, timeout=5)
    except Exception:
        pass


# ==================== SSH ====================

def ssh_exec(cmd):
    """SSH 执行命令，返回 stdout"""
    full = f"{SSH_CMD} '{cmd}'"
    try:
        result = subprocess.run(
            full, shell=True, capture_output=True, text=True, timeout=20)
        return result.stdout.strip()
    except (subprocess.TimeoutExpired, Exception):
        return None


def poll_logs():
    """一次 SSH 获取全部日志 + 进程数"""
    cmd = (
        f'cd {NITRO_DIR} && '
        'echo "===PROC==="; '
        'ps aux | grep -E "feed_gateway|bitmex_race" | grep -v grep | wc -l; '
        'echo "===SOL==="; tail -50 logs/sol_1m_live.log 2>/dev/null; '
        'echo "===ETH==="; tail -50 logs/eth_1m_live.log 2>/dev/null; '
        'echo "===XRP==="; tail -50 logs/xrp_5m_live.log 2>/dev/null; '
        'echo "===GW==="; tail -50 logs/gateway.log 2>/dev/null'
    )
    out = ssh_exec(cmd)
    if out is None:
        return None
    sections = {}
    current = None
    for line in out.split('\n'):
        if line.startswith('===') and line.endswith('==='):
            current = line.strip('=')
            sections[current] = []
        elif current is not None:
            sections[current].append(line)
    return sections


def query_bitmex():
    """SSH 到 Nitro 查 BitMEX 真实余额+持仓（1 次 REST）"""
    cmd = (
        f'cd {NITRO_DIR} && PYTHONPATH=src python3 -c "'
        'from exchange.bitmex.adapter import BitMEXAdapter;'
        'from dotenv import load_dotenv;'
        'import os,json;'
        'load_dotenv(\\".env\\");'
        'a=BitMEXAdapter({\\"api_key\\":os.getenv(\\"BITMEX_API_KEY\\"),'
        '\\"api_secret\\":os.getenv(\\"BITMEX_API_SECRET\\"),\\"testnet\\":False});'
        'a._ws=None;a._connected=True;'
        'b=a.get_balance();'
        'ps=[{\\"coin\\":p.coin,\\"side\\":p.side,\\"entry\\":p.entry_price,'
        '\\"pnl\\":p.unrealized_pnl,\\"size\\":p.size} for p in a.get_positions()];'
        'print(json.dumps({\\"balance\\":b.get(\\"usdc\\",0),\\"positions\\":ps}))'
        '"'
    )
    out = ssh_exec(cmd)
    if out:
        try:
            return json.loads(out)
        except json.JSONDecodeError:
            return None
    return None


# ==================== 事件解析 ====================

def parse_events(lines, coin):
    """解析日志行，提取关键事件"""
    events = []
    for line in lines:
        # [TRADE] 交易事件（开仓/平仓/反手）
        if '[TRADE]' in line:
            detail = line.split('[TRADE]')[1].strip()[:80]
            events.append(f"📌 {detail}")

        # Regime 变盘
        if '⚡变盘' in line:
            detail = line.split('⚡')[1].strip()[:60] if '⚡' in line else ''
            events.append(f"⚡ {coin} {detail}")

        # 智能平仓
        if '[Regime]' in line and ('平多仓' in line or '平空仓' in line):
            detail = line.split('[Regime]')[1].strip()[:80]
            events.append(f"🟡 {coin} {detail}")

        # TTP 触发（原始日志，TTP 自己打的）
        if 'TTP tick触发' in line or 'TTP触发' in line:
            events.append(f"📊 {coin} TTP触发!")

        # HALT 熔断
        if 'HALT' in line and '熔断' in line:
            events.append(f"🚨 {coin} HALT 熔断!")

        # Gateway 严重错误
        if coin == 'GW' and ('ERROR' in line or 'corrupted' in line):
            events.append(f"⚠️ Gateway ERROR: {line[-60:]}")

    return events


# ==================== 盈亏里程碑 ====================

def check_pnl_milestones(bitmex_data, last_milestones):
    """检查持仓盈亏是否跨过里程碑，返回推送列表"""
    if not bitmex_data or 'positions' not in bitmex_data:
        return []

    events = []
    for pos in bitmex_data['positions']:
        coin = pos['coin']
        side = pos['side']
        pnl = pos['pnl']        # BitMEX 真实 unrealisedPnl（美元）
        entry = pos['entry']
        size = pos['size']

        # 计算杠杆后百分比 = PnL / 保证金 × 100
        notional = entry * size
        margin = notional / 10  # 10x 杠杆
        if margin <= 0:
            continue
        pct = pnl / margin * 100  # 杠杆后百分比

        # 每 5% 一个里程碑
        milestone = int(pct / PNL_MILESTONE) * int(PNL_MILESTONE)
        last = last_milestones.get(coin, 0)

        if milestone != last and abs(pct) >= PNL_MILESTONE:
            last_milestones[coin] = milestone
            emoji = "🔥" if pct > 0 else "🔻"
            events.append(f"{emoji} {coin} {side} {pct:+.1f}% (${pnl:+.2f})")

    return events


# ==================== 主循环 ====================

def main():
    print(f"Monitor Bot 启动: 日志每{CHECK_INTERVAL}s | 盈亏每{PNL_CHECK_INTERVAL}s | Telegram @{CHAT_ID}")

    # 去重：初始化为 5 分钟前
    init_ts = time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(time.time() - 300))
    last_seen = {f: init_ts for f in LOG_FILES}

    last_summary = time.time()
    last_pnl_check = 0
    last_proc_alert = 0
    low_proc_streak = 0
    last_milestones = {}  # coin → 上次推送的里程碑 %

    # 启动确认
    send_telegram("✅ 监控已启动\nMac Mini → Nitro SSH\n交易事件+盈亏里程碑+每小时摘要")

    while True:
        try:
            sections = poll_logs()

            if sections is None:
                if time.time() - last_proc_alert > 300:
                    send_telegram("⚠️ SSH 隧道断了！无法连接 Nitro")
                    last_proc_alert = time.time()
                time.sleep(CHECK_INTERVAL)
                continue

            # 1. 进程存活检测
            proc_lines = sections.get('PROC', ['0'])
            try:
                proc_count = int(proc_lines[0].strip())
            except (ValueError, IndexError):
                proc_count = 0

            if proc_count < 7:
                low_proc_streak += 1
                if low_proc_streak >= 2 and time.time() - last_proc_alert > 60:
                    send_telegram(f"🚨 进程异常: {proc_count}/7 存活!")
                    last_proc_alert = time.time()
            else:
                low_proc_streak = 0

            # 2. 读日志找新事件
            section_map = {'SOL': 'sol_1m_live', 'ETH': 'eth_1m_live',
                           'XRP': 'xrp_5m_live', 'GW': 'gateway'}

            for section_key, log_name in section_map.items():
                lines = sections.get(section_key, [])
                coin = COIN_MAP[log_name]
                new_lines = []
                for line in lines:
                    ts = re.match(r'(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})', line)
                    if ts and ts.group(1) > last_seen[log_name]:
                        new_lines.append(line)

                if new_lines:
                    last_ts = re.match(
                        r'(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})', new_lines[-1])
                    if last_ts:
                        last_seen[log_name] = last_ts.group(1)
                    events = parse_events(new_lines, coin)
                    for event in events:
                        send_telegram(event)

            # 3. 盈亏里程碑（每 60 秒查一次 BitMEX）
            now = time.time()
            if now - last_pnl_check > PNL_CHECK_INTERVAL:
                bitmex_data = query_bitmex()
                if bitmex_data:
                    pnl_events = check_pnl_milestones(bitmex_data, last_milestones)
                    for event in pnl_events:
                        send_telegram(event)
                last_pnl_check = now

            # 4. 每小时摘要（用 BitMEX 真实数据）
            if now - last_summary > SUMMARY_INTERVAL:
                bitmex_data = bitmex_data if (now - last_pnl_check < 10) else query_bitmex()
                if bitmex_data:
                    bal = bitmex_data.get('balance', 0)
                    parts = [f"📊 每小时状态 | 进程: {proc_count}/7",
                             f"余额: ${bal:.2f}"]
                    for pos in bitmex_data.get('positions', []):
                        notional = pos['entry'] * pos['size']
                        margin = notional / 10
                        pct = pos['pnl'] / margin * 100 if margin > 0 else 0
                        parts.append(
                            f"{pos['coin']} {pos['side']} ${pos['pnl']:+.2f} ({pct:+.1f}%)")
                    # 从日志提取 regime
                    for sk, ln in section_map.items():
                        if ln == 'gateway':
                            continue
                        for line in reversed(sections.get(sk, [])):
                            rm = re.search(r'regime=(\S+)', line)
                            if rm:
                                parts[-1] = parts[-1] if parts[-1].startswith(COIN_MAP[ln]) else parts[-1]
                                break
                    send_telegram('\n'.join(parts))
                last_summary = now

        except Exception as e:
            print(f"监控异常: {e}")

        time.sleep(CHECK_INTERVAL)


if __name__ == '__main__':
    main()
