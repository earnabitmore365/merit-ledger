## 完整的反向合约模拟代码

```python
INITIAL_USD = 500.0    # 等值美元
LEVERAGE = 10
BET_PCT = 0.10         # 10% 余额
MIN_BET_USD = 100.0    # 最低 $100 等值

def simulate_coin_margin(trades):
    first_price = trades[0].entry_price
    initial_coins = INITIAL_USD / first_price   # $500 换成 BNB
    balance = initial_coins                      # 余额以 BNB 计

    for t in trades:
        entry_p = t.entry_price
        exit_p = t.exit_price

        # 下注：余额 10%，最低 $100 等值的 BNB
        min_bet_coins = MIN_BET_USD / entry_p
        bet = max(balance * BET_PCT, min_bet_coins)
        if bet > balance:
            break  # 爆仓

        # 反向合约 PnL（币单位）
        if t.direction == 'long':
            raw_pnl = bet * LEVERAGE * (exit_p - entry_p) / exit_p
        else:
            raw_pnl = bet * LEVERAGE * (entry_p - exit_p) / exit_p

        # 费用（从种子缩放）
        # 种子的费用基于 $1 × 10x = $10 名义价值
        # 实际名义 = bet_coins × entry_p × leverage
        scale = bet * entry_p   # 缩放因子
        cost_usd = (t.fee + t.funding_cost + t.slippage_cost) * scale
        cost_coins = cost_usd / exit_p   # 按 exit 价换成币

        pnl = raw_pnl - cost_coins
        if pnl < -bet:   # 逐仓：最多亏保证金
            pnl = -bet

        balance += pnl
        if balance <= 0:
            break
```

