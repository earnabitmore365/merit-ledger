## 五、实盘策略代码

### mean_reversion（当前在用）
```python
class MeanReversion(Strategy):
    REQUIRES = ['sma']
    # config: period=20, buy_threshold=0.995, sell_threshold=1.005 (±0.5%)

    def generate_signal(self, coin, klines):
        current = klines[-1]["close"]
        sma = get_indicator('sma', period=20)[self.current_idx]
        if current < sma * 0.995:   return Signal.BUY
        elif current > sma * 1.005: return Signal.SELL
        else:                        return Signal.HOLD
```

### MirrorStrategy v2.1（翻转 K 线，不翻信号）
```python
class MirrorStrategy(Strategy):
    def _mirror_klines(self, klines):
        sma200 = sum(closes[-200:]) / min(200, len(closes))
        mirrored = []
        for k in klines:
            m['open']  = 2 * sma200 - k['open']
            m['close'] = 2 * sma200 - k['close']
            m['high']  = 2 * sma200 - k['low']    # swap
            m['low']   = 2 * sma200 - k['high']   # swap
        return mirrored

    def generate_signal(self, coin, klines):
        mirrored = self._mirror_klines(klines)
        init_cache(coin, interval, mirrored, db_path=':memory:')
        return self._inner.generate_signal(coin, mirrored)  # 信号不翻转
```

