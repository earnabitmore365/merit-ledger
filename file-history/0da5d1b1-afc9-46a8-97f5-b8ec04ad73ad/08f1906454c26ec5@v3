<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Claude Code Mission Control</title>
<style>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --border: #30363d;
    --text: #c9d1d9;
    --text-muted: #8b949e;
    --accent: #58a6ff;
    --green: #3fb950;
    --yellow: #d29922;
    --red: #f85149;
    --purple: #bc8cff;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', monospace;
    background: var(--bg);
    color: var(--text);
    padding: 20px;
  }
  h1 {
    font-size: 1.4em;
    margin-bottom: 20px;
    color: var(--accent);
  }
  h2 {
    font-size: 1.1em;
    color: var(--text-muted);
    margin-bottom: 12px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 6px;
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 20px;
  }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px;
  }
  .card.full { grid-column: 1 / -1; }
  .role-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.85em;
    font-weight: 600;
  }
  .role-太极 { background: #1f6feb33; color: var(--accent); }
  .role-黑丝 { background: #f8514933; color: var(--red); }
  .role-白纱 { background: #bc8cff33; color: var(--purple); }
  .role-unknown { background: #30363d; color: var(--text-muted); }
  .session-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
  }
  .session-item:last-child { border-bottom: none; }
  .session-meta {
    color: var(--text-muted);
    font-size: 0.85em;
  }
  .msg-item {
    padding: 8px 12px;
    margin-bottom: 6px;
    border-left: 3px solid var(--border);
    font-size: 0.9em;
  }
  .msg-item .speaker {
    font-weight: 600;
    margin-right: 8px;
  }
  .msg-item .time {
    color: var(--text-muted);
    font-size: 0.8em;
  }
  .msg-item .tags {
    color: var(--yellow);
    font-size: 0.8em;
  }
  .stat {
    text-align: center;
    padding: 12px;
  }
  .stat .value {
    font-size: 2em;
    font-weight: 700;
    color: var(--green);
  }
  .stat .label {
    font-size: 0.85em;
    color: var(--text-muted);
  }
  .checkpoint-content {
    white-space: pre-wrap;
    font-size: 0.85em;
    line-height: 1.5;
    max-height: 400px;
    overflow-y: auto;
  }
  .health-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 6px;
  }
  .health-ok { background: var(--green); }
  .health-err { background: var(--red); }
  .refresh-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--accent);
    padding: 6px 14px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.9em;
  }
  .refresh-btn:hover { background: var(--border); }
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .auto-refresh {
    color: var(--text-muted);
    font-size: 0.8em;
  }
</style>
</head>
<body>

<div class="header">
  <h1>Claude Code Mission Control</h1>
  <div>
    <span class="auto-refresh" id="lastUpdate"></span>
    <button class="refresh-btn" onclick="refreshAll()">Refresh</button>
  </div>
</div>

<div class="grid">
  <!-- Health + Evolver Stats -->
  <div class="card">
    <h2>System Health</h2>
    <div id="health">Loading...</div>
  </div>

  <div class="card">
    <h2>Evolver Status</h2>
    <div id="evolver">Loading...</div>
  </div>

  <!-- Active Sessions -->
  <div class="card full">
    <h2>Active Sessions</h2>
    <div id="sessions">Loading...</div>
  </div>

  <!-- Recent Conversations -->
  <div class="card full">
    <h2>Recent Conversations</h2>
    <div id="conversations">Loading...</div>
  </div>

  <!-- Checkpoint -->
  <div class="card full">
    <h2>Auto-Trading CHECKPOINT</h2>
    <div id="checkpoint" class="checkpoint-content">Loading...</div>
  </div>
</div>

<script>
const API = 'http://127.0.0.1:8100';

function timeAgo(ts) {
  const now = Date.now() / 1000;
  const diff = now - ts;
  if (diff < 60) return Math.floor(diff) + 's ago';
  if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
  if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
  return Math.floor(diff / 86400) + 'd ago';
}

async function fetchJSON(path) {
  const res = await fetch(API + path);
  return res.json();
}

async function loadHealth() {
  try {
    const d = await fetchJSON('/api/health');
    const el = document.getElementById('health');
    el.innerHTML = `
      <div><span class="health-dot ${d.conversations_db ? 'health-ok' : 'health-err'}"></span>conversations.db</div>
      <div><span class="health-dot ${d.evolver_dir ? 'health-ok' : 'health-err'}"></span>evolver/</div>
      <div><span class="health-dot ${d.projects_dir ? 'health-ok' : 'health-err'}"></span>projects/</div>
      <div style="margin-top:8px;color:var(--green)">Status: ${d.status}</div>
    `;
  } catch(e) {
    document.getElementById('health').innerHTML = '<span style="color:var(--red)">API unreachable</span>';
  }
}

async function loadEvolver() {
  try {
    const d = await fetchJSON('/api/evolver/status');
    const lastRun = d.last_run ? new Date(d.last_run).toLocaleString('zh-CN') : 'N/A';
    const notifs = d.recent_notifications.slice(-3).map(n =>
      `<div style="font-size:0.85em;color:var(--text-muted)">${n.ts} — ${n.status} ${n.gene || ''}</div>`
    ).join('');
    document.getElementById('evolver').innerHTML = `
      <div class="stat">
        <div class="value">${d.cycle_count}</div>
        <div class="label">Total Cycles</div>
      </div>
      <div style="font-size:0.85em;color:var(--text-muted)">Last run: ${lastRun}</div>
      <div style="margin-top:8px">${notifs}</div>
    `;
  } catch(e) {
    document.getElementById('evolver').innerHTML = '<span style="color:var(--red)">Failed to load</span>';
  }
}

async function loadSessions() {
  try {
    const d = await fetchJSON('/api/sessions?limit=10');
    const el = document.getElementById('sessions');
    if (!d.sessions.length) { el.innerHTML = 'No sessions found'; return; }
    el.innerHTML = d.sessions.map(s => `
      <div class="session-item">
        <span class="role-badge role-${s.role}">${s.role}</span>
        <span>${s.project}</span>
        <span class="session-meta">${s.messages} msgs · ${s.size_kb}KB · ${timeAgo(s.modified)}</span>
      </div>
    `).join('');
  } catch(e) {
    document.getElementById('sessions').innerHTML = '<span style="color:var(--red)">Failed to load</span>';
  }
}

async function loadConversations() {
  try {
    const d = await fetchJSON('/api/conversations?limit=15');
    const el = document.getElementById('conversations');
    if (!d.messages.length) { el.innerHTML = 'No messages found'; return; }
    el.innerHTML = d.messages.map(m => `
      <div class="msg-item">
        <span class="speaker">${m.speaker}</span>
        <span class="time">${m.time}</span>
        ${m.tags ? '<span class="tags"> [' + m.tags + ']</span>' : ''}
        <div style="margin-top:4px">${m.content.substring(0, 200)}${m.content.length > 200 ? '...' : ''}</div>
      </div>
    `).join('');
  } catch(e) {
    document.getElementById('conversations').innerHTML = '<span style="color:var(--red)">Failed to load</span>';
  }
}

async function loadCheckpoint() {
  try {
    const d = await fetchJSON('/api/checkpoints/auto-trading');
    document.getElementById('checkpoint').textContent = d.content || d.error || 'No data';
  } catch(e) {
    document.getElementById('checkpoint').textContent = 'Failed to load';
  }
}

async function refreshAll() {
  document.getElementById('lastUpdate').textContent = 'Refreshing...';
  await Promise.all([
    loadHealth(),
    loadEvolver(),
    loadSessions(),
    loadConversations(),
    loadCheckpoint()
  ]);
  document.getElementById('lastUpdate').textContent =
    'Updated: ' + new Date().toLocaleTimeString('zh-CN');
}

// Initial load
refreshAll();
// Auto-refresh every 30s
setInterval(refreshAll, 30000);
</script>
</body>
</html>
