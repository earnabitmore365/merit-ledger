    parser.add_argument('--pop', type=int, default=config.POPULATION_SIZE,
                        help=f'种群大小 (default: {config.POPULATION_SIZE})')
    parser.add_argument('--gen', type=int, default=config.GENERATIONS,
                        help=f'每轮代数 (default: {config.GENERATIONS})')
    parser.add_argument('--coin', type=str, default=config.DATA_COIN,
                        help=f'币种 (default: {config.DATA_COIN})')
    parser.add_argument('--interval', type=str, default=config.DATA_INTERVAL,
                        help=f'K线周期 (default: {config.DATA_INTERVAL})')
    parser.add_argument('--sample', type=int, default=1,
                        help='数据子采样 (default: 1，即不采样)')
    parser.add_argument('--rounds', type=int, default=0,
                        help='运行N轮后退出 (default: 0=无限)')
    parser.add_argument('--islands', action='store_true',
                        help='启用岛屿模型 (v1.0)')
    parser.add_argument('--no-cmaes', action='store_true',
                        help='禁用 CMA-ES 参数精化')
    args = parser.parse_args()

    # 命令行覆盖 config
    config.DATA_COIN = args.coin
    config.DATA_INTERVAL = args.interval

    # v0.5: 按币种+周期隔离文件路径（多进程不冲突）
    global LOG_FILE, HALL_OF_FAME_FILE, ROUND_STATE_FILE, COOLDOWN_STATE_FILE, GRADUATE_DIR
    coin_interval = f"{args.coin}_{args.interval}"
    GRADUATE_DIR = os.path.join(BASE_DIR, 'graduates', coin_interval)
    LOG_FILE = os.path.join(BASE_DIR, 'results', f'forever_log_{coin_interval}.jsonl')
    HALL_OF_FAME_FILE = os.path.join(BASE_DIR, 'results', f'hall_of_fame_{coin_interval}.json')
    ROUND_STATE_FILE = os.path.join(BASE_DIR, 'results', f'round_state_{coin_interval}.json')
    COOLDOWN_STATE_FILE = os.path.join(BASE_DIR, 'results', f'cooldown_state_{coin_interval}.json')

    print("=" * 60)
    print("  GP Engine v0.9 — 统一指标系统")
    print("  停止: touch STOP 或 Ctrl+C")
    print("=" * 60)
    print(f"  币种: {args.coin} | 周期: {args.interval} | 种群: {args.pop} | 代数: {args.gen}"
          + (f" | 子采样: {args.sample}x" if args.sample > 1 else ""))
    print()

    # 数据只加载一次（不变的）
    print("加载数据...")
    (norm_data, close_raw, train_data, train_close, total_candles,
     mirror_norm_data, mirror_close_raw, data_split_idx, data_warmup) = \
        load_and_prepare_data(args.sample)
    print(f"  原始 K 线: {total_candles:,}")
    print(f"  有效数据: {len(close_raw):,} 根")
    orig_train_len = len(train_close)
    print(f"  训练集: {orig_train_len:,} 根")

    # v0.6: 镜像数据拼入训练集（毕业考10关，训练数据也要翻倍）
    has_mirror = mirror_norm_data is not None
    if has_mirror:
        split_idx = len(train_close)
        mirror_train_data = {k: v[:split_idx] for k, v in mirror_norm_data.items()}
        mirror_train_close = mirror_close_raw[:split_idx]
        train_data = {k: np.concatenate([train_data[k], mirror_train_data[k]]) for k in train_data}
        train_close = np.concatenate([train_close, mirror_train_close])
        print(f"  镜像训练: +{len(mirror_train_close):,} 根 → 训练集合计 {len(train_close):,} 根")
        print(f"  镜像毕业考: ✅（10关，需过{config.MIRROR_PASS_REQUIRED}关）")

    # v0.9: 统一指标管理器（通过 indicator_cache 获取所有指标）
    dyn_mgr = UnifiedIndicatorManager(data_split_idx, data_warmup, has_mirror=has_mirror)
    from blocks import PARAM_INDICATORS
    n_param = len(PARAM_INDICATORS)
    from blocks import FIXED_CACHE_TERMINALS
    n_fixed_cache = len(FIXED_CACHE_TERMINALS)
    print(f"  参数化指标: {n_param} 种（自由调参）| 固定终端: {n_fixed_cache} 个（默认参数）")
    print(f"  指标来源: indicator_cache.db（统一库）")
    print()

    round_num = 0
    graduates = 0

    # v0.7: 指标冷却追踪（从磁盘恢复，调度器模式不丢状态）
    indicator_cooldown = {}    # {indicator_name: rounds_remaining} 冷却中的指标
    indicator_usage = {}       # {indicator_name: use_count} 使用计数（达到门槛才冷却）
    if os.path.exists(COOLDOWN_STATE_FILE):
        try:
            with open(COOLDOWN_STATE_FILE) as f:
                _cs = json.load(f)
            indicator_cooldown = _cs.get('cooldown', {})
            indicator_usage = _cs.get('usage', {})
            if indicator_cooldown or indicator_usage:
                cool_names = ', '.join(sorted(indicator_cooldown.keys())) or '无'
                usage_names = ', '.join(f"{k}({v})" for k, v in sorted(indicator_usage.items())) or '无'
                print(f"  冷却恢复: 冷却中=[{cool_names}] 使用计数=[{usage_names}]")
        except Exception:
            pass

    # 加载精英库 + 用当前 fitness 重新评估
    hall_of_fame = load_hall_of_fame()
    n_long = len(hall_of_fame['long'])
    n_short = len(hall_of_fame['short'])
    hof_total = n_long + n_short
    if hof_total > 0:
        print(f"  精英库: L{n_long} / S{n_short} = {hof_total} 个（重新评估中...）")
        hall_of_fame = refresh_hall_of_fame(hall_of_fame, train_data, train_close, dyn_mgr)
        save_hall_of_fame(hall_of_fame)
        n_long = len(hall_of_fame['long'])
        n_short = len(hall_of_fame['short'])
        best_l = hall_of_fame['long'][0]['score'] if hall_of_fame['long'] else -999
        best_s = hall_of_fame['short'][0]['score'] if hall_of_fame['short'] else -999
        print(f"  精英库重新评估完成: L{n_long}(最佳={best_l:+.4f}) / S{n_short}(最佳={best_s:+.4f})")
    else:
        print(f"  精英库: 空（首次运行）")

    # 检查已有日志，确定轮次
    if os.path.exists(LOG_FILE):
        with open(LOG_FILE) as f:
            round_num = sum(1 for _ in f)
        print(f"  从第 {round_num + 1} 轮继续（已有 {round_num} 轮日志）")

    # 清除旧的 STOP 文件
    if os.path.exists(STOP_FILE):
        os.remove(STOP_FILE)

    # 检测中断的轮次（断点续传）
    interrupted = None
    if os.path.exists(ROUND_STATE_FILE):
        try:
            with open(ROUND_STATE_FILE) as f:
                interrupted = json.load(f)
            print(f"  检测到中断的第 {interrupted['round']} 轮，将恢复...")
        except Exception:
            os.remove(ROUND_STATE_FILE)

    try:
        while True:
            if interrupted:
                # 恢复中断的轮次
                round_num = interrupted['round']
                seed = interrupted['seed']
                timestamp = interrupted.get('timestamp', time.strftime('%Y%m%d_%H%M%S'))
                resume_evolve = True
                interrupted = None
                print(f"{'─'*60}")
                print(f"  第 {round_num} 轮（恢复中断）| seed={seed}")
                print(f"{'─'*60}")
            else:
                round_num += 1
                seed = random.randint(0, 2**31)
                timestamp = time.strftime('%Y%m%d_%H%M%S')
                resume_evolve = False
                print(f"{'─'*60}")
                print(f"  第 {round_num} 轮 | seed={seed} | {timestamp}")
                print(f"{'─'*60}")

            random.seed(seed)
            np.random.seed(seed % (2**32))
            t_start = time.time()

            # 精英库当前总数（用于日志）
            hof_total = len(hall_of_fame['long']) + len(hall_of_fame['short'])

            # v0.7: 指标冷却 — 使用计数门槛 + 全局解冻周期
            import blocks as blocks_mod
            cycle_len = config.COOLDOWN_THAW_CYCLE + config.COOLDOWN_THAW_ROUNDS
            cycle_pos = (round_num - 1) % cycle_len  # 0-based position in cycle
            in_thaw_window = cycle_pos >= config.COOLDOWN_THAW_CYCLE

            if in_thaw_window:
                # 解冻窗口：清除所有冷却+使用计数，全部指标可用
                indicator_cooldown.clear()
                indicator_usage.clear()
                blocks_mod.set_cooled_indicators(set())
                thaw_round = cycle_pos - config.COOLDOWN_THAW_CYCLE + 1
                print(f"  🔓 解冻期 ({thaw_round}/{config.COOLDOWN_THAW_ROUNDS}) — 全部指标可用")
            else:
                expired = [k for k, v in indicator_cooldown.items() if v <= 0]
                for k in expired:
                    del indicator_cooldown[k]
                cooled_set = set(indicator_cooldown.keys())
                blocks_mod.set_cooled_indicators(cooled_set)
                if cooled_set:
                    print(f"  冷却中: {', '.join(sorted(cooled_set))}")
                # 显示接近冷却门槛的指标
                warming = {k: v for k, v in indicator_usage.items()
                           if v > 0 and k not in cooled_set}
                if warming:
                    warn_str = ', '.join(f"{k}({v}/{config.INDICATOR_COOLDOWN_TRIGGER})"
                                         for k, v in sorted(warming.items()))
                    print(f"  使用计数: {warn_str}")

            # 保存轮次状态（断点续传用）
            os.makedirs(os.path.dirname(ROUND_STATE_FILE), exist_ok=True)
            with open(ROUND_STATE_FILE, 'w') as f:
                json.dump({'round': round_num, 'seed': seed,
                           'timestamp': timestamp}, f)

            try:
                # 精英种子：从精英库各方向取，注入对应池
                # resume 时不注入（已在 checkpoint 的种群里了）
                # v0.7b: 精英不受冷却过滤，进入精英库就固定作为种子，直到被淘汰
                seed_elites = None
                if not resume_evolve:
                    seed_elites = []
                    for d in ('long', 'short'):
                        for entry in hall_of_fame[d]:
                            seed_elites.append(entry['individual'])
                    n_seed_l = sum(1 for _, d in seed_elites if d == 'long')
                    n_seed_s = sum(1 for _, d in seed_elites if d == 'short')
                    if seed_elites:
                        print(f"  精英注入: L{n_seed_l} / S{n_seed_s}")
                    else:
                        seed_elites = None

                # v1.0: 岛屿模型 or v0.7 分池进化
                if args.islands:
                    candidates, history = evolve_islands(
                        train_data, train_close,
                        generations=args.gen,
                        verbose=True,
                        resume=resume_evolve,
                        seed_elites=seed_elites,
                        ckpt_suffix=coin_interval,
                        ensure_indicators_fn=dyn_mgr.ensure_population_train,
                    )
                else:
                    candidates, history = evolve(
                        train_data, train_close,
                        population_size=args.pop,
                        generations=args.gen,
                        verbose=True,
                        resume=resume_evolve,
                        seed_elites=seed_elites,
                        ckpt_suffix=coin_interval,
                        ensure_indicators_fn=dyn_mgr.ensure_population_train,
                    )

                elapsed = time.time() - t_start
                all_used_indicators = set()

                # 对每个候选人（long冠军 + short冠军）分别毕业考
                for best_ind, best_score, best_result in candidates:
                    best_tree, best_direction = best_ind
                    dir_label = '做多' if best_direction == 'long' else '做空'

                    # v0.7: 确保毕业考数据包含树的参数化指标
                    dyn_mgr.ensure_tree_full(best_tree, norm_data, mirror_norm_data)

                    # Walk-Forward 毕业考
                    if mirror_norm_data is not None:
                        grad_result = walk_forward_with_mirror(
                            best_tree, best_direction, norm_data, close_raw,
                            mirror_norm_data, mirror_close_raw
                        )
                    else:
                        grad_result = walk_forward_validate(
                            best_tree, best_direction, norm_data, close_raw
                        )

                    passed = grad_result['passed']

                    # v0.8: 弃权信息
                    abstain = grad_result.get('abstain_count', 0)
                    reason = grad_result.get('pass_reason', '')
                    abstain_str = f" 弃权{abstain}" if abstain > 0 else ""
                    reason_str = f" [{reason}]" if reason else ""

                    if passed:
                        # v1.0: CMA-ES 参数精化（毕业后自动触发）
                        if config.CMAES_ENABLED and not getattr(args, 'no_cmaes', False):
                            dyn_mgr.ensure_tree_full(best_tree, norm_data, mirror_norm_data)
                            opt_tree, opt_score = optimize_params(
                                best_tree, best_direction,
                                train_data, train_close, verbose=True)
                            if opt_score > best_score:
                                print(f"  🔧 CMA-ES 提升: {best_score:+.4f} → {opt_score:+.4f}")
                                best_tree = opt_tree
                                best_score = opt_score
                                # 精化后重跑毕业考确认
                                dyn_mgr.ensure_tree_full(best_tree, norm_data, mirror_norm_data)
                                if mirror_norm_data is not None:
                                    grad_result = walk_forward_with_mirror(
                                        best_tree, best_direction, norm_data, close_raw,
                                        mirror_norm_data, mirror_close_raw)
                                else:
                                    grad_result = walk_forward_validate(
                                        best_tree, best_direction, norm_data, close_raw)
                                passed = grad_result['passed']
                                if not passed:
                                    print(f"  ⚠️ CMA-ES 后毕业考未通过，用原版")
                                    best_tree = best_ind[0]  # 恢复原树
                            else:
                                print(f"  🔧 CMA-ES 无提升（{best_score:+.4f}），保持原版")

                        filepath = save_graduate(round_num, best_tree, best_direction,
                                                 best_score, grad_result, timestamp)
                        if filepath:
                            graduates += 1
                            print(f"\n  🎓 毕业! ({dir_label}) "
                                  f"{grad_result['profitable_windows']}/{grad_result['total_windows']}关"
                                  f"{abstain_str}{reason_str} "
                                  f"存档: {os.path.basename(filepath)}")
                        else:
                            print(f"\n  ⏭️ 毕业考通过 ({dir_label}) 但同骨架已有更强毕业生，跳过存档")
                    else:
                        print(f"\n  ❌ 未毕业 ({dir_label}) "
                              f"{grad_result['profitable_windows']}/{grad_result['total_windows']}关"
                              f"{abstain_str}{reason_str} "
                              f"均值={grad_result['avg_test_return']:+.4f}")

                    # v0.7: 显示冠军公式和使用的指标
                    formula = tree_mod.to_formula(best_tree)
                    used = extract_indicators(best_tree)
                    print(f"  📊 公式: {formula}")
                    print(f"  📊 指标: {', '.join(sorted(used)) if used else '(无)'}")

                    # 日志
                    log_entry = {
                        'round': round_num,
                        'timestamp': timestamp,
                        'seed': seed,
                        'elapsed_sec': round(elapsed, 1),
                        'passed': passed,
                        'direction': best_direction,
                        'formula': tree_mod.to_formula(best_tree),
                        'tree_size': tree_mod.size(best_tree),
                        'evolution_score': round(best_score, 4),
                        'train_return': round(grad_result['train_return'], 4),
                        'profitable_windows': grad_result['profitable_windows'],
                        'total_windows': grad_result['total_windows'],
                        'avg_test_return': round(grad_result['avg_test_return'], 4),
                        'overfit_score': round(grad_result['overfit_score'], 2),
                        'abstain_count': grad_result.get('abstain_count', 0),
                        'pass_reason': grad_result.get('pass_reason', ''),
                    }
                    if 'normal_profitable' in grad_result:
                        log_entry['normal_profitable'] = grad_result['normal_profitable']
                        log_entry['mirror_profitable'] = grad_result['mirror_profitable']
                    append_log(log_entry)

                    # 更新精英库
                    hall_of_fame = update_hall_of_fame(
                        hall_of_fame, round_num, best_ind, best_score, grad_result
                    )
                    save_hall_of_fame(hall_of_fame)

                    # 收集冠军用过的指标
                    all_used_indicators |= extract_indicators(best_tree)

                # v0.7: 指标冷却 — 使用计数达到门槛才冷却，解冻期不处理
                if not in_thaw_window:
                    for ind_name in all_used_indicators:
                        if ind_name in indicator_cooldown:
                            continue  # 已在冷却中，不重复计数
                        indicator_usage[ind_name] = indicator_usage.get(ind_name, 0) + 1
                        if indicator_usage[ind_name] >= config.INDICATOR_COOLDOWN_TRIGGER:
                            # 达到门槛，进入冷却
                            indicator_cooldown[ind_name] = config.INDICATOR_COOLDOWN_ROUNDS
                            indicator_usage.pop(ind_name, None)
                    # 递减已冷却指标的计数器
                    for ind_name in list(indicator_cooldown.keys()):
                        if ind_name not in all_used_indicators:
                            indicator_cooldown[ind_name] -= 1

                # 轮次完成，清除 round_state + 保存冷却状态
                if os.path.exists(ROUND_STATE_FILE):
                    os.remove(ROUND_STATE_FILE)
                with open(COOLDOWN_STATE_FILE, 'w') as f:
                    json.dump({'cooldown': indicator_cooldown,
                               'usage': indicator_usage}, f)

                cool_str = f" | 冷却: {','.join(sorted(all_used_indicators))}" if all_used_indicators else ""
                hof_total = len(hall_of_fame['long']) + len(hall_of_fame['short'])
                print(f"  耗时: {elapsed:.0f}s | 累计毕业: {graduates}/{round_num} "
                      f"| 精英库: L{len(hall_of_fame['long'])}/S{len(hall_of_fame['short'])}={hof_total}个{cool_str}")
                print()

            except Exception as e:
                elapsed = time.time() - t_start
                print(f"\n  ⚠️ 第 {round_num} 轮异常: {e}")
                traceback.print_exc()
                append_log({
                    'round': round_num,
                    'timestamp': timestamp,
                    'seed': seed,
                    'elapsed_sec': round(elapsed, 1),
                    'error': str(e),
                })
                print(f"  已记录错误，继续下一轮...\n")

            # 停止检查
            if os.path.exists(STOP_FILE):
                print("检测到 STOP 文件，停止。")
                os.remove(STOP_FILE)
                break

            # --rounds N: 达到指定轮数后退出
            if args.rounds > 0 and round_num >= args.rounds:
                print(f"已完成 {args.rounds} 轮，退出。")
                break

    except KeyboardInterrupt:
        print(f"\n\nCtrl+C 停止。完成 {round_num} 轮，毕业 {graduates} 个。")

    print(f"\n{'='*60}")
    print(f"  总计: {round_num} 轮, {graduates} 个毕业生")
    print(f"  毕业率: {graduates/max(round_num,1):.1%}")
    print(f"  日志: {LOG_FILE}")
    if graduates > 0:
        print(f"  毕业生: {GRADUATE_DIR}/")
    print(f"{'='*60}")


if __name__ == '__main__':
    main()
