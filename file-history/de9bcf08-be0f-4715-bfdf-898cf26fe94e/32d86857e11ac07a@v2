def load_and_prepare_data(sample=1):
    """加载数据 → 子采样 → 计算基础指标 → 归一化 → 初始化 indicator_cache → 镜像数据

    v0.9: 不再使用 pickle 缓存，所有指标通过 indicator_cache 按需获取。
    基础数据（close/volume/volume_ratio/obv_slope）仍由 GP 自算。
    """
    data_path = os.path.join(config.DATA_DIR, config.DATA_COIN,
                             f'{config.DATA_INTERVAL}.json')

    with open(data_path) as f:
        raw_candles = json.load(f)

    ohlcv = {
        'open':   np.array([c['open'] for c in raw_candles], dtype=float),
        'high':   np.array([c['high'] for c in raw_candles], dtype=float),
        'low':    np.array([c['low'] for c in raw_candles], dtype=float),
        'close':  np.array([c['close'] for c in raw_candles], dtype=float),
        'volume': np.array([c['volume'] for c in raw_candles], dtype=float),
    }

    if sample > 1:
        ohlcv = {k: v[::sample] for k, v in ohlcv.items()}
        raw_candles = raw_candles[::sample]

    # 初始化 indicator_cache（所有指标的统一入口）
    indicator_cache.init_cache(config.DATA_COIN, config.DATA_INTERVAL,
                               raw_candles, config.INDICATOR_CACHE_DB)

    # --- 基础数据（GP 自算，不经过 indicator_cache）---
    close = ohlcv['close']
    volume = ohlcv['volume']
    warmup = indicators.warmup_bars()

    # volume_ratio: 当前量 / 20日均量
    vol_ma20 = indicators.sma(volume, 20)
    volume_ratio = np.where(vol_ma20 > 1e-10, volume / vol_ma20, 1.0)

    # obv_slope: OBV 的 10 期斜率
    price_dir = np.sign(np.diff(close, prepend=close[0]))
    obv_raw = np.cumsum(price_dir * volume)
    obv_slope = obv_raw - np.roll(obv_raw, 10)
    obv_slope[:10] = 0.0

    base_indicators = {
        'close': close[warmup:],
        'volume': volume[warmup:],
        'volume_ratio': volume_ratio[warmup:],
        'obv_slope': obv_slope[warmup:],
    }
    close_raw = close[warmup:]

    split_idx = int(len(close_raw) * config.TRAIN_RATIO)
    norm_data, _ = indicators.normalize(base_indicators, train_end_idx=split_idx)

    train_data = {k: v[:split_idx] for k, v in norm_data.items()}
    train_close = close_raw[:split_idx]

    # --- 镜像数据（v0.3: 价格上下翻转）---
    mirror_norm_data = None
    mirror_close_raw = None
    if config.MIRROR_WF:
        mirror_ohlcv = indicators.mirror_ohlcv(ohlcv)
        mirror_close_raw = mirror_ohlcv['close'][warmup:]

        # 镜像基础数据
        mirror_volume = mirror_ohlcv['volume'][warmup:]
        mirror_vol_ma20 = indicators.sma(mirror_ohlcv['volume'], 20)
        mirror_volume_ratio = np.where(mirror_vol_ma20 > 1e-10,
                                        mirror_ohlcv['volume'] / mirror_vol_ma20, 1.0)
        mirror_price_dir = np.sign(np.diff(mirror_ohlcv['close'],
                                            prepend=mirror_ohlcv['close'][0]))
        mirror_obv = np.cumsum(mirror_price_dir * mirror_ohlcv['volume'])
        mirror_obv_slope = mirror_obv - np.roll(mirror_obv, 10)
        mirror_obv_slope[:10] = 0.0

        mirror_base = {
            'close': mirror_close_raw,
            'volume': mirror_volume,
            'volume_ratio': mirror_volume_ratio[warmup:],
            'obv_slope': mirror_obv_slope[warmup:],
        }
        mirror_norm_data, _ = indicators.normalize(mirror_base,
                                                    train_end_idx=split_idx)

    return (norm_data, close_raw, train_data, train_close, len(raw_candles),
            mirror_norm_data, mirror_close_raw, split_idx, warmup)


class UnifiedIndicatorManager:
    """
    v0.9: 统一指标管理器 — 所有指标通过 indicator_cache.get_indicator() 获取。

    GP 可以自由选择 RSI(23)、ATR(10)、HMA(50) 等任意周期。
    所有计算和 DB 缓存由 indicator_cache 处理，本管理器只做：
      1. 调用 get_indicator() 获取原始数据
      2. Z-score 归一化（训练集统计量）
      3. 内存缓存归一化结果
      4. 镜像数据取反（Z-score negation 近似）

    消除了旧的 pickle 缓存、compute_single_close、load_from_cache。
    """

    def __init__(self, split_idx, warmup, has_mirror=False):
        self.split_idx = split_idx   # 训练集切分点（warmup 后的索引）
        self.warmup = warmup         # 预热 K 线数
        self.has_mirror = has_mirror
        self._norm_cache = {}  # cache_key → 归一化后的全长数组（warmup 后）

    def _get_normalized(self, cache_name, dict_key=None, **params):
        """从 indicator_cache 获取原始数据 → Z-score 归一化 → 缓存"""
        cache_key = (cache_name, dict_key, tuple(sorted(params.items())))
        if cache_key in self._norm_cache:
            return self._norm_cache[cache_key]

        raw = indicator_cache.get_indicator(cache_name, **params)
        if isinstance(raw, dict):
            if dict_key and dict_key in raw:
                raw = raw[dict_key]
            else:
                # fallback: 取第一个 key
                raw = list(raw.values())[0]

        arr = np.array(raw, dtype=float)
        # 裁掉预热期
        arr = arr[self.warmup:]
        # Z-score 归一化（用训练集统计量）
        train_part = arr[:self.split_idx]
        valid = train_part[~np.isnan(train_part)]
        if len(valid) == 0:
            mean, std = 0.0, 1.0
        else:
            mean = float(np.mean(valid))
            std = float(np.std(valid))
            if std < 1e-10:
                std = 1.0
        normalized = (arr - mean) / std

        self._norm_cache[cache_key] = normalized
        return normalized

    def _resolve_terminal(self, node_name, node_param):
        """解析终端节点 → (cache_name, dict_key, params_dict)，或 None 表示基础数据"""
        from blocks import PARAM_INDICATORS, PARAM_DICT_PRIMARY, FIXED_CACHE_MAP

        if node_param is not None:
            # 参数化终端: rsi(14) → get_indicator('rsi', period=14)
            dict_key = PARAM_DICT_PRIMARY.get(node_name)
            return (node_name, dict_key, {'period': node_param})
        elif node_name in FIXED_CACHE_MAP:
            # 固定缓存终端: macd_hist → get_indicator('macd')['histogram']
            cache_name, params, dict_key = FIXED_CACHE_MAP[node_name]
            return (cache_name, dict_key, params)
        else:
            # 基础数据（close/volume/volume_ratio/obv_slope/const）→ 已在 data 中
            return None

    def ensure_terminal_train(self, data, node_name, node_param=None):
        """确保 train_data 中包含该终端的数据"""
        resolved = self._resolve_terminal(node_name, node_param)
        if resolved is None:
            return  # 基础数据，已预载

        cache_name, dict_key, params = resolved
        key = f"{node_name}_{node_param}" if node_param is not None else node_name
        if key in data:
            return

        norm = self._get_normalized(cache_name, dict_key, **params)
        if self.has_mirror:
            orig_train = norm[:self.split_idx]
            mirror_train = -norm[:self.split_idx]  # Z-score negation 近似
            data[key] = np.concatenate([orig_train, mirror_train])
        else:
            data[key] = norm[:self.split_idx]

    def ensure_terminal_full(self, data, node_name, node_param=None, is_mirror=False):
        """确保全长 norm_data 中包含该终端的数据（毕业考用）"""
        resolved = self._resolve_terminal(node_name, node_param)
        if resolved is None:
            return

        cache_name, dict_key, params = resolved
        key = f"{node_name}_{node_param}" if node_param is not None else node_name
        if key in data:
            return

        norm = self._get_normalized(cache_name, dict_key, **params)
        data[key] = -norm if is_mirror else norm.copy()

    def _scan_tree(self, node, callback):
        """递归扫描树的所有终端节点，对每个调用 callback(node_name, node_param)"""
        if node.kind == 'terminal' and node.name not in ('const',):
            callback(node.name, node.param)
        for child in node.children:
            self._scan_tree(child, callback)

    def ensure_population_train(self, data, population):
        """扫描整个种群，确保 train_data 包含所有需要的指标"""
        for tree, _ in population:
            self._scan_tree(tree,
                            lambda name, param: self.ensure_terminal_train(data, name, param))

    def ensure_tree_full(self, tree, norm_data, mirror_norm_data=None):
        """确保毕业考的全长数据包含树需要的所有指标"""
        self._scan_tree(tree,
                        lambda name, param: self.ensure_terminal_full(
                            norm_data, name, param, is_mirror=False))
        if mirror_norm_data is not None:
            self._scan_tree(tree,
                            lambda name, param: self.ensure_terminal_full(
                                mirror_norm_data, name, param, is_mirror=True))


def save_graduate(round_num, tree, direction, score, grad_result, timestamp):
    """保存毕业生（骨架去重：同骨架同方向只保留最强）"""
    os.makedirs(GRADUATE_DIR, exist_ok=True)

    skeleton = tree_mod.to_skeleton(tree)

    # 骨架去重：检查已有毕业生
    for existing_file in os.listdir(GRADUATE_DIR):
        if not existing_file.endswith('.json'):
            continue
        try:
            fpath = os.path.join(GRADUATE_DIR, existing_file)
            with open(fpath) as f:
                existing = json.load(f)
            if existing.get('direction') != direction:
                continue
            existing_tree = tree_mod.deserialize(existing['tree'])
            existing_skeleton = tree_mod.to_skeleton(existing_tree)
            if existing_skeleton == skeleton:
                if score > existing.get('evolution_score', 0):
                    os.remove(fpath)
                    print(f"  🔄 替换同骨架旧毕业生: {existing_file}")
                    break
                else:
                    return None  # 已有更强的同骨架毕业生
        except Exception:
            continue

    filename = f'grad_{timestamp}_r{round_num}.json'
    filepath = os.path.join(GRADUATE_DIR, filename)

    data = {
        'round': round_num,
        'timestamp': timestamp,
        'formula': tree_mod.to_formula(tree),
        'skeleton': skeleton,
        'direction': direction,
        'tree': tree_mod.serialize(tree),
        'tree_size': tree_mod.size(tree),
        'tree_depth': tree_mod.depth(tree),
        'evolution_score': score,
        'graduation': {
            'passed': grad_result['passed'],
            'pass_reason': grad_result.get('pass_reason', ''),
            'abstain_count': grad_result.get('abstain_count', 0),
            'valid_windows': grad_result.get('valid_windows', grad_result['total_windows']),
            'train_return': grad_result['train_return'],
            'train_sharpe': grad_result['train_sharpe'],
            'profitable_windows': grad_result['profitable_windows'],
            'total_windows': grad_result['total_windows'],
            'window_returns': grad_result['window_returns'],
            'avg_test_return': grad_result['avg_test_return'],
            'degradation': grad_result['degradation'],
            'overfit_score': grad_result['overfit_score'],
        },
    }
    with open(filepath, 'w') as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
    return filepath


