# === 精英库 ===

def load_hall_of_fame():
    """加载精英库（按方向分开）— 骨架去重（同结构不同参数只保留最强）

    来源优先级：
    1. graduates/ 目录（已毕业的好基因）
    2. hall_of_fame.json（精英库持久化文件）
    骨架去重后合并，各方向按分数排序。
    """
    all_candidates = []  # (skeleton_key, entry_dict)

    # 1. 从 graduates/ 加载已有毕业生
    if os.path.exists(GRADUATE_DIR):
        for filename in os.listdir(GRADUATE_DIR):
            if not filename.endswith('.json'):
                continue
            try:
                filepath = os.path.join(GRADUATE_DIR, filename)
                with open(filepath) as f:
                    data = json.load(f)
                formula = data.get('formula', '')
                direction = data.get('direction', 'long')
                tree = tree_mod.deserialize(data['tree'])
                skeleton = tree_mod.to_skeleton(tree)
                grad = data.get('graduation', {})
                entry = {
                    'individual': (tree, direction),
                    'score': data.get('evolution_score', 0),
                    'windows_passed': grad.get('profitable_windows', 0),
                    'total_windows': grad.get('total_windows', 0),
                    'round': data.get('round', 0),
                    'formula': formula,
                    'skeleton': skeleton,
                }
                skel_key = f"{skeleton}|{direction}"
                all_candidates.append((skel_key, entry))
            except Exception as e:
                print(f"  跳过损坏的毕业生 {filename}: {e}")

    # 2. 从精英库文件加载（兼容旧格式列表和新格式字典）
    if os.path.exists(HALL_OF_FAME_FILE):
        try:
            with open(HALL_OF_FAME_FILE) as f:
                raw = json.load(f)

            if isinstance(raw, dict):
                entries = raw.get('long', []) + raw.get('short', [])
            else:
                entries = raw

            for entry_data in entries:
                formula = entry_data.get('formula', '')
                direction = entry_data.get('direction', 'long')
                tree = tree_mod.deserialize(entry_data['tree'])
                skeleton = tree_mod.to_skeleton(tree)
                entry = {
                    'individual': (tree, direction),
                    'score': entry_data['score'],
                    'windows_passed': entry_data['windows_passed'],
                    'total_windows': entry_data['total_windows'],
                    'round': entry_data['round'],
                    'formula': formula,
                    'skeleton': skeleton,
                }
                skel_key = f"{skeleton}|{direction}"
                all_candidates.append((skel_key, entry))
        except Exception as e:
            print(f"  精英库文件加载失败: {e}")

    # 3. 骨架去重：同骨架+同方向只保留分数最高的
    best_by_skeleton = {}
    for skel_key, entry in all_candidates:
        if skel_key not in best_by_skeleton or entry['score'] > best_by_skeleton[skel_key]['score']:
            best_by_skeleton[skel_key] = entry

    # 4. 构建精英库
    hall = {'long': [], 'short': []}
    for entry in best_by_skeleton.values():
        _, direction = entry['individual']
        hall[direction].append(entry)

    for d in ('long', 'short'):
        hall[d].sort(key=lambda x: x['score'], reverse=True)
        hall[d] = hall[d][:HALL_OF_FAME_SIZE]

    return hall


def refresh_hall_of_fame(hall, train_data, train_close, dyn_mgr=None):
    """用当前 fitness 重新评估精英库所有个体，淘汰过时的"""
    from evaluator import fitness
    for d in ('long', 'short'):
        for entry in hall[d]:
            tree, direction = entry['individual']
            # v0.9: 统一管理器确保所有指标存在（含参数化和固定缓存终端）
            if dyn_mgr:
                dyn_mgr._scan_tree(tree,
                                    lambda name, param: dyn_mgr.ensure_terminal_train(
                                        train_data, name, param))
            score, _ = fitness(tree, train_data, train_close, direction)
            entry['score'] = score
        hall[d].sort(key=lambda x: x['score'], reverse=True)
        hall[d] = hall[d][:HALL_OF_FAME_SIZE]
    return hall


def save_hall_of_fame(hall):
    """保存精英库到文件（按方向分开）"""
    os.makedirs(os.path.dirname(HALL_OF_FAME_FILE), exist_ok=True)
    data = {}
    for d in ('long', 'short'):
        data[d] = [{
            'tree': tree_mod.serialize(e['individual'][0]),
            'direction': d,
            'score': e['score'],
            'windows_passed': e['windows_passed'],
            'total_windows': e['total_windows'],
            'round': e['round'],
            'formula': e['formula'],
        } for e in hall[d]]
    tmp = HALL_OF_FAME_FILE + '.tmp'
    with open(tmp, 'w') as f:
        json.dump(data, f, separators=(',', ':'))
    os.replace(tmp, HALL_OF_FAME_FILE)


def update_hall_of_fame(hall, round_num, best_ind, best_score, grad_result):
    """将本轮最佳加入对应方向的精英库（骨架去重）"""
    tree, direction = best_ind
    formula = tree_mod.to_formula(tree)
    skeleton = tree_mod.to_skeleton(tree)
    pool = hall[direction]

    # 骨架去重：同结构不同参数只保留最强的
    for entry in pool:
        entry_skeleton = entry.get('skeleton', '')
        if not entry_skeleton:
            entry_tree, _ = entry['individual']
            entry_skeleton = tree_mod.to_skeleton(entry_tree)
        if entry_skeleton == skeleton:
            # 同骨架：分数更高才替换
            if best_score > entry['score']:
                entry['individual'] = (tree, direction)
                entry['score'] = best_score
                entry['windows_passed'] = grad_result['profitable_windows']
                entry['total_windows'] = grad_result['total_windows']
                entry['round'] = round_num
                entry['formula'] = formula
                entry['skeleton'] = skeleton
            return hall

    pool.append({
        'individual': (tree, direction),
        'score': best_score,
        'windows_passed': grad_result['profitable_windows'],
        'total_windows': grad_result['total_windows'],
        'round': round_num,
        'formula': formula,
        'skeleton': skeleton,
    })

    pool.sort(key=lambda x: x['score'], reverse=True)
    hall[direction] = pool[:HALL_OF_FAME_SIZE]
    return hall


def extract_indicators(node):
    """从树中提取使用的指标名（不含 close/volume/const）。
    v0.7: 参数化指标返回类型名（如 'rsi'），用于按类型冷却。
    """
    used = set()
    if node.kind == 'terminal' and node.name not in ('const', 'close', 'volume'):
        # param 不为 None → 参数化指标，返回类型名（如 'rsi'）
        # param 为 None → 固定指标，返回完整名（如 'atr_7'）
        used.add(node.name)
    for child in node.children:
        used |= extract_indicators(child)
    return used


def main():
