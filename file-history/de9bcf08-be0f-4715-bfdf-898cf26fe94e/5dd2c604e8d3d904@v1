"""
表达式树 — GP 的核心数据结构

一棵树 = 一个交易信号规则
  - 根节点输出 BOOLEAN（1.0=做多, 0.0=空仓）
  - 内部节点是运算（加减乘除、比较、逻辑）
  - 叶子节点是数据（指标值、价格、常数）

主要操作:
  - random_tree(): 随机生成
  - crossover(): 两棵树交换子树
  - mutate(): 随机替换一个节点
  - evaluate(): 在数据上执行，输出信号数组
  - to_string(): 转成人类可读的规则
"""
import random
import copy
import numpy as np
from blocks import (
    NUMERIC, BOOLEAN,
    NUMERIC_TERMINALS, NUMERIC_FUNCTIONS, BOOLEAN_FUNCTIONS,
    FUNC_LOOKUP, random_constant, get_available_numeric_terminals,
    PARAM_INDICATORS, get_available_fixed_terminals,
    get_available_param_types, random_param,
)
from config import MAX_DEPTH, MIN_DEPTH

# 旧终端名 → (参数化类型, 周期) 映射（向后兼容反序列化）
# v0.9: 扩展所有已变为参数化的旧固定终端
