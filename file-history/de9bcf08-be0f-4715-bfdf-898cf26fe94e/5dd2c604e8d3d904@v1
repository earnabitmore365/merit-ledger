    'ema_9': ('ema', 9), 'ema_21': ('ema', 21),
    # v0.9: 旧 v0.8 固定终端 → 参数化
    'atr_7': ('atr', 7), 'atr_10': ('atr', 10), 'atr_14': ('atr', 14), 'atr_20': ('atr', 20),
    'cci_7': ('cci', 7), 'cci_20': ('cci', 20),
    'cmf_20': ('cmf', 20),
    'cmo_9': ('cmo', 9),
    'dema_5': ('dema', 5),
    'demand_index_20': ('demand_index', 20),
    'fisher_transform_9': ('fisher_transform', 9),
    'hma_9': ('hma', 9),
    'linreg_slope_10': ('linreg_slope', 10),
    'roc_10': ('roc', 10), 'roc_20': ('roc', 20),
    'tema_8': ('tema', 8),
    'ulcer_index_14': ('ulcer_index', 14),
    'volume_momentum_10': ('volume_momentum', 10),
    'vortex_14': ('vortex', 14),
    'vroc_20': ('vroc', 20),
    'vwap_20': ('vwap', 20),
