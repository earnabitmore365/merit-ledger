#!/usr/bin/env python3
"""
增量回测一致性验证

测试方法：
  1. 全量跑完整数据 → 得到交易列表 A
  2. 跑前半数据（全量）→ 保存断点 → 再跑后半数据（增量）→ 得到交易列表 B
  3. 对比 A 和 B 的每笔交易必须完全一致

选 3 个代表性 combo：
  - mean_reversion / ETH / 15m（均值回归，中频）
  - matriple / XRP / 5m（高频）
  - vol_reversion / BTC / 1h（低频，长周期）
"""

import sys
import os
import json
import sqlite3
import shutil
import tempfile
from datetime import datetime

_lab_dir = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, _lab_dir)
sys.path.insert(0, os.path.join(_lab_dir, 'src'))

from src.backtest.generate_seed import (
    load_candles, compute_regime_timeline, pair_trades,
    save_combo, save_regime_timeline, init_db, check_regime_exists,
    DAYS, INITIAL_CAPITAL, LEVERAGE, STOP_LOSS_PCT, FIXED_BET,
    FIXED_BET_AMOUNT, FEE_RATE, SLIPPAGE_PCT, FUNDING_RATE_8H,
)
from src.backtest.backtest import BacktestEngine
from incremental_backtest import (
    ensure_checkpoint_table, run_incremental, save_checkpoint,
    load_checkpoint, get_combo_id, _BARS_PER_DAY,
)
from core.indicator_cache import close_cache


def run_full_backtest(db_path, strategy_name, coin, interval, candles,
                      regime_timeline, enable_ttp=False):
    """全量跑一个 combo，返回配对交易列表"""
    bars_per_day = _BARS_PER_DAY.get(interval, 24)
    bar_minutes = {'1m': 1, '5m': 5, '15m': 15, '30m': 30, '1h': 60}.get(interval, 60)
    bars_per_funding = int((8 * 60) / bar_minutes) if bar_minutes > 0 else 999999

    engine = BacktestEngine(
        coin=coin, interval=interval, days=DAYS,
        initial_capital=INITIAL_CAPITAL, enable_ttp=enable_ttp,
        stop_loss_pct=STOP_LOSS_PCT, leverage=LEVERAGE,
        enable_withdraw=False, fixed_bet=FIXED_BET,
        candles=candles, fixed_bet_amount=FIXED_BET_AMOUNT,
        fee_rate=FEE_RATE, slippage_pct=SLIPPAGE_PCT,
        funding_rate_8h=FUNDING_RATE_8H)
    result = engine.run_backtest(strategy_name)
    if result is None:
        return []

    paired = pair_trades(
        engine.trades, engine.trade_candle_indices,
        regime_timeline, LEVERAGE,
        candles=engine.candles, bars_per_funding=bars_per_funding)

    close_cache()
    return paired


def compare_trades(full_trades, incr_trades, label):
    """逐笔对比交易，报告差异"""
    print(f"\n{'='*60}")
    print(f"验证: {label}")
    print(f"全量: {len(full_trades)} 笔, 增量: {len(incr_trades)} 笔")

    if len(full_trades) != len(incr_trades):
        print(f"❌ 交易数不一致! 全量={len(full_trades)}, 增量={len(incr_trades)}")
        # 找出第一个不同的位置
        min_len = min(len(full_trades), len(incr_trades))
        for i in range(min_len):
            if abs(full_trades[i]['pnl'] - incr_trades[i]['pnl']) > 0.0001:
                print(f"  第 {i} 笔开始不一致:")
                print(f"    全量: {full_trades[i]['open_time']} → {full_trades[i]['close_time']} "
                      f"pnl={full_trades[i]['pnl']:.6f} type={full_trades[i]['close_type']}")
                print(f"    增量: {incr_trades[i]['open_time']} → {incr_trades[i]['close_time']} "
                      f"pnl={incr_trades[i]['pnl']:.6f} type={incr_trades[i]['close_type']}")
                break
        return False

    mismatches = 0
    for i in range(len(full_trades)):
        f = full_trades[i]
        inc = incr_trades[i]

        # 关键字段对比
        checks = [
            ('open_time', f['open_time'], inc['open_time']),
            ('close_time', f['close_time'], inc['close_time']),
            ('direction', f['direction'], inc['direction']),
            ('entry_price', f['entry_price'], inc['entry_price']),
            ('exit_price', f['exit_price'], inc['exit_price']),
            ('close_type', f['close_type'], inc['close_type']),
        ]

        for field, fv, iv in checks:
            if fv != iv:
                if mismatches < 5:
                    print(f"  ❌ 第 {i} 笔 {field}: 全量={fv}, 增量={iv}")
                mismatches += 1

        # 数值字段用容差
        num_checks = [
            ('pnl', f['pnl'], inc['pnl']),
            ('r_value', f['r_value'], inc['r_value']),
            ('balance_after', f['balance_after'], inc['balance_after']),
        ]
        for field, fv, iv in num_checks:
            if abs(fv - iv) > 0.001:
                if mismatches < 5:
                    print(f"  ❌ 第 {i} 笔 {field}: 全量={fv:.6f}, 增量={iv:.6f}")
                mismatches += 1

    if mismatches == 0:
        print(f"✅ 完全一致! {len(full_trades)} 笔交易逐笔匹配")
        return True
    else:
        print(f"❌ {mismatches} 处不一致")
        return False


def test_combo(strategy_name, coin, interval, split_ratio=0.5):
    """测试单个 combo 的增量一致性"""
    print(f"\n{'#'*60}")
    print(f"测试: {strategy_name} / {coin} / {interval}")
    print(f"分割比例: {split_ratio}")

    # 加载完整数据
    candles = load_candles(coin, interval)
    if not candles:
        print(f"  跳过: 无K线数据")
        return None

    print(f"  K线数: {len(candles)}")

    # 计算 regime（用完整数据）
    regime_full = compute_regime_timeline(candles, interval, DAYS)

    # ===== 1. 全量跑 =====
    print(f"\n  [1/3] 全量回测...")
    full_trades = run_full_backtest(
        None, strategy_name, coin, interval, candles, regime_full)
    print(f"  全量结果: {len(full_trades)} 笔交易")

    if not full_trades:
        print(f"  跳过: 全量回测无交易")
        return None

    # ===== 2. 前半全量 → 保存 → 后半增量 =====
    split_idx = int(len(candles) * split_ratio)
    candles_first = candles[:split_idx]
    regime_first = compute_regime_timeline(candles_first, interval, DAYS)

    # 用临时 DB
    tmp_dir = tempfile.mkdtemp()
    db_path = os.path.join(tmp_dir, 'test_incr.db')

    try:
        conn = init_db(db_path)
        ensure_checkpoint_table(conn)

        # 保存 regime（前半）
        save_regime_timeline(conn, coin, interval, regime_first)
        conn.commit()

        # 前半全量
        print(f"\n  [2/3] 前半全量 ({len(candles_first)} K线)...")
        result_first = run_incremental(
            conn, strategy_name, coin, interval,
            candles_first, regime_first,
            enable_ttp=False, force_full=True)
        print(f"  前半结果: status={result_first['status']}, trades={result_first['new_trades']}")

        close_cache()

        # 检查断点
        cp = load_checkpoint(conn, strategy_name, coin, interval)
        if cp:
            print(f"  断点: position={cp['position']}, balance=${cp['balance']:.2f}, "
                  f"last_time={cp['last_candle_time_ms']}")

        # 后半增量（用完整K线 + 完整 regime）
        # 需要先删掉旧 regime 再存完整的
        conn.execute("DELETE FROM regime_timeline WHERE coin=? AND interval=?",
                     (coin, interval))
        save_regime_timeline(conn, coin, interval, regime_full)
        conn.commit()

        print(f"\n  [3/3] 后半增量 ({len(candles)} K线，增量 {len(candles) - split_idx})...")
        result_incr = run_incremental(
            conn, strategy_name, coin, interval,
            candles, regime_full,
            enable_ttp=False, force_full=False)
        print(f"  增量结果: status={result_incr['status']}, trades={result_incr['new_trades']}")

        close_cache()

        # 读取增量后的所有交易
        combo_id = get_combo_id(conn, strategy_name, coin, interval)
        cur = conn.execute(
            """SELECT open_candle_idx, close_candle_idx, open_time, close_time,
                      holding_bars, direction, entry_price, exit_price,
                      pnl, r_value, balance_after, close_type
               FROM paired_trades WHERE combo_id=? ORDER BY id""",
            (combo_id,))
        incr_trades = [
            {'open_candle_idx': r[0], 'close_candle_idx': r[1],
             'open_time': r[2], 'close_time': r[3],
             'holding_bars': r[4], 'direction': r[5],
             'entry_price': r[6], 'exit_price': r[7],
             'pnl': r[8], 'r_value': r[9],
             'balance_after': r[10], 'close_type': r[11]}
            for r in cur.fetchall()]

        conn.close()

        # ===== 3. 对比 =====
        return compare_trades(full_trades, incr_trades,
                              f"{strategy_name}/{coin}/{interval}")

    finally:
        shutil.rmtree(tmp_dir, ignore_errors=True)


def main():
    combos = [
        ('mean_reversion', 'ETH', '15m'),
        ('vol_reversion', 'XRP', '5m'),
        ('matriple', 'BTC', '1h'),
    ]

    results = {}
    for strategy, coin, interval in combos:
        ok = test_combo(strategy, coin, interval, split_ratio=0.6)
        results[f"{strategy}/{coin}/{interval}"] = ok

    print(f"\n{'='*60}")
    print("汇总:")
    all_pass = True
    for label, ok in results.items():
        status = "✅ PASS" if ok else ("⚠️ SKIP" if ok is None else "❌ FAIL")
        print(f"  {status} — {label}")
        if ok is False:
            all_pass = False

    if all_pass:
        print("\n🎉 全部通过!")
    else:
        print("\n⚠️ 有失败项，需要排查")


if __name__ == '__main__':
    main()
