### 代码改动

只改 `regime_router.py` 的 `_determine_mode()` 方法：

```python
def _determine_mode(self, klines: List[Dict]) -> str:
    from core.indicator_cache import get_indicator, set_active_namespace
    set_active_namespace('normal')

    adx_data = get_indicator('adx', period=14)
    if adx_data is None or not adx_data.get('adx'):
        return 'normal'  # 数据不足，安全模式

    adx_val = float(adx_data['adx'][-1])

    if adx_val > 25:
        return 'flipped'
    elif adx_val < 20:
        return 'normal'
    else:
        return self._current_mode  # 缓冲区：保持惯性
```

