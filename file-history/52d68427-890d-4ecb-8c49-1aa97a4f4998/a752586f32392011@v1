#!/usr/bin/env python3
"""
MirrorStrategy — 翻转数据 + 反转信号

等价于回测里的 mirror_candles（generate_seed.py）：
1. 收到实时 K 线 → 翻转 OHLCV（max_price - price, swap high/low）
2. 用翻转数据初始化 indicator_cache → 策略基于翻转指标发信号
3. 信号反转（翻转世界的 BUY = 真实的 SELL）

白纱指出关键问题：简单反转信号是错的，必须先翻转数据再跑策略。
"""

from typing import Dict, List
from core.strategy.base import Strategy, Signal, TradingSignal


class MirrorStrategy(Strategy):
    """Mirror 策略包装器

    包装任意策略，翻转 OHLCV 数据后喂给策略，再反转信号。
    """

    def __init__(self, inner_strategy: Strategy):
        super().__init__(inner_strategy.name + '_mirror')
        self._inner = inner_strategy

    @property
    def name(self) -> str:
        return self._inner.name + '_mirror'

    @name.setter
    def name(self, value):
        pass  # 忽略外部设置，name 由 inner 决定

    def _mirror_klines(self, klines: List[Dict]) -> List[Dict]:
        """翻转 OHLCV — 同 generate_seed.py mirror_candles()

        max_price - price 翻转所有价格，swap high/low。
        volume/time 不变。
        """
        if not klines:
            return klines
        max_price = max(k['high'] for k in klines)
        mirrored = []
        for k in klines:
            m = dict(k)
            m['open'] = max_price - k['open']
            m['close'] = max_price - k['close']
            m['high'] = max_price - k['low']    # swap
            m['low'] = max_price - k['high']    # swap
            mirrored.append(m)
        return mirrored

    def _flip_signal(self, signal):
        """BUY↔SELL 反转，HOLD/CLOSE 不变

        支持 TradingSignal 和 Signal 两种类型。
        """
        if isinstance(signal, TradingSignal):
            if signal.signal == Signal.BUY:
                signal.signal = Signal.SELL
            elif signal.signal == Signal.SELL:
                signal.signal = Signal.BUY
            return signal
        elif isinstance(signal, Signal):
            if signal == Signal.BUY:
                return Signal.SELL
            elif signal == Signal.SELL:
                return Signal.BUY
            return signal
        return signal

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        """翻转数据 → 跑策略 → 反转信号"""
        if not klines:
            return TradingSignal(signal=Signal.HOLD, coin=coin)

        # 1. 翻转 OHLCV
        mirrored = self._mirror_klines(klines)

        # 2. 初始化 indicator_cache 用翻转数据
        try:
            from core.indicator_cache import init_cache
            # 需要 interval，从 inner strategy 取（backtest 会设 strategy.interval）
            interval = getattr(self._inner, 'interval', getattr(self, 'interval', '5m'))
            init_cache(coin, interval, mirrored)
        except Exception:
            pass

        # 3. 设置 current_idx
        self._inner.current_idx = len(mirrored) - 1

        # 4. 跑原策略（基于翻转数据的指标发信号）
        signal = self._inner.generate_signal(coin, mirrored)

        # 5. 反转信号
        return self._flip_signal(signal)
