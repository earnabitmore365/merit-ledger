# ==================== Exchange Netflow ====================

class ExchangeNetflowIndicator(BaseIndicator):
    """交易所净流入

    BTC 流入交易所 - 流出交易所
    评分:
      大量流出(负) → 0.8 (看涨，提币囤币)
      少量流出    → 0.65
      少量流入    → 0.35
      大量流入(正) → 0.2 (看跌，准备抛售)
    """

    name = "exchange_netflow"
    source = "onchain"

    def fetch(self, **kwargs) -> float:
        cached = self._read_cache("netflow", CACHE_TTL)
        if cached is not None:
            return cached

        try:
            data = _bg_fetch("/v1/exchange-netflow-btc/last")
        except urllib.error.HTTPError as e:
            if e.code == 429:
                stale = self._read_cache_stale("netflow")
                if stale is not None:
                    return stale
            raise

        value = _extract_value(data, "netflow", "Netflow")
        self._write_cache("netflow", value, CACHE_TTL)
        return round(value, 2)

    def score(self, raw_value: float) -> float:
        v = raw_value
        if v < -5000:
            return 0.85
        elif v < -1000:
            return 0.7
        elif v < -100:
            return 0.6
        elif v < 100:
            return 0.5
        elif v < 1000:
            return 0.4
        elif v < 5000:
            return 0.3
        else:
            return 0.2


register_indicator("exchange_netflow", ExchangeNetflowIndicator)


__all__ = [
    'MVRVIndicator', 'NUPLIndicator',
    'PuellMultipleIndicator', 'ExchangeNetflowIndicator',
]
