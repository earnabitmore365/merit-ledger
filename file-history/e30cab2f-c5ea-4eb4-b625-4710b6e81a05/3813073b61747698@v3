#!/usr/bin/env python3
"""
On-Chain Indicators

链上数据指标（BGeometrics / bitcoin-data.com 免费 API，8次/小时）
- MVRV Z-Score
- NUPL（Net Unrealized Profit/Loss）
- Puell Multiple
- Exchange Netflow
"""

import json
import time
import urllib.request
from typing import Any, Dict, Optional

from .base import BaseIndicator, register_indicator

BGEOMETRICS_BASE = "https://bitcoin-data.com/api"
CACHE_TTL = 21600  # 6小时（8次/小时限制，4个指标=2轮/小时足够）
REQUEST_INTERVAL = 0.5  # 请求间隔秒数

# 模块级时间戳，控制请求节奏
_last_request_time = 0


def _bg_fetch(endpoint: str) -> Any:
    """BGeometrics API 请求（含节奏控制）"""
    global _last_request_time

    elapsed = time.time() - _last_request_time
    if elapsed < REQUEST_INTERVAL:
        time.sleep(REQUEST_INTERVAL - elapsed)

    url = f"{BGEOMETRICS_BASE}{endpoint}"
    req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
    with urllib.request.urlopen(req, timeout=15) as resp:
        _last_request_time = time.time()
        return json.loads(resp.read())


def _try_float(v: Any) -> Optional[float]:
    """尝试转 float，失败返回 None"""
    try:
        return float(v)
    except (ValueError, TypeError):
        return None


# 排除这些 key（日期/时间戳，不是指标值）
_SKIP_KEYS = {"d", "date", "unixTs", "unix_ts", "timestamp", "time", "t"}


def _extract_value(data: Any, fallback_key: str, label: str) -> float:
    """从 API 返回提取数值（兼容 dict/list/直接数字/字符串数字）"""
    if isinstance(data, (int, float)):
        return float(data)
    if isinstance(data, str):
        f = _try_float(data)
        if f is not None:
            return f
    if isinstance(data, dict):
        # 尝试常见字段名
        for key in ["value", fallback_key, "data"]:
            if key in data:
                f = _try_float(data[key])
                if f is not None:
                    return f
        # 排除日期/时间字段，找唯一数值字段
        nums = {}
        for k, v in data.items():
            if k in _SKIP_KEYS:
                continue
            f = _try_float(v)
            if f is not None:
                nums[k] = f
        if len(nums) == 1:
            return list(nums.values())[0]
        if len(nums) > 1:
            # 多个数值字段，取第一个非时间的
            return list(nums.values())[0]
        raise ValueError(f"{label} API 返回 dict 但无法提取值: {list(data.keys())}")
    if isinstance(data, list) and data:
        return _extract_value(data[-1], fallback_key, label)
    raise ValueError(f"{label} API 返回格式异常: {type(data)}")


# ==================== MVRV Z-Score ====================

class MVRVIndicator(BaseIndicator):
    """MVRV Z-Score

    Market Value to Realized Value 的标准化偏差
    评分:
      <0   → 0.9 (历史底部)
      0-2  → 0.7
      2-4  → 0.5
      4-7  → 0.2
      >7   → 0.05 (顶部)
    """

    name = "mvrv"
    source = "onchain"

    def fetch(self, **kwargs) -> float:
        cached = self._read_cache("mvrv", CACHE_TTL)
        if cached is not None:
            return cached

        try:
            data = _bg_fetch("/v1/mvrv-zscore/last")
        except urllib.error.HTTPError as e:
            if e.code == 429:
                stale = self._read_cache_stale("mvrv")
                if stale is not None:
                    return stale
            raise

        value = _extract_value(data, "mvrv", "MVRV")
        self._write_cache("mvrv", value, CACHE_TTL)
        return round(value, 4)

    def score(self, raw_value: float) -> float:
        v = raw_value
        if v < 0:
            return 0.9
        elif v < 2:
            return 0.7
        elif v < 4:
            return 0.5
        elif v < 7:
            return 0.2
        else:
            return 0.05


register_indicator("mvrv", MVRVIndicator)


