#!/usr/bin/env python3
"""
Local Indicators

本地计算指标（不需要外部 API）
- AHR999（九神指标）
- Pi Cycle Top
"""

import json
import math
from collections import OrderedDict
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List, Optional

from .base import BaseIndicator, register_indicator

# BTC 创世日期 (2009-01-03)
BTC_GENESIS = datetime(2009, 1, 3, tzinfo=timezone.utc)

# BTC 1h 数据路径
BTC_1H_PATH = Path(__file__).parent.parent / "backtest" / "data" / "historical" / "BTC" / "1h.json"


def _load_btc_1h() -> List[Dict]:
    """加载 BTC 1h K线数据"""
    if not BTC_1H_PATH.exists():
        raise FileNotFoundError(f"BTC 1h 数据不存在: {BTC_1H_PATH}")
    with open(BTC_1H_PATH) as f:
        return json.load(f)


def _aggregate_daily(klines: List[Dict]) -> List[Dict]:
    """1h K线聚合成日线（取每天最后一根收盘价）"""
    daily = OrderedDict()
    for k in klines:
        dt = datetime.fromtimestamp(k['time'] / 1000, tz=timezone.utc)
        day = dt.strftime('%Y-%m-%d')
        daily[day] = k  # 后覆盖前，保留当天最后一根
    return [
        {'time': v['time'], 'close': v['close'], 'date': d}
        for d, v in daily.items()
    ]


def _sma(closes: List[float], period: int) -> Optional[float]:
    """简单移动平均"""
    if len(closes) < period:
        return None
    return sum(closes[-period:]) / period


# ==================== AHR999 ====================

class AHR999Indicator(BaseIndicator):
    """AHR999 九神指标

    公式: (price / 200日均价) × (price / 对数增长估值)
    对数增长: 10^(5.84 * log10(距创世天数) - 17.01)

    评分:
      <0.45  → 1.0 (抄底)
      0.45-1.2 → 0.6-0.8 (定投)
      1.2-5.0 → 0.2-0.6
      >5.0   → 0.0 (逃顶)
    """

    name = "ahr999"
    source = "local"

    def fetch(self, **kwargs) -> float:
        klines = kwargs.get('klines') or _load_btc_1h()
        daily = _aggregate_daily(klines)

        if len(daily) < 200:
            raise ValueError(f"需要至少200天日线数据，当前只有{len(daily)}天")

        closes = [d['close'] for d in daily]
        current_price = closes[-1]
        ma200 = _sma(closes, 200)

        # 计算距创世天数
        last_time = daily[-1]['time']
        last_dt = datetime.fromtimestamp(last_time / 1000, tz=timezone.utc)
        days_since_genesis = (last_dt - BTC_GENESIS).days

        # 对数增长估值
        log_value = 10 ** (5.84 * math.log10(days_since_genesis) - 17.01)

        # AHR999 = (price/MA200) * (price/log_value)
        ahr999 = (current_price / ma200) * (current_price / log_value)
        return round(ahr999, 4)

    def score(self, raw_value: float) -> float:
        v = raw_value
        if v < 0.45:
            return 1.0
        elif v < 1.2:
            # 0.45→0.8, 1.2→0.6 线性插值
            return 0.8 - (v - 0.45) / (1.2 - 0.45) * 0.2
        elif v < 5.0:
            # 1.2→0.6, 5.0→0.2 线性插值
            return 0.6 - (v - 1.2) / (5.0 - 1.2) * 0.4
        else:
            return 0.0


register_indicator("ahr999", AHR999Indicator)


# ==================== Pi Cycle Top ====================

class PiCycleTopIndicator(BaseIndicator):
    """Pi Cycle Top 指标

    当 111日SMA 上穿 350日SMA×2 时，标志顶部
    历史上精准预测了每次 BTC 周期顶部

    评分:
      交叉 → 0.0 (逃顶)
      接近(<5%) → 0.2
      远离 → 0.7
      很远(>30%) → 0.9
    """

    name = "pi_cycle_top"
    source = "local"

    def fetch(self, **kwargs) -> Dict:
        klines = kwargs.get('klines') or _load_btc_1h()
        daily = _aggregate_daily(klines)

        if len(daily) < 350:
            raise ValueError(f"需要至少350天日线数据，当前只有{len(daily)}天")

        closes = [d['close'] for d in daily]
        sma111 = _sma(closes, 111)
        sma350x2 = _sma(closes, 350) * 2

        # 间距百分比
        gap_pct = (sma350x2 - sma111) / sma350x2 * 100

        # 检测交叉（最近2天）
        crossed = False
        if len(closes) >= 351:
            prev_sma111 = _sma(closes[:-1], 111)
            prev_sma350x2 = _sma(closes[:-1], 350) * 2
            if prev_sma111 is not None and prev_sma350x2 is not None:
                crossed = (prev_sma111 < prev_sma350x2) and (sma111 >= sma350x2)

        return {
            "crossed": crossed,
            "sma111": round(sma111, 2),
            "sma350x2": round(sma350x2, 2),
            "gap_pct": round(gap_pct, 2),
        }

    def score(self, raw_value: Dict) -> float:
        if raw_value["crossed"]:
            return 0.0
        gap = raw_value["gap_pct"]
        if gap < 0:
            # sma111 已经超过 sma350x2（可能在顶部区域）
            return 0.1
        elif gap < 5:
            return 0.2
        elif gap < 15:
            # 5%→0.4, 15%→0.7 线性插值
            return 0.4 + (gap - 5) / 10 * 0.3
        elif gap < 30:
            return 0.7 + (gap - 15) / 15 * 0.2
        else:
            return 0.9


register_indicator("pi_cycle_top", PiCycleTopIndicator)


__all__ = ['AHR999Indicator', 'PiCycleTopIndicator']
