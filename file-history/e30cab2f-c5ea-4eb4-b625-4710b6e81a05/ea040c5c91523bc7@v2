#!/usr/bin/env python3
"""
全矩阵回测 v2：43策略 × 10币种 × 4周期 = 1720 组

使用固定注码（fixed_bet=True）公平评估策略的真实边际优势，
消除复利带来的路径依赖偏差。

参数：365天 · $500 · 10x杠杆 · 止损10% · TTP开 · 固定注码
结果保存到 reports/backtest/summary_full_matrix.json
"""

import sys
import os
import time
import json
import logging

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..'))

from backtest.backtest import BacktestEngine
from core.strategy import list_strategies

# 减少日志噪音
logging.basicConfig(level=logging.WARNING)


# ==================== 配置 ====================

COINS = ['BTC', 'ETH', 'XRP', 'BNB', 'SOL', 'ADA', 'TRX', 'AVAX', 'LINK', 'DOT']
INTERVALS = ['1m', '5m', '15m', '1h']

# 自动发现所有策略，排除不参与的
SKIP_STRATEGIES = {'_base', 'adaptive'}

DAYS = 365
INITIAL_CAPITAL = 500
LEVERAGE = 10.0
STOP_LOSS_PCT = 0.1
ENABLE_TTP = True
FIXED_BET = True  # 固定注码模式


def get_strategies():
    """获取所有可用策略"""
    all_names = sorted(list_strategies())
    return [name for name in all_names if name not in SKIP_STRATEGIES]


def run_all():
    """运行全矩阵回测"""
    strategies = get_strategies()
    total = len(strategies) * len(COINS) * len(INTERVALS)
    bet_mode = "固定注码" if FIXED_BET else "复利注码"

    print("=" * 90)
    print("  全矩阵回测 v2")
    print("  %d 策略 × %d 币种 × %d 周期 = %d 组" % (len(strategies), len(COINS), len(INTERVALS), total))
    print("  参数：%d天 · $%d · %.0fx杠杆 · 止损%.0f%% · TTP%s · %s" % (
        DAYS, INITIAL_CAPITAL, LEVERAGE, STOP_LOSS_PCT * 100,
        '开' if ENABLE_TTP else '关', bet_mode))
    print("=" * 90)
    print()

    results = []
    start_all = time.time()
    idx = 0

    for strategy in strategies:
        for interval in INTERVALS:
            for coin in COINS:
                idx += 1

                elapsed_total = time.time() - start_all
                if idx > 1:
                    avg_per = elapsed_total / (idx - 1)
                    eta = avg_per * (total - idx + 1)
                    eta_str = " | ETA %.0fmin" % (eta / 60)
                else:
                    eta_str = ""

                print("  [%3d/%d] %-22s %-5s %-4s%s" % (idx, total, strategy, coin, interval, eta_str), end="", flush=True)

                start = time.time()

                try:
                    engine = BacktestEngine(
                        coin=coin,
                        interval=interval,
                        days=DAYS,
                        initial_capital=INITIAL_CAPITAL,
                        enable_ttp=ENABLE_TTP,
                        stop_loss_pct=STOP_LOSS_PCT,
                        leverage=LEVERAGE,
                        enable_withdraw=False,
                        fixed_bet=FIXED_BET,
                    )
                    result = engine.run_backtest(strategy)

                    if result is None:
                        results.append({
                            "coin": coin, "strategy": strategy, "interval": interval,
                            "status": "FAIL", "return": 0, "sharpe": 0, "win_rate": 0,
                            "trades": 0, "max_dd": 0, "final": 0,
                            "fastest_double": 0, "avg_double": 0, "double_count": 0,
                        })
                        print(" -> FAIL")
                        continue

                    elapsed = time.time() - start

                    results.append({
                        "coin": coin,
                        "strategy": strategy,
                        "interval": interval,
                        "status": "OK",
                        "return": round(result.total_return, 2),
                        "sharpe": round(result.sharpe_ratio, 2),
                        "win_rate": round(result.win_rate, 1),
                        "max_dd": round(result.max_drawdown, 1),
                        "trades": result.total_trades,
                        "final": round(result.final_balance, 2),
                        "fastest_double": result.fastest_double_days,
                        "avg_double": result.avg_double_days,
                        "double_count": result.double_count,
                        "time": round(elapsed, 1),
                    })

                    ret = result.total_return
                    symbol = "+" if ret > 0 else ""
                    print(" -> %s%.1f%% | S %5.2f | %4.1fs" % (symbol, ret, result.sharpe_ratio, elapsed))

                except Exception as e:
                    print(" -> ERROR: %s" % e)
                    results.append({
                        "coin": coin, "strategy": strategy, "interval": interval,
                        "status": "ERROR", "return": 0, "sharpe": 0, "win_rate": 0,
                        "trades": 0, "max_dd": 0, "final": 0,
                        "fastest_double": 0, "avg_double": 0, "double_count": 0,
                        "error": str(e),
                    })

    elapsed_all = time.time() - start_all

    # ====== 汇总 ======
    ok_results = [r for r in results if r.get("status") == "OK"]
    profitable = [r for r in ok_results if r["return"] > 0]
    n_ok = len(ok_results)

    print("\n\n" + "=" * 100)
    print("  全矩阵回测汇总 (%d 组, 耗时 %.1f 分钟)" % (total, elapsed_all / 60))
    print("=" * 100)
    print("  成功: %d/%d | 盈利: %d/%d (%.0f%%)" % (
        n_ok, total, len(profitable), n_ok, len(profitable) * 100 / max(n_ok, 1)))

    # ====== TOP 30 按收益 ======
    print("\n" + "=" * 100)
    print("  TOP 30 最佳组合（按收益排序 — 固定注码）")
    print("=" * 100)
    print("  %3s %-6s %-22s %-4s %10s %7s %7s %7s %5s %6s %6s" % (
        '#', '币种', '策略', '周期', '收益', 'Sharpe', '胜率', '回撤', '交易', '翻倍', '最快'))
    print("  %s %s %s %s %s %s %s %s %s %s %s" % (
        '-' * 3, '-' * 6, '-' * 22, '-' * 4, '-' * 10, '-' * 7, '-' * 7, '-' * 7, '-' * 5, '-' * 6, '-' * 6))

    top30 = sorted(ok_results, key=lambda r: r["return"], reverse=True)[:30]
    for rank, r in enumerate(top30, 1):
        dbl = "%dx" % r["double_count"] if r["double_count"] > 0 else "-"
        fast = "%dd" % r["fastest_double"] if r["fastest_double"] > 0 else "-"
        print("  %3d %-6s %-22s %-4s %+9.1f%% %6.2f %6.1f%% %6.1f%% %5d %6s %6s" % (
            rank, r['coin'], r['strategy'], r['interval'],
            r['return'], r['sharpe'], r['win_rate'], r['max_dd'], r['trades'],
            dbl, fast))

    # ====== TOP 30 按 Sharpe ======
    print("\n" + "=" * 100)
    print("  TOP 30 最佳组合（按 Sharpe 排序 — 风险调整收益）")
    print("=" * 100)
    print("  %3s %-6s %-22s %-4s %7s %10s %7s %7s %5s" % (
        '#', '币种', '策略', '周期', 'Sharpe', '收益', '胜率', '回撤', '交易'))
    print("  %s %s %s %s %s %s %s %s %s" % (
        '-' * 3, '-' * 6, '-' * 22, '-' * 4, '-' * 7, '-' * 10, '-' * 7, '-' * 7, '-' * 5))

    top30_sharpe = sorted([r for r in ok_results if r["return"] > 0],
                          key=lambda r: r["sharpe"], reverse=True)[:30]
    for rank, r in enumerate(top30_sharpe, 1):
        print("  %3d %-6s %-22s %-4s %6.2f %+9.1f%% %6.1f%% %6.1f%% %5d" % (
            rank, r['coin'], r['strategy'], r['interval'],
            r['sharpe'], r['return'], r['win_rate'], r['max_dd'], r['trades']))

    # ====== 按策略汇总（所有周期平均）======
    print("\n" + "=" * 100)
    print("  按策略汇总（所有币种×周期平均）")
    print("=" * 100)
    print("  %-22s %6s %10s %7s %7s %7s %6s" % (
        '策略', '盈利率', '平均收益', 'Sharpe', '胜率', '回撤', '翻倍'))
    print("  %s %s %s %s %s %s %s" % (
        '-' * 22, '-' * 6, '-' * 10, '-' * 7, '-' * 7, '-' * 7, '-' * 6))

    strat_stats = {}
    for r in ok_results:
        s = r["strategy"]
        if s not in strat_stats:
            strat_stats[s] = []
        strat_stats[s].append(r)

    strat_summary = []
    for s, rs in strat_stats.items():
        avg_ret = sum(r["return"] for r in rs) / len(rs)
        avg_sharpe = sum(r["sharpe"] for r in rs) / len(rs)
        avg_wr = sum(r["win_rate"] for r in rs) / len(rs)
        avg_dd = sum(r["max_dd"] for r in rs) / len(rs)
        n_profit = sum(1 for r in rs if r["return"] > 0)
        total_dbl = sum(r["double_count"] for r in rs)
        strat_summary.append({
            "strategy": s, "avg_return": avg_ret, "avg_sharpe": avg_sharpe,
            "avg_win_rate": avg_wr, "avg_max_dd": avg_dd,
            "profit_rate": n_profit / len(rs) * 100, "total_doubles": total_dbl,
            "count": len(rs),
        })

    for ss in sorted(strat_summary, key=lambda x: x["avg_return"], reverse=True):
        print("  %-22s %5.0f%% %+9.1f%% %6.2f %6.1f%% %6.1f%% %5d" % (
            ss['strategy'], ss['profit_rate'], ss['avg_return'],
            ss['avg_sharpe'], ss['avg_win_rate'], ss['avg_max_dd'], ss['total_doubles']))

    # ====== 保存 JSON ======
    report_dir = os.path.join(os.path.dirname(__file__), '..', '..', 'reports', 'backtest')
    os.makedirs(report_dir, exist_ok=True)
    summary_file = os.path.join(report_dir, 'summary_full_matrix.json')

    summary = {
        "config": {
            "days": DAYS,
            "initial_capital": INITIAL_CAPITAL,
            "leverage": LEVERAGE,
            "stop_loss_pct": STOP_LOSS_PCT,
            "enable_ttp": ENABLE_TTP,
            "fixed_bet": FIXED_BET,
            "coins": COINS,
            "intervals": INTERVALS,
            "strategies": strategies,
            "total_combos": total,
            "elapsed_minutes": round(elapsed_all / 60, 1),
        },
        "results": [
            {
                "coin": r["coin"],
                "strategy": r["strategy"],
                "interval": r["interval"],
                "status": r.get("status", "?"),
                "total_return": r.get("return", 0),
                "sharpe_ratio": r.get("sharpe", 0),
                "win_rate": r.get("win_rate", 0),
                "max_drawdown": r.get("max_dd", 0),
                "total_trades": r.get("trades", 0),
                "final_balance": r.get("final", 0),
                "fastest_double_days": r.get("fastest_double", 0),
                "avg_double_days": r.get("avg_double", 0),
                "double_count": r.get("double_count", 0),
            }
            for r in results
        ],
    }

    with open(summary_file, 'w', encoding='utf-8') as f:
        json.dump(summary, f, ensure_ascii=False, indent=2)

    print("\n  汇总报告: %s" % summary_file)
    print()


if __name__ == "__main__":
    run_all()
