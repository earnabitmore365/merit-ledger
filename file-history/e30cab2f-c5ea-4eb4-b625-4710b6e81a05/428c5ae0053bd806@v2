#!/usr/bin/env python3
"""
Market Indicators

市场结构指标
- Stablecoin Supply（稳定币总供应量）
- BTC Dominance（BTC市占率）
"""

import json
import time
import urllib.request
from typing import Any, Dict

from .base import BaseIndicator, register_indicator

CACHE_TTL = 3600  # 1小时


# ==================== Stablecoin Supply ====================

class StablecoinSupplyIndicator(BaseIndicator):
    """稳定币总供应量

    来源: DefiLlama
    评分基于月增长率:
      增长>5%/月  → 0.8 (资金流入)
      增长2-5%   → 0.65
      稳定±2%    → 0.5
      下降2-5%   → 0.35
      下降>5%/月  → 0.2 (资金流出)
    """

    name = "stablecoin_supply"
    source = "api"

    def fetch(self, **kwargs) -> Dict:
        cached = self._read_cache("stablecoin_supply", CACHE_TTL)
        if cached is not None:
            return cached

        url = "https://stablecoins.llama.fi/stablecoins"
        try:
            req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=15) as resp:
                data = json.loads(resp.read())
        except urllib.error.HTTPError as e:
            if e.code == 429:
                stale = self._read_cache_stale("stablecoin_supply")
                if stale:
                    return stale
            raise

        # 汇总所有稳定币的 circulating peg
        total = 0
        for sc in data.get("peggedAssets", []):
            chains = sc.get("chainCirculating", {})
            for chain_data in chains.values():
                for peg_type in chain_data.get("current", {}).values():
                    total += peg_type if isinstance(peg_type, (int, float)) else 0

        current = {"supply": round(total, 2), "time": time.time()}

        # 读历史记录算趋势
        history = self._read_cache_stale("stablecoin_history") or []
        cutoff = time.time() - 60 * 86400  # 保留60天
        history = [h for h in history if h["time"] > cutoff]
        history.append(current)
        self._write_cache("stablecoin_history", history, 999999)

        # 计算30天变化率
        change_30d = 0.0
        if len(history) > 1:
            target = time.time() - 30 * 86400
            closest = min(history[:-1], key=lambda h: abs(h["time"] - target))
            if closest["supply"] > 0:
                change_30d = (total - closest["supply"]) / closest["supply"] * 100

        result = {
            "supply_b": round(total / 1e9, 2),  # 十亿美元
            "change_30d_pct": round(change_30d, 2),
        }
        self._write_cache("stablecoin_supply", result, CACHE_TTL)
        return result

    def score(self, raw_value: Dict) -> float:
        change = raw_value["change_30d_pct"]
        if change > 5:
            return 0.8
        elif change > 2:
            return 0.65
        elif change > -2:
            return 0.5
        elif change > -5:
            return 0.35
        else:
            return 0.2


register_indicator("stablecoin_supply", StablecoinSupplyIndicator)


# ==================== BTC Dominance ====================

class BTCDominanceIndicator(BaseIndicator):
    """BTC 市占率

    来源: CoinGecko
    评分:
      >60% → 0.3 (避险，资金集中BTC)
      50-60% → 0.5 (正常)
      40-50% → 0.7 (山寨币开始活跃)
      <40% → 0.9 (山寨季)
    """

    name = "btc_dominance"
    source = "api"

    def fetch(self, **kwargs) -> float:
        cached = self._read_cache("btc_dominance", CACHE_TTL)
        if cached is not None:
            return cached

        url = "https://api.coingecko.com/api/v3/global"
        try:
            req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=10) as resp:
                data = json.loads(resp.read())
        except urllib.error.HTTPError as e:
            if e.code == 429:
                stale = self._read_cache_stale("btc_dominance")
                if stale:
                    return stale
            raise

        dominance = data["data"]["market_cap_percentage"]["btc"]
        result = round(dominance, 2)
        self._write_cache("btc_dominance", result, CACHE_TTL)
        return result

    def score(self, raw_value: float) -> float:
        d = raw_value
        if d > 65:
            return 0.2
        elif d > 60:
            return 0.3
        elif d > 50:
            # 50→0.5, 60→0.3 线性
            return 0.5 - (d - 50) / 10 * 0.2
        elif d > 40:
            # 40→0.7, 50→0.5 线性
            return 0.7 - (d - 40) / 10 * 0.2
        else:
            return 0.9


register_indicator("btc_dominance", BTCDominanceIndicator)


__all__ = ['StablecoinSupplyIndicator', 'BTCDominanceIndicator']
