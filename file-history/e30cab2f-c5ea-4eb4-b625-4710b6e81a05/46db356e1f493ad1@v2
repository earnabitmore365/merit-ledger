#!/usr/bin/env python3
"""
Sentiment Indicators

情绪指标
- Fear & Greed Index（恐惧贪婪指数）
"""

import json
import urllib.request
from typing import Any, Dict

from .base import BaseIndicator, register_indicator

CACHE_TTL = 14400  # 4小时


class FearGreedIndicator(BaseIndicator):
    """恐惧贪婪指数

    来源: alternative.me
    原始值: 0-100 (0=极度恐惧, 100=极度贪婪)

    **反向评分**（逆向思维）:
      极度恐惧(0-25)  → score 0.8-1.0 (买入)
      恐惧(25-45)     → score 0.6-0.8
      中性(45-55)     → score 0.5
      贪婪(55-75)     → score 0.2-0.4
      极度贪婪(75-100) → score 0.0-0.2 (卖出)
    """

    name = "fear_greed"
    source = "api"

    def fetch(self, **kwargs) -> Dict:
        cached = self._read_cache("fear_greed", CACHE_TTL)
        if cached is not None:
            return cached

        url = "https://api.alternative.me/fng/"
        try:
            req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
            with urllib.request.urlopen(req, timeout=10) as resp:
                data = json.loads(resp.read())
        except urllib.error.HTTPError as e:
            if e.code == 429:
                stale = self._read_cache_stale("fear_greed")
                if stale:
                    return stale
            raise

        result = {
            "value": int(data["data"][0]["value"]),
            "classification": data["data"][0]["value_classification"],
        }
        self._write_cache("fear_greed", result, CACHE_TTL)
        return result

    def score(self, raw_value: Dict) -> float:
        v = raw_value["value"]
        # 反向：恐惧=买入，贪婪=卖出
        return max(0.0, min(1.0, 1.0 - v / 100))


register_indicator("fear_greed", FearGreedIndicator)


__all__ = ['FearGreedIndicator']
