#!/usr/bin/env python3
"""
HyperLiquid Indicators

衍生品指标（HyperLiquid API）
- Funding Rate（资金费率）
- Open Interest（持仓量）
"""

import json
import time
import urllib.request
from typing import Any, Dict, List, Optional

from .base import BaseIndicator, register_indicator

HYPERLIQUID_API = "https://api.hyperliquid.xyz/info"
CACHE_TTL = 300  # 5分钟


def _fetch_meta_and_ctxs() -> Dict:
    """获取 HyperLiquid 全市场元数据和上下文"""
    body = json.dumps({"type": "metaAndAssetCtxs"}).encode()
    req = urllib.request.Request(
        HYPERLIQUID_API,
        data=body,
        headers={"Content-Type": "application/json"},
    )
    with urllib.request.urlopen(req, timeout=10) as resp:
        return json.loads(resp.read())


def _find_coin_ctx(data: Dict, coin: str) -> Optional[Dict]:
    """从返回数据中找到指定币种的上下文"""
    meta = data[0]  # universe info
    ctxs = data[1]  # asset contexts
    coin_upper = coin.upper().replace("USDT", "").replace("USD", "")
    for i, asset in enumerate(meta.get("universe", [])):
        if asset.get("name", "").upper() == coin_upper:
            return ctxs[i]
    return None


# ==================== Funding Rate ====================

class FundingRateIndicator(BaseIndicator):
    """资金费率指标

    原始值: 8小时费率 (如 0.0001 = 0.01%)
    评分:
      <-0.01% → 0.8 (空头付费=看涨)
      ±0.01%  → 0.5 (中性)
      >0.05%  → 0.1 (过热)
    """

    name = "funding_rate"
    source = "hyperliquid"

    def fetch(self, coin: str = "BTC", **kwargs) -> float:
        cache_key = f"hl_meta_{int(time.time()) // CACHE_TTL}"
        cached = self._read_cache("hl_meta", CACHE_TTL)
        if cached is None:
            cached = _fetch_meta_and_ctxs()
            self._write_cache("hl_meta", cached, CACHE_TTL)

        ctx = _find_coin_ctx(cached, coin)
        if ctx is None:
            raise ValueError(f"币种 {coin} 在 HyperLiquid 未找到")

        return float(ctx["funding"])

    def score(self, raw_value: float) -> float:
        rate = raw_value * 100  # 转百分比
        if rate < -0.01:
            # 越负越看涨，-0.05%→0.9, -0.01%→0.8
            return min(0.95, 0.8 + abs(rate + 0.01) / 0.04 * 0.15)
        elif rate < 0.01:
            # ±0.01% → 0.5 附近
            return 0.5 + (0 - rate) / 0.01 * 0.15
        elif rate < 0.05:
            # 0.01%→0.45, 0.05%→0.2
            return 0.45 - (rate - 0.01) / 0.04 * 0.25
        else:
            # >0.05% 过热
            return max(0.05, 0.2 - (rate - 0.05) / 0.1 * 0.15)


register_indicator("funding_rate", FundingRateIndicator)


# ==================== Open Interest ====================

class OpenInterestIndicator(BaseIndicator):
    """持仓量指标

    原始值: 未平仓合约的 USD 价值
    评分基于与历史值对比的变化率:
      OI 骤降 → 0.7 (去杠杆，可能见底)
      OI 稳定 → 0.5 (中性)
      OI 暴涨 → 0.2 (过度杠杆)
    """

    name = "open_interest"
    source = "hyperliquid"

    def fetch(self, coin: str = "BTC", **kwargs) -> Dict:
        cached = self._read_cache("hl_meta", CACHE_TTL)
        if cached is None:
            cached = _fetch_meta_and_ctxs()
            self._write_cache("hl_meta", cached, CACHE_TTL)

        ctx = _find_coin_ctx(cached, coin)
        if ctx is None:
            raise ValueError(f"币种 {coin} 在 HyperLiquid 未找到")

        oi_coins = float(ctx["openInterest"])
        mark_price = float(ctx["markPx"])
        oi_usd = oi_coins * mark_price

        # 读取历史 OI 记录
        history = self._read_cache_stale("oi_history") or []
        current = {"time": time.time(), "oi_usd": oi_usd}

        # 保留最近 7 天的记录（每5分钟一条 ≈ 2016条）
        cutoff = time.time() - 7 * 86400
        history = [h for h in history if h["time"] > cutoff]
        history.append(current)
        self._write_cache("oi_history", history, 999999)

        # 计算24小时变化率
        change_24h = 0.0
        if len(history) > 1:
            target_time = time.time() - 86400
            closest = min(history[:-1], key=lambda h: abs(h["time"] - target_time))
            if closest["oi_usd"] > 0:
                change_24h = (oi_usd - closest["oi_usd"]) / closest["oi_usd"] * 100

        return {
            "oi_usd": round(oi_usd, 2),
            "change_24h_pct": round(change_24h, 2),
        }

    def score(self, raw_value: Dict) -> float:
        change = raw_value["change_24h_pct"]
        if change < -15:
            return 0.8  # 大幅去杠杆
        elif change < -5:
            return 0.7
        elif change < 5:
            return 0.5  # 稳定
        elif change < 15:
            return 0.3
        else:
            return 0.2  # 过度杠杆


register_indicator("open_interest", OpenInterestIndicator)


__all__ = ['FundingRateIndicator', 'OpenInterestIndicator']
