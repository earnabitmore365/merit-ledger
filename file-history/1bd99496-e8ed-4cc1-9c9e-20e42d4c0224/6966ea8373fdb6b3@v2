#!/usr/bin/env python3
"""test_bet_calc.py — 模拟 21 策略按顺序开仓，验证注码计算

跑这个脚本确认：
1. 每笔保证金 = $100（$2,100 余额 ÷ 21 策略）
2. 每笔名义 = $1,000（$100 × 10x 杠杆）
3. 币数量 = 名义 ÷ 当前价格
"""

import os
import sys

_lab_dir = os.path.dirname(os.path.abspath(__file__))
if _lab_dir not in sys.path:
    sys.path.insert(0, _lab_dir)

from team_config import TEAM, get_bet_amount, LEVERAGE, TOTAL_STRATEGIES

# 假设价格（2026-03-23 近似）
PRICES = {
    'BTC': 68700,
    'ETH': 2080,
    'SOL': 87,
    'XRP': 1.40,
    'BNB': 580,
    'ADA': 0.55,
    'AVAX': 25,
    'LINK': 14,
    'DOT': 5.5,
}

def simulate(initial_balance):
    print(f"\n{'='*80}")
    print(f"模拟 {len(TEAM)} 策略按顺序开仓 | 初始余额: ${initial_balance:,.0f}")
    print(f"{'='*80}")
    print(f"{'#':>3} {'策略ID':<40} {'可用余额':>10} {'保证金':>8} {'名义':>8} {'币数量':>12} {'币种'}")
    print(f"{'-'*3} {'-'*40} {'-'*10} {'-'*8} {'-'*8} {'-'*12} {'-'*4}")

    balance = initial_balance
    used_margin = 0.0
    positions = []

    for i, cfg in enumerate(TEAM):
        sid = f"{cfg.coin}_{cfg.strategy}{'_mirror' if cfg.mirror else ''}_{cfg.interval}"
        available = balance - used_margin
        bet = get_bet_amount(available)
        nominal = bet * LEVERAGE
        price = PRICES.get(cfg.coin, 100)
        qty = nominal / price

        print(f"{i+1:>3} {sid:<40} ${available:>9,.0f} ${bet:>7} ${nominal:>7} {qty:>11.4f} {cfg.coin}")

        used_margin += bet
        positions.append({
            'id': sid,
            'margin': bet,
            'nominal': nominal,
            'qty': qty,
            'coin': cfg.coin,
        })

    print(f"\n总保证金: ${used_margin:,.0f}")
    print(f"总名义: ${sum(p['nominal'] for p in positions):,.0f}")
    print(f"剩余可用: ${balance - used_margin:,.0f}")

    # 验证
    all_correct = True
    for p in positions:
        if p['nominal'] < 900:  # 允许 10% 误差（最小 $100 margin × 10x = $1000）
            print(f"⚠️  {p['id']}: 名义 ${p['nominal']} 过小!")
            all_correct = False

    if all_correct:
        print(f"\n✅ 全部 {len(positions)} 策略注码正确（名义均为 ${positions[0]['nominal']}）")
    else:
        print(f"\n❌ 存在注码异常")


if __name__ == '__main__':
    simulate(2100)     # 最低安全本金
    simulate(5000)     # 中等余额
    simulate(21000)    # 满额运行
    simulate(50000)    # 超额（应 cap 在 $1000 margin）
