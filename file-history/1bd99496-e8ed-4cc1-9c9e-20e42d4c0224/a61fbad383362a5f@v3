#!/usr/bin/env python3
"""限价挂单 + 重试 + 转市价"""

import os, sys, time, logging

_lab_dir = os.path.dirname(os.path.abspath(__file__))
_src_dir = os.path.join(_lab_dir, 'src')
if _src_dir not in sys.path:
    sys.path.insert(0, _src_dir)

from exchange.base import OrderRequest, OrderSide, OrderType

logger = logging.getLogger(__name__)


class LimitOrderExecutor:
    MAX_RETRIES = 5
    RETRY_INTERVAL = 10  # 秒
    SMALL_TF = {'1m', '5m'}

    def execute_limit(self, strategy, side, size, adapter, dispatcher=None):
        """限价挂单 + 重试。返回 {'success': bool, 'price': float, ...}"""
        order_side = OrderSide.BUY if side == 'BUY' else OrderSide.SELL

        for attempt in range(self.MAX_RETRIES):
            bid, ask = adapter.get_best_bid_ask(strategy.coin)
            if bid <= 0 or ask <= 0:
                time.sleep(self.RETRY_INTERVAL)
                continue

            price = bid if side == 'BUY' else ask
            order = OrderRequest(coin=strategy.coin, side=order_side,
                                 order_type=OrderType.LIMIT, size=size, price=price)
            result = adapter.place_order(order)
            if not result.success:
                time.sleep(self.RETRY_INTERVAL)
                continue

            order_id = result.order_id
            time.sleep(self.RETRY_INTERVAL)

            status = adapter.get_order_status(order_id)
            ord_status = status.get('ordStatus', '')
            filled_qty = float(status.get('cumQty', 0) or 0)

            if ord_status == 'Filled':
                return {'success': True, 'price': float(status.get('avgPx', 0) or 0),
                        'actual_size': filled_qty or size, 'attempts': attempt + 1}

            if filled_qty > 0:
                adapter.cancel_order(order_id)
                remaining = size - filled_qty
                avg_price = float(status.get('avgPx', 0) or 0)
                if remaining > 0:
                    mkt = OrderRequest(coin=strategy.coin, side=order_side,
                                       order_type=OrderType.MARKET, size=remaining)
                    mkt_result = adapter.place_order(mkt)
                    mkt_price = mkt_result.filled_price or price
                    blended = (avg_price * filled_qty + mkt_price * remaining) / size
                    return {'success': True, 'price': blended, 'actual_size': size,
                            'attempts': attempt + 1, 'partial_fill': True}
                return {'success': True, 'price': avg_price, 'actual_size': filled_qty,
                        'attempts': attempt + 1, 'partial_fill': True}

            adapter.cancel_order(order_id)

            if strategy.interval in self.SMALL_TF and dispatcher:
                klines = dispatcher.get_window(strategy.coin, strategy.interval)
                if klines and len(klines) >= 2:
                    new_signal = strategy.on_bar(klines[-1], klines)
                    if new_signal != side:
                        return {'success': False, 'reason': 'signal_gone',
                                'attempts': attempt + 1}

        # 5 次失败 → 转市价
        mkt = OrderRequest(coin=strategy.coin, side=order_side,
                           order_type=OrderType.MARKET, size=size)
        mkt_result = adapter.place_order(mkt)
        if mkt_result.success:
            return {'success': True, 'price': mkt_result.filled_price or 0,
                    'actual_size': mkt_result.filled_size or size,
                    'attempts': self.MAX_RETRIES, 'fallback': 'market'}
        return {'success': False, 'reason': f'market_failed: {mkt_result.message}',
                'attempts': self.MAX_RETRIES}
