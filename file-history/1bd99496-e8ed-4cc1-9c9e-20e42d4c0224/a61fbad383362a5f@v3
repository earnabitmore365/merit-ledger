#!/usr/bin/env python3
"""单个策略的完整生命周期管理"""

import os, sys, logging
from datetime import datetime

_lab_dir = os.path.dirname(os.path.abspath(__file__))
if _lab_dir not in sys.path:
    sys.path.insert(0, _lab_dir)
_src_dir = os.path.join(_lab_dir, 'src')
if _src_dir not in sys.path:
    sys.path.insert(0, _src_dir)

from core.strategy.base import get_strategy, Signal
from core.risk.ttp import TTPManager, TTPConfig
from exchange.base import OrderSide

logger = logging.getLogger(__name__)


class StrategyRunner:
    """状态机：idle → pending_open → active → pending_close → idle"""

    def __init__(self, config, adapter):
        self.coin = config.coin
        self.strategy_name = config.strategy
        self.interval = config.interval
        self.mirror = config.mirror
        self.id = f"{config.coin}_{config.strategy}_{config.interval}"

        self._inner_strategy = get_strategy(config.strategy)
        self._adapter = adapter
        self.ttp_manager = TTPManager(TTPConfig())

        # 内部持仓状态（不靠 API 查）
        self.position = None          # 'BUY' / 'SELL' / None
        self.entry_price = 0.0
        self.position_size = 0.0
        self._target_size = 0.0
        self.open_time = None
        self.sl_order_id = None
        self.tp_order_id = None
        self.state = 'idle'
        self._last_ttp_level = 0.0

    def on_bar(self, bar, klines):
        """收到 K 线，返回信号（不执行交易）"""
        if not klines or len(klines) < 2:
            return None
        klines_list = list(klines)
        if self.mirror:
            klines_list = self._flip_klines(klines_list)
            bar = klines_list[-1]
        try:
            from core.indicator_cache import init_cache
            namespace = 'flipped' if self.mirror else 'normal'
            init_cache(self.coin, self.interval, klines_list, namespace=namespace)
        except Exception as e:
            logger.warning(f"[{self.id}] indicator_cache 更新失败: {e}")
        self._inner_strategy.current_idx = len(klines_list) - 1
        try:
            result = self._inner_strategy.generate_signal(self.coin, klines_list)
            if result is None:
                return None
            if hasattr(result, 'signal'):
                sig = result.signal
                return sig.value if hasattr(sig, 'value') else str(sig)
            return str(result)
        except Exception as e:
            logger.error(f"[{self.id}] generate_signal 异常: {e}")
            return None

    def _flip_klines(self, klines):
        if not klines:
            return klines
        max_price = max(k['high'] for k in klines)
        return [dict(k, open=max_price-k['open'], close=max_price-k['close'],
                     high=max_price-k['low'], low=max_price-k['high']) for k in klines]

    def after_open(self, adapter):
        """开仓后挂 SL 单(±10%)"""
        if not self.position or self.entry_price <= 0:
            return
        if self.position == 'BUY':
            sl_price, sl_side = round(self.entry_price * 0.90, 2), OrderSide.SELL
        else:
            sl_price, sl_side = round(self.entry_price * 1.10, 2), OrderSide.BUY
        try:
            result = adapter.place_stop_loss(coin=self.coin, stop_price=sl_price,
                                             size=self.position_size, side=sl_side)
            if result.success:
                self.sl_order_id = result.order_id
        except Exception as e:
            logger.error(f"[{self.id}] after_open 异常: {e}")
        self.tp_order_id = None
        self._last_ttp_level = 0.0
        self.ttp_manager.state.reset()

    def update_ttp_on_exchange(self, adapter, current_price):
        """TTP level 变化时更新 TP 单"""
        if not self.position or self.entry_price <= 0:
            return None
        pos_side = "LONG" if self.position == "BUY" else "SHORT"
        result = self.ttp_manager.check(position=None, current_price=current_price,
                                        position_side=pos_side, entry_price=self.entry_price)
        if result.should_close:
            return 'TTP_TRIGGERED'
        ttp_level = self.ttp_manager.state.ttp_level
        if self.ttp_manager.state.active and ttp_level > 0:
            if abs(ttp_level - self._last_ttp_level) > 0.001:
                if self.tp_order_id:
                    try: adapter.cancel_order(self.tp_order_id)
                    except: pass
                tp_side = OrderSide.SELL if self.position == 'BUY' else OrderSide.BUY
                try:
                    tp_result = adapter.place_take_profit(coin=self.coin, tp_price=round(ttp_level, 2),
                                                          size=self.position_size, side=tp_side)
                    if tp_result.success:
                        self.tp_order_id = tp_result.order_id
                        self._last_ttp_level = ttp_level
                except Exception as e:
                    logger.error(f"[{self.id}] update_ttp 异常: {e}")
        return None

    def before_close(self, adapter):
        """平仓前撤 SL+TP 单"""
        for oid_attr in ('sl_order_id', 'tp_order_id'):
            oid = getattr(self, oid_attr)
            if oid:
                try: adapter.cancel_order(oid)
                except: pass
                setattr(self, oid_attr, None)

    def to_dict(self):
        return {
            'id': self.id, 'coin': self.coin, 'strategy_name': self.strategy_name,
            'interval': self.interval, 'mirror': self.mirror,
            'position': self.position, 'entry_price': self.entry_price,
            'position_size': self.position_size, '_target_size': self._target_size,
            'open_time': self.open_time, 'sl_order_id': self.sl_order_id,
            'tp_order_id': self.tp_order_id, 'state': self.state,
            '_last_ttp_level': self._last_ttp_level,
            'ttp_state': {k: getattr(self.ttp_manager.state, k)
                          for k in ('position_side','entry_price','highest','pullback_low',
                                    'lowest','pullback_high','in_pullback','swing_count',
                                    'ttp_level','active')},
        }

    def from_dict(self, d):
        for k in ('position','entry_price','position_size','_target_size','open_time',
                   'sl_order_id','tp_order_id','state','_last_ttp_level'):
            if k in d:
                setattr(self, k, d[k])
        ttp = d.get('ttp_state', {})
        for k, v in ttp.items():
            setattr(self.ttp_manager.state, k, v)
