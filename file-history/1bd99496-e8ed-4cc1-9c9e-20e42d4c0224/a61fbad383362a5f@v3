#!/usr/bin/env python3
"""实盘交易记录（SQLite）"""

import os, sqlite3, logging
from datetime import datetime

logger = logging.getLogger(__name__)
DEFAULT_DB = os.path.join(os.path.dirname(__file__), 'reports', 'live_trades.db')


class TradeLogger:
    def __init__(self, db_path=None):
        self.db_path = db_path or DEFAULT_DB
        os.makedirs(os.path.dirname(self.db_path), exist_ok=True)
        self.conn = sqlite3.connect(self.db_path)
        self.conn.execute("""
            CREATE TABLE IF NOT EXISTS live_trades (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                strategy_id TEXT, coin TEXT, strategy TEXT, interval TEXT,
                side TEXT, entry_price REAL, exit_price REAL,
                position_size REAL, pnl REAL, fee REAL,
                open_time TEXT, close_time TEXT, close_reason TEXT,
                bet_amount REAL, balance_after REAL)""")
        self.conn.commit()

    def log_trade(self, strategy, close_reason, exit_price, pnl, fee, balance):
        bet = strategy.position_size / 10 if strategy.position_size else 0
        self.conn.execute("""
            INSERT INTO live_trades VALUES (NULL,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""",
            (strategy.id, strategy.coin, strategy.strategy_name, strategy.interval,
             strategy.position, strategy.entry_price, exit_price,
             strategy.position_size, pnl, fee, strategy.open_time,
             datetime.utcnow().isoformat(), close_reason, bet, balance))
        self.conn.commit()

    def get_daily_report(self, date=None):
        if not date: date = datetime.utcnow().strftime('%Y-%m-%d')
        return self.conn.execute("""
            SELECT strategy_id, COUNT(*), SUM(pnl), SUM(fee)
            FROM live_trades WHERE close_time LIKE ?
            GROUP BY strategy_id ORDER BY SUM(pnl) DESC""", (f"{date}%",)).fetchall()

    def close(self):
        if self.conn: self.conn.close()
