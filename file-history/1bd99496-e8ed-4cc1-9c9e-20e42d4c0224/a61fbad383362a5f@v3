from exchange.bitmex.adapter import BitMEXAdapter
from exchange.base import OrderRequest, OrderSide, OrderType

logging.basicConfig(level=logging.INFO, format='%(asctime)s [%(levelname)s] %(name)s: %(message)s')
logger = logging.getLogger('unified_trader')
STATE_FILE = os.path.join(_lab_dir, 'strategy_states.json')


class UnifiedTrader:
    def __init__(self):
        self.adapter = BitMEXAdapter()
        self.feed_client = FeedClient()
        self.executor = LimitOrderExecutor()
        self.logger = TradeLogger()
        self.strategies = [StrategyRunner(cfg, self.adapter) for cfg in TEAM]
        self.dispatcher = KlineDispatcher(on_bar_callback=self._on_bar)
        self._strategy_map = {}
        for s in self.strategies:
            self._strategy_map.setdefault((s.coin, s.interval), []).append(s)
        self._running = True
        self._reconcile_timer = self._daily_report_timer = self._last_ttp_check = 0.0
        signal.signal(signal.SIGTERM, lambda s, f: setattr(self, '_running', False))
        signal.signal(signal.SIGINT, lambda s, f: setattr(self, '_running', False))

    def start(self):
        self._startup_recovery()
        self.dispatcher.startup(self.adapter)
        for coin in get_needed_intervals():
            self.feed_client.subscribe(coin, '1m')
        self._reconcile()
        now = time.time()
        self._reconcile_timer = self._daily_report_timer = self._last_ttp_check = now
        self._run_forever()

    def _run_forever(self):
        while self._running:
            if not self.feed_client.wait_for_kline(timeout=120):
                if not self.feed_client.is_gateway_alive():
                    self._on_gateway_disconnect()
                continue
            for coin in get_needed_intervals():
                klines = self.feed_client.get_klines(coin, '1m')
                if klines: self.dispatcher.on_1m_bar(coin, klines[-1])
            now = time.time()
            if now - self._last_ttp_check >= 1:
                self._check_ttp(); self._last_ttp_check = now
            self._check_circuit_breaker()
            if now - self._reconcile_timer >= 3600:
                self._reconcile(); self._reconcile_timer = now
            if now - self._daily_report_timer >= 86400:
                self._send_daily_report(); self._daily_report_timer = now
        self._save_states(); self.logger.close()

    def _on_bar(self, coin, interval, bar, klines):
        for s in self._strategy_map.get((coin, interval), []):
            if s.state in ('pending_open', 'pending_close'): continue
            try:
                sig = s.on_bar(bar, klines)
                if sig and sig != 'HOLD': self._execute(s, sig)
            except Exception as e:
                logger.error(f"[{s.id}] on_bar: {e}")

    def _execute(self, strategy, signal_str):
        if signal_str in ('BUY','SELL') and not strategy.position:
            available = self.adapter.get_balance().get('available', 0)
            bet = get_bet_amount(available)
            if available < bet / LEVERAGE: return
            strategy.state = 'pending_open'
            strategy._target_size = bet
            result = self.executor.execute_limit(strategy, signal_str, bet, self.adapter, self.dispatcher)
            if result['success']:
                strategy.position = signal_str
                strategy.entry_price = result['price']
                strategy.position_size = result.get('actual_size', bet)
                strategy.open_time = datetime.utcnow().isoformat()
                strategy.state = 'active'
                strategy.after_open(self.adapter)
                self._save_states()
            else:
                strategy.state = 'idle'
        elif strategy.position:
            close_side = 'SELL' if strategy.position == 'BUY' else 'BUY'
            if signal_str in (close_side, 'CLOSE'):
                self._close_position(strategy, close_side, 'SIGNAL')

    def _close_position(self, strategy, close_side, reason):
        strategy.state = 'pending_close'
        strategy.before_close(self.adapter)
        result = self.executor.execute_limit(strategy, close_side, strategy.position_size,
                                              self.adapter, self.dispatcher)
        if result['success']:
            pnl = self._calc_pnl(strategy, result['price'])
            bal = self.adapter.get_balance().get('available', 0)
            self.logger.log_trade(strategy, reason, result['price'], pnl, 0, bal)
            strategy.position = None; strategy.entry_price = 0
            strategy.position_size = 0; strategy.state = 'idle'
            strategy.ttp_manager.state.reset()
            self._save_states()
        else:
            strategy.state = 'active'

    def _calc_pnl(self, s, exit_price):
        if s.position == 'BUY': return (exit_price - s.entry_price) / s.entry_price * s.position_size
        if s.position == 'SELL': return (s.entry_price - exit_price) / s.entry_price * s.position_size
        return 0.0

    def _check_ttp(self):
        for s in self.strategies:
            if s.state != 'active' or not s.position: continue
            price = self.feed_client.get_price(s.coin)
            if price <= 0: continue
            if s.update_ttp_on_exchange(self.adapter, price) == 'TTP_TRIGGERED':
                self._close_position(s, 'SELL' if s.position=='BUY' else 'BUY', 'TTP')

    def _check_circuit_breaker(self):
        bal = self.feed_client.get_balance()
        avail = bal.get('availableMargin', 0)
        avail_usd = avail / 1e6 if avail > 1000 else avail
        if 0 < avail_usd < CIRCUIT_BREAKER_USD: self._circuit_break()

    def _circuit_break(self):
        self.adapter.cancel_all_orders()
        for s in self.strategies:
            if s.position:
                self.adapter.place_order(OrderRequest(
                    coin=s.coin, side=OrderSide.SELL if s.position=='BUY' else OrderSide.BUY,
                    order_type=OrderType.MARKET, size=s.position_size, reduce_only=True))
                s.position = None; s.position_size = 0; s.state = 'idle'
        self._save_states()

    def _startup_recovery(self):
        self._load_states()
        # pending_open → 查交易所补齐或撤销
        # pending_close → 市价平完
        # 撤无主挂单（完整逻辑见磁盘 unified_trader.py L290-L350）

    def _save_states(self):
        tmp = STATE_FILE + '.tmp'
        with open(tmp, 'w') as f: json.dump({s.id: s.to_dict() for s in self.strategies}, f, indent=2)
        os.replace(tmp, STATE_FILE)

    def _load_states(self):
        if not os.path.exists(STATE_FILE): return
        with open(STATE_FILE) as f: states = json.load(f)
        for s in self.strategies:
            if s.id in states: s.from_dict(states[s.id])

    def _reconcile(self):
        positions = self.adapter.get_positions()
        internal = {}
        for s in self.strategies:
            if s.position:
                internal.setdefault(s.coin, {'long':0,'short':0})
                internal[s.coin]['long' if s.position=='BUY' else 'short'] += s.position_size
        ex_map = {p.coin: p.size if p.side=='LONG' else -p.size for p in positions}
        for coin in set(list(internal)+list(ex_map)):
            i = internal.get(coin, {'long':0,'short':0})
            diff = abs(ex_map.get(coin,0) - (i['long']-i['short']))
            if diff > 0.01: logger.warning(f"⚠️ 对账偏差 {coin}: {diff:.4f}")

    def _on_gateway_disconnect(self):
        self.dispatcher.on_reconnect(self.adapter)
        self._save_states()

    def _send_daily_report(self):
        report = self.logger.get_daily_report()
        if report: logger.info(f"📊 每日: {sum(r[1] for r in report)}笔 PnL={sum(r[2] or 0 for r in report):.2f}")


if __name__ == '__main__':
    UnifiedTrader().start()
