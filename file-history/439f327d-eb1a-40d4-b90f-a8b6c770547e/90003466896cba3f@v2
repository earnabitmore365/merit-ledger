#!/usr/bin/env python3
"""通讯部总机 — Feed Gateway"""

import os, sys, json, time, logging, threading, argparse
from datetime import datetime, timezone
from typing import Dict, List, Optional
from collections import deque

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..'))

import zmq
from exchange.bitmex.adapter import BitMEXAdapter, SYMBOL_MAP, API_BASE
from exchange.bitmex.websocket import BitMEXWebSocket

logger = logging.getLogger('FeedGateway')

def parse_ts(iso_str):
    dt = datetime.fromisoformat(iso_str.replace('Z', '+00:00'))
    return int(dt.timestamp() * 1000)

def normalize_kline(row):
    ts_ms = parse_ts(row['timestamp'])
    return {'timestamp': ts_ms, 'time': ts_ms,
            'open': float(row.get('open',0)), 'high': float(row.get('high',0)),
            'low': float(row.get('low',0)), 'close': float(row.get('close',0)),
            'volume': float(row.get('volume',0))}

_REVERSE_SYMBOL_MAP = {v: k for k, v in SYMBOL_MAP.items()}
def symbol_to_coin(symbol): return _REVERSE_SYMBOL_MAP.get(symbol)

class FeedGateway:
    def __init__(self, coins, intervals, zmq_port=5555):
        self.coins = coins
        self.intervals = intervals
        self.zmq_port = zmq_port
        self._kline_windows = {f"{c}_{intervals[c]}": deque(maxlen=250) for c in coins}
        self._last_price = {}
        self._positions = {}
        self._margin = {}
        self._lock = threading.Lock()
        self._ctx = zmq.Context()
        self._pub = self._rep = self._ws = None
        self._running = False

    def start(self, api_key, api_secret, testnet=False):
        self._running = True
        self._load_history(api_key, api_secret, testnet)
        self._ws = BitMEXWebSocket(testnet=testnet)
        self._ws._on_reconnect_callback = lambda: self._load_history(api_key, api_secret, testnet)
        if not self._ws.connect(api_key=api_key, api_secret=api_secret): return
        self._ws._on_table_callback = self._on_ws_table
        self._pub = self._ctx.socket(zmq.PUB)
        self._pub.setsockopt(zmq.SNDHWM, 1000)
        self._pub.setsockopt(zmq.RCVHWM, 1000)
        self._pub.bind(f"tcp://127.0.0.1:{self.zmq_port}")
        self._rep = self._ctx.socket(zmq.REP)
        self._rep.bind(f"tcp://127.0.0.1:{self.zmq_port+1}")
        topics = []
        for c in self.coins:
            s = SYMBOL_MAP.get(c, f"{c}USDT")
            topics += [f'tradeBin{self.intervals[c]}:{s}', f'trade:{s}']
        self._ws.subscribe_private()
        self._ws.subscribe(topics)
        threading.Thread(target=self._rep_loop, daemon=True).start()
        threading.Thread(target=self._heartbeat_loop, daemon=True).start()
        while self._running: time.sleep(1)

    def _load_history(self, api_key, api_secret, testnet):
        adapter = BitMEXAdapter({'api_key':api_key,'api_secret':api_secret,'testnet':testnet})
        adapter._ws = None; adapter._connected = True
        for c in self.coins:
            iv = self.intervals[c]; key = f"{c}_{iv}"
            klines = adapter.get_klines(c, iv, limit=250)
            if klines:
                self._kline_windows[key] = deque(klines, maxlen=250)
                logger.info(f"  {key}: 加载 {len(klines)} 根 K 线")

    def _on_ws_table(self, table, action, rows):
        if not self._pub: return
        if table.startswith('tradeBin'):
            iv = table.replace('tradeBin','')
            for r in rows:
                c = symbol_to_coin(r.get('symbol',''));
                if not c: continue
                kl = normalize_kline(r); key = f"{c}_{iv}"
                with self._lock:
                    w = self._kline_windows.get(key)
                    if w is not None and (not w or w[-1]['timestamp']!=kl['timestamp']): w.append(kl)
                self._pub.send_string(f"KLINE.{c}.{iv} {json.dumps(kl)}")
        elif table == 'trade':
            for r in rows:
                c = symbol_to_coin(r.get('symbol','')); p = r.get('price',0)
                if c and p>0:
                    with self._lock: self._last_price[c] = p
                    self._pub.send_string(f"TICK.{c} {p}")
        elif table == 'position':
            for r in rows:
                c = symbol_to_coin(r.get('symbol',''))
                if c:
                    with self._lock:
                        if action in ('partial','insert'): self._positions[c] = r
                        elif action=='update': self._positions.setdefault(c,{}).update(r)
                        elif action=='delete': self._positions.pop(c,None)
                    self._pub.send_string(f"POS.{c} {json.dumps(r)}")
        elif table == 'margin':
            for r in rows:
                with self._lock: self._margin.update(r)
                self._pub.send_string(f"BALANCE {json.dumps(r)}")

    def _rep_loop(self):
        poller = zmq.Poller(); poller.register(self._rep, zmq.POLLIN)
        while self._running:
            if self._rep in dict(poller.poll(1000)):
                msg = self._rep.recv_string(); parts = msg.split()
                if len(parts)==3 and parts[0]=='KLINES':
                    with self._lock: data = list(self._kline_windows.get(f"{parts[1]}_{parts[2]}", deque()))
                    self._rep.send_string(json.dumps(data))
                else: self._rep.send_string("[]")

    def _heartbeat_loop(self):
        while self._running:
            if self._pub: self._pub.send_string(f"HEARTBEAT {time.time():.3f}")
            time.sleep(10)
