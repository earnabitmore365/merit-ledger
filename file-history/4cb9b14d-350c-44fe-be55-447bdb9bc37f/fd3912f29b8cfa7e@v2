#!/bin/bash
# start_mcp.sh — 一键启动 Trading MCP Server + Cloudflare Tunnel
#
# 用法：./start_mcp.sh
# 依赖：cloudflared 已安装（brew install cloudflare/cloudflare/cloudflared）
#       ~/.cloudflared/config.yml 已配置（见下方说明）
#
# 安全：Tunnel URL 本身即认证，不知道 URL 连不上，无需额外 token

set -e

PROJECT_DIR="/Volumes/BIWIN NV 7400 2TB/project/auto-trading"
MCP_PORT=8765
LOG_DIR="$PROJECT_DIR/logs"
MCP_LOG="$LOG_DIR/mcp_server.log"

mkdir -p "$LOG_DIR"

# ── 1. 加载环境变量 ──────────────────────────────────────────
if [ -f "$PROJECT_DIR/.env.mcp" ]; then
    export $(grep -v '^#' "$PROJECT_DIR/.env.mcp" | xargs)
fi

# ── 2. 检查依赖 ─────────────────────────────────────────────
if ! command -v cloudflared &> /dev/null; then
    echo "❌ cloudflared 未安装，请先运行："
    echo "   brew install cloudflare/cloudflare/cloudflared"
    exit 1
fi

# ── 3. 停止旧进程 ────────────────────────────────────────────
pkill -f "mcp_server.py" 2>/dev/null && echo "🔄 旧 MCP Server 已停止" || true

# ── 4. 启动 MCP Server（后台）────────────────────────────────
echo "🚀 启动 MCP Server（端口 $MCP_PORT）..."
cd "$PROJECT_DIR"
nohup python3 mcp_server.py http $MCP_PORT >> "$MCP_LOG" 2>&1 &
MCP_PID=$!
echo "   PID: $MCP_PID"

# 等待启动
sleep 2
if ! kill -0 $MCP_PID 2>/dev/null; then
    echo "❌ MCP Server 启动失败，查看日志："
    tail -20 "$MCP_LOG"
    exit 1
fi
echo "✅ MCP Server 启动成功"

# ── 5. 启动 Cloudflare Tunnel ────────────────────────────────
echo ""
echo "🌐 启动 Cloudflare Tunnel..."
echo "   Tunnel URL 将显示在下方（复制到 Claude.ai 的 Connector 设置里）"
echo "   按 Ctrl+C 停止"
echo ""

# 如果有命名 tunnel（config.yml 配置好了）用命名 tunnel
if cloudflared tunnel list 2>/dev/null | grep -q "trading-mcp"; then
    cloudflared tunnel run trading-mcp
else
    # 否则用临时 tunnel（每次重启 URL 会变）
    echo "⚠️  未找到 trading-mcp 命名 tunnel，使用临时 URL（重启后 URL 会变）"
    echo "   建议运行一次性配置：cloudflared tunnel create trading-mcp"
    echo ""
    cloudflared tunnel --url http://localhost:$MCP_PORT
fi
