# 优先级：环境变量 > .env.mcp > lab/.env
def _load_env(path, overwrite=False):
    """加载 .env 文件，跳过占位符值（含 'your_' 或 '_here'）"""
    if not os.path.exists(path):
        return
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith('#') or '=' not in line:
                continue
            k, v = line.split('=', 1)
            k, v = k.strip(), v.strip()
            if 'your_' in v or '_here' in v:   # 跳过未填写的占位符
                continue
            if overwrite or k not in os.environ:
                os.environ[k] = v

