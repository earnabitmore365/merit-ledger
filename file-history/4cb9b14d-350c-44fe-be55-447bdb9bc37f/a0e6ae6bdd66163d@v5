# ==================== 内部工具函数 ====================

def _ssh_exec(cmd: str) -> str:
    """在 Nitro 上执行命令，返回输出"""
    full_cmd = f"{SSH_CMD_BASE} '{cmd}'"
    try:
        result = subprocess.run(
            full_cmd, shell=True, capture_output=True, text=True, timeout=15
        )
        return result.stdout if result.returncode == 0 else f"ERROR: {result.stderr[:300]}"
    except subprocess.TimeoutExpired:
        return "ERROR: SSH 超时（Nitro 可能离线）"
    except Exception as e:
        return f"ERROR: {e}"


def _bitmex_request(verb: str, path: str, query: dict = None) -> dict:
    """BitMEX REST 只读请求（urllib，零依赖）"""
    if not BITMEX_API_KEY or not BITMEX_API_SECRET:
        return {"error": "未配置 BITMEX_API_KEY / BITMEX_API_SECRET"}

    expires = int(time.time()) + 30
    query_str = urllib.parse.urlencode(query) if query else ''
    full_path = f"/api/v1{path}"
    if query_str:
        full_path += f"?{query_str}"

    msg = verb + full_path + str(expires)
    sig = hmac.new(
        BITMEX_API_SECRET.encode(),
        msg.encode(),
        hashlib.sha256
    ).hexdigest()

    url = f"{BITMEX_BASE_URL}{full_path}"
    req = urllib.request.Request(url)
    req.add_header('api-key', BITMEX_API_KEY)
    req.add_header('api-signature', sig)
    req.add_header('api-expires', str(expires))
    req.add_header('Content-Type', 'application/json')

    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        return {"error": f"HTTP {e.code}: {e.read().decode()[:200]}"}
    except Exception as e:
        return {"error": str(e)}


