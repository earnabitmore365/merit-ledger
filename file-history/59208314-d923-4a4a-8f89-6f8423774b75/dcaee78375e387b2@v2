"""无极自动交易 — 路径配置（唯一权威来源）

所有脚本通过 `from path_config import ROOT, DATA_DIR, ...` 获取路径。
项目根目录通过 .wuji-root 标记文件定位，文件搬到任何子目录都能正确找到根。

用法（入口脚本开头）：
    import os, sys
    _p = os.path.dirname(os.path.abspath(__file__))
    while _p != os.path.dirname(_p) and not os.path.exists(os.path.join(_p, '.wuji-root')):
        _p = os.path.dirname(_p)
    if _p not in sys.path:
        sys.path.insert(0, _p)
    from path_config import ROOT, DATA_DIR, REPORT_DIR  # noqa: E402
"""

import os

# 项目根 = path_config.py 所在目录（它就在根目录）
ROOT = os.path.dirname(os.path.abspath(__file__))

# ── 共享数据层 ──
DATA_DIR = os.path.join(ROOT, "data")                    # K线 DuckDB + historical JSON
KLINES_DB = os.path.join(DATA_DIR, "klines.duckdb")      # K线主仓库

# ── 种子/报告输出 ──
REPORT_DIR = os.path.join(ROOT, "reports")                # 种子库输出目录
RESULT_DIR = os.path.join(ROOT, "results")                # Gate 报告输出目录

# ── 源代码 ──
SRC_DIR = os.path.join(ROOT, "src")                       # 共享源代码

# ── 配置 ──
CONFIG_DIR = os.path.join(ROOT, "config")                 # 配置文件

# ── 日志 ──
LOG_DIR = os.path.join(ROOT, "logs")                      # 日志输出

# 确保输出目录存在
for d in [REPORT_DIR, RESULT_DIR, LOG_DIR]:
    os.makedirs(d, exist_ok=True)
