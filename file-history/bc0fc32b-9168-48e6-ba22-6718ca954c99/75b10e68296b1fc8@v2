#!/usr/bin/env python3
"""
Gate v4.1 管线 — 币本位专用版
与 run_gate_v41.py 相同流程，但只看 _COIN 结尾的币种
输出到 results/gate_v41_coin/gate_v41_coin_report.db
"""
import sqlite3
import os, sys
import time
import random
_p = os.path.dirname(os.path.abspath(__file__))
while _p != os.path.dirname(_p) and not os.path.exists(os.path.join(_p, '.wuji-root')):
    _p = os.path.dirname(_p)
if _p not in sys.path:
    sys.path.insert(0, _p)
from path_config import ROOT, DATA_DIR, REPORT_DIR, RESULT_DIR, SRC_DIR  # noqa: E402

DB_PATH = os.path.join(REPORT_DIR, 'seed_signal.db')
COIN_REPORT_DIR = os.path.join(RESULT_DIR, 'gate_v41_coin')
REPORT_PATH = os.path.join(COIN_REPORT_DIR, 'gate_v41_coin_report.db')

INTERVALS = ['1m', '5m', '15m', '30m', '1h', '2h', '4h', '8h', '12h', '1d']
REGIMES = ['牛', '熊', '盘整', '初牛', '初熊']
SUB_PHASES = ['sprint', 'rest', 'dip', 'bounce', 'up', 'flat', 'down']
REGIME_PREFIX = {
    '牛': 'bull', '熊': 'bear', '盘整': 'ranging',
    '初牛': 'early_bull', '初熊': 'early_bear',
}

# 初考 X 值
X_MAP = {
    '1m': 500, '5m': 500, '15m': 500, '30m': 500,
    '1h': 350, '2h': 350, '4h': 350,
    '8h': 200, '12h': 200, '1d': 200,
}

# 组考
TEAMS = {
    'short': ['1m', '5m', '15m', '30m'],
    'mid':   ['1h', '2h', '4h'],
    'long':  ['8h', '12h', '1d'],
}
REGIME_DIMS = ['all', 'bull', 'bear', 'ranging', 'early_bull', 'early_bear']
SUB_PHASE_DIMS = ['sp_sprint', 'sp_rest', 'sp_dip', 'sp_bounce', 'sp_up', 'sp_flat', 'sp_down']
ALL_DIMS = REGIME_DIMS + SUB_PHASE_DIMS
TOP_N = 5

# MC
BARS_PER_DAY = {
    '1m': 1440, '5m': 288, '15m': 96, '30m': 48,
    '1h': 24, '2h': 12, '4h': 6, '8h': 3, '12h': 2, '1d': 1,
}
MC_RUNS = 100
MC_INITIAL = 500.0
MC_FRACTION = 0.02
MC_DOUBLE_TARGET = 1000.0
MC_CHAMPION_THRESHOLD = 50.0
MIN_TRADES_FOR_RANK = 10


# ==================== Step 1: 初考 ====================

def run_gate1(seed, rpt):
    """初考 — 交易数够不够多（只看 _COIN 币种）"""
    rpt.execute('''CREATE TABLE gate1_summary (
        interval TEXT PRIMARY KEY,
        total INTEGER, passed INTEGER, failed INTEGER,
        pass_rate REAL, threshold_min INTEGER, threshold_max INTEGER, x_value INTEGER
    )''')

    for iv in INTERVALS:
        rpt.execute(f'''CREATE TABLE gate1_{iv} (
            combo_id INTEGER PRIMARY KEY,
            strategy TEXT, coin TEXT, interval TEXT,
            total_trades INTEGER, klines INTEGER, threshold INTEGER,
            passed INTEGER, reason TEXT
        )''')

    # K线数（只看 _COIN）
    kline_counts = {}
    for r in seed.execute('''
        SELECT coin, interval, COUNT(*) as cnt FROM regime_timeline
        WHERE coin LIKE '%_COIN' GROUP BY coin, interval
    ''').fetchall():
        kline_counts[(r['coin'], r['interval'])] = r['cnt']

    # combo（只看 _COIN）
    combos = seed.execute('''
        SELECT id, strategy, coin, interval, total_trades
        FROM combo_summary WHERE coin LIKE '%_COIN'
        ORDER BY interval, strategy, coin
    ''').fetchall()

    by_interval = {iv: {'total': 0, 'passed': 0, 'failed': 0, 'thresholds': [], 'records': []}
                   for iv in INTERVALS}

    for c in combos:
        interval = c['interval']
        if interval not in X_MAP:
            continue
        coin = c['coin']
        trades = c['total_trades']
        klines = kline_counts.get((coin, interval), 0)
        x = X_MAP[interval]
        threshold = klines // x
        is_pass = trades >= threshold

        reason = (f"通过: {trades}笔 >= 门槛{threshold}" if is_pass
                  else f"不通过: {trades}笔 < 门槛{threshold} (K线{klines}/X{x}={threshold})")

        by_interval[interval]['records'].append(
            (c['id'], c['strategy'], coin, interval, trades, klines, threshold,
             1 if is_pass else 0, reason))
        by_interval[interval]['total'] += 1
        by_interval[interval]['thresholds'].append(threshold)
        if is_pass:
            by_interval[interval]['passed'] += 1
        else:
            by_interval[interval]['failed'] += 1

    total_all = passed_all = 0
    for iv in INTERVALS:
        info = by_interval[iv]
        if not info['records']:
            continue
        rpt.executemany(f'INSERT INTO gate1_{iv} VALUES (?,?,?,?,?,?,?,?,?)', info['records'])
        total_all += info['total']
        passed_all += info['passed']
        thresholds = info['thresholds']
        pass_rate = round(info['passed'] / info['total'] * 100, 1) if info['total'] else 0
        rpt.execute("INSERT INTO gate1_summary VALUES (?,?,?,?,?,?,?,?)",
                    (iv, info['total'], info['passed'], info['failed'], pass_rate,
                     min(thresholds) if thresholds else 0,
                     max(thresholds) if thresholds else 0, X_MAP[iv]))
    rpt.commit()

    print(f"初考: {passed_all}/{total_all} 通过 ({round(passed_all/total_all*100,1) if total_all else 0}%)")
    for iv in INTERVALS:
        info = by_interval[iv]
        if info['total'] == 0:
            continue
        pr = round(info['passed'] / info['total'] * 100, 1)
        print(f"  {iv:>4s}  {info['total']:>4d}  {info['passed']:>4d}  {info['failed']:>4d}  {pr:>5.1f}%  X{X_MAP[iv]}")

    return passed_all, total_all


# ==================== Step 2: 专考 ====================

def run_gate2(seed, rpt):
    """专考 — 13维度打分"""
    passed_by_iv = {}
    for iv in INTERVALS:
        try:
            rows = rpt.execute(f"SELECT combo_id, strategy, coin FROM gate1_{iv} WHERE passed = 1").fetchall()
        except sqlite3.OperationalError:
            rows = []
        passed_by_iv[iv] = {r['combo_id']: {'strategy': r['strategy'], 'coin': r['coin']} for r in rows}

    for iv in INTERVALS:
        cols = '''combo_id INTEGER PRIMARY KEY, strategy TEXT, coin TEXT, interval TEXT,
                  all_pnl REAL, all_trades INTEGER, all_win_rate REAL, all_avg_r REAL, rank_all INTEGER'''
        for regime in REGIMES:
            p = REGIME_PREFIX[regime]
            cols += f''', {p}_pnl REAL, {p}_trades INTEGER, {p}_win_rate REAL, {p}_avg_r REAL,
                     {p}_insufficient INTEGER, rank_{p} INTEGER'''
        for sp in SUB_PHASES:
            cols += f''', sp_{sp}_pnl REAL, sp_{sp}_trades INTEGER, sp_{sp}_win_rate REAL, sp_{sp}_avg_r REAL,
                     sp_{sp}_insufficient INTEGER, rank_sp_{sp} INTEGER'''
        rpt.execute(f"CREATE TABLE gate2_{iv} ({cols})")

    total = 0
    for iv in INTERVALS:
        combo_map = passed_by_iv[iv]
        combo_ids = list(combo_map.keys())
        if not combo_ids:
            continue

        print(f"  专考 {iv}: {len(combo_ids)} 组...", end=' ', flush=True)
        ph = ','.join('?' * len(combo_ids))

        # 全程
        scores = {}
        for r in seed.execute(f'''
            SELECT combo_id, SUM(r_value) as pnl, COUNT(*) as cnt,
                   AVG(CASE WHEN r_value > 0 THEN 1.0 ELSE 0.0 END) as wr, AVG(r_value) as ar
            FROM paired_trades WHERE combo_id IN ({ph}) GROUP BY combo_id
        ''', combo_ids).fetchall():
            scores[r['combo_id']] = {
                'all_pnl': round(r['pnl'] or 0, 4), 'all_trades': r['cnt'] or 0,
                'all_win_rate': round(r['wr'] or 0, 4), 'all_avg_r': round(r['ar'] or 0, 6),
            }

        # Regime
        for regime in REGIMES:
            p = REGIME_PREFIX[regime]
            regime_map = {}
            for r in seed.execute(f'''
                SELECT pt.combo_id, SUM(pt.r_value) as pnl, COUNT(*) as cnt,
                       AVG(CASE WHEN pt.r_value > 0 THEN 1.0 ELSE 0.0 END) as wr, AVG(pt.r_value) as ar
                FROM paired_trades pt JOIN regime_fact_labels rfl ON pt.id = rfl.trade_id
                WHERE pt.combo_id IN ({ph}) AND (rfl.regime_fact = ? OR rfl.regime_fact_2 = ?)
                GROUP BY pt.combo_id
            ''', combo_ids + [regime, regime]).fetchall():
                regime_map[r['combo_id']] = r

            for cid in combo_ids:
                if cid not in scores:
                    continue
                r = regime_map.get(cid)
                if r:
                    t = r['cnt'] or 0
                    scores[cid].update({f'{p}_pnl': round(r['pnl'] or 0, 4), f'{p}_trades': t,
                        f'{p}_win_rate': round(r['wr'] or 0, 4), f'{p}_avg_r': round(r['ar'] or 0, 6),
                        f'{p}_insufficient': 1 if t < MIN_TRADES_FOR_RANK else 0})
                else:
                    scores[cid].update({f'{p}_pnl': 0, f'{p}_trades': 0, f'{p}_win_rate': 0,
                        f'{p}_avg_r': 0, f'{p}_insufficient': 1})

        # Sub_phase
        for sp in SUB_PHASES:
            sp_map = {}
            for r in seed.execute(f'''
                SELECT spl.combo_id, SUM(pt.r_value) as pnl, COUNT(*) as cnt,
                       AVG(CASE WHEN pt.r_value > 0 THEN 1.0 ELSE 0.0 END) as wr, AVG(pt.r_value) as ar
                FROM paired_trades pt JOIN sub_phase_labels spl ON pt.id = spl.trade_id
                WHERE spl.combo_id IN ({ph}) AND spl.sub_phase = ?
                GROUP BY spl.combo_id
            ''', combo_ids + [sp]).fetchall():
                sp_map[r['combo_id']] = r

            for cid in combo_ids:
                if cid not in scores:
                    continue
                r = sp_map.get(cid)
                if r:
                    t = r['cnt'] or 0
                    scores[cid].update({f'sp_{sp}_pnl': round(r['pnl'] or 0, 4), f'sp_{sp}_trades': t,
                        f'sp_{sp}_win_rate': round(r['wr'] or 0, 4), f'sp_{sp}_avg_r': round(r['ar'] or 0, 6),
                        f'sp_{sp}_insufficient': 1 if t < MIN_TRADES_FOR_RANK else 0})
                else:
                    scores[cid].update({f'sp_{sp}_pnl': 0, f'sp_{sp}_trades': 0, f'sp_{sp}_win_rate': 0,
                        f'sp_{sp}_avg_r': 0, f'sp_{sp}_insufficient': 1})

        # 排名
        scored_list = [(cid, scores[cid]) for cid in combo_ids if cid in scores]
        scored_list.sort(key=lambda x: x[1]['all_pnl'], reverse=True)
        for i, (cid, s) in enumerate(scored_list):
            s['rank_all'] = i + 1

        for regime in REGIMES:
            p = REGIME_PREFIX[regime]
            eligible = [(c, s) for c, s in scored_list if not s.get(f'{p}_insufficient')]
            eligible.sort(key=lambda x: x[1][f'{p}_pnl'], reverse=True)
            for i, (c, s) in enumerate(eligible):
                s[f'rank_{p}'] = i + 1
            for c, s in scored_list:
                if f'rank_{p}' not in s:
                    s[f'rank_{p}'] = None

        for sp in SUB_PHASES:
            eligible = [(c, s) for c, s in scored_list if not s.get(f'sp_{sp}_insufficient')]
            eligible.sort(key=lambda x: x[1][f'sp_{sp}_pnl'], reverse=True)
            for i, (c, s) in enumerate(eligible):
                s[f'rank_sp_{sp}'] = i + 1
            for c, s in scored_list:
                if f'rank_sp_{sp}' not in s:
                    s[f'rank_sp_{sp}'] = None

        # 写入
        rows_to_insert = []
        for cid, s in scored_list:
            info = combo_map[cid]
            row = [cid, info['strategy'], info['coin'], iv,
                   s['all_pnl'], s['all_trades'], s['all_win_rate'], s['all_avg_r'], s['rank_all']]
            for regime in REGIMES:
                p = REGIME_PREFIX[regime]
                row.extend([s.get(f'{p}_pnl', 0), s.get(f'{p}_trades', 0), s.get(f'{p}_win_rate', 0),
                            s.get(f'{p}_avg_r', 0), s.get(f'{p}_insufficient', 1), s.get(f'rank_{p}')])
            for sp in SUB_PHASES:
                row.extend([s.get(f'sp_{sp}_pnl', 0), s.get(f'sp_{sp}_trades', 0),
                            s.get(f'sp_{sp}_win_rate', 0), s.get(f'sp_{sp}_avg_r', 0),
                            s.get(f'sp_{sp}_insufficient', 1), s.get(f'rank_sp_{sp}')])
            rows_to_insert.append(tuple(row))

        n_cols = 9 + len(REGIMES) * 6 + len(SUB_PHASES) * 6
        rpt.executemany(f'INSERT INTO gate2_{iv} VALUES ({",".join("?" * n_cols)})', rows_to_insert)
        rpt.commit()
        total += len(rows_to_insert)
        print(f"完成 ({len(rows_to_insert)} 条)")

    print(f"  专考完成: {total} 组 (13维度)")
    return total


# ==================== Step 3: 组考 ====================

def run_gate3(rpt):
    """组考 — 跨周期组队"""
    for team_name, intervals in TEAMS.items():
        rpt.execute(f'''CREATE TABLE gate3_{team_name} (
            combo_id INTEGER PRIMARY KEY, strategy TEXT, coin TEXT, interval TEXT,
            all_pnl REAL, selected INTEGER, selected_dimensions TEXT, reason TEXT
        )''')

        all_candidates = []
        for iv in intervals:
            try:
                rows = rpt.execute(f"SELECT * FROM gate2_{iv}").fetchall()
                all_candidates.extend(rows)
            except sqlite3.OperationalError:
                pass

        if not all_candidates:
            print(f"  组考 {team_name}队: 0 个候选，跳过")
            continue

        print(f"  组考 {team_name}队: {len(all_candidates)} 个候选...", end=' ', flush=True)

        selected_combos = {}
        for dim in ALL_DIMS:
            pnl_key = f'{dim}_pnl'
            insuf_key = f'{dim}_insufficient' if dim != 'all' else None
            eligible = []
            for r in all_candidates:
                if insuf_key and r[insuf_key]:
                    continue
                pnl = r[pnl_key] if r[pnl_key] is not None else 0
                eligible.append((r, pnl))
            eligible.sort(key=lambda x: x[1], reverse=True)
            for r, pnl in eligible[:TOP_N]:
                cid = r['combo_id']
                if cid not in selected_combos:
                    selected_combos[cid] = set()
                selected_combos[cid].add(dim)

        # 去重
        by_strat_coin = {}
        for cid, dims in selected_combos.items():
            r = next(x for x in all_candidates if x['combo_id'] == cid)
            key = (r['strategy'], r['coin'])
            pnl = r['all_pnl'] or 0
            if key not in by_strat_coin or pnl > by_strat_coin[key][1]:
                by_strat_coin[key] = (cid, pnl, dims)
        final_selected = {v[0]: v[2] for v in by_strat_coin.values()}

        batch = []
        seen = set()
        for r in all_candidates:
            cid = r['combo_id']
            if cid in seen:
                continue
            seen.add(cid)
            if cid in final_selected:
                dims = final_selected[cid]
                batch.append((cid, r['strategy'], r['coin'], r['interval'], r['all_pnl'] or 0,
                              1, ','.join(sorted(dims)),
                              f"入选: {','.join(sorted(dims))}维度TOP{TOP_N}"))
            else:
                reason = ("未入选: 同(策略,币种)有更优周期" if cid in selected_combos
                          else "未入选: 13维度均排名TOP5以外")
                batch.append((cid, r['strategy'], r['coin'], r['interval'], r['all_pnl'] or 0,
                              0, '', reason))

        rpt.executemany(f"INSERT OR REPLACE INTO gate3_{team_name} VALUES (?,?,?,?,?,?,?,?)", batch)
        rpt.commit()
        n_selected = sum(1 for b in batch if b[5] == 1)
        print(f"{n_selected} 入选 / {len(all_candidates)} 总候选")


# ==================== Step 4: MC照妖镜 ====================

def monte_carlo(seed_conn, combo_id, interval):
    trades = seed_conn.execute(
        'SELECT r_value, holding_bars FROM paired_trades WHERE combo_id = ?', (combo_id,)
    ).fetchall()
    trade_list = [(t['r_value'], t['holding_bars']) for t in trades]
    bpd = BARS_PER_DAY.get(interval, 24)

    results = []
    for _ in range(MC_RUNS):
        random.shuffle(trade_list)
        balance = MC_INITIAL
        peak = MC_INITIAL
        max_dd = 0.0
        cumulative_days = 0.0
        days_to_double = None
        busted = False

        for r_value, holding_bars in trade_list:
            pnl = r_value * (balance * MC_FRACTION)
            balance += pnl
            cumulative_days += holding_bars / bpd
            if balance <= 0:
                busted = True
                break
            peak = max(peak, balance)
            dd = (peak - balance) / peak
            max_dd = max(max_dd, dd)
            if days_to_double is None and balance >= MC_DOUBLE_TARGET:
                days_to_double = cumulative_days

        results.append({'final_balance': balance, 'days_to_double': days_to_double,
                        'max_dd': max_dd * 100, 'busted': busted})

    doubled = [r for r in results if r['days_to_double'] is not None]
    dd_list = sorted([r['max_dd'] for r in results if not r['busted']])
    bal_list = sorted([r['final_balance'] for r in results if not r['busted']])
    d2d_list = sorted([r['days_to_double'] for r in doubled])
    busted_count = sum(1 for r in results if r['busted'])

    def pct(lst, p):
        if not lst:
            return None
        return round(lst[min(int(len(lst) * p / 100), len(lst) - 1)], 2)

    double_rate = round(len(doubled) / MC_RUNS * 100, 1)
    return {
        'double_rate': double_rate,
        'bust_rate': round(busted_count / MC_RUNS * 100, 1),
        'd2d_p5': pct(d2d_list, 5), 'd2d_p50': pct(d2d_list, 50), 'd2d_p95': pct(d2d_list, 95),
        'max_dd_p5': pct(dd_list, 5), 'max_dd_p50': pct(dd_list, 50), 'max_dd_p95': pct(dd_list, 95),
        'balance_p50': pct(bal_list, 50),
        'is_champion': double_rate >= MC_CHAMPION_THRESHOLD,
        'reason': (f"通过: 翻倍率{double_rate}% >= {MC_CHAMPION_THRESHOLD}%"
                   if double_rate >= MC_CHAMPION_THRESHOLD
                   else f"不通过: 翻倍率{double_rate}% < {MC_CHAMPION_THRESHOLD}%"),
    }


def run_gate_mc(seed, rpt):
    """MC照妖镜"""
    random.seed(42)

    rpt.execute('''CREATE TABLE mc_results (
        combo_id INTEGER PRIMARY KEY, strategy TEXT, coin TEXT, interval TEXT,
        team TEXT, all_pnl REAL, double_rate REAL, bust_rate REAL,
        d2d_p5 REAL, d2d_p50 REAL, d2d_p95 REAL,
        max_dd_p5 REAL, max_dd_p50 REAL, max_dd_p95 REAL,
        balance_p50 REAL, is_champion INTEGER, reason TEXT
    )''')
    rpt.execute('''CREATE TABLE champions (
        combo_id INTEGER PRIMARY KEY, strategy TEXT, coin TEXT, interval TEXT,
        team TEXT, all_pnl REAL, double_rate REAL, bust_rate REAL,
        d2d_p50 REAL, max_dd_p95 REAL, balance_p50 REAL
    )''')

    total_candidates = total_champions = 0

    for team in ['short', 'mid', 'long']:
        try:
            rows = rpt.execute(f'''
                SELECT combo_id, strategy, coin, interval, all_pnl
                FROM gate3_{team} WHERE selected = 1
            ''').fetchall()
        except sqlite3.OperationalError:
            rows = []

        if not rows:
            print(f"  MC {team}队: 0 个候选，跳过")
            continue

        print(f"\n  MC {team}队: {len(rows)} 个候选")
        team_champs = 0

        for r in rows:
            cid, iv = r['combo_id'], r['interval']
            print(f"    {r['strategy']}/{r['coin']}/{iv}...", end=' ', flush=True)
            mc = monte_carlo(seed, cid, iv)

            rpt.execute('INSERT INTO mc_results VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)', (
                cid, r['strategy'], r['coin'], iv, team, r['all_pnl'],
                mc['double_rate'], mc['bust_rate'],
                mc['d2d_p5'], mc['d2d_p50'], mc['d2d_p95'],
                mc['max_dd_p5'], mc['max_dd_p50'], mc['max_dd_p95'],
                mc['balance_p50'], 1 if mc['is_champion'] else 0, mc['reason']))

            if mc['is_champion']:
                rpt.execute('INSERT INTO champions VALUES (?,?,?,?,?,?,?,?,?,?,?)', (
                    cid, r['strategy'], r['coin'], iv, team, r['all_pnl'],
                    mc['double_rate'], mc['bust_rate'],
                    mc['d2d_p50'], mc['max_dd_p95'], mc['balance_p50']))
                team_champs += 1
                print(f"翻倍率={mc['double_rate']}% d2d_p50={mc['d2d_p50']} ✅")
            else:
                print(f"翻倍率={mc['double_rate']}% ❌")

        rpt.commit()
        total_candidates += len(rows)
        total_champions += team_champs
        print(f"  {team}队冠军: {team_champs}/{len(rows)}")

    # gate_index
    rpt.execute('''CREATE TABLE gate_index (
        table_name TEXT PRIMARY KEY, description TEXT, record_count INTEGER
    )''')
    entries = [('gate1_summary', '初考（门槛）汇总',
                rpt.execute("SELECT COUNT(*) FROM gate1_summary").fetchone()[0])]
    for iv in INTERVALS:
        try:
            cnt = rpt.execute(f"SELECT COUNT(*) FROM gate1_{iv}").fetchone()[0]
            entries.append((f'gate1_{iv}', f'初考明细 {iv}', cnt))
        except sqlite3.OperationalError:
            pass
    for iv in INTERVALS:
        try:
            cnt = rpt.execute(f"SELECT COUNT(*) FROM gate2_{iv}").fetchone()[0]
            entries.append((f'gate2_{iv}', f'专考成绩单 {iv} — 13维度', cnt))
        except sqlite3.OperationalError:
            pass
    for team in ['short', 'mid', 'long']:
        try:
            cnt = rpt.execute(f"SELECT COUNT(*) FROM gate3_{team}").fetchone()[0]
            entries.append((f'gate3_{team}', f'组考{team}队', cnt))
        except sqlite3.OperationalError:
            pass
    entries.append(('mc_results', '照妖镜MC',
                    rpt.execute("SELECT COUNT(*) FROM mc_results").fetchone()[0]))
    entries.append(('champions', '冠军 — MC翻倍率≥50%',
                    rpt.execute("SELECT COUNT(*) FROM champions").fetchone()[0]))
    rpt.executemany("INSERT INTO gate_index VALUES (?,?,?)", entries)
    rpt.commit()

    print(f"\n  照妖镜MC完成: {total_champions}/{total_candidates} 冠军")
    return total_champions, total_candidates


# ==================== 主流程 ====================

def main():
    print("=" * 60)
    print("Gate v4.1 管线 — 币本位专用版")
    print("=" * 60)

    # 前置检查
    seed = sqlite3.connect(DB_PATH)
    seed.row_factory = sqlite3.Row

    coin_combos = seed.execute(
        "SELECT COUNT(*) FROM combo_summary WHERE coin LIKE '%_COIN'"
    ).fetchone()[0]
    coins = [r[0] for r in seed.execute(
        "SELECT DISTINCT coin FROM combo_summary WHERE coin LIKE '%_COIN' ORDER BY coin"
    ).fetchall()]
    print(f"\n币本位数据: {coin_combos} 组 ({', '.join(coins)})")

    for table in ['regime_fact_labels', 'sub_phase_labels']:
        cnt = seed.execute(f"SELECT COUNT(*) FROM {table}").fetchone()[0]
        print(f"✅ {table}: {cnt:,} 条")

    # 报告文件
    os.makedirs(COIN_REPORT_DIR, exist_ok=True)
    if os.path.exists(REPORT_PATH):
        os.remove(REPORT_PATH)
    rpt = sqlite3.connect(REPORT_PATH)
    rpt.row_factory = sqlite3.Row

    # Step 1
    print("\n[Step 1] 初考...")
    t0 = time.time()
    run_gate1(seed, rpt)
    print(f"  耗时: {time.time()-t0:.1f}s")

    # Step 2
    print("\n[Step 2] 专考（13维度）...")
    t0 = time.time()
    run_gate2(seed, rpt)
    print(f"  耗时: {time.time()-t0:.1f}s")

    # Step 3
    print("\n[Step 3] 组考...")
    t0 = time.time()
    run_gate3(rpt)
    print(f"  耗时: {time.time()-t0:.1f}s")

    # Step 4
    print("\n[Step 4] MC照妖镜...")
    t0 = time.time()
    run_gate_mc(seed, rpt)
    print(f"  耗时: {time.time()-t0:.1f}s")

    # 汇总
    print("\n" + "=" * 60)
    print("Gate v4.1 币本位管线完成!")
    print("=" * 60)

    print("\n报告目录:")
    for row in rpt.execute("SELECT * FROM gate_index ORDER BY table_name").fetchall():
        print(f"  {row['table_name']:>20s} | {row['record_count']:>6d} | {row['description']}")

    champs = rpt.execute('SELECT * FROM champions ORDER BY team, all_pnl DESC').fetchall()
    if champs:
        print(f"\n冠军队 ({len(champs)} 个):")
        print(f"{'队伍':>6s}  {'策略':<20s}  {'币种':<10s}  {'周期':<4s}  {'PnL(R)':>8s}  {'翻倍率':>6s}  {'d2d_p50':>8s}  {'max_dd_95%':>10s}")
        print("-" * 90)
        for c in champs:
            print(f"{c['team']:>6s}  {c['strategy']:<20s}  {c['coin']:<10s}  {c['interval']:<4s}  "
                  f"{c['all_pnl']:>+8.1f}  {c['double_rate']:>5.1f}%  {c['d2d_p50']:>8.1f}  {c['max_dd_p95']:>9.1f}%")
    else:
        print("\n无冠军")

    seed.close()
    rpt.close()
    print(f"\n输出: {REPORT_PATH}")


