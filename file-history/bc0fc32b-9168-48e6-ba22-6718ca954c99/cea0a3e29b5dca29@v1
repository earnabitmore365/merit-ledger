# ==================== 断点读写 ====================

def ensure_checkpoint_table(conn: sqlite3.Connection):
    """确保断点表存在"""
    conn.executescript(CHECKPOINT_SCHEMA)
    conn.commit()


def save_checkpoint(conn: sqlite3.Connection, strategy: str, coin: str,
                    interval: str, state: Dict):
    """保存断点状态"""
    conn.execute(
        """INSERT OR REPLACE INTO backtest_checkpoint
           (strategy, coin, interval_, last_candle_time_ms, total_candle_count,
            balance, position, entry_price, position_open_time_ms,
            buy_signals, sell_signals, withdraw_count, first_withdraw_day,
            ttp_state, regime_state, updated_at)
           VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""",
        (strategy, coin, interval,
         state['last_candle_time_ms'],
         state['total_candle_count'],
         state['balance'],
         state['position'],
         state['entry_price'],
         state['position_open_time_ms'],
         state['buy_signals'],
         state['sell_signals'],
         state['withdraw_count'],
         state.get('first_withdraw_day'),
         json.dumps(state.get('ttp_state', {})),
         json.dumps(state.get('regime_state', {})),
         datetime.now().strftime('%Y-%m-%d %H:%M:%S'))
    )
    conn.commit()


def load_checkpoint(conn: sqlite3.Connection, strategy: str, coin: str,
                    interval: str) -> Optional[Dict]:
    """读取断点状态，无断点返回 None"""
    cur = conn.execute(
        """SELECT last_candle_time_ms, total_candle_count,
                  balance, position, entry_price, position_open_time_ms,
                  buy_signals, sell_signals, withdraw_count, first_withdraw_day,
                  ttp_state, regime_state, updated_at
           FROM backtest_checkpoint
           WHERE strategy=? AND coin=? AND interval_=?""",
        (strategy, coin, interval)
    )
    row = cur.fetchone()
    if row is None:
        return None
    return {
        'last_candle_time_ms': row[0],
        'total_candle_count': row[1],
        'balance': row[2],
        'position': row[3],
        'entry_price': row[4],
        'position_open_time_ms': row[5],
        'buy_signals': row[6],
        'sell_signals': row[7],
        'withdraw_count': row[8],
        'first_withdraw_day': row[9],
        'ttp_state': json.loads(row[10]) if row[10] else {},
        'regime_state': json.loads(row[11]) if row[11] else {},
        'updated_at': row[12],
    }


def delete_checkpoint(conn: sqlite3.Connection, strategy: str, coin: str,
                      interval: str):
    """删除断点（全量重跑时用）"""
    conn.execute(
        "DELETE FROM backtest_checkpoint WHERE strategy=? AND coin=? AND interval_=?",
        (strategy, coin, interval)
    )
    conn.commit()


# ==================== 时间戳对齐 ====================

def find_candle_index_by_time(candles: List[Dict], time_ms: int) -> int:
    """用时间戳二分查找K线索引

    Returns:
        匹配的索引，找不到返回 -1
    """
    times = [c.get('timestamp', c.get('time', 0)) for c in candles]
    idx = bisect.bisect_left(times, time_ms)
    if idx < len(times) and times[idx] == time_ms:
        return idx
    return -1


# ==================== end_of_data 交易处理 ====================

def remove_end_of_data_trade(conn: sqlite3.Connection, combo_id: int) -> Optional[Dict]:
    """删除最后一笔 end_of_data 交易，返回删除的交易信息（用于恢复持仓状态）

    Returns:
        被删除的 end_of_data 交易记录，或 None
    """
    cur = conn.execute(
        """SELECT id, direction, entry_price, exit_price, pnl, balance_after,
                  open_candle_idx, close_candle_idx, open_time, capital
           FROM paired_trades
           WHERE combo_id=? AND close_type='end_of_data'
           ORDER BY id DESC LIMIT 1""",
        (combo_id,)
    )
    row = cur.fetchone()
    if row is None:
        return None

    trade_info = {
        'id': row[0],
        'direction': row[1],
        'entry_price': row[2],
        'exit_price': row[3],
        'pnl': row[4],
        'balance_after': row[5],
        'open_candle_idx': row[6],
        'close_candle_idx': row[7],
        'open_time': row[8],
        'capital': row[9],
    }

    # 删除这笔交易
    conn.execute("DELETE FROM paired_trades WHERE id=?", (trade_info['id'],))
    conn.commit()

    return trade_info


def get_combo_id(conn: sqlite3.Connection, strategy: str, coin: str,
                 interval: str) -> Optional[int]:
    """获取 combo_id"""
    cur = conn.execute(
        "SELECT id FROM combo_summary WHERE strategy=? AND coin=? AND interval=?",
        (strategy, coin, interval)
    )
    row = cur.fetchone()
    return row[0] if row else None


# ==================== 增量回测核心 ====================

def run_incremental(conn: sqlite3.Connection, strategy_name: str,
                    coin: str, interval: str, candles: List[Dict],
                    regime_timeline: List[Dict],
                    enable_ttp: bool = False,
                    force_full: bool = False) -> Dict:
    """对单个 combo 执行增量回测

    Args:
        conn: DB 连接
        strategy_name: 策略名
        coin: 币种
        interval: 周期
        candles: 完整K线（旧+新）
        regime_timeline: regime 时间线（完整）
        enable_ttp: 是否开启 TTP
        force_full: 强制全量重跑

    Returns:
        {'status': 'incremental'|'full'|'skipped', 'new_trades': int, 'elapsed': float}
    """
    t0 = time.time()
    bars_per_day = _BARS_PER_DAY.get(interval, 24)
    bar_minutes = _BAR_MINUTES.get(interval, 60)
    bars_per_funding = int((8 * 60) / bar_minutes) if bar_minutes > 0 else 999999
    n_candles = len(candles)

    # 查断点
    checkpoint = None if force_full else load_checkpoint(conn, strategy_name, coin, interval)

    if checkpoint is not None:
        # 检查是否有新数据
        last_time = checkpoint['last_candle_time_ms']
        last_idx = find_candle_index_by_time(candles, last_time)

        if last_idx < 0:
            # 断点K线被裁剪了，必须全量重跑
            logger.warning(f"[{strategy_name}/{coin}/{interval}] 断点K线已被裁剪，全量重跑")
            checkpoint = None
            force_full = True
        elif last_idx >= n_candles - 1:
            # 没有新数据
            return {'status': 'skipped', 'new_trades': 0,
                    'elapsed': time.time() - t0, 'reason': '无新K线'}

    if checkpoint is None:
        # 安全检查：如果已有交易数据，不能直接删掉重跑
        combo_id_check = get_combo_id(conn, strategy_name, coin, interval)
        if combo_id_check is not None and not force_full:
            trade_count = conn.execute(
                "SELECT COUNT(*) FROM paired_trades WHERE combo_id=?",
                (combo_id_check,)
            ).fetchone()[0]
            if trade_count > 0:
                logger.warning(
                    f"[{strategy_name}/{coin}/{interval}] 已有 {trade_count} 笔交易但无断点。"
                    f"请先运行 bootstrap_checkpoints.py 或使用 --full 强制重跑。跳过。")
                return {'status': 'skipped', 'new_trades': 0,
                        'elapsed': time.time() - t0,
                        'reason': '无断点但有已有数据，需先 bootstrap'}
        # 全量跑（复用 generate_seed 的逻辑）
        return _run_full(conn, strategy_name, coin, interval, candles,
                         regime_timeline, enable_ttp, bars_per_day,
                         bars_per_funding, t0)

    # ==================== 增量续跑 ====================
    resume_idx = last_idx  # 断点位置（已处理过的最后一根K线）
    new_start = resume_idx + 1  # 从下一根开始

    logger.info(f"[{strategy_name}/{coin}/{interval}] 增量续跑: "
                f"K线 {resume_idx+1}/{n_candles}，新增 {n_candles - new_start} 根")

    # 加载策略
    strategy = get_strategy(strategy_name)
    if not strategy:
        return {'status': 'failed', 'new_trades': 0,
                'elapsed': time.time() - t0, 'reason': f'策略不存在: {strategy_name}'}

    # 初始化 indicator_cache（用完整K线）
    init_cache(coin, interval, candles)
    strategy.interval = interval

    if hasattr(strategy, 'REQUIRES') and strategy.REQUIRES:
        validate_requires(strategy_name, strategy.REQUIRES)

    # 恢复引擎状态
    position = checkpoint['position']
    entry_price = checkpoint['entry_price']
    balance = checkpoint['balance']
    buy_signals = checkpoint['buy_signals']
    sell_signals = checkpoint['sell_signals']
    withdraw_count = checkpoint['withdraw_count']
    first_withdraw_day = checkpoint['first_withdraw_day']

    # 恢复 position_open_bar（从时间戳转索引）
    position_open_bar = -1
    if position != 'NO_POSITION' and checkpoint['position_open_time_ms'] > 0:
        position_open_bar = find_candle_index_by_time(
            candles, checkpoint['position_open_time_ms'])
        if position_open_bar < 0:
            # 开仓K线被裁剪，视为全量重跑
            logger.warning(f"[{strategy_name}/{coin}/{interval}] 开仓K线被裁剪，全量重跑")
            return _run_full(conn, strategy_name, coin, interval, candles,
                             regime_timeline, enable_ttp, bars_per_day,
                             bars_per_funding, t0)

    # 恢复 TTP 状态
    ttp_config = TTPConfig(
        ttp_enabled=enable_ttp,
        ttp_buffer_pips=5.0,
        ttp_trigger_pct=0.01
    )
    ttp_manager = TTPManager(ttp_config)
    if enable_ttp and position != 'NO_POSITION':
        ttp_state = checkpoint.get('ttp_state', {})
        if ttp_state:
            ttp_manager.state.position_side = ttp_state.get('position_side', '')
            ttp_manager.state.entry_price = ttp_state.get('entry_price', 0.0)
            ttp_manager.state.highest = ttp_state.get('highest', 0.0)
            ttp_manager.state.pullback_low = ttp_state.get('pullback_low', 0.0)
            ttp_manager.state.lowest = ttp_state.get('lowest', 0.0)
            ttp_manager.state.pullback_high = ttp_state.get('pullback_high', 0.0)
            ttp_manager.state.in_pullback = ttp_state.get('in_pullback', False)
            ttp_manager.state.swing_count = ttp_state.get('swing_count', 0)
            ttp_manager.state.ttp_level = ttp_state.get('ttp_level', 0.0)
            ttp_manager.state.active = ttp_state.get('active', False)

    # 处理 end_of_data：如果断点时有持仓，DB 里最后一笔是 end_of_data 强平
    combo_id = get_combo_id(conn, strategy_name, coin, interval)
    if combo_id is not None and position != 'NO_POSITION':
        removed = remove_end_of_data_trade(conn, combo_id)
        if removed:
            # 恢复余额到 end_of_data 之前
            # balance_after 是扣除了 end_of_data pnl 后的值，要加回去
            balance = removed['balance_after'] - removed['pnl']
            logger.info(f"  已删除 end_of_data 交易，恢复余额: ${balance:.2f}")

    # 如果没有 combo_id（全新的策略），走全量
    if combo_id is None:
        return _run_full(conn, strategy_name, coin, interval, candles,
                         regime_timeline, enable_ttp, bars_per_day,
                         bars_per_funding, t0)

    # ==================== 回测循环（增量部分） ====================
    closes = [c['close'] for c in candles]
    times_str = [datetime.fromtimestamp(
        c.get('timestamp', c.get('time', 0)) / 1000
    ).strftime('%Y-%m-%d %H:%M') for c in candles]

    # 用于固定注码
    fixed_bet = FIXED_BET
    fixed_bet_amount = FIXED_BET_AMOUNT
    stop_loss_pct = STOP_LOSS_PCT
    leverage = LEVERAGE
    enable_withdraw = False  # 种子生成不开提款

    def get_trade_capital():
        if fixed_bet:
            return fixed_bet_amount
        return max(balance * 0.1, 100)

    def calc_trading_costs(pos_size, holding):
        fee = pos_size * FEE_RATE * 2
        slippage = pos_size * SLIPPAGE_PCT * 2
        fc = int(holding / bars_per_funding) if bars_per_funding > 0 else 0
        funding = pos_size * FUNDING_RATE_8H * fc
        return fee, slippage, funding

    # 新交易记录
    new_trades = []
    new_candle_indices = []
    balance_list = [balance]  # 用于后续计算

    # 如果有持仓，注入合成开仓交易（让 pair_trades 能配对第一笔平仓）
    if position != 'NO_POSITION' and position_open_bar >= 0:
        open_time_str = times_str[position_open_bar]
        synthetic_open = Trade(open_time_str, position, entry_price,
                               FIXED_BET_AMOUNT if FIXED_BET else max(balance * 0.1, 100),
                               0, balance)
        new_trades.append(synthetic_open)
        new_candle_indices.append(position_open_bar)

    MAX_WINDOW = 200

    for i in range(new_start, n_candles):
        strategy.current_idx = i

        try:
            if hasattr(strategy, 'generate_signal'):
                window_start = max(0, i + 1 - MAX_WINDOW)
                signal = strategy.generate_signal(coin, candles[window_start:i+1])
                if hasattr(signal, 'signal'):
                    action = signal.signal.value
                else:
                    from core.strategy.base import Signal
                    action = signal.value if isinstance(signal, Signal) else signal
            else:
                signal = strategy.get_signal(i)
                from core.strategy.base import Signal
                action = signal.value if isinstance(signal, Signal) else signal
        except Exception as e:
            logger.error(f"信号生成错误: {e}")
            action = 'HOLD'

        current_price = closes[i]
        current_time = times_str[i]
        trade_capital = get_trade_capital()
        position_size = trade_capital * leverage

        # ===== BUY 持仓 TTP 检测 =====
        if enable_ttp and position == 'BUY' and balance > 0:
            position_info = {'coin': coin, 'side': 'LONG', 'entry_price': entry_price}
            result = ttp_manager.check(
                position=position_info, current_price=current_price,
                entry_price=entry_price, position_side='LONG')
            if result.should_close:
                ttp_price = result.ttp_level or current_price
                raw_pnl = (ttp_price - entry_price) / entry_price * position_size
                holding = i - position_open_bar
                fee, slip, fund = calc_trading_costs(position_size, holding)
                pnl = raw_pnl - fee - slip - fund
                balance += pnl
                balance_list.append(balance)
                new_trades.append(Trade(current_time, 'TTP_CLOSE_BUY', ttp_price,
                                        trade_capital, pnl, balance, 0, fee, slip, fund))
                new_candle_indices.append(i)
                position = 'NO_POSITION'
                ttp_manager.reset()
                continue

        # ===== SELL 持仓 TTP 检测 =====
        if enable_ttp and position == 'SELL' and balance > 0:
            position_info = {'coin': coin, 'side': 'SHORT', 'entry_price': entry_price}
            result = ttp_manager.check(
                position=position_info, current_price=current_price,
                entry_price=entry_price, position_side='SHORT')
            if result.should_close:
                ttp_price = result.ttp_level or current_price
                raw_pnl = (entry_price - ttp_price) / entry_price * position_size
                holding = i - position_open_bar
                fee, slip, fund = calc_trading_costs(position_size, holding)
                pnl = raw_pnl - fee - slip - fund
                balance += pnl
                balance_list.append(balance)
                new_trades.append(Trade(current_time, 'TTP_CLOSE_SELL', ttp_price,
                                        trade_capital, pnl, balance, 0, fee, slip, fund))
                new_candle_indices.append(i)
                position = 'NO_POSITION'
                ttp_manager.reset()
                continue

        # ===== CLOSE 信号 =====
        if action == 'CLOSE' and position != 'NO_POSITION':
            if position == 'BUY':
                raw_pnl = (current_price - entry_price) / entry_price * position_size
            else:
                raw_pnl = (entry_price - current_price) / entry_price * position_size
            holding = i - position_open_bar
            fee, slip, fund = calc_trading_costs(position_size, holding)
            pnl = raw_pnl - fee - slip - fund
            balance += pnl
            balance_list.append(balance)
            close_type = 'CLOSE_BUY' if position == 'BUY' else 'CLOSE_SELL'
            new_trades.append(Trade(current_time, close_type, current_price,
                                    trade_capital, pnl, balance, 0, fee, slip, fund))
            new_candle_indices.append(i)
            if balance <= 0:
                new_trades.append(Trade(current_time, 'LIQUIDATION', current_price, 0, 0, balance))
                new_candle_indices.append(i)
                balance_list.append(0)
                position = 'NO_POSITION'
                break
            position = 'NO_POSITION'
            ttp_manager.reset()
            trade_capital = get_trade_capital()
            position_size = trade_capital * leverage

        # ===== BUY 信号 =====
        if action == 'BUY' and position != 'BUY':
            if position == 'SELL':
                raw_pnl = (entry_price - current_price) / entry_price * position_size
                holding = i - position_open_bar
                fee, slip, fund = calc_trading_costs(position_size, holding)
                pnl = raw_pnl - fee - slip - fund
                balance += pnl
                balance_list.append(balance)
                new_trades.append(Trade(current_time, 'CLOSE_SELL', current_price,
                                        trade_capital, pnl, balance, 0, fee, slip, fund))
                new_candle_indices.append(i)
                if balance <= 0:
                    new_trades.append(Trade(current_time, 'LIQUIDATION', current_price, 0, 0, balance))
                    new_candle_indices.append(i)
                    balance_list.append(0)
                    position = 'NO_POSITION'
                    break
                trade_capital = get_trade_capital()
                position_size = trade_capital * leverage

            new_trades.append(Trade(current_time, 'BUY', current_price, trade_capital, 0, balance))
            new_candle_indices.append(i)
            position_open_bar = i
            position = 'BUY'
            entry_price = current_price
            buy_signals += 1

        # ===== BUY 止损 =====
        elif position == 'BUY':
            price_change = (current_price - entry_price) / entry_price
            if price_change <= -stop_loss_pct:
                raw_pnl = -position_size * stop_loss_pct
                holding = i - position_open_bar
                fee, slip, fund = calc_trading_costs(position_size, holding)
                pnl = raw_pnl - fee - slip - fund
                balance += pnl
                balance_list.append(balance)
                new_trades.append(Trade(current_time, 'CLOSE_BUY', current_price,
                                        trade_capital, pnl, balance, 0, fee, slip, fund))
                new_candle_indices.append(i)
                if balance <= 0:
                    new_trades.append(Trade(current_time, 'LIQUIDATION', current_price, 0, 0, balance))
                    new_candle_indices.append(i)
                    balance_list.append(0)
                    position = 'NO_POSITION'
                    break
                position = 'NO_POSITION'
                trade_capital = get_trade_capital()
                position_size = trade_capital * leverage

        # ===== SELL 信号 =====
        if action == 'SELL' and position != 'SELL':
            if position == 'BUY':
                raw_pnl = (current_price - entry_price) / entry_price * position_size
                holding = i - position_open_bar
                fee, slip, fund = calc_trading_costs(position_size, holding)
                pnl = raw_pnl - fee - slip - fund
                balance += pnl
                balance_list.append(balance)
                new_trades.append(Trade(current_time, 'CLOSE_BUY', current_price,
                                        trade_capital, pnl, balance, 0, fee, slip, fund))
                new_candle_indices.append(i)
                if balance <= 0:
                    new_trades.append(Trade(current_time, 'LIQUIDATION', current_price, 0, 0, balance))
                    new_candle_indices.append(i)
                    balance_list.append(0)
                    position = 'NO_POSITION'
                    break
                trade_capital = get_trade_capital()
                position_size = trade_capital * leverage

            new_trades.append(Trade(current_time, 'SELL', current_price, trade_capital, 0, balance))
            new_candle_indices.append(i)
            position_open_bar = i
            position = 'SELL'
            entry_price = current_price
            sell_signals += 1

        # ===== SELL 止损 =====
        elif position == 'SELL':
            price_change = (entry_price - current_price) / entry_price
            if price_change <= -stop_loss_pct:
                raw_pnl = -position_size * stop_loss_pct
                holding = i - position_open_bar
                fee, slip, fund = calc_trading_costs(position_size, holding)
                pnl = raw_pnl - fee - slip - fund
                balance += pnl
                balance_list.append(balance)
                new_trades.append(Trade(current_time, 'CLOSE_SELL', current_price,
                                        trade_capital, pnl, balance, 0, fee, slip, fund))
                new_candle_indices.append(i)
                if balance <= 0:
                    new_trades.append(Trade(current_time, 'LIQUIDATION', current_price, 0, 0, balance))
                    new_candle_indices.append(i)
                    balance_list.append(0)
                    position = 'NO_POSITION'
                    break
                position = 'NO_POSITION'
                trade_capital = get_trade_capital()
                position_size = trade_capital * leverage

    # ===== 数据末尾平仓（end_of_data） =====
    if position != 'NO_POSITION':
        final_price = candles[-1]['close']
        final_time = datetime.fromtimestamp(
            candles[-1].get('timestamp', candles[-1].get('time', 0)) / 1000
        ).strftime('%Y-%m-%d %H:%M')
        trade_capital = get_trade_capital()
        position_size = trade_capital * leverage

        if position == 'BUY':
            raw_pnl = (final_price - entry_price) / entry_price * position_size
        else:
            raw_pnl = (entry_price - final_price) / entry_price * position_size

        holding = (n_candles - 1) - position_open_bar
        fee, slip, fund = calc_trading_costs(position_size, holding)
        pnl = raw_pnl - fee - slip - fund
        balance += pnl
        balance_list.append(balance)
        close_type = 'CLOSE_BUY' if position == 'BUY' else 'CLOSE_SELL'
        new_trades.append(Trade(final_time, close_type, final_price,
                                trade_capital, pnl, balance, 0, fee, slip, fund))
        new_candle_indices.append(n_candles - 1)

    # ===== 配对新交易并写入 DB =====
    new_paired = []
    if new_trades:
        new_paired = pair_trades(
            new_trades, new_candle_indices,
            regime_timeline, LEVERAGE,
            candles=candles, bars_per_funding=bars_per_funding)

        if new_paired:
            conn.executemany(
                """INSERT INTO paired_trades
                   (combo_id, open_candle_idx, close_candle_idx, open_time, close_time,
                    holding_bars, direction, entry_price, exit_price, capital, position_size,
                    pnl, r_value, balance_after, close_type, regime_at_open,
                    fee, funding_cost, slippage_cost, mfe, mae,
                    open_atr_pct, open_volume, funding_count)
                   VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)""",
                [(combo_id, p['open_candle_idx'], p['close_candle_idx'],
                  p['open_time'], p['close_time'], p['holding_bars'],
                  p['direction'], p['entry_price'], p['exit_price'],
                  p['capital'], p['position_size'], p['pnl'], p['r_value'],
                  p['balance_after'], p['close_type'], p['regime_at_open'],
                  p['fee'], p['funding_cost'], p['slippage_cost'],
                  p['mfe'], p['mae'], p['open_atr_pct'], p['open_volume'],
                  p['funding_count'])
                 for p in new_paired]
            )

    # ===== 保存断点 =====
    last_candle = candles[-1]
    last_time_ms = last_candle.get('timestamp', last_candle.get('time', 0))

    # 用 paired trades 的 close_type 判断是否有 end_of_data 持仓
    # 如果最后一笔配对交易是 end_of_data，说明数据末尾有未平仓位
    save_position = 'NO_POSITION'
    save_entry = 0.0
    save_open_time = 0
    save_balance = balance

    if new_paired:
        if new_paired[-1]['close_type'] == 'end_of_data':
            last_p = new_paired[-1]
            save_position = 'BUY' if last_p['direction'] == 'long' else 'SELL'
            save_entry = last_p['entry_price']
            open_idx = last_p['open_candle_idx']
            save_open_time = candles[open_idx].get('timestamp', candles[open_idx].get('time', 0))
            # 余额还原到 end_of_data 平仓前
            save_balance = last_p['balance_after'] - last_p['pnl']
    else:
        # 没有新交易，保持原断点状态
        save_position = checkpoint['position']
        save_entry = checkpoint['entry_price']
        save_open_time = checkpoint['position_open_time_ms']

    ttp_state_dict = {}
    # TTP 状态在 end_of_data 后已被引擎 reset，无法恢复
    # 下次增量时 TTP 会从持仓开始重新追踪（轻微偏差，可接受）

    save_checkpoint(conn, strategy_name, coin, interval, {
        'last_candle_time_ms': last_time_ms,
        'total_candle_count': n_candles,
        'balance': save_balance if save_position != 'NO_POSITION' else balance,
        'position': save_position,
        'entry_price': save_entry,
        'position_open_time_ms': save_open_time,
        'buy_signals': buy_signals,
        'sell_signals': sell_signals,
        'withdraw_count': withdraw_count,
        'first_withdraw_day': first_withdraw_day,
        'ttp_state': ttp_state_dict,
        'regime_state': {},
    })

    conn.commit()

    new_paired_count = len([t for t in new_trades
                            if 'CLOSE' in t.order_type or 'TTP' in t.order_type])
    elapsed = time.time() - t0
    logger.info(f"  ✅ 增量完成: +{new_paired_count} 笔交易, {elapsed:.1f}s")

    return {'status': 'incremental', 'new_trades': new_paired_count, 'elapsed': elapsed}


def _run_full(conn: sqlite3.Connection, strategy_name: str,
              coin: str, interval: str, candles: List[Dict],
              regime_timeline: List[Dict], enable_ttp: bool,
              bars_per_day: int, bars_per_funding: int,
              t0: float) -> Dict:
    """全量跑一个 combo（删旧数据+重跑）"""
    # 删除旧数据
    combo_id = get_combo_id(conn, strategy_name, coin, interval)
    if combo_id is not None:
        conn.execute("DELETE FROM paired_trades WHERE combo_id=?", (combo_id,))
        conn.execute("DELETE FROM combo_summary WHERE id=?", (combo_id,))
        conn.commit()

    # 删除旧断点
    delete_checkpoint(conn, strategy_name, coin, interval)

    n_candles = len(candles)

    # 跑回测
    engine = BacktestEngine(
        coin=coin, interval=interval, days=DAYS,
        initial_capital=INITIAL_CAPITAL, enable_ttp=enable_ttp,
        stop_loss_pct=STOP_LOSS_PCT, leverage=LEVERAGE,
        enable_withdraw=False, fixed_bet=FIXED_BET,
        candles=candles, fixed_bet_amount=FIXED_BET_AMOUNT,
        fee_rate=FEE_RATE, slippage_pct=SLIPPAGE_PCT,
        funding_rate_8h=FUNDING_RATE_8H)
    result = engine.run_backtest(strategy_name)

    if result is None:
        return {'status': 'failed', 'new_trades': 0,
                'elapsed': time.time() - t0, 'reason': '回测失败'}

    paired = pair_trades(
        engine.trades, engine.trade_candle_indices,
        regime_timeline, LEVERAGE,
        candles=engine.candles, bars_per_funding=bars_per_funding)

    save_combo(conn, strategy_name, coin, interval, result, paired,
               INITIAL_CAPITAL, DAYS, n_candles, bars_per_day)

    # 保存断点
    last_candle = candles[-1]
    last_time_ms = last_candle.get('timestamp', last_candle.get('time', 0))

    # 用 paired trades 判断 end_of_data
    final_position = 'NO_POSITION'
    final_entry = 0.0
    final_open_time = 0
    final_balance = engine.current_balance

    if paired and paired[-1]['close_type'] == 'end_of_data':
        last_p = paired[-1]
        final_position = 'BUY' if last_p['direction'] == 'long' else 'SELL'
        final_entry = last_p['entry_price']
        open_idx = last_p['open_candle_idx']
        final_open_time = candles[open_idx].get('timestamp', candles[open_idx].get('time', 0))
        # 余额还原到 end_of_data 平仓前
        final_balance = last_p['balance_after'] - last_p['pnl']

    save_checkpoint(conn, strategy_name, coin, interval, {
        'last_candle_time_ms': last_time_ms,
        'total_candle_count': n_candles,
        'balance': final_balance,
        'position': final_position,
        'entry_price': final_entry,
        'position_open_time_ms': final_open_time,
        'buy_signals': result.buy_signals,
        'sell_signals': result.sell_signals,
        'withdraw_count': engine.withdraw_count,
        'first_withdraw_day': engine.first_withdraw_day,
        'ttp_state': {},
        'regime_state': {},
    })

    conn.commit()

    total_trades = result.total_trades
    elapsed = time.time() - t0
    logger.info(f"  ✅ 全量完成: {total_trades} 笔交易, {elapsed:.1f}s")

    return {'status': 'full', 'new_trades': total_trades, 'elapsed': elapsed}


# ==================== 主入口 ====================

def parse_args():
    parser = argparse.ArgumentParser(description='增量回测引擎')
    parser.add_argument('--coins', nargs='+', help='指定币种')
    parser.add_argument('--intervals', nargs='+', help='指定周期')
    parser.add_argument('--strategy', nargs='+', help='指定策略')
    parser.add_argument('--ttp', action='store_true', help='TTP 模式')
    parser.add_argument('--full', action='store_true', help='强制全量重跑')
    parser.add_argument('--db', type=str, default=None, help='指定数据库路径')
    return parser.parse_args()


def main():
    args = parse_args()

    # 确定 DB 路径
    if args.db:
        db_path = args.db
    elif args.ttp:
        db_path = DB_PATH_TTP
    else:
        db_path = DB_PATH

    # 确定币种和周期
    all_coins, all_intervals = detect_coins_and_intervals()
    coins = args.coins or all_coins
    intervals = args.intervals or all_intervals
    strategies = args.strategy or get_strategies()

    logger.info(f"增量回测: {len(coins)}币种 × {len(intervals)}周期 × {len(strategies)}策略")
    logger.info(f"数据库: {db_path}")

    conn = init_db(db_path)
    ensure_checkpoint_table(conn)

    total_results = {'incremental': 0, 'full': 0, 'skipped': 0, 'failed': 0}
    t_start = time.time()

    for coin in coins:
        for interval in intervals:
            candles = load_candles(coin, interval)
            if not candles or len(candles) < MIN_KLINES:
                logger.info(f"[{coin}/{interval}] 跳过: K线不足")
                continue

            bars_per_day = _BARS_PER_DAY.get(interval, 24)

            # Regime 时间线
            if check_regime_exists(conn, coin, interval):
                cur = conn.execute(
                    "SELECT candle_idx, candle_time_ms, regime, adx, sma_direction "
                    "FROM regime_timeline WHERE coin=? AND interval=? ORDER BY candle_idx",
                    (coin, interval))
                regime_timeline = [
                    {'candle_idx': r[0], 'candle_time_ms': r[1],
                     'regime': r[2], 'adx': r[3], 'sma_direction': r[4]}
                    for r in cur.fetchall()]

                # 检查是否有新K线需要补充 regime
                max_regime_idx = max(e['candle_idx'] for e in regime_timeline) if regime_timeline else -1
                if max_regime_idx < len(candles) - 1:
                    # 需要补充新K线的 regime
                    full_regime = compute_regime_timeline(candles, interval, DAYS)
                    new_entries = [e for e in full_regime if e['candle_idx'] > max_regime_idx]
                    if new_entries:
                        save_regime_timeline(conn, coin, interval, new_entries)
                        conn.commit()
                        regime_timeline.extend(new_entries)
                        logger.info(f"[{coin}/{interval}] 补充 {len(new_entries)} 条 regime")
            else:
                regime_timeline = compute_regime_timeline(candles, interval, DAYS)
                save_regime_timeline(conn, coin, interval, regime_timeline)
                conn.commit()

            # 逐策略跑
            for strategy_name in strategies:
                try:
                    result = run_incremental(
                        conn, strategy_name, coin, interval,
                        candles, regime_timeline,
                        enable_ttp=args.ttp, force_full=args.full)
                    total_results[result['status']] = total_results.get(result['status'], 0) + 1
                except Exception as e:
                    logger.error(f"[{strategy_name}/{coin}/{interval}] 错误: {e}")
                    total_results['failed'] += 1

            close_cache()

    conn.close()
    elapsed = time.time() - t_start

    logger.info(f"\n{'='*60}")
    logger.info(f"增量回测完成: {elapsed:.0f}s")
    logger.info(f"  增量: {total_results['incremental']} | "
                f"全量: {total_results['full']} | "
                f"跳过: {total_results['skipped']} | "
                f"失败: {total_results['failed']}")


if __name__ == '__main__':
    main()
