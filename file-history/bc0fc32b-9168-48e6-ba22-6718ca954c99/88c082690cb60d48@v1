#!/usr/bin/env python3
"""
Regime-aware Walk-Forward v2 — 两两合并regime版

合并相邻regime做LOO，解决盘整只有2段的问题：
- 牛+初牛:   9段 → pass≥6/9
- 初牛+盘整: 5段 → pass≥3/5
- 盘整+初熊: 8段 → pass≥5/8
- 初熊+熊:  10段 → pass≥7/10

冠军通过条件：4个合并组中，有≥10笔交易的组全部通过LOO

输入: seed_v3.db (paired_trades) + gate_v41_report.db (champions)
输出: gate_v41_report.db (wf_paired_results + wf_paired_champions)
"""
import sqlite3
import os, sys
_p = os.path.dirname(os.path.abspath(__file__))
while _p != os.path.dirname(_p) and not os.path.exists(os.path.join(_p, '.wuji-root')):
    _p = os.path.dirname(_p)
if _p not in sys.path:
    sys.path.insert(0, _p)
from path_config import ROOT, DATA_DIR, REPORT_DIR, RESULT_DIR, SRC_DIR  # noqa: E402

DB_PATH = os.path.join(REPORT_DIR, 'seed_v3.db')
REPORT_PATH = os.path.join(RESULT_DIR, 'gate_v41', 'gate_v41_report.db')

TIMELINE = [
    (1,  '2017-12', '2018-01', '初熊'),
    (2,  '2018-02', '2018-12', '熊'),
    (3,  '2019-01', '2019-03', '初牛'),
    (4,  '2019-04', '2019-06', '牛'),
    (5,  '2019-07', '2019-08', '初熊'),
    (6,  '2019-09', '2020-03', '熊'),
    (7,  '2020-04', '2020-09', '初牛'),
    (8,  '2020-10', '2021-04', '牛'),
    (9,  '2021-05', '2021-07', '初熊'),
    (10, '2021-08', '2021-11', '牛'),
    (11, '2021-12', '2022-01', '初熊'),
    (12, '2022-02', '2022-11', '熊'),
    (13, '2022-12', '2023-03', '初牛'),
    (14, '2023-04', '2023-09', '盘整'),
    (15, '2023-10', '2024-03', '牛'),
    (16, '2024-04', '2024-09', '盘整'),
    (17, '2024-10', '2025-01', '牛'),
    (18, '2025-02', '2025-03', '初熊'),
    (19, '2025-04', '2025-10', '牛'),
    (20, '2025-11', '2025-12', '初熊'),
    (21, '2026-01', '2026-03', '熊'),
]

# 3个合并组（盘整并入过渡带）
PAIRED_GROUPS = [
    ('bull_early_bull',    '牛+初牛',         ['牛', '初牛']),
    ('transition',         '初牛+盘整+初熊',  ['初牛', '盘整', '初熊']),
    ('early_bear_bear',    '初熊+熊',         ['初熊', '熊']),
]

MIN_TRADES = 10


def build_month_to_segment():
    mapping = {}
    for seg_id, start_ym, end_ym, regime in TIMELINE:
        ym = start_ym
        while ym <= end_ym:
            mapping[ym] = (seg_id, regime)
            y, m = int(ym[:4]), int(ym[5:7])
            m += 1
            if m > 12:
                m = 1
                y += 1
            ym = f'{y:04d}-{m:02d}'
    return mapping


def get_threshold(n):
    """约2/3通过"""
    return max(1, round(n * 2 / 3))


def paired_wf(seed_conn, combo_id, month_map):
    trades = seed_conn.execute('''
        SELECT open_time, r_value FROM paired_trades
        WHERE combo_id = ?
    ''', (combo_id,)).fetchall()

    # 每笔交易 → (segment_id, regime)
    by_segment = {}  # seg_id → [r_values]
    seg_regime = {}  # seg_id → regime
    for t in trades:
        month = t['open_time'][:7]
        seg_info = month_map.get(month)
        if not seg_info:
            continue
        seg_id, regime = seg_info
        by_segment.setdefault(seg_id, []).append(t['r_value'])
        seg_regime[seg_id] = regime

    group_results = {}
    any_fail = False
    testable = 0

    for group_en, group_cn, regimes in PAIRED_GROUPS:
        # 找属于这组的segments
        group_segs = {}
        for seg_id, r_values in by_segment.items():
            if seg_regime[seg_id] in regimes:
                group_segs[seg_id] = r_values

        n_segments = len(group_segs)
        total_trades = sum(len(v) for v in group_segs.values())
        total_pnl = sum(sum(v) for v in group_segs.values())

        if total_trades < MIN_TRADES or n_segments < 2:
            group_results[group_en] = {
                'status': 'skip',
                'label': group_cn,
                'trades': total_trades,
                'segments': n_segments,
                'pnl': round(total_pnl, 4),
                'folds_passed': None,
                'folds_total': None,
                'threshold': None,
                'reason': f'skip: trades={total_trades} segs={n_segments}',
            }
            continue

        testable += 1

        # LOO
        seg_ids = sorted(group_segs.keys())
        seg_pnl = {sid: sum(group_segs[sid]) for sid in seg_ids}
        total_group_pnl = sum(seg_pnl.values())

        pass_count = 0
        for held_out in seg_ids:
            remaining = total_group_pnl - seg_pnl[held_out]
            if remaining > 0:
                pass_count += 1

        threshold = get_threshold(n_segments)
        passed = pass_count >= threshold

        if not passed:
            any_fail = True

        group_results[group_en] = {
            'status': 'pass' if passed else 'fail',
            'label': group_cn,
            'trades': total_trades,
            'segments': n_segments,
            'pnl': round(total_group_pnl, 4),
            'folds_passed': pass_count,
            'folds_total': n_segments,
            'threshold': threshold,
            'reason': f"{'通过' if passed else '不通过'}: {pass_count}/{n_segments} (≥{threshold})",
        }

    overall = not any_fail and testable > 0
    if testable == 0:
        reason = "无可测组 (交易太少)"
        overall = False
    elif any_fail:
        failed = [v['label'] for v in group_results.values() if v['status'] == 'fail']
        reason = f"不通过: {','.join(failed)}"
    else:
        passed_list = [v['label'] for v in group_results.values() if v['status'] == 'pass']
        reason = f"通过: {','.join(passed_list)} ({testable}组)"

    return {
        'group_results': group_results,
        'overall_passed': overall,
        'testable': testable,
        'reason': reason,
    }


def main():
    print("=" * 60)
    print("Regime-aware WF v2 — 两两合并regime")
    print("=" * 60)

    month_map = build_month_to_segment()

    # 打印组信息
    regime_segs = {}
    for seg_id, _, _, regime in TIMELINE:
        regime_segs.setdefault(regime, []).append(seg_id)

    for group_en, group_cn, regimes in PAIRED_GROUPS:
        segs = []
        for r in regimes:
            segs.extend(regime_segs[r])
        segs.sort()
        t = get_threshold(len(segs))
        print(f"  {group_cn}: {len(segs)}段 → pass≥{t}/{len(segs)}")

    seed = sqlite3.connect(DB_PATH)
    seed.row_factory = sqlite3.Row
    rpt = sqlite3.connect(REPORT_PATH)
    rpt.row_factory = sqlite3.Row

    champions = rpt.execute('''
        SELECT * FROM champions ORDER BY team, all_pnl DESC
    ''').fetchall()

    print(f"\n冠军候选: {len(champions)} 个")

    # 建表
    rpt.execute("DROP TABLE IF EXISTS wf_paired_results")
    rpt.execute('''CREATE TABLE wf_paired_results (
        combo_id INTEGER,
        strategy TEXT, coin TEXT, interval TEXT, team TEXT,
        all_pnl REAL,
        pair_group TEXT, pair_label TEXT,
        status TEXT,
        trades INTEGER, segments INTEGER, pnl REAL,
        folds_passed INTEGER, folds_total INTEGER, threshold INTEGER,
        reason TEXT
    )''')

    rpt.execute("DROP TABLE IF EXISTS wf_paired_champions")
    rpt.execute('''CREATE TABLE wf_paired_champions (
        combo_id INTEGER PRIMARY KEY,
        strategy TEXT, coin TEXT, interval TEXT,
        team TEXT, all_pnl REAL,
        double_rate REAL, bust_rate REAL,
        d2d_p50 REAL, max_dd_p95 REAL, balance_p50 REAL,
        testable_groups INTEGER, reason TEXT
    )''')

    total_pass = 0
    total_fail = 0

    for c in champions:
        cid = c['combo_id']
        label = f"{c['strategy']}/{c['coin']}/{c['interval']}"
        print(f"\n  [{c['team']}] {label} (PnL={c['all_pnl']:+.1f}R)...")

        result = paired_wf(seed, cid, month_map)

        for group_en, gr in result['group_results'].items():
            rpt.execute('''INSERT INTO wf_paired_results VALUES
                (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)''', (
                cid, c['strategy'], c['coin'], c['interval'],
                c['team'], c['all_pnl'],
                group_en, gr['label'],
                gr['status'],
                gr['trades'], gr['segments'], gr['pnl'],
                gr['folds_passed'], gr['folds_total'], gr['threshold'],
                gr['reason'],
            ))

        if result['overall_passed']:
            total_pass += 1
            rpt.execute('''INSERT INTO wf_paired_champions VALUES
                (?,?,?,?,?,?,?,?,?,?,?,?,?)''', (
                cid, c['strategy'], c['coin'], c['interval'],
                c['team'], c['all_pnl'],
                c['double_rate'], c['bust_rate'],
                c['d2d_p50'], c['max_dd_p95'], c['balance_p50'],
                result['testable'], result['reason'],
            ))
            print(f"    ✅ {result['reason']}")
        else:
            total_fail += 1
            print(f"    ❌ {result['reason']}")

        for group_en, gr in result['group_results'].items():
            sym = '✅' if gr['status'] == 'pass' else '❌' if gr['status'] == 'fail' else '⏭'
            detail = f"{gr['folds_passed']}/{gr['folds_total']}(≥{gr['threshold']})" if gr['folds_passed'] is not None else gr['reason']
            print(f"       {gr['label']}: {sym} {detail} trades={gr['trades']} PnL={gr['pnl']:+.1f}")

    rpt.commit()

    # 更新 gate_index
    rpt.execute("DELETE FROM gate_index WHERE table_name IN ('wf_paired_results', 'wf_paired_champions')")
    wf_cnt = rpt.execute("SELECT COUNT(*) FROM wf_paired_results").fetchone()[0]
    wf_champ_cnt = rpt.execute("SELECT COUNT(*) FROM wf_paired_champions").fetchone()[0]
    rpt.execute("INSERT INTO gate_index VALUES (?, ?, ?)",
                ('wf_paired_results', 'Regime-aware WF(合并版)明细', wf_cnt))
    rpt.execute("INSERT INTO gate_index VALUES (?, ?, ?)",
                ('wf_paired_champions', 'Regime-aware WF(合并版)冠军', wf_champ_cnt))
    rpt.commit()

    seed.close()
    rpt.close()

    print("\n" + "=" * 60)
    print(f"Regime-aware WF (合并版) 完成: {total_pass}/{len(champions)} 通过")
    print(f"  通过: {total_pass}")
    print(f"  不通过: {total_fail}")
    print(f"  淘汰率: {total_fail/len(champions)*100:.1f}%")
    print(f"输出: {REPORT_PATH}")
    print("=" * 60)


if __name__ == '__main__':
    main()
