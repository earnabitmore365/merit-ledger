#!/usr/bin/env python3
"""
通讯部写入脚本 — 由 Claude Code Hooks 自动触发
处理 Stop 和 UserPromptSubmit 两个事件，写入 ~/.claude/dashboard.db
"""

import sys
import json
import sqlite3
import os
from datetime import datetime

DB_PATH = os.path.expanduser('~/.claude/dashboard.db')


def get_project(cwd):
    home = os.path.expanduser('~')
    if cwd == home:
        return 'home'
    rel = cwd.replace(home + '/', '')
    parts = rel.split('/')
    return parts[-1] if parts else 'unknown'


def get_speaker(cwd, transcript_path):
    home = os.path.expanduser('~')
    if cwd == home:
        return '太极'
    try:
        with open(transcript_path, 'r') as f:
            lines = f.readlines()
        for line in reversed(lines[-100:]):
            try:
                data = json.loads(line.strip())
                model = data.get('model', '')
                if 'opus' in model:
                    return '黑丝'
                elif 'sonnet' in model:
                    return '白纱'
            except Exception:
                continue
    except Exception:
        pass
    return '未知'


def write_message(conn, speaker, content, project, session_id):
    now = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    conn.execute(
        'INSERT INTO messages (time, speaker, content, project, session_id) VALUES (?, ?, ?, ?, ?)',
        (now, speaker, content, project, session_id)
    )
    conn.commit()


def main():
    try:
        data = json.load(sys.stdin)
    except Exception:
        sys.exit(0)

    event = data.get('hook_event_name', '')
    session_id = data.get('session_id', '')
    cwd = data.get('cwd', os.getcwd())
    project = get_project(cwd)

    conn = sqlite3.connect(DB_PATH)

    if event == 'Stop':
        content = data.get('last_assistant_message', '').strip()
        transcript_path = data.get('transcript_path', '')
        speaker = get_speaker(cwd, transcript_path)
        if content:
            write_message(conn, speaker, content, project, session_id)

    elif event == 'UserPromptSubmit':
        content = data.get('prompt', '').strip()
        if content:
            write_message(conn, '混沌', content, project, session_id)

    conn.close()


if __name__ == '__main__':
    main()
