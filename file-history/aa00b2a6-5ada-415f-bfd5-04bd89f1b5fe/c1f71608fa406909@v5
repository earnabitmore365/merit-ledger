#!/usr/bin/env python3
"""
通讯部写入脚本 — 由 Claude Code Hooks 自动触发
处理 Stop 和 UserPromptSubmit 两个事件，写入 ~/.claude/dashboard.db
"""

import sys
import json
import sqlite3
import os
from datetime import datetime

DB_PATH = os.path.expanduser('~/.claude/dashboard.db')


def get_project(cwd):
    home = os.path.expanduser('~')
    if cwd == home:
        return 'home'
    rel = cwd.replace(home + '/', '')
    parts = rel.split('/')
    return parts[-1] if parts else 'unknown'


def get_speaker(cwd, transcript_path):
    home = os.path.expanduser('~')
    if cwd == home:
        return '太极'
    try:
        with open(transcript_path, 'r') as f:
            lines = f.readlines()
        for line in reversed(lines[-100:]):
            try:
                data = json.loads(line.strip())
                model = data.get('message', {}).get('model', '') or data.get('model', '')
                if 'opus' in model:
                    return '黑丝'
                elif 'sonnet' in model:
                    return '白纱'
            except Exception:
                continue
    except Exception:
        pass
    return '未知'


def get_last_text_content(transcript_path):
    """从 JSONL 提取最后一条 assistant 消息的纯文字，跳过工具调用"""
    try:
        with open(transcript_path, 'r') as f:
            lines = f.readlines()
        for line in reversed(lines):
            try:
                d = json.loads(line.strip())
                if d.get('type') != 'assistant':
                    continue
                blocks = d.get('message', {}).get('content', [])
                parts = [b.get('text', '') for b in blocks if isinstance(b, dict) and b.get('type') == 'text']
                text = '\n'.join(parts).strip()
                if text:
                    return text
            except Exception:
                continue
    except Exception:
        pass
    return ''


def write_message(conn, speaker, content, project, session_id):
    now = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    conn.execute(
        'INSERT INTO messages (time, speaker, content, project, session_id) VALUES (?, ?, ?, ?, ?)',
        (now, speaker, content, project, session_id)
    )
    conn.commit()


def main():
    try:
        data = json.load(sys.stdin)
    except Exception:
        sys.exit(0)

    event = data.get('hook_event_name', '')
    session_id = data.get('session_id', '')
    cwd = data.get('cwd', os.getcwd())

    # 太极（home）频道不写入，上层对话不对两仪开放
    if cwd == os.path.expanduser('~'):
        sys.exit(0)

    project = get_project(cwd)

    conn = sqlite3.connect(DB_PATH)

    if event == 'Stop':
        transcript_path = data.get('transcript_path', '')
        speaker = get_speaker(cwd, transcript_path)
        # 从 JSONL 提取最后一条 assistant 消息的纯文字块，跳过工具调用
        content = get_last_text_content(transcript_path)
        if content:
            write_message(conn, speaker, content, project, session_id)

    elif event == 'UserPromptSubmit':
        content = data.get('prompt', '').strip()
        if content:
            write_message(conn, '混沌', content, project, session_id)

    conn.close()


if __name__ == '__main__':
    main()
