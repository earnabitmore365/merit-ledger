def load_config():
    """从 .env 读取 BitMEX API 配置"""
    env_path = os.path.join(os.path.dirname(__file__), '.env')
    load_dotenv(env_path)

    api_key = os.getenv('BITMEX_API_KEY')
    api_secret = os.getenv('BITMEX_API_SECRET')
    testnet = os.getenv('BITMEX_TESTNET', 'false').lower() == 'true'

    if not api_key or not api_secret:
        print("错误: .env 里没有 BITMEX_API_KEY / BITMEX_API_SECRET")
        sys.exit(1)

    return {
        'api_key': api_key,
        'api_secret': api_secret,
        'testnet': testnet,
        'default_leverage': 10,
    }


def reconcile_positions(adapter, coin: str):
    """启动时从 BitMEX 拉真实持仓，对账

    Returns:
        tuple: (position, entry_price) — 如果有持仓则返回方向和开仓价
    """
    pos = adapter.get_position(coin)
    if pos and pos.size > 0:
        direction = 'BUY' if pos.side == 'LONG' else 'SELL'
        print(f"  已有持仓: {direction} {coin} @ ${pos.entry_price:.2f}"
              f"  数量={pos.size}  未实现盈亏=${pos.unrealized_pnl:.4f}")
        return direction, pos.entry_price
    else:
        print(f"  无 {coin} 持仓")
        return 'NO_POSITION', 0.0


