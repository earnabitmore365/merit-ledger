#!/usr/bin/env python3
"""
MirrorStrategy v2.1 — SMA(200) 轴翻转，不翻信号

v2.1 核心改动（Grok+Gemini+白纱 联合拍板 2026-03-17）：
- 翻转轴从 max_price 改为 SMA(200)：mirrored = 2 × SMA(200) - price
  解决了 max_price 在实盘漂移导致指标重绘的致命问题
- 不翻转信号：翻转K线下 BUY = 真实 BUY（对齐回测行为）
"""

from typing import Dict, List
from core.strategy.base import Strategy, Signal, TradingSignal


class MirrorStrategy(Strategy):
    """Mirror v2.1 策略包装器

    包装任意策略，用 SMA(200) 翻转 OHLCV 数据后喂给策略。
    信号不翻转——翻转K线下的均值回归 = 真实趋势跟踪。
    """

    def __init__(self, inner_strategy: Strategy, interval: str = '1m'):
        super().__init__(inner_strategy.name + '_mirror')
        self._inner = inner_strategy
        self._interval = interval

    @property
    def name(self) -> str:
        return self._inner.name + '_mirror'

    @name.setter
    def name(self, value):
        pass  # 忽略外部设置，name 由 inner 决定

    @property
    def current_idx(self):
        return getattr(self._inner, 'current_idx', 0)

    @current_idx.setter
    def current_idx(self, value):
        self._inner.current_idx = value

    def _mirror_klines(self, klines: List[Dict]) -> List[Dict]:
        """v2.1 SMA(200) 翻转

        mirror_axis = SMA(200) of close prices
        mirrored_price = 2 × SMA(200) - price
        high/low 互换（翻转后大小关系反转）
        """
        if not klines:
            return klines

        # 计算 SMA(200) 作为翻转轴
        closes = [k['close'] for k in klines]
        period = min(200, len(closes))
        sma200 = sum(closes[-period:]) / period

        mirrored = []
        for k in klines:
            m = dict(k)
            m['open'] = 2 * sma200 - k['open']
            m['close'] = 2 * sma200 - k['close']
            m['high'] = 2 * sma200 - k['low']    # swap
            m['low'] = 2 * sma200 - k['high']    # swap
            mirrored.append(m)
        return mirrored

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        """翻转K线 → init_cache(:memory:) → 跑策略 → 直接返回信号（不翻转）"""
        if not klines:
            return TradingSignal(signal=Signal.HOLD, coin=coin)

        # 1. SMA(200) 翻转K线
        mirrored = self._mirror_klines(klines)

        # 2. 用翻转数据初始化 indicator_cache（内存模式，不污染文件缓存）
        from core.indicator_cache import init_cache
        init_cache(coin, self._interval, mirrored, db_path=':memory:')

        # 3. 设置 current_idx
        self._inner.current_idx = len(mirrored) - 1

        # 4. 跑策略，信号不翻转（v2.1: mirror K线下 BUY = 真实 BUY）
        return self._inner.generate_signal(coin, mirrored)
