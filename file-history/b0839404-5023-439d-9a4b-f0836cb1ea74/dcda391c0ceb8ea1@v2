#!/usr/bin/env python3
"""
哨兵营无限循环 — 持续进化 4 方向兵王
@see lab/README.md#architecture — 架构约束（指标统一调用 indicator_cache）

用法:
  cd lab/sentinel_camp
  python3 sentinel_evolve.py                    # 默认参数
  python3 sentinel_evolve.py --sample 10        # 10x 子采样
  python3 sentinel_evolve.py --pop 300 --gen 150

功能:
  - 自动循环: 每轮训练 4 个方向，跑完自动开下一轮
  - 兵王更新: 测试集 F1 超过当前兵王则替换
  - 进度日志: 每轮结果追加到 forever_log.jsonl
  - 优雅停止: 创建 STOP 文件 或 Ctrl+C

停止方式:
  touch lab/sentinel_camp/STOP
  Ctrl+C
"""
import sys
import os
import json
import time
import random
import argparse
import traceback
import numpy as np
import importlib
import importlib.util

_THIS_DIR = os.path.dirname(os.path.abspath(__file__))
_GP_DIR = os.path.join(_THIS_DIR, '..', 'gp_engine')
if _GP_DIR not in sys.path:
    sys.path.insert(0, _GP_DIR)
import tree as tree_mod
import blocks as blocks_mod
blocks_mod.enable_param_indicators(False)  # 哨兵营不用参数化指标

# 显式从文件加载，避免与 gp_engine 同名模块冲突
def _load_local(name):
    spec = importlib.util.spec_from_file_location(name, os.path.join(_THIS_DIR, f'{name}.py'))
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return mod

_data_loader = _load_local('data_loader')
_evaluator = _load_local('evaluator')
_engine = _load_local('engine')

load_all_coins = _data_loader.load_all_coins
sentinel_fitness = _evaluator.sentinel_fitness
evolve = _engine.evolve

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
CHAMPION_DIR = os.path.join(BASE_DIR, 'champions')
RESULTS_DIR = os.path.join(BASE_DIR, 'results')
LOG_FILE = os.path.join(RESULTS_DIR, 'forever_log.jsonl')
STOP_FILE = os.path.join(BASE_DIR, 'STOP')
HALL_OF_FAME_FILE = os.path.join(RESULTS_DIR, 'hall_of_fame.json')
ROUND_STATE_FILE = os.path.join(RESULTS_DIR, 'round_state.json')

HALL_OF_FAME_SIZE = 20   # 每个方向最多保留精英数
INDICATOR_COOLDOWN_ROUNDS = 2  # 冠军指标冷却轮数


def extract_indicators(node):
    """从树中提取所有使用的技术指标名（不含 close/volume/const）"""
    used = set()
    if node.kind == 'terminal' and node.name not in ('const', 'close', 'volume'):
        used.add(node.name)
    for child in node.children:
        used |= extract_indicators(child)
    return used

# v2: 叠加定义 — 转折点检测范围扩大（盘整+初牛/初熊）
TRANSITIONS = {
    '偏多检测': {'target': ['初牛', '盘整'], 'task_type': 'transition'},
    '牛市确认': {'target': '牛',              'task_type': 'confirm'},
    '偏空检测': {'target': ['初熊', '盘整'], 'task_type': 'transition'},
    '熊市确认': {'target': '熊',              'task_type': 'confirm'},
}


def load_champion(name):
    """加载已有兵王"""
    path = os.path.join(CHAMPION_DIR, f'{name}.json')
    if os.path.exists(path):
        with open(path) as f:
            data = json.load(f)
        return data.get('test_f1', 0), data
    return 0, None


def save_champion(name, tree, result, round_num, timestamp):
    """保存兵王"""
    os.makedirs(CHAMPION_DIR, exist_ok=True)
    path = os.path.join(CHAMPION_DIR, f'{name}.json')
    data = {
        'direction': name,
        'target_regime': TRANSITIONS[name]['target'],
        'round': round_num,
        'timestamp': timestamp,
        'formula': tree_mod.to_formula(tree),
        'tree': tree_mod.serialize(tree),
        'tree_size': tree_mod.size(tree),
        'tree_depth': tree_mod.depth(tree),
        'test_f1': result.get('f1', 0),
        'test_precision': result.get('precision', 0),
        'test_recall': result.get('recall', 0),
        'test_n_signals': result.get('n_signals', 0),
    }
    with open(path, 'w') as f:
        json.dump(data, f, indent=2, ensure_ascii=False)
    return path


def append_log(entry):
    """追加日志"""
    os.makedirs(RESULTS_DIR, exist_ok=True)
    with open(LOG_FILE, 'a') as f:
        f.write(json.dumps(entry, ensure_ascii=False) + '\n')


# === 精英库（按方向分开） ===

def load_hall_of_fame():
    """加载精英库，返回 {方向名: [entries]}"""
    hall = {name: [] for name in TRANSITIONS}

    # 先从现有兵王加载（已有的好基因不丢）
    for name in TRANSITIONS:
        f1, data = load_champion(name)
        if data and 'tree' in data:
            tree = tree_mod.deserialize(data['tree'])
            hall[name].append({
                'tree': tree,
                'test_f1': f1,
                'train_f1': 0,
                'round': data.get('round', 0),
                'formula': data.get('formula', ''),
            })

    # 再从精英库文件加载
    if os.path.exists(HALL_OF_FAME_FILE):
        try:
            with open(HALL_OF_FAME_FILE) as f:
                saved = json.load(f)
            for name, entries in saved.items():
                if name not in hall:
                    continue
                existing_formulas = {e['formula'] for e in hall[name]}
                for entry in entries:
                    if entry['formula'] not in existing_formulas:
                        tree = tree_mod.deserialize(entry['tree'])
                        hall[name].append({
                            'tree': tree,
                            'test_f1': entry['test_f1'],
                            'train_f1': entry.get('train_f1', 0),
                            'round': entry['round'],
                            'formula': entry['formula'],
                        })
        except Exception as e:
            print(f"  精英库文件加载失败: {e}")

    # 排序+截断
    for name in hall:
        hall[name].sort(key=lambda x: x['train_f1'], reverse=True)
        hall[name] = hall[name][:HALL_OF_FAME_SIZE]

    return hall


def refresh_hall_of_fame(hall, train_data, train_labels):
    """用当前 fitness 重新评估精英库所有个体，淘汰过时的"""
    for name, trans_cfg in TRANSITIONS.items():
        regime = trans_cfg['target']
        task_type = trans_cfg['task_type']
        for entry in hall[name]:
            _, result = sentinel_fitness(
                entry['tree'], train_data, train_labels, regime,
                min_signals=30, parsimony_coeff=0.005,
                task_type=task_type,
            )
            entry['train_f1'] = result.get('f1', 0)
        hall[name].sort(key=lambda x: x['train_f1'], reverse=True)
        hall[name] = hall[name][:HALL_OF_FAME_SIZE]
    return hall


def save_hall_of_fame(hall):
    """保存精英库到文件"""
    os.makedirs(RESULTS_DIR, exist_ok=True)
    data = {}
    for name, entries in hall.items():
        data[name] = [{
            'tree': tree_mod.serialize(e['tree']),
            'test_f1': e['test_f1'],
            'train_f1': e.get('train_f1', 0),
            'round': e['round'],
            'formula': e['formula'],
        } for e in entries]
    tmp = HALL_OF_FAME_FILE + '.tmp'
    with open(tmp, 'w') as f:
        json.dump(data, f, separators=(',', ':'))
    os.replace(tmp, HALL_OF_FAME_FILE)


def update_hall_of_fame(hall, name, tree, train_f1, test_f1, round_num):
    """将本轮结果加入对应方向的精英库"""
    formula = tree_mod.to_formula(tree)
    entries = hall.get(name, [])

    # 去重
    for entry in entries:
        if entry['formula'] == formula:
            if test_f1 > entry['test_f1']:
                entry['test_f1'] = test_f1
                entry['train_f1'] = train_f1
                entry['round'] = round_num
            return

    entries.append({
        'tree': tree,
        'test_f1': test_f1,
        'train_f1': train_f1,
        'round': round_num,
        'formula': formula,
    })

    entries.sort(key=lambda x: x['train_f1'], reverse=True)
    hall[name] = entries[:HALL_OF_FAME_SIZE]


def main():
    parser = argparse.ArgumentParser(description='哨兵营无限循环')
    parser.add_argument('--pop', type=int, default=200, help='种群大小 (default: 200)')
    parser.add_argument('--gen', type=int, default=100, help='每轮代数 (default: 100)')
    parser.add_argument('--sample', type=int, default=5, help='子采样 (default: 5)')
    parser.add_argument('--no-mirror', action='store_true', help='不使用镜像数据')
    parser.add_argument('--no-cache', action='store_true', help='强制重新计算指标（不用缓存）')
    parser.add_argument('--rounds', type=int, default=0, help='跑几轮后停止（0=无限循环）')
    parser.add_argument('--coins', nargs='+', default=None, help='指定币种（默认全部）')
    args = parser.parse_args()

    print("=" * 60)
    print("  哨兵营 — 无限循环模式")
    print("  停止: touch STOP 或 Ctrl+C")
    print("=" * 60)
    print(f"  种群: {args.pop} | 代数: {args.gen} | 子采样: {args.sample}x")
    print()

    # 数据只加载一次
    coins = args.coins if args.coins else _data_loader.discover_coins()
    print(f"加载数据（{len(coins)}币种 × 1m × 镜像）...")
    train_data, train_labels, test_data, test_labels = load_all_coins(
        sample=args.sample,
        mirror=not args.no_mirror,
        use_cache=not args.no_cache,
        coins=coins,
    )

    # Regime 分布
    print(f"\n训练集 regime 分布:")
    for regime in ['牛', '初牛', '盘整', '初熊', '熊']:
        n = int(np.sum(train_labels == regime))
        print(f"  {regime}: {n:,} ({n/len(train_labels):.1%})")
    # 叠加分布
    n_bullish = int(np.sum((train_labels == '初牛') | (train_labels == '盘整')))
    n_bearish = int(np.sum((train_labels == '初熊') | (train_labels == '盘整')))
    print(f"  偏多(初牛+盘整): {n_bullish:,} ({n_bullish/len(train_labels):.1%})")
    print(f"  偏空(初熊+盘整): {n_bearish:,} ({n_bearish/len(train_labels):.1%})")

    # 加载已有兵王
    print(f"\n当前兵王:")
    champion_f1 = {}
    for name in TRANSITIONS:
        f1, data = load_champion(name)
        champion_f1[name] = f1
        if data:
            print(f"  {name}: F1={f1:.3f} | {data.get('formula', '?')}")
        else:
            print(f"  {name}: (空缺)")

    # 加载精英库 + 用当前 fitness 重新评估
    hall_of_fame = load_hall_of_fame()
    hof_count = sum(len(v) for v in hall_of_fame.values())
    if hof_count > 0:
        print(f"\n精英库: {hof_count} 个（重新评估中...）")
        hall_of_fame = refresh_hall_of_fame(hall_of_fame, train_data, train_labels)
        save_hall_of_fame(hall_of_fame)
        hof_count = sum(len(v) for v in hall_of_fame.values())
        print(f"精英库重新评估完成: {hof_count} 个")
        for name in TRANSITIONS:
            n = len(hall_of_fame[name])
            if n > 0:
                best = hall_of_fame[name][0]
                print(f"  {name}: {n}个 (最佳 F1={best['train_f1']:.3f})")
            else:
                print(f"  {name}: 空")
    else:
        print(f"\n精英库: 空（首次运行）")

    # 确定起始轮次
    round_num = 0
    if os.path.exists(LOG_FILE):
        with open(LOG_FILE) as f:
            round_num = sum(1 for _ in f)
        print(f"\n  从第 {round_num + 1} 轮继续（已有 {round_num} 轮日志）")

    # 清除旧 STOP 文件
    if os.path.exists(STOP_FILE):
        os.remove(STOP_FILE)

    upgrades_total = 0

    # 指标冷却追踪 {indicator_name: rounds_remaining}
    indicator_cooldown = {}

    # 检测中断的轮次（断点续传）
    interrupted = None
    if os.path.exists(ROUND_STATE_FILE):
        try:
            with open(ROUND_STATE_FILE) as f:
                interrupted = json.load(f)
            completed = interrupted.get('completed', {})
            print(f"\n  检测到中断的第 {interrupted['round']} 轮，"
                  f"已完成 {len(completed)}/4 方向，将恢复...")
        except Exception:
            os.remove(ROUND_STATE_FILE)

    try:
        while True:
            if interrupted:
                round_num = interrupted['round']
                seed = interrupted['seed']
                timestamp = interrupted.get('timestamp', time.strftime('%Y%m%d_%H%M%S'))
                completed_dirs = interrupted.get('completed', {})
                round_log = interrupted.get('round_log', {
                    'round': round_num, 'timestamp': timestamp,
                    'seed': seed, 'directions': {},
                })
                # 恢复 round_log 中已完成的方向
                round_log['directions'].update(completed_dirs)
                interrupted = None
                print(f"\n{'─'*60}")
                print(f"  第 {round_num} 轮（恢复中断）| seed={seed}")
                print(f"  已完成: {', '.join(completed_dirs.keys()) or '无'}")
                print(f"{'─'*60}")
            else:
                round_num += 1
                seed = random.randint(0, 2**31)
                timestamp = time.strftime('%Y%m%d_%H%M%S')
                completed_dirs = {}
                round_log = {
                    'round': round_num, 'timestamp': timestamp,
                    'seed': seed, 'directions': {},
                }
                print(f"\n{'─'*60}")
                print(f"  第 {round_num} 轮 | seed={seed} | {timestamp}")
                print(f"{'─'*60}")

            random.seed(seed)
            np.random.seed(seed % (2**32))
            t_round_start = time.time()

            # 指标冷却: 递减计数器，过期的解冻
            expired = [k for k, v in indicator_cooldown.items() if v <= 0]
            for k in expired:
                del indicator_cooldown[k]
            cooled_set = set(indicator_cooldown.keys())
            blocks_mod.set_cooled_indicators(cooled_set)
            if cooled_set:
                print(f"  冷却中: {', '.join(sorted(cooled_set))}")

            try:
                for name, trans_cfg in TRANSITIONS.items():
                    regime = trans_cfg['target']
                    task_type = trans_cfg['task_type']
                    regime_label = regime if isinstance(regime, str) else '+'.join(regime)

                    # 跳过已完成的方向（断点续传）
                    if name in completed_dirs:
                        print(f"\n  --- {name} ({regime_label}) --- 已完成，跳过")
                        continue

                    t_start = time.time()
                    print(f"\n  --- {name} ({regime_label}) [{task_type}] ---")

                    # 保存轮次状态（断点续传用）
                    os.makedirs(RESULTS_DIR, exist_ok=True)
                    with open(ROUND_STATE_FILE, 'w') as f:
                        json.dump({
                            'round': round_num, 'seed': seed,
                            'timestamp': timestamp,
                            'completed': completed_dirs,
                            'round_log': round_log,
                        }, f, ensure_ascii=False)

                    # 精英种子
                    seed_elites = None
                    if hall_of_fame.get(name):
                        seed_elites = [
                            e['tree'] for e in hall_of_fame[name]
                        ]

                    # 用 lambda 包装 fitness，注入 task_type
                    def _fitness_fn(root, data, labels, target,
                                    min_signals=30, parsimony_coeff=0.005,
                                    _tt=task_type):
                        return sentinel_fitness(root, data, labels, target,
                                               min_signals=min_signals,
                                               parsimony_coeff=parsimony_coeff,
                                               task_type=_tt)

                    best_tree, best_score, history = evolve(
                        train_data, train_labels, regime, _fitness_fn,
                        population_size=args.pop,
                        generations=args.gen,
                        verbose=False,
                        seed_elites=seed_elites,
                        checkpoint_name=name,
                        resume=True,
                    )

                    # 测试集评估
                    test_score, test_result = sentinel_fitness(
                        best_tree, test_data, test_labels, regime,
                        min_signals=10, parsimony_coeff=0,
                        task_type=task_type,
                    )

                    elapsed = time.time() - t_start
                    test_f1 = test_result.get('f1', 0)
                    train_f1 = history[-1]['f1'] if history else 0

                    # 与当前兵王比较
                    upgraded = False
                    if test_f1 > champion_f1[name]:
                        old_f1 = champion_f1[name]
                        champion_f1[name] = test_f1
                        save_champion(name, best_tree, test_result, round_num, timestamp)
                        upgraded = True
                        upgrades_total += 1
                        print(f"  🏆 新兵王! F1: {old_f1:.3f} → {test_f1:.3f} | "
                              f"P={test_result.get('precision', 0):.3f} "
                              f"R={test_result.get('recall', 0):.3f} | {elapsed:.0f}s")
                    else:
                        print(f"  F1={test_f1:.3f} (兵王={champion_f1[name]:.3f}) | "
                              f"P={test_result.get('precision', 0):.3f} "
                              f"R={test_result.get('recall', 0):.3f} | {elapsed:.0f}s")

                    dir_result = {
                        'train_f1': round(train_f1, 4),
                        'test_f1': round(test_f1, 4),
                        'test_precision': round(test_result.get('precision', 0), 4),
                        'test_recall': round(test_result.get('recall', 0), 4),
                        'test_n_signals': test_result.get('n_signals', 0),
                        'formula': tree_mod.to_formula(best_tree),
                        'tree_size': tree_mod.size(best_tree),
                        'elapsed_sec': round(elapsed, 1),
                        'upgraded': upgraded,
                    }
                    round_log['directions'][name] = dir_result
                    completed_dirs[name] = dir_result

                    # 每个方向完成后立即存盘
                    update_hall_of_fame(
                        hall_of_fame, name, best_tree, train_f1, test_f1, round_num
                    )
                    save_hall_of_fame(hall_of_fame)

                    # 更新 round_state（记录已完成方向）
                    with open(ROUND_STATE_FILE, 'w') as f:
                        json.dump({
                            'round': round_num, 'seed': seed,
                            'timestamp': timestamp,
                            'completed': completed_dirs,
                            'round_log': round_log,
                        }, f, ensure_ascii=False)

                round_elapsed = time.time() - t_round_start
                round_log['elapsed_sec'] = round(round_elapsed, 1)
                append_log(round_log)

                # 指标冷却: 收集本轮4方向冠军用过的指标，冷却N轮
                round_used_indicators = set()
                for name in TRANSITIONS:
                    _, champ_data = load_champion(name)
                    if champ_data and 'tree' in champ_data:
                        champ_tree = tree_mod.deserialize(champ_data['tree'])
                        round_used_indicators |= extract_indicators(champ_tree)
                for ind in round_used_indicators:
                    indicator_cooldown[ind] = INDICATOR_COOLDOWN_ROUNDS
                # 递减其他已冷却指标
                for ind in list(indicator_cooldown.keys()):
                    if ind not in round_used_indicators:
                        indicator_cooldown[ind] -= 1
                if round_used_indicators:
                    print(f"  新冷却: {', '.join(sorted(round_used_indicators))}")

                # 轮次完成，清除 round_state
                if os.path.exists(ROUND_STATE_FILE):
                    os.remove(ROUND_STATE_FILE)

                hof_count = sum(len(v) for v in hall_of_fame.values())
                print(f"\n  轮耗时: {round_elapsed:.0f}s | 累计升级: {upgrades_total}/{round_num*4} "
                      f"| 精英库: {hof_count}个")
                print(f"  兵王: " + " | ".join(
                    f"{n}={champion_f1[n]:.3f}" for n in TRANSITIONS
                ))

            except Exception as e:
                round_elapsed = time.time() - t_round_start
                print(f"\n  ⚠️ 第 {round_num} 轮异常: {e}")
                traceback.print_exc()
                round_log['error'] = str(e)
                round_log['elapsed_sec'] = round(round_elapsed, 1)
                append_log(round_log)
                print(f"  已记录错误，继续下一轮...\n")

            # 停止检查
            if os.path.exists(STOP_FILE):
                print("\n检测到 STOP 文件，停止。")
                os.remove(STOP_FILE)
                break
            if args.rounds > 0 and round_num >= args.rounds:
                print(f"\n已完成 {args.rounds} 轮，停止。")
                break

    except KeyboardInterrupt:
        print(f"\n\nCtrl+C 停止。完成 {round_num} 轮，升级 {upgrades_total} 次。")

    print(f"\n{'='*60}")
    print(f"  总计: {round_num} 轮, {upgrades_total} 次兵王升级")
    print(f"  最终兵王:")
    for name in TRANSITIONS:
        f1, data = load_champion(name)
        if data:
            print(f"    {name}: F1={f1:.3f} | {data.get('formula', '?')}")
        else:
            print(f"    {name}: (空缺)")
    print(f"  日志: {LOG_FILE}")
    print(f"  兵王: {CHAMPION_DIR}/")
    print(f"{'='*60}")


if __name__ == '__main__':
    main()
