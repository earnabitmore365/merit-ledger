"""
哨兵进化引擎 — 无方向版

与 gp_engine/engine.py 的区别:
  - 个体 = 树（无 long/short 方向）
  - 适应度 = F1 score（检测 regime）
  - 接受外部 fitness_fn，不硬编码
"""
import random
import copy
import time
import json
import os
import numpy as np
import sys

_GP_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), '..', 'gp_engine')
if _GP_DIR not in sys.path:
    sys.path.insert(0, _GP_DIR)
import tree as tree_mod


CHECKPOINT_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'results')
CHECKPOINT_EVERY = 10


# === 断点存档 ===

def _ckpt_path(checkpoint_name):
    """断点文件路径"""
    name = checkpoint_name or 'default'
    return os.path.join(CHECKPOINT_DIR, f'ckpt_{name}.json')


def _save_checkpoint(path, gen, population, global_best, global_best_score, history):
    """保存断点"""
    data = {
        'gen': gen,
        'population': [tree_mod.serialize(t) for t in population],
        'global_best': tree_mod.serialize(global_best) if global_best else None,
        'global_best_score': global_best_score,
        'history': history,
    }
    tmp = path + '.tmp'
    with open(tmp, 'w') as f:
        json.dump(data, f, separators=(',', ':'))
    os.replace(tmp, path)


def _load_checkpoint(path):
    """读断点，返回 (gen, population, global_best, global_best_score, history) 或 None"""
    if not os.path.exists(path):
        return None
    try:
        with open(path) as f:
            data = json.load(f)
        population = [tree_mod.deserialize(d) for d in data['population']]
        best = tree_mod.deserialize(data['global_best']) if data['global_best'] else None
        return data['gen'], population, best, data['global_best_score'], data['history']
    except Exception as e:
        print(f"  断点文件损坏，忽略: {e}")
        return None


def evolve(data, regime_labels, target_regime, fitness_fn,
           population_size=200, generations=100,
           tournament_size=5, crossover_prob=0.7,
           mutation_prob=0.2, elitism=5,
           parsimony_coeff=0.001, min_signals=30,
           verbose=True, checkpoint_name=None,
           seed_elites=None, resume=False):
    """
    进化哨兵树。

    Args:
        data: dict 归一化指标
        regime_labels: np.array regime标签
        target_regime: str 目标regime
        fitness_fn: callable(root, data, labels, target, ...) → (score, result)
        population_size: 种群大小
        generations: 代数
        checkpoint_name: 断点文件名（如 '红变黄'）
        seed_elites: 精英种子（树列表）
        resume: 是否从断点恢复

    Returns:
        best_tree, best_score, history
    """
    os.makedirs(CHECKPOINT_DIR, exist_ok=True)
    ckpt_file = _ckpt_path(checkpoint_name)

    start_gen = 0
    population = None
    global_best = None
    global_best_score = -float('inf')
    history = []

    # 断点恢复
    if resume:
        ckpt = _load_checkpoint(ckpt_file)
        if ckpt:
            start_gen, population, global_best, global_best_score, history = ckpt
            start_gen += 1
            if verbose:
                print(f"  从断点恢复: 第 {start_gen} 代，种群 {len(population)} 个")

    # 初始化种群（纯树，无方向）
    if population is None:
        if seed_elites:
            population = [copy.deepcopy(t) for t in seed_elites[:population_size]]
            remaining = population_size - len(population)
            if remaining > 0:
                population.extend([tree_mod.random_tree() for _ in range(remaining)])
            if verbose:
                print(f"  种群: {len(seed_elites)} 精英 + {remaining} 随机")
        else:
            population = [tree_mod.random_tree() for _ in range(population_size)]

    t_start = time.time()

    for gen in range(start_gen, generations):
        t_gen = time.time()

        # 评估
        scores = []
        results = []
        for tree in population:
            score, result = fitness_fn(
                tree, data, regime_labels, target_regime,
                min_signals=min_signals,
                parsimony_coeff=parsimony_coeff,
            )
            scores.append(score)
            results.append(result)

        scores_arr = np.array(scores)

        # 记录最优
        best_idx = np.argmax(scores_arr)
        best_score = scores_arr[best_idx]
        best_result = results[best_idx]

        if best_score > global_best_score:
            global_best_score = best_score
            global_best = copy.deepcopy(population[best_idx])

        valid_count = int(np.sum(scores_arr > -999))
        avg_score = float(np.mean(scores_arr[scores_arr > -999])) if valid_count > 0 else -999.0
        gen_time = time.time() - t_gen

        entry = {
            'gen': gen,
            'best_score': float(best_score),
            'avg_score': avg_score,
            'best_formula': tree_mod.to_formula(population[best_idx]),
            'best_size': tree_mod.size(population[best_idx]),
            'f1': best_result.get('f1', 0),
            'precision': best_result.get('precision', 0),
            'recall': best_result.get('recall', 0),
            'n_signals': best_result.get('n_signals', 0),
            'valid_trees': valid_count,
            'time_sec': gen_time,
        }
        history.append(entry)

        if verbose and (gen % 10 == 0 or gen == generations - 1):
            print(f"  Gen {gen:>3d}/{generations} | "
                  f"F1={best_result.get('f1', 0):.3f} | "
                  f"P={best_result.get('precision', 0):.3f} "
                  f"R={best_result.get('recall', 0):.3f} | "
                  f"有效={valid_count:>3d}/{population_size} | "
                  f"信号={best_result.get('n_signals', 0):>6d} | "
                  f"{gen_time:.1f}s")

        # 断点存档
        if gen % CHECKPOINT_EVERY == 0 or gen == generations - 1:
            _save_checkpoint(ckpt_file, gen, population, global_best,
                            global_best_score, history)

        # 繁殖下一代
        new_pop = []

        # 精英保留
        elite_indices = np.argsort(scores_arr)[-elitism:]
        for idx in elite_indices:
            new_pop.append(copy.deepcopy(population[idx]))

        # 填满
        while len(new_pop) < population_size:
            r = random.random()

            if r < crossover_prob:
                p1 = _tournament_select(population, scores_arr, tournament_size)
                p2 = _tournament_select(population, scores_arr, tournament_size)
                c1, c2 = tree_mod.crossover(p1, p2)
                new_pop.append(c1)
                if len(new_pop) < population_size:
                    new_pop.append(c2)

            elif r < crossover_prob + mutation_prob:
                parent = _tournament_select(population, scores_arr, tournament_size)
                child = tree_mod.mutate(parent)
                new_pop.append(child)

            else:
                parent = _tournament_select(population, scores_arr, tournament_size)
                new_pop.append(copy.deepcopy(parent))

        population = new_pop[:population_size]

    total_time = time.time() - t_start

    # 进化完成，清除断点
    if os.path.exists(ckpt_file):
        os.remove(ckpt_file)

    if verbose:
        print(f"\n  进化完成! {total_time:.1f}s")
        if global_best:
            print(f"  最优 F1: {global_best_score:+.4f}")
            print(f"  规则: {tree_mod.to_formula(global_best)}")

    return global_best, global_best_score, history


def _tournament_select(population, scores, k):
    """锦标赛选择"""
    indices = random.sample(range(len(population)), min(k, len(population)))
    best_idx = max(indices, key=lambda i: scores[i])
    return population[best_idx]
