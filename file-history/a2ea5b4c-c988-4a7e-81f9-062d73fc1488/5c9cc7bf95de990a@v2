#!/usr/bin/env python3
"""
Gate v4 管线 — 一键串联执行
流程: 初考(复用v3) → 专考(6维度) → 组考(无WF) → MC

与v3的区别:
- 去掉 WF (Walk-Forward)
- 专考用 regime_fact_labels (已知事实) 替代 regime_at_open (ADX推断)
- 6维度: 全程/牛/熊/盘整/初牛/初熊

依赖: 必须先跑 regime_fact_timeline.py 生成 regime_fact_labels 表
"""
import sqlite3
import os
import time
import shutil

# 路径
DB_PATH = os.path.join(os.path.dirname(__file__), 'reports', 'seed_v3.db')
V3_REPORT = os.path.join(os.path.dirname(__file__), 'results', 'gate_v3', 'gate_v3_report.db')
V4_REPORT = os.path.join(os.path.dirname(__file__), 'results', 'gate_v4', 'gate_v4_report.db')

INTERVALS = ['1m', '5m', '15m', '30m', '1h', '2h', '4h', '8h', '12h', '1d']


def check_prerequisites():
    """检查前置条件"""
    # 1. seed_v3.db 必须存在
    if not os.path.exists(DB_PATH):
        raise FileNotFoundError(f"种子库不存在: {DB_PATH}")

    # 2. regime_fact_labels 表必须存在
    conn = sqlite3.connect(DB_PATH)
    table_check = conn.execute(
        "SELECT name FROM sqlite_master WHERE type='table' AND name='regime_fact_labels'"
    ).fetchone()
    if not table_check:
        conn.close()
        raise RuntimeError("regime_fact_labels 表不存在! 请先运行 regime_fact_timeline.py")

    count = conn.execute("SELECT COUNT(*) FROM regime_fact_labels").fetchone()[0]
    conn.close()
    print(f"✅ regime_fact_labels: {count:,} 条")

    return count


def copy_gate1_from_v3():
    """从 v3 报告复制 gate1 表（初考不变）"""
    if not os.path.exists(V3_REPORT):
        raise FileNotFoundError(f"v3报告不存在: {V3_REPORT}\n请先运行 Gate v3 管线")

    os.makedirs(os.path.dirname(V4_REPORT), exist_ok=True)

    # 如果v4报告已存在，删除重建
    if os.path.exists(V4_REPORT):
        os.remove(V4_REPORT)

    v3 = sqlite3.connect(V3_REPORT)
    v4 = sqlite3.connect(V4_REPORT)

    # 复制 gate1_summary
    v4.execute('''CREATE TABLE gate1_summary (
        interval TEXT PRIMARY KEY,
        total INTEGER, passed INTEGER, failed INTEGER,
        pass_rate REAL, threshold_min INTEGER, threshold_max INTEGER, x_value INTEGER
    )''')

    rows = v3.execute("SELECT * FROM gate1_summary").fetchall()
    v4.executemany("INSERT INTO gate1_summary VALUES (?,?,?,?,?,?,?,?)", rows)

    # 复制各周期 gate1 表
    for iv in INTERVALS:
        table = f"gate1_{iv}"
        v4.execute(f'''CREATE TABLE {table} (
            combo_id INTEGER PRIMARY KEY,
            strategy TEXT, coin TEXT, interval TEXT,
            total_trades INTEGER, klines INTEGER, threshold INTEGER,
            passed INTEGER, reason TEXT
        )''')

        rows = v3.execute(f"SELECT * FROM {table}").fetchall()
        v4.executemany(f"INSERT INTO {table} VALUES (?,?,?,?,?,?,?,?,?)", rows)

    v4.commit()

    # 打印汇总
    summary = v4.execute("SELECT SUM(passed), SUM(total) FROM gate1_summary").fetchone()
    print(f"✅ 初考: {summary[0]}/{summary[1]} 通过（从 v3 复制）")

    v3.close()
    v4.close()


def main():
    print("=" * 60)
    print("Gate v4 管线 — 已知事实 + 6维度 + 无WF")
    print("=" * 60)

    # Step 0: 检查前置条件
    print("\n[Step 0] 检查前置条件...")
    label_count = check_prerequisites()

    # Step 1: 复制 gate1
    print("\n[Step 1] 初考（门槛）— 复用 v3...")
    t0 = time.time()
    copy_gate1_from_v3()
    print(f"  耗时: {time.time()-t0:.1f}s")

    # Step 2: 专考（6维度）
    print("\n[Step 2] 专考（成绩单 6维度）...")
    t0 = time.time()
    import gate2v4_scorecard
    gate2v4_scorecard.main()
    print(f"  耗时: {time.time()-t0:.1f}s")

    # Step 3: 组考（无WF）
    print("\n[Step 3] 组考（组队，无WF）...")
    t0 = time.time()
    import gate3v4_team
    gate3v4_team.main()
    print(f"  耗时: {time.time()-t0:.1f}s")

    # Step 4: MC
    print("\n[Step 4] 照妖镜 MC...")
    t0 = time.time()
    import gate_mcv4
    gate_mcv4.main()
    print(f"  耗时: {time.time()-t0:.1f}s")

    # 最终汇总
    print("\n" + "=" * 60)
    print("Gate v4 管线完成!")
    print("=" * 60)

    rpt = sqlite3.connect(V4_REPORT)
    rpt.row_factory = sqlite3.Row

    # 打印gate_index
    print("\n报告目录:")
    for row in rpt.execute("SELECT * FROM gate_index ORDER BY table_name").fetchall():
        print(f"  {row['table_name']:>20s} | {row['record_count']:>6d} | {row['description']}")

    # 冠军列表
    champs = rpt.execute('''
        SELECT * FROM champions ORDER BY team, all_pnl DESC
    ''').fetchall()

    if champs:
        print(f"\n冠军队 ({len(champs)} 个):")
        print(f"{'队伍':>6s}  {'策略':<20s}  {'币种':<6s}  {'周期':<4s}  {'PnL(R)':>8s}  {'翻倍率':>6s}  {'d2d_p50':>8s}  {'max_dd_95%':>10s}")
        print("-" * 85)
        for c in champs:
            print(f"{c['team']:>6s}  {c['strategy']:<20s}  {c['coin']:<6s}  {c['interval']:<4s}  "
                  f"{c['all_pnl']:>+8.1f}  {c['double_rate']:>5.1f}%  {c['d2d_p50']:>8.1f}  {c['max_dd_p95']:>9.1f}%")

    rpt.close()
    print(f"\n输出: {V4_REPORT}")


if __name__ == '__main__':
    main()
