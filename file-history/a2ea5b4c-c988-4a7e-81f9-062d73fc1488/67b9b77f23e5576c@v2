#!/usr/bin/env python3
"""
照妖镜（WF + MC）— Walk-Forward 验证 + Monte Carlo 模拟
输入: seed_v3.db + gate3_short/mid/long.json
输出: gate4_wf_short/mid/long.json + gate4_mc_short/mid/long.json + champion_v3.json
"""
import json
import sqlite3
import os
import random

DB_PATH = os.path.join(os.path.dirname(__file__), 'reports', 'seed_v3.db')
OUT_DIR = os.path.join(os.path.dirname(__file__), 'results')

TEAMS = {
    'short': {'intervals': ['1m', '5m', '15m', '30m'], 'wf_segments': 5, 'wf_pass': 4},
    'mid':   {'intervals': ['1h', '2h', '4h'],         'wf_segments': 5, 'wf_pass': 4},
    'long':  {'intervals': ['8h', '12h', '1d'],        'wf_segments': 3, 'wf_pass': 2},
}

BARS_PER_DAY = {
    '1m': 1440, '5m': 288, '15m': 96, '30m': 48,
    '1h': 24, '2h': 12, '4h': 6, '8h': 3, '12h': 2, '1d': 1,
}

MC_RUNS = 100
MC_INITIAL = 500.0
MC_FRACTION = 0.02
MC_DOUBLE_TARGET = 1000.0
MC_CHAMPION_THRESHOLD = 0.50  # 翻倍率 >= 50%

MIN_TRADES_PER_SEGMENT = 5


def walk_forward(conn, combo_id, n_segments, min_pass):
    """Walk-Forward: 按交易时间顺序均分N段，每段sum(r_value)>0则通过"""
    trades = conn.execute('''
        SELECT r_value FROM paired_trades
        WHERE combo_id = ?
        ORDER BY open_candle_idx
    ''', (combo_id,)).fetchall()

    total = len(trades)
    if total < n_segments:
        return {'passed': False, 'reason': 'too_few_trades', 'total_trades': total,
                'segments': [], 'pass_count': 0, 'required': min_pass}

    # 均分
    seg_size = total // n_segments
    segments = []
    valid_count = 0
    pass_count = 0

    for i in range(n_segments):
        start = i * seg_size
        end = start + seg_size if i < n_segments - 1 else total
        seg_trades = trades[start:end]
        seg_r = sum(t['r_value'] for t in seg_trades)
        seg_count = len(seg_trades)

        if seg_count < MIN_TRADES_PER_SEGMENT:
            segments.append({
                'segment': i + 1, 'trades': seg_count,
                'r_sum': round(seg_r, 4), 'status': 'skipped',
            })
        else:
            valid_count += 1
            is_pass = seg_r > 0
            if is_pass:
                pass_count += 1
            segments.append({
                'segment': i + 1, 'trades': seg_count,
                'r_sum': round(seg_r, 4), 'status': 'pass' if is_pass else 'fail',
            })

    # 合格标准：通过段数 >= min_pass（分母是有效段数）
    effective_required = min(min_pass, valid_count)
    passed = pass_count >= effective_required and valid_count > 0

    return {
        'passed': passed,
        'total_trades': total,
        'segments': segments,
        'pass_count': pass_count,
        'valid_count': valid_count,
        'required': effective_required,
        'result': f"{pass_count}/{valid_count}",
    }


def monte_carlo(conn, combo_id, interval):
    """Monte Carlo: 打乱交易顺序100次，统计翻倍率/d2d/max_dd/爆仓率"""
    trades = conn.execute('''
        SELECT r_value, holding_bars FROM paired_trades
        WHERE combo_id = ?
    ''', (combo_id,)).fetchall()

    trade_list = [(t['r_value'], t['holding_bars']) for t in trades]
    bpd = BARS_PER_DAY.get(interval, 24)

    results = []
    for _ in range(MC_RUNS):
        random.shuffle(trade_list)
        balance = MC_INITIAL
        peak = MC_INITIAL
        max_dd = 0.0
        cumulative_days = 0.0
        days_to_double = None
        busted = False

        for r_value, holding_bars in trade_list:
            pnl = r_value * (balance * MC_FRACTION)
            balance += pnl
            cumulative_days += holding_bars / bpd

            if balance <= 0:
                busted = True
                break

            peak = max(peak, balance)
            dd = (peak - balance) / peak
            max_dd = max(max_dd, dd)

            if days_to_double is None and balance >= MC_DOUBLE_TARGET:
                days_to_double = cumulative_days

        results.append({
            'final_balance': round(balance, 2),
            'days_to_double': round(days_to_double, 1) if days_to_double else None,
            'max_dd': round(max_dd * 100, 2),
            'busted': busted,
        })

    # 统计
    doubled = [r for r in results if r['days_to_double'] is not None]
    busted_count = sum(1 for r in results if r['busted'])
    d2d_list = sorted([r['days_to_double'] for r in doubled])
    dd_list = sorted([r['max_dd'] for r in results if not r['busted']])
    bal_list = sorted([r['final_balance'] for r in results if not r['busted']])

    def percentile(lst, p):
        if not lst:
            return None
        idx = int(len(lst) * p / 100)
        idx = min(idx, len(lst) - 1)
        return lst[idx]

    return {
        'runs': MC_RUNS,
        'double_rate': round(len(doubled) / MC_RUNS * 100, 1),
        'bust_rate': round(busted_count / MC_RUNS * 100, 1),
        'd2d_p5': percentile(d2d_list, 5),
        'd2d_p50': percentile(d2d_list, 50),
        'd2d_p95': percentile(d2d_list, 95),
        'max_dd_p5': percentile(dd_list, 5),
        'max_dd_p50': percentile(dd_list, 50),
        'max_dd_p95': percentile(dd_list, 95),
        'balance_p5': percentile(bal_list, 5),
        'balance_p50': percentile(bal_list, 50),
        'balance_p95': percentile(bal_list, 95),
    }


def main():
    random.seed(42)  # 可复现
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row

    all_champions = []

    for team_name, config in TEAMS.items():
        # 读组考候选
        gate3_path = os.path.join(OUT_DIR, f'gate3_{team_name}.json')
        with open(gate3_path) as f:
            gate3 = json.load(f)

        candidates = gate3['all_candidates']
        n_seg = config['wf_segments']
        min_pass = config['wf_pass']

        print(f"\n照妖镜 {team_name}队: {len(candidates)} 个候选, WF {n_seg}段/{min_pass}通过")

        # Walk-Forward
        wf_results = []
        wf_passed = []
        for c in candidates:
            cid = c['combo_id']
            wf = walk_forward(conn, cid, n_seg, min_pass)
            entry = {
                'combo_id': cid,
                'strategy': c['strategy'],
                'coin': c['coin'],
                'interval': c['interval'],
                'all_pnl': c['all_pnl'],
                'wf': wf,
            }
            wf_results.append(entry)
            if wf['passed']:
                wf_passed.append(entry)

        print(f"  WF: {len(wf_passed)}/{len(candidates)} 通过")

        # 输出WF结果
        wf_out = os.path.join(OUT_DIR, f'gate4_wf_{team_name}.json')
        with open(wf_out, 'w') as f:
            json.dump({
                'group': team_name,
                'total': len(candidates),
                'wf_passed': len(wf_passed),
                'wf_config': {'segments': n_seg, 'required': min_pass},
                'results': wf_results,
            }, f, indent=2, ensure_ascii=False)

        # Monte Carlo（仅WF通过的）
        mc_results = []
        team_champions = []
        for entry in wf_passed:
            cid = entry['combo_id']
            iv = entry['interval']
            print(f"  MC: {entry['strategy']}/{entry['coin']}/{iv}...", end=' ', flush=True)
            mc = monte_carlo(conn, cid, iv)
            mc_entry = {
                'combo_id': cid,
                'strategy': entry['strategy'],
                'coin': entry['coin'],
                'interval': iv,
                'all_pnl': entry['all_pnl'],
                'mc': mc,
            }
            mc_results.append(mc_entry)

            is_champion = mc['double_rate'] >= MC_CHAMPION_THRESHOLD * 100
            print(f"翻倍率={mc['double_rate']}% {'✅' if is_champion else '❌'}")

            if is_champion:
                team_champions.append({
                    'combo_id': cid,
                    'strategy': entry['strategy'],
                    'coin': entry['coin'],
                    'interval': iv,
                    'group': team_name,
                    'all_pnl': entry['all_pnl'],
                    'wf_result': entry['wf']['result'],
                    'mc_double_rate': mc['double_rate'],
                    'mc_d2d_p50': mc['d2d_p50'],
                    'mc_max_dd_p95': mc['max_dd_p95'],
                    'mc_bust_rate': mc['bust_rate'],
                })

        # 输出MC结果
        mc_out = os.path.join(OUT_DIR, f'gate4_mc_{team_name}.json')
        with open(mc_out, 'w') as f:
            json.dump({
                'group': team_name,
                'wf_passed': len(wf_passed),
                'mc_champions': len(team_champions),
                'results': mc_results,
            }, f, indent=2, ensure_ascii=False)

        all_champions.extend(team_champions)
        print(f"  冠军: {len(team_champions)} 个 (翻倍率≥{MC_CHAMPION_THRESHOLD*100:.0f}%)")

    # 输出冠军汇总
    champion_path = os.path.join(OUT_DIR, 'champion_v3.json')
    with open(champion_path, 'w') as f:
        json.dump({
            'total_champions': len(all_champions),
            'by_group': {
                'short': [c for c in all_champions if c['group'] == 'short'],
                'mid': [c for c in all_champions if c['group'] == 'mid'],
                'long': [c for c in all_champions if c['group'] == 'long'],
            },
            'all': all_champions,
        }, f, indent=2, ensure_ascii=False)

    conn.close()

    print(f"\n照妖镜完成: {len(all_champions)} 个冠军")
    print(f"输出: gate4_wf/mc_short/mid/long.json + champion_v3.json")
    return all_champions


if __name__ == '__main__':
    main()
