#!/usr/bin/env python3
"""
专考（成绩单）— 给初考通过的组合出4维度成绩单
输入: seed_v3.db + gate_v3_report.db (gate1)
输出: gate_v3_report.db (gate2_{interval} × 10 表)

优化：批量SQL查询，不逐条查
"""
import sqlite3
import os

DB_PATH = os.path.join(os.path.dirname(__file__), 'reports', 'seed_v3.db')
REPORT_PATH = os.path.join(os.path.dirname(__file__), 'results', 'gate_v3', 'gate_v3_report.db')

INTERVALS = ['1m', '5m', '15m', '30m', '1h', '2h', '4h', '8h', '12h', '1d']
REGIMES = ['bull', 'bear', 'ranging']
MIN_TRADES_FOR_RANK = 10


def main():
    seed = sqlite3.connect(DB_PATH)
    seed.row_factory = sqlite3.Row
    rpt = sqlite3.connect(REPORT_PATH)
    rpt.row_factory = sqlite3.Row

    # 从 gate1 读通过的 combo_id（按周期）
    passed_by_iv = {}
    for iv in INTERVALS:
        rows = rpt.execute(f"SELECT combo_id, strategy, coin FROM gate1_{iv} WHERE passed = 1").fetchall()
        passed_by_iv[iv] = {r['combo_id']: {'strategy': r['strategy'], 'coin': r['coin']} for r in rows}

    # 建各周期的 gate2 表
    for iv in INTERVALS:
        rpt.execute(f"DROP TABLE IF EXISTS gate2_{iv}")
        rpt.execute(f'''CREATE TABLE gate2_{iv} (
            combo_id INTEGER PRIMARY KEY,
            strategy TEXT, coin TEXT, interval TEXT,
            all_pnl REAL, all_trades INTEGER, all_win_rate REAL, all_avg_r REAL, rank_all INTEGER,
            bull_pnl REAL, bull_trades INTEGER, bull_win_rate REAL, bull_avg_r REAL,
            bull_insufficient INTEGER, rank_bull INTEGER,
            bear_pnl REAL, bear_trades INTEGER, bear_win_rate REAL, bear_avg_r REAL,
            bear_insufficient INTEGER, rank_bear INTEGER,
            ranging_pnl REAL, ranging_trades INTEGER, ranging_win_rate REAL, ranging_avg_r REAL,
            ranging_insufficient INTEGER, rank_ranging INTEGER
        )''')

    # 逐周期批量查分数
    for iv in INTERVALS:
        combo_map = passed_by_iv[iv]
        combo_ids = list(combo_map.keys())
        if not combo_ids:
            print(f"专考 {iv}: 0 组，跳过")
            continue

        print(f"专考 {iv}: {len(combo_ids)} 组...", end=' ', flush=True)

        placeholders = ','.join('?' * len(combo_ids))

        # 全程统计
        all_rows = seed.execute(f'''
            SELECT combo_id,
                   SUM(r_value) as total_pnl,
                   COUNT(*) as trade_count,
                   AVG(CASE WHEN r_value > 0 THEN 1.0 ELSE 0.0 END) as win_rate,
                   AVG(r_value) as avg_r
            FROM paired_trades
            WHERE combo_id IN ({placeholders})
            GROUP BY combo_id
        ''', combo_ids).fetchall()

        scores = {}
        for r in all_rows:
            scores[r['combo_id']] = {
                'all_pnl': round(r['total_pnl'] or 0, 4),
                'all_trades': r['trade_count'] or 0,
                'all_win_rate': round(r['win_rate'] or 0, 4),
                'all_avg_r': round(r['avg_r'] or 0, 6),
            }

        # 各regime统计
        for regime in REGIMES:
            regime_rows = seed.execute(f'''
                SELECT combo_id,
                       SUM(r_value) as total_pnl,
                       COUNT(*) as trade_count,
                       AVG(CASE WHEN r_value > 0 THEN 1.0 ELSE 0.0 END) as win_rate,
                       AVG(r_value) as avg_r
                FROM paired_trades
                WHERE combo_id IN ({placeholders}) AND regime_at_open = ?
                GROUP BY combo_id
            ''', combo_ids + [regime]).fetchall()

            regime_map = {r['combo_id']: r for r in regime_rows}

            for cid in combo_ids:
                if cid not in scores:
                    continue
                r = regime_map.get(cid)
                if r:
                    trades = r['trade_count'] or 0
                    scores[cid][f'{regime}_pnl'] = round(r['total_pnl'] or 0, 4)
                    scores[cid][f'{regime}_trades'] = trades
                    scores[cid][f'{regime}_win_rate'] = round(r['win_rate'] or 0, 4)
                    scores[cid][f'{regime}_avg_r'] = round(r['avg_r'] or 0, 6)
                    scores[cid][f'{regime}_insufficient'] = 1 if trades < MIN_TRADES_FOR_RANK else 0
                else:
                    scores[cid][f'{regime}_pnl'] = 0
                    scores[cid][f'{regime}_trades'] = 0
                    scores[cid][f'{regime}_win_rate'] = 0
                    scores[cid][f'{regime}_avg_r'] = 0
                    scores[cid][f'{regime}_insufficient'] = 1

        # 排名
        scored_list = [(cid, scores[cid]) for cid in combo_ids if cid in scores]

        # 全程排名 by pnl
        scored_list.sort(key=lambda x: x[1]['all_pnl'], reverse=True)
        for i, (cid, s) in enumerate(scored_list):
            s['rank_all'] = i + 1

        # 各regime排名
        for regime in REGIMES:
            eligible = [(cid, s) for cid, s in scored_list if not s.get(f'{regime}_insufficient')]
            eligible.sort(key=lambda x: x[1][f'{regime}_pnl'], reverse=True)
            for i, (cid, s) in enumerate(eligible):
                s[f'rank_{regime}'] = i + 1
            for cid, s in scored_list:
                if f'rank_{regime}' not in s:
                    s[f'rank_{regime}'] = None

        # 写入
        rows_to_insert = []
        for cid, s in scored_list:
            info = combo_map[cid]
            rows_to_insert.append((
                cid, info['strategy'], info['coin'], iv,
                s['all_pnl'], s['all_trades'], s['all_win_rate'], s['all_avg_r'], s['rank_all'],
                s.get('bull_pnl', 0), s.get('bull_trades', 0), s.get('bull_win_rate', 0), s.get('bull_avg_r', 0),
                s.get('bull_insufficient', 1), s.get('rank_bull'),
                s.get('bear_pnl', 0), s.get('bear_trades', 0), s.get('bear_win_rate', 0), s.get('bear_avg_r', 0),
                s.get('bear_insufficient', 1), s.get('rank_bear'),
                s.get('ranging_pnl', 0), s.get('ranging_trades', 0), s.get('ranging_win_rate', 0), s.get('ranging_avg_r', 0),
                s.get('ranging_insufficient', 1), s.get('rank_ranging'),
            ))

        rpt.executemany(f'''INSERT INTO gate2_{iv} VALUES
            (?,?,?,?, ?,?,?,?,?, ?,?,?,?,?,?, ?,?,?,?,?,?, ?,?,?,?,?,?)''', rows_to_insert)
        rpt.commit()

        print(f"完成 ({len(rows_to_insert)} 条)")

    seed.close()
    rpt.close()

    total = sum(len(v) for v in passed_by_iv.values())
    print(f"\n专考完成: {total} 组评分，存入 gate_v3_report.db")
    return total


if __name__ == '__main__':
    main()
