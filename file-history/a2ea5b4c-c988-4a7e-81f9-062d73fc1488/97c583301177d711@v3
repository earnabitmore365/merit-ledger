#!/usr/bin/env python3
"""
组考（组队）— 从 WF 通过的组合中选队员
输入: gate_v3_report.db (gate2 + wf_results)
输出: gate_v3_report.db (gate3_short / gate3_mid / gate3_long 表)

逻辑：只从WF通过的里面选，每个维度TOP5，4维度合并去重，同(strategy,coin)只留最优周期
"""
import sqlite3
import os

REPORT_PATH = os.path.join(os.path.dirname(__file__), 'results', 'gate_v3', 'gate_v3_report.db')

TEAMS = {
    'short': ['1m', '5m', '15m', '30m'],
    'mid':   ['1h', '2h', '4h'],
    'long':  ['8h', '12h', '1d'],
}

DIMENSIONS = ['all', 'bull', 'bear', 'ranging']
TOP_N = 5


def main():
    rpt = sqlite3.connect(REPORT_PATH)
    rpt.row_factory = sqlite3.Row

    for team_name, intervals in TEAMS.items():
        # 建表
        rpt.execute(f"DROP TABLE IF EXISTS gate3_{team_name}")
        rpt.execute(f'''CREATE TABLE gate3_{team_name} (
            combo_id INTEGER PRIMARY KEY,
            strategy TEXT, coin TEXT, interval TEXT,
            all_pnl REAL, wf_result TEXT,
            selected INTEGER, selected_dimensions TEXT, reason TEXT
        )''')

        # 收集所有WF通过 + 在这些周期的组合
        wf_passed = []
        for iv in intervals:
            rows = rpt.execute(f'''
                SELECT w.combo_id, w.strategy, w.coin, w.interval, w.all_pnl, w.wf_result,
                       g.all_pnl as g2_all_pnl,
                       g.bull_pnl, g.bear_pnl, g.ranging_pnl,
                       g.bull_insufficient, g.bear_insufficient, g.ranging_insufficient
                FROM wf_results w
                LEFT JOIN gate2_{iv} g ON w.combo_id = g.combo_id
                WHERE w.interval = ? AND w.passed = 1
            ''', (iv,)).fetchall()
            wf_passed.extend(rows)

        if not wf_passed:
            print(f"组考 {team_name}队: 0 个WF通过，跳过")
            continue

        print(f"组考 {team_name}队: {len(wf_passed)} 个WF通过...", end=' ', flush=True)

        # 各维度选TOP5
        selected_combos = {}  # combo_id -> set of dimensions

        for dim in DIMENSIONS:
            if dim == 'all':
                pnl_key = 'g2_all_pnl'
                insuf_key = None
            else:
                pnl_key = f'{dim}_pnl'
                insuf_key = f'{dim}_insufficient'

            # 过滤+排序
            eligible = []
            for r in wf_passed:
                if insuf_key and r[insuf_key]:
                    continue
                pnl = r[pnl_key] if r[pnl_key] is not None else 0
                eligible.append((r, pnl))

            eligible.sort(key=lambda x: x[1], reverse=True)

            for r, pnl in eligible[:TOP_N]:
                cid = r['combo_id']
                if cid not in selected_combos:
                    selected_combos[cid] = set()
                selected_combos[cid].add(dim)

        # 去重：同(strategy, coin)只留 all_pnl 最高的
        by_strat_coin = {}
        for cid, dims in selected_combos.items():
            r = next(x for x in wf_passed if x['combo_id'] == cid)
            key = (r['strategy'], r['coin'])
            pnl = r['all_pnl'] or 0
            if key not in by_strat_coin or pnl > by_strat_coin[key][1]:
                by_strat_coin[key] = (cid, pnl, dims)

        final_selected = {v[0]: v[2] for v in by_strat_coin.values()}

        # 写入所有WF通过的记录（标注是否入选+理由）
        batch = []
        for r in wf_passed:
            cid = r['combo_id']
            if cid in final_selected:
                dims = final_selected[cid]
                batch.append((
                    cid, r['strategy'], r['coin'], r['interval'],
                    r['all_pnl'] or 0, r['wf_result'],
                    1, ','.join(sorted(dims)),
                    f"入选: {','.join(sorted(dims))}维度TOP{TOP_N}"
                ))
            else:
                if cid in selected_combos:
                    reason = "未入选: 同(策略,币种)有更优周期"
                else:
                    reason = "未入选: 4维度均排名TOP5以外"
                batch.append((
                    cid, r['strategy'], r['coin'], r['interval'],
                    r['all_pnl'] or 0, r['wf_result'],
                    0, '', reason
                ))

        rpt.executemany(f"INSERT OR REPLACE INTO gate3_{team_name} VALUES (?,?,?,?,?,?,?,?,?)", batch)
        rpt.commit()

        n_selected = sum(1 for b in batch if b[6] == 1)
        print(f"{n_selected} 入选 / {len(batch)} 总WF通过")

    rpt.close()
    print(f"\n组考完成，存入 gate_v3_report.db")


if __name__ == '__main__':
    main()
