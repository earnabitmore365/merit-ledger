#!/usr/bin/env python3
"""
一键执行 Gate 管线: 初考 → 专考 → 组考 → 照妖镜
"""
import time

def main():
    start = time.time()

    print("=" * 60)
    print("Gate 管线 v3 — 开始执行")
    print("=" * 60)

    # 初考
    print("\n[1/4] 初考（门槛）")
    print("-" * 40)
    import gate1_threshold
    gate1_threshold.main()

    # 专考
    print("\n[2/4] 专考（成绩单）")
    print("-" * 40)
    import gate2_scorecard
    gate2_scorecard.main()

    # 组考
    print("\n[3/4] 组考（组队）")
    print("-" * 40)
    import gate3_team
    gate3_team.main()

    # 照妖镜
    print("\n[4/4] 照妖镜（WF + MC）")
    print("-" * 40)
    import gate4_mirror
    gate4_mirror.main()

    elapsed = time.time() - start
    print("\n" + "=" * 60)
    print(f"Gate 管线完成，耗时 {elapsed:.0f} 秒")
    print("=" * 60)


if __name__ == '__main__':
    main()
