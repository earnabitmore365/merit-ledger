#!/usr/bin/env python3
"""
Regime-aware Walk-Forward — v4.1冠军LOO交叉验证（盘整ranking-only版）

对v4.1冠军，在同regime类型内做Leave-One-Out验证。
核心问题：策略在某regime内的表现是否跨时间段一致？（而非一段行情的幻觉）

LOO设计（BTC已知事实21段）：
- 牛(6段): 6 folds → pass ≥ 4/6
- 熊(4段): 4 folds → pass ≥ 3/4
- 初牛(3段): 3 folds → pass ≥ 2/3
- 初熊(6段): 6 folds → pass ≥ 4/6
- 盘整(2段): 只排名，不淘汰（2段统计上不够格当门槛）

冠军通过条件：所有有≥10笔交易的非盘整regime类型都通过LOO

输入: seed_v3.db (paired_trades) + gate_v41_report.db (champions)
输出: gate_v41_report.db (wf_regime_results + wf_champions)
"""
import sqlite3
import os

DB_PATH = os.path.join(os.path.dirname(__file__), 'reports', 'seed_v3.db')
REPORT_PATH = os.path.join(os.path.dirname(__file__), 'results', 'gate_v41', 'gate_v41_report.db')

# BTC 已知事实时间表（与 regime_fact_timeline.py 一致）
TIMELINE = [
    (1,  '2017-12', '2018-01', '初熊'),
    (2,  '2018-02', '2018-12', '熊'),
    (3,  '2019-01', '2019-03', '初牛'),
    (4,  '2019-04', '2019-06', '牛'),
    (5,  '2019-07', '2019-08', '初熊'),
    (6,  '2019-09', '2020-03', '熊'),
    (7,  '2020-04', '2020-09', '初牛'),
    (8,  '2020-10', '2021-04', '牛'),
    (9,  '2021-05', '2021-07', '初熊'),
    (10, '2021-08', '2021-11', '牛'),
    (11, '2021-12', '2022-01', '初熊'),
    (12, '2022-02', '2022-11', '熊'),
    (13, '2022-12', '2023-03', '初牛'),
    (14, '2023-04', '2023-09', '盘整'),
    (15, '2023-10', '2024-03', '牛'),
    (16, '2024-04', '2024-09', '盘整'),
    (17, '2024-10', '2025-01', '牛'),
    (18, '2025-02', '2025-03', '初熊'),
    (19, '2025-04', '2025-10', '牛'),
    (20, '2025-11', '2025-12', '初熊'),
    (21, '2026-01', '2026-03', '熊'),
]

REGIME_NAMES = {'牛': 'bull', '熊': 'bear', '初牛': 'early_bull', '初熊': 'early_bear', '盘整': 'ranging'}

# 盘整只有2段，统计上不够格当淘汰门槛，只做排名参考
RANKING_ONLY = {'盘整'}

MIN_TRADES_PER_REGIME = 10

TEAMS = ['short', 'mid', 'long']


def build_month_to_segment():
    """月份 → (segment_id, regime) 映射"""
    mapping = {}
    for seg_id, start_ym, end_ym, regime in TIMELINE:
        ym = start_ym
        while ym <= end_ym:
            mapping[ym] = (seg_id, regime)
            y, m = int(ym[:4]), int(ym[5:7])
            m += 1
            if m > 12:
                m = 1
                y += 1
            ym = f'{y:04d}-{m:02d}'
    return mapping


def get_pass_threshold(n_segments):
    """LOO通过阈值：大约2/3"""
    if n_segments >= 6:
        return 4   # 4/6 = 67%
    if n_segments >= 4:
        return 3   # 3/4 = 75%
    if n_segments >= 3:
        return 2   # 2/3 = 67%
    return n_segments  # 2/2 = 100%


def regime_aware_wf(seed_conn, combo_id, month_map):
    """
    对单个combo做Regime-aware LOO验证。

    返回: {
        'regime_results': {regime_name: {status, folds_passed, folds_total, ...}},
        'overall_passed': bool,
        'reason': str,
    }
    """
    trades = seed_conn.execute('''
        SELECT open_time, r_value FROM paired_trades
        WHERE combo_id = ?
    ''', (combo_id,)).fetchall()

    # 按regime类型分组，每组内按segment_id再分
    by_regime = {}  # regime → {seg_id: [r_values]}
    unmapped = 0

    for t in trades:
        month = t['open_time'][:7]
        seg_info = month_map.get(month)
        if not seg_info:
            unmapped += 1
            continue
        seg_id, regime = seg_info
        if regime not in by_regime:
            by_regime[regime] = {}
        if seg_id not in by_regime[regime]:
            by_regime[regime][seg_id] = []
        by_regime[regime][seg_id].append(t['r_value'])

    regime_results = {}
    any_fail = False
    testable_count = 0

    for regime_cn, regime_en in REGIME_NAMES.items():
        segments = by_regime.get(regime_cn, {})
        n_segments = len(segments)
        total_trades = sum(len(v) for v in segments.values())
        total_pnl = sum(sum(v) for v in segments.values())

        if total_trades < MIN_TRADES_PER_REGIME:
            regime_results[regime_en] = {
                'status': 'skip',
                'trades': total_trades,
                'segments': n_segments,
                'pnl': round(total_pnl, 4),
                'folds_passed': None,
                'folds_total': None,
                'threshold': None,
                'reason': f'trades={total_trades}<{MIN_TRADES_PER_REGIME}',
            }
            continue

        if n_segments < 2:
            regime_results[regime_en] = {
                'status': 'skip',
                'trades': total_trades,
                'segments': n_segments,
                'pnl': round(total_pnl, 4),
                'folds_passed': None,
                'folds_total': None,
                'threshold': None,
                'reason': f'segments={n_segments}<2',
            }
            continue

        is_ranking_only = regime_cn in RANKING_ONLY
        testable_count += 1

        # LOO: hold out each segment, check remaining PnL
        seg_ids = sorted(segments.keys())
        seg_pnl = {sid: sum(segments[sid]) for sid in seg_ids}
        total_regime_pnl = sum(seg_pnl.values())

        pass_count = 0
        fold_details = []
        for held_out in seg_ids:
            remaining_pnl = total_regime_pnl - seg_pnl[held_out]
            fold_passed = remaining_pnl > 0
            if fold_passed:
                pass_count += 1
            fold_details.append({
                'held_out_seg': held_out,
                'held_out_pnl': round(seg_pnl[held_out], 4),
                'remaining_pnl': round(remaining_pnl, 4),
                'passed': fold_passed,
            })

        threshold = get_pass_threshold(n_segments)
        passed = pass_count >= threshold

        if is_ranking_only:
            # 盘整：只排名不淘汰，不影响 any_fail
            status = 'rank'
            reason_str = f"排名: {pass_count}/{n_segments} folds (不淘汰)"
        else:
            status = 'pass' if passed else 'fail'
            reason_str = f"{'通过' if passed else '不通过'}: {pass_count}/{n_segments} folds (需≥{threshold})"
            if not passed:
                any_fail = True

        regime_results[regime_en] = {
            'status': status,
            'trades': total_trades,
            'segments': n_segments,
            'pnl': round(total_regime_pnl, 4),
            'folds_passed': pass_count,
            'folds_total': n_segments,
            'threshold': threshold,
            'reason': reason_str,
        }

    # 判定：只看非ranking-only的regime
    gate_count = sum(1 for v in regime_results.values() if v['status'] in ('pass', 'fail'))
    overall_passed = not any_fail and gate_count > 0
    if gate_count == 0:
        reason = "无可测regime (所有regime交易<10笔或<2段或仅排名)"
        overall_passed = False
    elif any_fail:
        failed = [k for k, v in regime_results.items() if v['status'] == 'fail']
        reason = f"不通过: {','.join(failed)} regime LOO失败"
    else:
        passed_list = [k for k, v in regime_results.items() if v['status'] == 'pass']
        ranked_list = [k for k, v in regime_results.items() if v['status'] == 'rank']
        parts = [f"{','.join(passed_list)} LOO通过"]
        if ranked_list:
            parts.append(f"{','.join(ranked_list)} 排名")
        reason = f"通过: {' + '.join(parts)} ({gate_count}门槛+{len(ranked_list)}排名)"

    return {
        'regime_results': regime_results,
        'overall_passed': overall_passed,
        'testable_regimes': testable_count,
        'reason': reason,
    }


def main():
    print("=" * 60)
    print("Regime-aware Walk-Forward — v4.1冠军LOO交叉验证")
    print("=" * 60)

    month_map = build_month_to_segment()
    print(f"月度映射: {len(month_map)} 个月")

    # 按regime统计段数
    regime_segments = {}
    for seg_id, _, _, regime in TIMELINE:
        regime_segments.setdefault(regime, []).append(seg_id)
    print("\n各regime段数:")
    for regime, segs in regime_segments.items():
        en = REGIME_NAMES[regime]
        threshold = get_pass_threshold(len(segs))
        print(f"  {regime}({en}): {len(segs)}段 → LOO pass≥{threshold}/{len(segs)}")

    seed = sqlite3.connect(DB_PATH)
    seed.row_factory = sqlite3.Row
    rpt = sqlite3.connect(REPORT_PATH)
    rpt.row_factory = sqlite3.Row

    # 读取冠军列表
    champions = rpt.execute('''
        SELECT c.combo_id, c.strategy, c.coin, c.interval, c.team, c.all_pnl,
               c.double_rate, c.bust_rate, c.d2d_p50, c.max_dd_p95, c.balance_p50
        FROM champions c
        ORDER BY c.team, c.all_pnl DESC
    ''').fetchall()

    print(f"\n冠军候选: {len(champions)} 个")

    # 创建结果表
    rpt.execute("DROP TABLE IF EXISTS wf_regime_results")
    rpt.execute('''CREATE TABLE wf_regime_results (
        combo_id INTEGER,
        strategy TEXT, coin TEXT, interval TEXT, team TEXT,
        all_pnl REAL,
        regime TEXT,
        status TEXT,
        trades INTEGER, segments INTEGER, pnl REAL,
        folds_passed INTEGER, folds_total INTEGER, threshold INTEGER,
        reason TEXT
    )''')

    rpt.execute("DROP TABLE IF EXISTS wf_champions")
    rpt.execute('''CREATE TABLE wf_champions (
        combo_id INTEGER PRIMARY KEY,
        strategy TEXT, coin TEXT, interval TEXT,
        team TEXT, all_pnl REAL,
        double_rate REAL, bust_rate REAL,
        d2d_p50 REAL, max_dd_p95 REAL, balance_p50 REAL,
        testable_regimes INTEGER, reason TEXT
    )''')

    total_pass = 0
    total_fail = 0

    for champ in champions:
        cid = champ['combo_id']
        label = f"{champ['strategy']}/{champ['coin']}/{champ['interval']}"
        print(f"\n  [{champ['team']}] {label} (PnL={champ['all_pnl']:+.1f}R)...")

        result = regime_aware_wf(seed, cid, month_map)

        # 写入详细结果
        for regime_en, rr in result['regime_results'].items():
            rpt.execute('''INSERT INTO wf_regime_results VALUES
                (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)''', (
                cid, champ['strategy'], champ['coin'], champ['interval'],
                champ['team'], champ['all_pnl'],
                regime_en, rr['status'],
                rr['trades'], rr['segments'], rr['pnl'],
                rr['folds_passed'], rr['folds_total'], rr['threshold'],
                rr['reason'],
            ))

        if result['overall_passed']:
            total_pass += 1
            rpt.execute('''INSERT INTO wf_champions VALUES
                (?,?,?,?,?,?,?,?,?,?,?,?,?)''', (
                cid, champ['strategy'], champ['coin'], champ['interval'],
                champ['team'], champ['all_pnl'],
                champ['double_rate'], champ['bust_rate'],
                champ['d2d_p50'], champ['max_dd_p95'], champ['balance_p50'],
                result['testable_regimes'], result['reason'],
            ))
            print(f"    ✅ {result['reason']}")
        else:
            total_fail += 1
            print(f"    ❌ {result['reason']}")

        # 打印每个regime的明细
        for regime_en, rr in result['regime_results'].items():
            if rr['status'] == 'skip':
                print(f"       {regime_en}: ⏭ {rr['reason']}")
            elif rr['status'] == 'pass':
                print(f"       {regime_en}: ✅ {rr['folds_passed']}/{rr['folds_total']} (≥{rr['threshold']}) PnL={rr['pnl']:+.1f}")
            elif rr['status'] == 'rank':
                print(f"       {regime_en}: 📊 {rr['folds_passed']}/{rr['folds_total']} (排名,不淘汰) PnL={rr['pnl']:+.1f}")
            else:
                print(f"       {regime_en}: ❌ {rr['folds_passed']}/{rr['folds_total']} (需≥{rr['threshold']}) PnL={rr['pnl']:+.1f}")

    rpt.commit()

    # 更新 gate_index
    wf_cnt = rpt.execute("SELECT COUNT(*) FROM wf_regime_results").fetchone()[0]
    wf_champ_cnt = rpt.execute("SELECT COUNT(*) FROM wf_champions").fetchone()[0]

    # 先删旧条目再插入
    rpt.execute("DELETE FROM gate_index WHERE table_name IN ('wf_regime_results', 'wf_champions')")
    rpt.execute("INSERT INTO gate_index VALUES (?, ?, ?)",
                ('wf_regime_results', 'Regime-aware WF明细 — 各regime LOO结果', wf_cnt))
    rpt.execute("INSERT INTO gate_index VALUES (?, ?, ?)",
                ('wf_champions', 'Regime-aware WF冠军 — LOO全通过', wf_champ_cnt))
    rpt.commit()

    seed.close()
    rpt.close()

    print("\n" + "=" * 60)
    print(f"Regime-aware WF完成: {total_pass}/{len(champions)} 通过")
    print(f"  通过: {total_pass}")
    print(f"  不通过: {total_fail}")
    print(f"  淘汰率: {total_fail/len(champions)*100:.1f}%")
    print(f"输出: {REPORT_PATH}")
    print("=" * 60)


if __name__ == '__main__':
    main()
