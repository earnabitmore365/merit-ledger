#!/usr/bin/env python3
"""
照妖镜 WF 全量 — 对所有通过初考的组合跑 Walk-Forward 验证
输入: seed_v3.db + gate_v3_report.db (gate1)
输出: gate_v3_report.db (wf_results 表, 7231条)

Walk-Forward: 按交易时间顺序均分N段，每段 sum(r_value)>0 则通过
短中期(1m~4h): 5段, ≥4段通过
长期(8h/12h/1d): 3段, ≥2段通过
"""
import sqlite3
import os

DB_PATH = os.path.join(os.path.dirname(__file__), 'reports', 'seed_v3.db')
REPORT_PATH = os.path.join(os.path.dirname(__file__), 'results', 'gate_v3', 'gate_v3_report.db')

INTERVALS = ['1m', '5m', '15m', '30m', '1h', '2h', '4h', '8h', '12h', '1d']

WF_CONFIG = {
    '1m': (5, 4), '5m': (5, 4), '15m': (5, 4), '30m': (5, 4),
    '1h': (5, 4), '2h': (5, 4), '4h': (5, 4),
    '8h': (3, 2), '12h': (3, 2), '1d': (3, 2),
}

MIN_TRADES_PER_SEGMENT = 5


def walk_forward(seed_conn, combo_id, n_segments, min_pass):
    """WF验证: 按时间均分N段, 每段sum(r)>0则pass"""
    trades = seed_conn.execute('''
        SELECT r_value FROM paired_trades
        WHERE combo_id = ?
        ORDER BY open_candle_idx
    ''', (combo_id,)).fetchall()

    total = len(trades)
    if total < n_segments:
        return {
            'passed': False,
            'total_trades': total,
            'pass_count': 0,
            'valid_count': 0,
            'required': min_pass,
            'result': f"0/0",
            'reason': f"交易数({total})不足{n_segments}段",
            'segments': '',
        }

    seg_size = total // n_segments
    pass_count = 0
    valid_count = 0
    seg_details = []

    for i in range(n_segments):
        start = i * seg_size
        end = start + seg_size if i < n_segments - 1 else total
        seg_trades = trades[start:end]
        seg_r = sum(t['r_value'] for t in seg_trades)
        seg_count = len(seg_trades)

        if seg_count < MIN_TRADES_PER_SEGMENT:
            seg_details.append(f"S{i+1}:skip({seg_count}笔)")
        else:
            valid_count += 1
            is_pass = seg_r > 0
            if is_pass:
                pass_count += 1
            seg_details.append(f"S{i+1}:{'P' if is_pass else 'F'}({seg_r:+.2f}R/{seg_count}笔)")

    effective_required = min(min_pass, valid_count)
    passed = pass_count >= effective_required and valid_count > 0

    if passed:
        reason = f"通过: {pass_count}/{valid_count}段盈利 >= {effective_required}段要求"
    else:
        if valid_count == 0:
            reason = f"不通过: 无有效段(每段<{MIN_TRADES_PER_SEGMENT}笔)"
        else:
            reason = f"不通过: {pass_count}/{valid_count}段盈利 < {effective_required}段要求"

    return {
        'passed': passed,
        'total_trades': total,
        'pass_count': pass_count,
        'valid_count': valid_count,
        'required': effective_required,
        'result': f"{pass_count}/{valid_count}",
        'reason': reason,
        'segments': ' | '.join(seg_details),
    }


def main():
    seed = sqlite3.connect(DB_PATH)
    seed.row_factory = sqlite3.Row
    rpt = sqlite3.connect(REPORT_PATH)
    rpt.row_factory = sqlite3.Row

    # 建 WF 结果表
    rpt.execute("DROP TABLE IF EXISTS wf_results")
    rpt.execute('''CREATE TABLE wf_results (
        combo_id INTEGER PRIMARY KEY,
        strategy TEXT, coin TEXT, interval TEXT,
        all_pnl REAL,
        wf_segments INTEGER, wf_required INTEGER,
        wf_pass_count INTEGER, wf_valid_count INTEGER,
        wf_result TEXT, passed INTEGER, reason TEXT, segments TEXT
    )''')

    # 逐周期处理
    total_combos = 0
    total_passed = 0

    for iv in INTERVALS:
        # 从 gate1 读通过的 combo
        rows = rpt.execute(f"SELECT combo_id, strategy, coin FROM gate1_{iv} WHERE passed = 1").fetchall()
        if not rows:
            print(f"WF {iv}: 0 组，跳过")
            continue

        # 从 gate2 读 all_pnl
        pnl_map = {}
        try:
            pnl_rows = rpt.execute(f"SELECT combo_id, all_pnl FROM gate2_{iv}").fetchall()
            pnl_map = {r['combo_id']: r['all_pnl'] for r in pnl_rows}
        except:
            pass

        n_seg, min_pass = WF_CONFIG[iv]
        print(f"WF {iv}: {len(rows)} 组, {n_seg}段/{min_pass}通过...", end=' ', flush=True)

        iv_passed = 0
        batch = []

        for r in rows:
            cid = r['combo_id']
            wf = walk_forward(seed, cid, n_seg, min_pass)

            batch.append((
                cid, r['strategy'], r['coin'], iv,
                pnl_map.get(cid, 0),
                n_seg, min_pass,
                wf['pass_count'], wf['valid_count'],
                wf['result'], 1 if wf['passed'] else 0,
                wf['reason'], wf['segments'],
            ))

            if wf['passed']:
                iv_passed += 1

        rpt.executemany('''INSERT INTO wf_results VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?)''', batch)
        rpt.commit()

        total_combos += len(rows)
        total_passed += iv_passed
        print(f"{iv_passed}/{len(rows)} 通过 ({round(iv_passed/len(rows)*100, 1)}%)")

    seed.close()
    rpt.close()

    print(f"\nWF全量完成: {total_passed}/{total_combos} 通过 ({round(total_passed/total_combos*100, 1)}%)")
    print(f"输出: {REPORT_PATH} → wf_results 表")
    return total_passed, total_combos


if __name__ == '__main__':
    main()
