#!/usr/bin/env python3
"""gp_evolve.py: 毕业考前加指标数量门槛"""

EVOLVE_PATH = '/home/pc_heisi_claude/trading/gp_engine/gp_evolve.py'
with open(EVOLVE_PATH) as f:
    content = f.read()

if 'MIN_INDICATORS' in content and '指标不足' in content:
    print("毕业考指标门槛已存在，跳过")
else:
    # 在毕业考循环里，Walk-Forward 之前加检查
    # 找到 "# Walk-Forward 毕业考" 那行
    old_block = (
        "                    # Walk-Forward 毕业考\n"
        "                    if mirror_norm_data is not None:"
    )
    new_block = (
        "                    # v1.1: 指标数量门槛 — 不足 MIN_INDICATORS 个不准考\n"
        "                    used_indicators = extract_indicators(best_tree)\n"
        "                    n_ind = len(used_indicators)\n"
        "                    if n_ind < config.MIN_INDICATORS:\n"
        "                        print(f\"\\n  ❌ 指标不足 ({dir_label}) \"\n"
        "                              f\"使用 {n_ind} 个指标 ({', '.join(sorted(used_indicators))})\"\n"
        "                              f\"，最少需要 {config.MIN_INDICATORS} 个，不准参加毕业考\")\n"
        "                        continue\n"
        "\n"
        "                    # Walk-Forward 毕业考\n"
        "                    if mirror_norm_data is not None:"
    )
    if old_block in content:
        content = content.replace(old_block, new_block)
        with open(EVOLVE_PATH, 'w') as f:
            f.write(content)
        print("✅ gp_evolve.py: 毕业考前加指标数量门槛")
    else:
        print("❌ 找不到目标代码块，需手动检查")
