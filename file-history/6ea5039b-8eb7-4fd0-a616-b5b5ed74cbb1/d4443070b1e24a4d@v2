#!/usr/bin/env python3
"""石卫 v7 端到端测试"""
import json
import subprocess
import os
import sys

GATE = os.path.expanduser("~/.claude/scripts/merit_gate.py")
CREDIT = os.path.expanduser("~/.claude/credit.json")
MISSION = os.path.expanduser("~/.claude/mission.json")
CM = os.path.expanduser("~/.claude/scripts/credit_manager.py")

passed = 0
failed = 0


def run_gate(data):
    """模拟 hook 调用 merit_gate.py"""
    result = subprocess.run(
        ["python3", GATE],
        input=json.dumps(data),
        capture_output=True, text=True, timeout=15,
    )
    return result.stdout.strip(), result.stderr.strip(), result.returncode


def run_cm(args):
    result = subprocess.run(
        ["python3", CM] + args,
        capture_output=True, text=True, timeout=15,
    )
    return result.stdout.strip()


def get_score(agent="太极"):
    with open(CREDIT) as f:
        return json.load(f)["agents"][agent]["score"]


def get_held(agent="太极"):
    with open(CREDIT) as f:
        return json.load(f)["agents"][agent].get("held", 0)


def test(name, condition):
    global passed, failed
    if condition:
        print(f"  ✅ {name}")
        passed += 1
    else:
        print(f"  ❌ {name}")
        failed += 1


# ══════════════════════════════════════════════════════
print("=== A. PreToolUse 基础测试 ===")

# A1: 正常 Bash 放行
out, err, rc = run_gate({
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {"command": "ls /tmp"},
    "cwd": "/Users/allenbot",
    "transcript_path": "",
})
test("正常 Bash 放行（无输出=放行）", out == "" and rc == 0)

# A2: 破坏性 Bash 拦截
out, err, rc = run_gate({
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {"command": "rm -rf /important/file.py"},
    "cwd": "/Users/allenbot",
    "transcript_path": "",
})
combined = out + err
test("破坏性 Bash 拦截（deny）", "deny" in combined or "门卫拦截" in combined or "rm 删除文件" in combined)

# A3: /tmp/ 下删除豁免
out, err, rc = run_gate({
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {"command": "rm /tmp/test_file.txt"},
    "cwd": "/Users/allenbot",
    "transcript_path": "",
})
test("/tmp/ 下删除豁免", out == "")

# A4: Agent model 限制（两仪 Lv.1）
out, err, rc = run_gate({
    "hook_event_name": "PreToolUse",
    "tool_name": "Agent",
    "tool_input": {"prompt": "搜索文件", "subagent_type": "search-specialist", "description": "search"},
    "cwd": "/Volumes/SSD-2TB/project/auto-trading",
    "transcript_path": "",
})
test("两仪 Agent model 限制（deny，需 sonnet）", "deny" in out and "sonnet" in out)

# ══════════════════════════════════════════════════════
print("\n=== B. Mission 任务计划测试 ===")

# 清理
if os.path.exists(MISSION):
    os.remove(MISSION)

# B1: submit
score_before = get_score()
output = run_cm(["mission", "submit", "测试任务", "--modify", "/tmp/test_m.py", "--delete", "/tmp/test_d.py"])
test("mission submit 成功", "任务提交成功" in output)
test("mission.json 写入", os.path.exists(MISSION))
test("held 预扣", get_held() > 0)

# B2: status
output = run_cm(["mission", "status"])
test("mission status 显示", "测试任务" in output and "active" in output)

# B3: 计划内 Bash 放行
out, err, rc = run_gate({
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {"command": "rm /tmp/test_d.py"},
    "cwd": "/Users/allenbot",
    "transcript_path": "",
})
test("计划内删除放行", out == "")

# B4: 计划外 Bash 拦截
out, err, rc = run_gate({
    "hook_event_name": "PreToolUse",
    "tool_name": "Bash",
    "tool_input": {"command": "rm /home/user/other.py"},
    "cwd": "/Users/allenbot",
    "transcript_path": "",
})
test("计划外删除拦截", "deny" in out)

# B5: complete 有漏项
output = run_cm(["mission", "complete"])
test("complete 漏项提醒", "未完成" in output)

# B6: abort
held_before = get_held()
score_before = get_score()
output = run_cm(["mission", "abort"])
test("abort 成功", "放弃" in output)
test("abort 押金全扣", get_score() < score_before or held_before > 0)

# B7: extend
run_cm(["mission", "submit", "延期测试", "--modify", "/tmp/ext.py"])
output = run_cm(["mission", "extend"])
test("extend 延期", "延期" in output)
# 清理
run_cm(["mission", "abort"])

# ══════════════════════════════════════════════════════
print("\n=== C. PostToolUse 测试 ===")

# C1: PostToolUse Write py_compile
out, err, rc = run_gate({
    "hook_event_name": "PostToolUse",
    "tool_name": "Write",
    "tool_input": {"file_path": "/tmp/test_merit_v7.py"},
    "cwd": "/Users/allenbot",
})
test("PostToolUse Write（py_compile 无错误）", "错误" not in out)

# ══════════════════════════════════════════════════════
print("\n=== D. Stop 评分测试 ===")

# D1: Stop 事件处理（不崩溃）
out, err, rc = run_gate({
    "hook_event_name": "Stop",
    "cwd": "/Users/allenbot",
    "transcript_path": "",
})
test("Stop 事件不崩溃", rc == 0)

# ══════════════════════════════════════════════════════
print("\n=== E. UserPromptSubmit 语气测试 ===")

# E1: 正面语气
score_before = get_score()
out, err, rc = run_gate({
    "hook_event_name": "UserPromptSubmit",
    "cwd": "/Users/allenbot",
    "message": {"content": "太好了，做得非常好"},
})
test("正面语气识别（不崩溃）", rc == 0)

# E2: 负面语气
out, err, rc = run_gate({
    "hook_event_name": "UserPromptSubmit",
    "cwd": "/Users/allenbot",
    "message": {"content": "你搞什么东西"},
})
test("负面语气识别（不崩溃）", rc == 0)

# ══════════════════════════════════════════════════════
print("\n=== F. Reflect 合体测试 ===")

# F1: trigger_count 文件
TRIGGER_PATH = os.path.expanduser("~/.claude/merit_trigger_counts.json")
if os.path.exists(TRIGGER_PATH):
    with open(TRIGGER_PATH) as f:
        counts = json.load(f)
    test("trigger_count 文件存在且可读", isinstance(counts, dict))
else:
    test("trigger_count 文件（无触发记录=正常）", True)

# F2: LEARNINGS 写入
LEARNINGS = os.path.expanduser("~/.claude/learnings/LEARNINGS.md")
if os.path.exists(LEARNINGS):
    with open(LEARNINGS) as f:
        content = f.read()
    test("LEARNINGS.md 存在", len(content) > 0)
else:
    test("LEARNINGS.md 存在", False)

# ══════════════════════════════════════════════════════
print(f"\n{'='*50}")
print(f"结果: {passed} 通过, {failed} 失败, 共 {passed+failed} 项")
if failed == 0:
    print("🎉 全部通过!")
else:
    print(f"⚠️ {failed} 项需要修复")
