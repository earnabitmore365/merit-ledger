#!/usr/bin/env python3
"""
HyperLiquid 账号管理

集中管理 HyperLiquid 的 API 配置
支持多账号（测试网/主网）
"""

from dataclasses import dataclass
from typing import Dict, Optional


@dataclass
class HLAccount:
    """HyperLiquid 账号"""
    name: str                    # 账号名称
    wallet_address: str          # 钱包地址
    private_key: str            # 私钥
    api_address: str = ""       # API 地址（可选）
    testnet: bool = True        # 是否测试网
    enabled: bool = True        # 是否启用


# ==================== 账号配置 ====================

# 测试网账号
HL_TESTNET_ACCOUNTS: Dict[str, HLAccount] = {
    "default": HLAccount(
        name="默认测试账号",
        wallet_address="0x1989FC0A5DFa745C34Bb4a640D47eF8da7499c64",
        api_address="0x390034556e1b6932e1b15f67c8e35bf30710d16e",
        private_key="0x620f634ab8f176f59b498ff0b18228d7ae39b3863bb27ac08f865026a8bf3538",
        testnet=True,
    ),
}

# 主网账号
HL_MAINNET_ACCOUNTS: Dict[str, HLAccount] = {
    # 主网账号后续添加
}


# ==================== 工厂函数 ====================

def get_account(
    name: str = "default",
    network: str = "testnet",
) -> Optional[HLAccount]:
    """获取账号配置

    Args:
        name: 账号名称
        network: 网络类型 ("testnet" 或 "mainnet")

    Returns:
        HLAccount: 账号配置，找不到返回 None
    """
    if network.lower() == "testnet":
        return HL_TESTNET_ACCOUNTS.get(name)
    else:
        return HL_MAINNET_ACCOUNTS.get(name)


def list_accounts(network: str = "testnet") -> Dict[str, HLAccount]:
    """列出所有账号

    Args:
        network: 网络类型 ("testnet" 或 "mainnet")

    Returns:
        Dict[str, HLAccount]: 账号字典
    """
    if network.lower() == "testnet":
        return HL_TESTNET_ACCOUNTS.copy()
    else:
        return HL_MAINNET_ACCOUNTS.copy()


def add_account(
    name: str,
    wallet_address: str,
    private_key: str,
    api_address: str = "",
    network: str = "testnet",
) -> bool:
    """添加账号

    Args:
        name: 账号名称
        wallet_address: 钱包地址
        private_key: 私钥
        api_address: API 地址（可选）
        network: 网络类型

    Returns:
        bool: 是否添加成功
    """
    account = HLAccount(
        name=name,
        wallet_address=wallet_address,
        private_key=private_key,
        api_address=api_address,
        testnet=(network.lower() == "testnet"),
    )

    if network.lower() == "testnet":
        HL_TESTNET_ACCOUNTS[name] = account
    else:
        HL_MAINNET_ACCOUNTS[name] = account

    return True


def remove_account(name: str, network: str = "testnet") -> bool:
    """删除账号

    Args:
        name: 账号名称
        network: 网络类型

    Returns:
        bool: 是否删除成功
    """
    if network.lower() == "testnet":
        if name in HL_TESTNET_ACCOUNTS:
            del HL_TESTNET_ACCOUNTS[name]
            return True
    else:
        if name in HL_MAINNET_ACCOUNTS:
            del HL_MAINNET_ACCOUNTS[name]
            return True
    return False


def get_adapter_config(
    name: str = "default",
    network: str = "testnet",
) -> Dict:
    """获取适配器配置（用于创建 Adapter）

    Args:
        name: 账号名称
        network: 网络类型

    Returns:
        Dict: 适配器配置字典
    """
    account = get_account(name, network)
    if not account:
        raise ValueError(f"账号不存在: {name} ({network})")

    return {
        "wallet_address": account.wallet_address,
        "private_key": account.private_key,
        "api_address": account.api_address,
        "testnet": account.testnet,
    }


# ==================== 导出 ====================

__all__ = [
    'HLAccount',
    'HL_TESTNET_ACCOUNTS',
    'HL_MAINNET_ACCOUNTS',
    'get_account',
    'list_accounts',
    'add_account',
    'remove_account',
    'get_adapter_config',
]
