#!/usr/bin/env python3
"""
Abby 回测系统 - 交互式菜单
使用上下键选择，空格键多选，Enter确定，Esc返回/退出
"""

import sys
import os

# 添加项目路径
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'src'))

try:
    import curses
except ImportError:
    try:
        import subprocess
        subprocess.run([sys.executable, '-m', 'pip', 'install', 'windows-curses'], check=True)
        import curses
    except:
        print("请安装 curses 库: pip install windows-curses")
        sys.exit(1)

from core.strategy import list_strategies


class MenuSystem:
    def __init__(self, stdscr):
        self.stdscr = stdscr
        self.stdscr.nodelay(False)
        self.stdscr.keypad(True)
        self.selected_indices = []

        curses.start_color()
        curses.init_pair(1, curses.COLOR_CYAN, curses.COLOR_BLACK)
        curses.init_pair(2, curses.COLOR_GREEN, curses.COLOR_BLACK)
        curses.init_pair(3, curses.COLOR_YELLOW, curses.COLOR_BLACK)
        curses.init_pair(4, curses.COLOR_WHITE, curses.COLOR_BLACK)
        curses.init_pair(5, curses.COLOR_RED, curses.COLOR_BLACK)

        self.height, self.width = stdscr.getmaxyx()

    def draw_title(self, title):
        self.stdscr.attron(curses.color_pair(1) | curses.A_BOLD)
        self.stdscr.addstr(0, 0, " " + "=" * (self.width - 2) + " ")
        self.stdscr.addstr(1, (self.width - len(title)) // 2, title)
        self.stdscr.addstr(2, 0, " " + "=" * (self.width - 2) + " ")
        self.stdscr.attroff(curses.color_pair(1) | curses.A_BOLD)

    def draw_options(self, options, selected_idx, title, multi=False, start_row=7):
        self.stdscr.clear()
        self.draw_title(title)

        if multi:
            hint = "[上下键] 移动  [空格] 选择/取消  [Enter] 确定  [Esc] 返回"
        else:
            hint = "[上下键] 移动  [Enter] 确定  [Esc] 返回"
        self.stdscr.addstr(4, 0, hint, curses.color_pair(5))
        self.stdscr.addstr(5, 0, "-" * (self.width - 1))

        if multi and self.selected_indices:
            self.stdscr.addstr(6, 0, f"已选择: {len(self.selected_indices)} 项", curses.color_pair(3))

        for i, option in enumerate(options):
            y = start_row + i
            if y >= self.height - 1:
                break

            if i == selected_idx:
                if multi:
                    mark = "[x]" if i in self.selected_indices else "[ ]"
                else:
                    mark = ">>"
                self.stdscr.attron(curses.color_pair(2) | curses.A_REVERSE)
                self.stdscr.addstr(y, 2, f"{mark} {option}")
                self.stdscr.attroff(curses.color_pair(2) | curses.A_REVERSE)
            else:
                if multi:
                    mark = "[x]" if i in self.selected_indices else "[ ]"
                else:
                    mark = "  "
                self.stdscr.addstr(y, 2, f"{mark} {option}", curses.color_pair(4))

        self.stdscr.refresh()

    def navigate_options(self, options, title, multi=False):
        self.selected_indices = []
        selected_idx = 0
        max_visible = self.height - 12
        offset = 0

        while True:
            if selected_idx >= offset + max_visible:
                offset = selected_idx - max_visible + 1
            elif selected_idx < offset:
                offset = selected_idx

            visible_options = options[offset:offset + max_visible]
            adjusted_idx = selected_idx - offset

            self.draw_options(visible_options, adjusted_idx, title, multi)

            key = self.stdscr.getch()

            if key == curses.KEY_UP:
                if selected_idx > 0:
                    selected_idx -= 1
            elif key == curses.KEY_DOWN:
                if selected_idx < len(options) - 1:
                    selected_idx += 1
            elif key == ord(' '):
                if multi:
                    if selected_idx in self.selected_indices:
                        self.selected_indices.remove(selected_idx)
                    else:
                        self.selected_indices.append(selected_idx)
            elif key in [10, 13]:
                if multi:
                    if self.selected_indices:
                        return [options[i] for i in self.selected_indices]
                    return [options[0]]
                else:
                    return options[selected_idx]
            elif key == 27:
                return None

    def get_yes_no(self, title, default=True):
        options = ["YES", "NO"]
        selected_idx = 0 if default else 1

        while True:
            self.stdscr.clear()
            self.draw_title(title)
            self.stdscr.addstr(4, 0, "[左右键] 选择  [Enter] 确定  [Esc] 返回", curses.color_pair(5))
            self.stdscr.addstr(5, 0, "-" * (self.width - 1))

            y = 8
            for i, opt in enumerate(options):
                if i == selected_idx:
                    self.stdscr.attron(curses.color_pair(2) | curses.A_REVERSE)
                    self.stdscr.addstr(y, (self.width - len(opt)) // 2, f" {opt} ")
                    self.stdscr.attroff(curses.color_pair(2) | curses.A_REVERSE)
                else:
                    self.stdscr.addstr(y, (self.width - len(opt)) // 2, f" {opt} ", curses.color_pair(4))

            self.stdscr.refresh()
            key = self.stdscr.getch()

            if key == curses.KEY_LEFT:
                selected_idx = max(0, selected_idx - 1)
            elif key == curses.KEY_RIGHT:
                selected_idx = min(len(options) - 1, selected_idx + 1)
            elif key in [10, 13]:
                return selected_idx == 0
            elif key == 27:
                return None

    def get_number(self, title, default):
        self.stdscr.clear()
        self.draw_title(title)
        self.stdscr.addstr(4, 0, "[输入数字]  [Enter] 确定  [Esc] 返回", curses.color_pair(5))
        self.stdscr.addstr(5, 0, "-" * (self.width - 1))
        self.stdscr.addstr(7, 0, f"默认值: {default} (直接回车使用默认值)")
        self.stdscr.addstr(9, 0, "输入: ")

        curses.echo()
        try:
            input_str = self.stdscr.getstr(9, 8, 20).decode()
            curses.noecho()
            if input_str.strip():
                return int(input_str)
            return default
        except:
            curses.noecho()
            return default

    def show_results(self, results):
        """显示多个回测结果"""
        self.stdscr.clear()
        self.draw_title("回测结果")

        y = 4
        for r in results:
            self.stdscr.addstr(y, 0, "-" * 40, curses.color_pair(3))
            y += 1
            self.stdscr.addstr(y, 0, f"策略: {r['strategy']} | 周期: {r['interval']}")
            y += 1
            self.stdscr.addstr(y, 0, f"交易: {r['total_trades']} | 胜率: {r['win_rate']:.1%} | 收益: {r['total_return']:.2%}")
            y += 1
            self.stdscr.addstr(y, 0, f"余额: ${r['balance']:.2f} | 夏普: {r['sharpe']:.2f} | 回撤: {r['drawdown']:.1%}")
            y += 2

        # 汇总最佳
        if results:
            best = max(results, key=lambda x: x['total_return'])
            self.stdscr.addstr(y, 0, "=" * 40, curses.color_pair(2))
            y += 1
            self.stdscr.addstr(y, 0, f"最佳: {best['strategy']} / {best['interval']} | 收益: {best['total_return']:.2%}", curses.color_pair(2))
            y += 1

        self.stdscr.addstr(y + 1, 0, "[Enter] 重新开始  [Esc] 退出", curses.color_pair(5))
        self.stdscr.refresh()

        while True:
            key = self.stdscr.getch()
            if key in [curses.KEY_ENTER, 10, 13]:
                return True
            elif key == 27:
                return False


def get_available_coins():
    """获取可用的币种"""
    data_dir = os.path.join(os.path.dirname(__file__), '..', 'src', 'backtest', 'data')
    if os.path.exists(data_dir):
        files = [f.replace('.json', '') for f in os.listdir(data_dir) if f.endswith('.json')]
        if files:
            return sorted(files)
    return ['ETH', 'BTC', 'SOL', 'ARB', 'AVAX', 'MATIC', 'LINK', 'UNI', 'ATOM', 'LTC', 'XLM', 'ADA', 'DOT', 'DOGE']


def main(stdscr):
    menu = MenuSystem(stdscr)

    while True:
        # 步骤1: 选择币种 (多选)
        coins = get_available_coins()
        selected_coins = menu.navigate_options(coins, "选择交易币种 [空格多选]", multi=True)
        if selected_coins is None:
            break
        if not selected_coins:
            continue

        # 步骤2: 选择策略 (多选)
        strategies = list_strategies()
        selected_strategies = menu.navigate_options(strategies, "选择策略 [空格多选]", multi=True)
        if selected_strategies is None:
            continue
        if not selected_strategies:
            continue

        # 步骤3: 选择时间周期 (多选)
        intervals = ["1m", "5m", "15m", "1h", "4h"]
        selected_intervals = menu.navigate_options(intervals, "选择时间周期 [空格多选]", multi=True)
        if selected_intervals is None:
            continue
        if not selected_intervals:
            continue

        # 步骤4: 回测时长
        days = menu.get_number("回测时长 (天数)", 1095)
        if days is None:
            continue

        # 步骤5: 是否启用 TTP
        enable_ttp = menu.get_yes_no("是否启用移动止盈 (TTP)", True)
        if enable_ttp is None:
            continue

        # 步骤6: 是否启用自动提款
        enable_withdraw = menu.get_yes_no("是否启用自动提款", False)
        if enable_withdraw is None:
            continue

        # 运行回测 - 遍历所有组合
        stdscr.clear()
        stdscr.addstr(0, 0, "正在运行回测，请稍候...")
        stdscr.refresh()

        from backtest.backtest import run_backtest
        results = []

        total = len(selected_coins) * len(selected_strategies) * len(selected_intervals)
        current = 0

        for coin in selected_coins:
            for strategy in selected_strategies:
                for interval in selected_intervals:
                    current += 1
                    stdscr.addstr(1, 0, f"进度: {current}/{total} ({coin} / {strategy} / {interval})")
                    stdscr.refresh()

                    try:
                        result = run_backtest(
                            coin=coin,
                            strategy_name=strategy,
                            interval=interval,
                            days=days,
                            initial_capital=1000
                        )

                        results.append({
                            'coin': coin,
                            'strategy': strategy,
                            'interval': interval,
                            'total_trades': result.total_trades,
                            'win_rate': result.win_rate,
                            'total_return': result.total_return,
                            'balance': result.final_balance,
                            'sharpe': result.sharpe_ratio,
                            'drawdown': result.max_drawdown,
                        })
                    except Exception as e:
                        pass

        # 显示结果
        restart = menu.show_results(results)
        if not restart:
            break


if __name__ == "__main__":
    try:
        curses.wrapper(main)
    except Exception as e:
        print(f"错误: {e}")
        import traceback
        traceback.print_exc()
        input("按回车键退出...")
