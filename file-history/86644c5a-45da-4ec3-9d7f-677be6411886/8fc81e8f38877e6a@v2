#!/bin/bash
# Abby Auto Trading - 交易系统
# 双击运行

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

cd "$PROJECT_DIR"

python3 -c "
import sys
sys.path.insert(0, 'src')

from trading.system import TradingSystem
from exchange.hyperliquid.adapter import HyperLiquidAdapter
from exchange.hyperliquid.accounts import get_adapter_config
from core.strategy import get_strategy

# 获取账号配置
config = get_adapter_config('default', 'testnet')
config['testnet'] = True

# 创建适配器
adapter = HyperLiquidAdapter(config)
adapter.connect()

# 获取策略
strategy = get_strategy('vwap')

# 创建交易系统
system = TradingSystem(
    exchange=adapter,
    strategy=strategy,
    config={'coin': 'ETH', 'leverage': 10}
)

print('=' * 50)
print('交易系统启动')
print('=' * 50)
print(f'交易所: {adapter.get_exchange_name()}')
print(f'策略: {strategy.name}')
print(f'余额: \${adapter.get_balance().get(\"usdc\", 0):.2f}')
print('=' * 50)

# 运行一次
result = system.run_once()
print(f'信号: {result.get(\"signal\")}')
print(f'操作: {result.get(\"action\")}')
print(f'持仓: {result.get(\"position\")}')

adapter.disconnect()
print('交易系统已停止')
"

read -p "按回车键退出..."
