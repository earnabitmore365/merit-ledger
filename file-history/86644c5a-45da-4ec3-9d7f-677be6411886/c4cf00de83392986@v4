#!/usr/bin/env python3
"""
Risk Manager Base

风险管理基类
所有风险管理模块都必须实现以下接口
"""

from abc import ABC, abstractmethod
from dataclasses import dataclass, field
from typing import Dict, List, Optional


# ==================== 配置类定义 ====================

@dataclass
class RiskConfig:
    """风险管理配置
    
    Attributes:
        stop_loss_pct: 止损比例（如 0.10 表示亏损 10% 平仓）
        ttp_enabled: 是否启用移动止盈
        ttp_buffer_pips: 移动止盈缓冲（pips）
        max_position_pct: 最大仓位比例
        trailing_stop_pct: 跟踪止损比例
    """
    stop_loss_pct: float = 0.10
    ttp_enabled: bool = True
    ttp_buffer_pips: float = 5.0
    max_position_pct: float = 0.5
    trailing_stop_pct: float = 0.0


# ==================== 结果类定义 ====================

@dataclass
class RiskCheckResult:
    """风险检查结果
    
    Attributes:
        should_close: 是否应该平仓
        reason: 平仓原因
        confidence: 置信度 0-1
        ttp_level: 移动止盈触发价位
    """
    should_close: bool = False
    reason: str = ""
    confidence: float = 1.0
    ttp_level: Optional[float] = None


# ==================== 风险管理基类 ====================

class RiskManager(ABC):
    """风险管理基类
    
    所有风险管理模块都必须继承此类
    负责检查持仓风险，判断是否需要平仓
    
    Usage:
        class StopLossManager(RiskManager):
            def check(self, position: Dict, current_price: float) -> RiskCheckResult:
                ...
    """
    
    def __init__(self, config: RiskConfig = None):
        """初始化
        
        Args:
            config: 风险管理配置
        """
        self.config = config or RiskConfig()
    
    @abstractmethod
    def check(
        self,
        position: Dict,
        current_price: float,
        **kwargs
    ) -> RiskCheckResult:
        """风险检查（子类必须实现）
        
        Args:
            position: 持仓信息
            current_price: 当前价格
            **kwargs: 附加参数
        
        Returns:
            RiskCheckResult: 检查结果
        """
        pass
    
    def reset(self) -> None:
        """重置状态"""
        pass
    
    def __repr__(self) -> str:
        """字符串表示"""
        return f"<{self.__class__.__name__}: stop_loss={self.config.stop_loss_pct}>"


# ==================== 风险管理工厂 ====================

class RiskManagerFactory:
    """风险管理工厂
    
    用于创建风险管理实例
    """
    
    _managers = {}
    
    @classmethod
    def register(cls, name: str, manager_class: type):
        """注册风险管理类
        
        Args:
            name: 名称
            manager_class: 管理类
        """
        cls._managers[name.lower()] = manager_class
    
    @classmethod
    def create(cls, name: str, config: RiskConfig = None) -> RiskManager:
        """创建风险管理实例
        
        Args:
            name: 风险管理类型
            config: 配置
        
        Returns:
            RiskManager: 风险管理实例
        """
        name_lower = name.lower()
        if name_lower in cls._managers:
            return cls._managers[name_lower](config)
        raise ValueError(f"Unknown risk manager: {name}")
    
    @classmethod
    def list_managers(cls) -> List[str]:
        """列出所有可用的风险管理类型"""
        return list(cls._managers.keys())


# ==================== 自动注册风险管理类 ====================

# 导入所有风险管理模块（自动注册）
from . import stop_loss
from . import ttp
from . import combined

# 自动注册：遍历所有 RiskManager 子类
for _cls in RiskManager.__subclasses__():
    _name = _cls.__name__.replace('Manager', '').lower()
    RiskManagerFactory.register(_name, _cls)
