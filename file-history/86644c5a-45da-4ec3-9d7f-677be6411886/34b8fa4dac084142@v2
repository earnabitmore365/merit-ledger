#!/usr/bin/env python3
"""
Test Strategy - 测试策略

用于测试交易系统：
- 运行15秒后开始发送信号
- 每隔10秒发送一次信号
- 信号序列：BUY → SELL → BUY → SELL → BUY → SELL → BUY → SELL

Features:
- 测试开仓、反手记录
- 测试盈亏统计

Usage:
    在菜单中选择 "test" 策略
"""

from typing import Dict, List, Optional
from dataclasses import dataclass
import time

from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class TestConfig:
    """Test strategy configuration"""
    wait_seconds: int = 15  # 初始等待秒数
    interval_seconds: int = 10  # 信号间隔秒数


class TestStrategy(Strategy):
    """Test strategy for debugging"""

    def __init__(self, exchange=None, config: Optional[TestConfig] = None):
        self.name = "test"
        self.config = config or TestConfig()
        self.exchange = exchange
        self.start_time = None
        self.signal_index = 0

        # 信号序列
        self.signal_sequence = [
            Signal.BUY,
            Signal.SELL,
            Signal.BUY,
            Signal.SELL,
            Signal.BUY,
            Signal.SELL,
            Signal.BUY,
            Signal.SELL,
        ]

    def generate_signal(self, coin: str, klines: List[Dict]) -> Signal:
        """生成信号

        Args:
            coin: 币种
            klines: K线数据

        Returns:
            Signal: 信号
        """
        current_time = time.time()

        # 初始化开始时间
        if self.start_time is None:
            self.start_time = current_time

        # 计算已运行秒数
        elapsed = current_time - self.start_time

        # 前15秒返回 HOLD
        if elapsed < self.config.wait_seconds:
            return Signal.HOLD

        # 计算应该发送第几个信号
        signal_time = elapsed - self.config.wait_seconds
        index = int(signal_time // self.config.interval_seconds)

        # 如果信号发完了，返回 HOLD
        if index >= len(self.signal_sequence):
            return Signal.HOLD

        return self.signal_sequence[index]

    def get_params(self) -> Dict:
        """获取参数"""
        return {
            "wait_seconds": self.config.wait_seconds,
            "interval_seconds": self.config.interval_seconds,
        }

    def set_params(self, **params):
        """设置参数"""
        if "wait_seconds" in params:
            self.config.wait_seconds = params["wait_seconds"]
        if "interval_seconds" in params:
            self.config.interval_seconds = params["interval_seconds"]
