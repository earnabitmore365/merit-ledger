#!/bin/bash
# Abby Auto Trading - 回测系统
# 双击运行

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

cd "$PROJECT_DIR"

python3 -c "
import sys
sys.path.insert(0, 'src')

from core.strategy import list_strategies

print('=' * 60)
print('🔷 Abby 回测系统')
print('=' * 60)
print()

# 1. 选择币种
print('📌 选择交易币种:')
print('  1) ETH')
print('  2) BTC')
print('  3) SOL')
coin_choice = input('请选择 (1-3) [默认: 1]: ').strip() or '1')
coins = {'1': 'ETH', '2': 'BTC', '3': 'SOL'}
coin = coins.get(coin_choice, 'ETH')
print(f'  ➜ 已选择: {coin}')
print()

# 2. 选择策略
print('📌 选择策略:')
strategies = list_strategies()
for i, s in enumerate(strategies[:10], 1):  # 显示前10个
    print(f'  {i}) {s}')
if len(strategies) > 10:
    print(f'  ... 共 {len(strategies)} 个策略')
strategy_choice = input('请选择策略名称 [默认: vwap]: ').strip() or 'vwap'
strategy = strategy_choice if strategy_choice in strategies else 'vwap'
print(f'  ➜ 已选择: {strategy}')
print()

# 3. 选择时间周期
print('📌 选择时间周期:')
print('  1) 1m   (1分钟)')
print('  2) 5m   (5分钟)')
print('  3) 15m  (15分钟)')
print('  4) 1h   (1小时)')
print('  5) 4h   (4小时)')
interval_choice = input('请选择 (1-5) [默认: 4]: ').strip() or '4'
intervals = {'1': '1m', '2': '5m', '3': '15m', '4': '1h', '5': '4h'}
interval = intervals.get(interval_choice, '1h')
print(f'  ➜ 已选择: {interval}')
print()

# 4. 选择回测时长
print('📌 选择回测时长:')
print('  1) 30 天')
print('  2) 90 天')
print('  3) 180 天')
print('  4) 365 天 (1年)')
print('  5) 1095 天 (3年)')
days_choice = input('请选择 (1-5) [默认: 4]: ').strip() or '4'
days_map = {'1': 30, '2': 90, '3': 180, '4': 365, '5': 1095}
days = days_map.get(days_choice, 365)
print(f'  ➜ 已选择: {days} 天')
print()

# 5. 初始资金
initial_capital = input('请输入初始资金 [默认: 1000]: ').strip() or '1000'
initial_capital = float(initial_capital)
print(f'  ➜ 已选择: \${initial_capital}')
print()

# 6. 是否启用 TTP
ttp_choice = input('是否启用移动止盈 (TTP)? (y/n) [默认: y]: ').strip() or 'y'
enable_ttp = ttp_choice.lower() in ['y', 'yes']
print(f'  ➜ 已选择: {\"启用\" if enable_ttp else \"禁用\"}')
print()

# 7. 是否启用自动提款
withdraw_choice = input('是否启用自动提款? (y/n) [默认: n]: ').strip() or 'n'
enable_withdraw = withdraw_choice.lower() in ['y', 'yes']
print(f'  ➜ 已选择: {\"启用\" if enable_withdraw \"禁用\"}')
print()

print('=' * 60)
print('🚀 开始回测...')
print('=' * 60)
print()

# 运行回测
from backtest.backtest import run_backtest

result = run_backtest(
    coin=coin,
    strategy_name=strategy,
    interval=interval,
    days=days,
    initial_capital=initial_capital
)

print()
print('=' * 60)
print('📊 回测结果')
print('=' * 60)
print(f'策略: {strategy}')
print(f'周期: {interval}')
print(f'时长: {days} 天')
print('-' * 60)
print(f'总交易次数: {result.total_trades}')
print(f'盈利交易: {result.winning_trades}')
print(f'亏损交易: {result.losing_trades}')
print(f'胜率: {result.win_rate:.2%}')
print('-' * 60)
print(f'总收益率: {result.total_return:.2%}')
print(f'最终余额: \${result.final_balance:.2f}')
print(f'最大余额: \${result.max_balance:.2f}')
print(f'最小余额: \${result.min_balance:.2f}')
print('-' * 60)
print(f'夏普比率: {result.sharpe_ratio:.2f}')
print(f'索提诺比率: {result.sortino_ratio:.2f}')
print(f'卡玛比率: {result.calmar_ratio:.2f}')
print(f'最大回撤: {result.max_drawdown:.2%}')
print('=' * 60)
"

read -p "按回车键退出..."
