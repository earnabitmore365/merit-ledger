#!/usr/bin/env python3
"""
Abby 回测系统 - 交互式菜单
使用上下键选择，空格键多选，Enter确定，Esc返回/退出
"""

import sys
import os

# 添加项目路径
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'src'))

try:
    import curses
except ImportError:
    try:
        import subprocess
        subprocess.run([sys.executable, '-m', 'pip', 'install', 'windows-curses'], check=True)
        import curses
    except:
        print("请安装 curses 库: pip install windows-curses")
        sys.exit(1)

from core.strategy import list_strategies


class MenuSystem:
    def __init__(self, stdscr):
        self.stdscr = stdscr
        self.stdscr.nodelay(False)
        self.stdscr.keypad(True)
        self.selected_indices = []

        curses.start_color()
        curses.init_pair(1, curses.COLOR_CYAN, curses.COLOR_BLACK)
        curses.init_pair(2, curses.COLOR_GREEN, curses.COLOR_BLACK)
        curses.init_pair(3, curses.COLOR_YELLOW, curses.COLOR_BLACK)
        curses.init_pair(4, curses.COLOR_WHITE, curses.COLOR_BLACK)
        curses.init_pair(5, curses.COLOR_RED, curses.COLOR_BLACK)
        curses.init_pair(6, curses.COLOR_MAGENTA, curses.COLOR_BLACK)

        self.height, self.width = stdscr.getmaxyx()

    def draw_header(self, selections):
        """绘制已选择的信息"""
        self.stdscr.attron(curses.color_pair(1) | curses.A_BOLD)
        self.stdscr.addstr(0, 0, " " + "=" * (self.width - 2) + " ")
        title = " Abby 回测系统 "
        self.stdscr.addstr(1, (self.width - len(title)) // 2, title)
        self.stdscr.addstr(2, 0, " " + "=" * (self.width - 2) + " ")
        self.stdscr.attroff(curses.color_pair(1) | curses.A_BOLD)

        # 显示已选择的项目
        y = 4
        if selections:
            self.stdscr.addstr(y, 0, "已选择:", curses.color_pair(3))
            y += 1
            for key, value in selections.items():
                line = f"  {key}: {value}"
                if len(line) > self.width - 1:
                    line = line[:self.width - 4] + "..."
                self.stdscr.addstr(y, 0, line, curses.color_pair(6))
                y += 1
            y += 1

        return y

    def draw_options(self, options, selected_idx, title, multi=False, start_row=7):
        self.stdscr.clear()

        if multi:
            hint = "[上下键] 移动  [空格] 选择/取消  [Enter] 确定  [Esc] 返回"
        else:
            hint = "[上下键] 移动  [Enter] 确定  [Esc] 返回"
        self.stdscr.addstr(4, 0, hint, curses.color_pair(5))
        self.stdscr.addstr(5, 0, "-" * (self.width - 1))

        if multi and self.selected_indices:
            self.stdscr.addstr(6, 0, f"已选择: {len(self.selected_indices)} 项", curses.color_pair(3))

        for i, option in enumerate(options):
            y = start_row + i
            if y >= self.height - 1:
                break

            if i == selected_idx:
                if multi:
                    mark = "[x]" if i in self.selected_indices else "[ ]"
                else:
                    mark = ">>"
                self.stdscr.attron(curses.color_pair(2) | curses.A_REVERSE)
                self.stdscr.addstr(y, 2, f"{mark} {option}")
                self.stdscr.attroff(curses.color_pair(2) | curses.A_REVERSE)
            else:
                if multi:
                    mark = "[x]" if i in self.selected_indices else "[ ]"
                else:
                    mark = "  "
                self.stdscr.addstr(y, 2, f"{mark} {option}", curses.color_pair(4))

        self.stdscr.refresh()

    def navigate_options(self, options, title, multi=False, selections=None, searchable=False):
        self.selected_indices = []
        search_query = ""
        selected_idx = 0
        max_visible = self.height - 15
        offset = 0

        while True:
            # 如果支持搜索，过滤选项
            if searchable and search_query:
                filtered_options = [opt for opt in options if search_query.lower() in opt.lower()]
            else:
                filtered_options = options

            if not filtered_options:
                filtered_options = options

            if selected_idx >= len(filtered_options):
                selected_idx = max(0, len(filtered_options) - 1)

            if selected_idx >= offset + max_visible:
                offset = selected_idx - max_visible + 1
            elif selected_idx < offset:
                offset = selected_idx

            visible_options = filtered_options[offset:offset + max_visible]
            adjusted_idx = selected_idx - offset

            self.stdscr.clear()
            start_y = self.draw_header(selections)
            self.stdscr.addstr(start_y, 0, "-" * (self.width - 1))
            self.stdscr.addstr(start_y + 1, 0, title)

            # 如果支持搜索，显示搜索框
            if searchable:
                self.stdscr.addstr(start_y + 2, 0, "搜索: ", curses.color_pair(3))
                search_display = search_query + "_" * (20 - len(search_query))
                self.stdscr.addstr(start_y + 2, 8, search_display[:20], curses.color_pair(4))
                hint_y = start_y + 3
            else:
                hint_y = start_y + 2

            start_row = hint_y + 2

            if multi:
                hint = "[上下键] 移动  [空格] 选择/取消  [Enter] 确定  [Esc] 返回"
            else:
                hint = "[上下键] 移动  [Enter] 确定  [Esc] 返回"
            if searchable:
                hint += "  [字母] 搜索"
            self.stdscr.addstr(hint_y, 0, hint, curses.color_pair(5))

            if multi and self.selected_indices:
                self.stdscr.addstr(start_row - 1, 0, f"已选择: {len(self.selected_indices)} 项", curses.color_pair(3))

            for i, option in enumerate(visible_options):
                y = start_row + i
                if y >= self.height - 1:
                    break

                real_idx = i + offset
                if real_idx == selected_idx:
                    if multi:
                        mark = "[x]" if real_idx in self.selected_indices else "[ ]"
                    else:
                        mark = ">>"
                    self.stdscr.attron(curses.color_pair(2) | curses.A_REVERSE)
                    self.stdscr.addstr(y, 2, f"{mark} {option}")
                    self.stdscr.attroff(curses.color_pair(2) | curses.A_REVERSE)
                else:
                    if multi:
                        mark = "[x]" if real_idx in self.selected_indices else "[ ]"
                    else:
                        mark = "  "
                    self.stdscr.addstr(y, 2, f"{mark} {option}", curses.color_pair(4))

            self.stdscr.refresh()

            key = self.stdscr.getch()

            if key == curses.KEY_UP:
                if selected_idx > 0:
                    selected_idx -= 1
            elif key == curses.KEY_DOWN:
                if selected_idx < len(filtered_options) - 1:
                    selected_idx += 1
            elif key == ord(' '):
                if multi and filtered_options:
                    real_idx = filtered_options[selected_idx]
                    orig_idx = options.index(real_idx)
                    if orig_idx in self.selected_indices:
                        self.selected_indices.remove(orig_idx)
                    else:
                        self.selected_indices.append(orig_idx)
            elif key in [10, 13]:
                if filtered_options:
                    if multi:
                        if self.selected_indices:
                            return [options[i] for i in self.selected_indices]
                        return [options[0]]
                    else:
                        return filtered_options[selected_idx]
            elif key == 27:  # Esc
                return None
            elif searchable and 32 <= key <= 126:  # 可打印字符
                # 退格键
                if key == 127 or key == 8:
                    search_query = search_query[:-1]
                else:
                    search_query += chr(key)
                selected_idx = 0
                offset = 0

    def get_yes_no(self, title, default=True, selections=None):
        options = ["YES", "NO"]
        selected_idx = 0 if default else 1

        while True:
            self.stdscr.clear()
            self.draw_header(selections)
            y = selections.get('__y', 6) if selections else 6

            self.stdscr.addstr(y, 0, "-" * (self.width - 1))
            self.stdscr.addstr(y + 1, 0, title)
            self.stdscr.addstr(y + 2, 0, "[左右键] 选择  [Enter] 确定  [Esc] 返回", curses.color_pair(5))
            self.stdscr.addstr(y + 3, 0, "-" * (self.width - 1))

            # 并排显示 Yes / No
            opt_y = y + 5
            x_pos = 2
            for i, opt in enumerate(options):
                label = f" [ {opt} ] "
                if i == selected_idx:
                    self.stdscr.attron(curses.color_pair(2) | curses.A_REVERSE)
                    self.stdscr.addstr(opt_y, x_pos, label)
                    self.stdscr.attroff(curses.color_pair(2) | curses.A_REVERSE)
                else:
                    self.stdscr.addstr(opt_y, x_pos, label, curses.color_pair(4))
                x_pos += len(label) + 2  # 移动到下一个位置

            self.stdscr.refresh()
            key = self.stdscr.getch()

            if key == curses.KEY_LEFT:
                selected_idx = max(0, selected_idx - 1)
            elif key == curses.KEY_RIGHT:
                selected_idx = min(len(options) - 1, selected_idx + 1)
            elif key in [10, 13]:
                return selected_idx == 0
            elif key == 27:
                return None

    def get_number(self, title, default, selections=None):
        while True:
            self.stdscr.clear()
            start_y = self.draw_header(selections)

            self.stdscr.addstr(start_y, 0, "-" * (self.width - 1))
            self.stdscr.addstr(start_y + 1, 0, title)
            self.stdscr.addstr(start_y + 2, 0, "[输入数字]  [Enter] 确定  [Esc] 返回", curses.color_pair(5))
            self.stdscr.addstr(start_y + 3, 0, "-" * (self.width - 1))
            self.stdscr.addstr(start_y + 5, 0, f"默认值: {default} (直接回车使用默认值)")
            self.stdscr.addstr(start_y + 7, 0, "输入: ")

            curses.echo()
            try:
                input_str = self.stdscr.getstr(start_y + 7, 8, 20).decode()
                curses.noecho()
                if input_str.strip():
                    return int(input_str)
                return default
            except:
                curses.noecho()
                return default

    def show_results(self, results):
        self.stdscr.clear()
        self.draw_title("回测结果")

        y = 4
        for r in results:
            self.stdscr.addstr(y, 0, "-" * 40, curses.color_pair(3))
            y += 1
            self.stdscr.addstr(y, 0, f"策略: {r['strategy']} | 周期: {r['interval']}")
            y += 1
            self.stdscr.addstr(y, 0, f"交易: {r['total_trades']} | 胜率: {r['win_rate']:.1%} | 收益: {r['total_return']:.2%}")
            y += 1
            self.stdscr.addstr(y, 0, f"余额: ${r['balance']:.2f} | 夏普: {r['sharpe']:.2f} | 回撤: {r['drawdown']:.1%}")
            y += 2

        if results:
            best = max(results, key=lambda x: x['total_return'])
            self.stdscr.addstr(y, 0, "=" * 40, curses.color_pair(2))
            y += 1
            self.stdscr.addstr(y, 0, f"最佳: {best['strategy']} / {best['interval']} | 收益: {best['total_return']:.2%}", curses.color_pair(2))
            y += 1

        self.stdscr.addstr(y + 1, 0, "[Enter] 重新开始  [Esc] 退出", curses.color_pair(5))
        self.stdscr.refresh()

        while True:
            key = self.stdscr.getch()
            if key in [curses.KEY_ENTER, 10, 13]:
                return True
            elif key == 27:
                return False

    def draw_title(self, title):
        self.stdscr.attron(curses.color_pair(1) | curses.A_BOLD)
        self.stdscr.addstr(0, 0, " " + "=" * (self.width - 2) + " ")
        self.stdscr.addstr(1, (self.width - len(title)) // 2, title)
        self.stdscr.addstr(2, 0, " " + "=" * (self.width - 2) + " ")
        self.stdscr.attroff(curses.color_pair(1) | curses.A_BOLD)


def get_available_coins():
    """获取可用的币种"""
    data_dir = os.path.join(os.path.dirname(__file__), '..', 'src', 'backtest', 'data')
    if os.path.exists(data_dir):
        files = [f.replace('.json', '') for f in os.listdir(data_dir) if f.endswith('.json')]
        if files:
            return sorted(files)
    return ['ETH', 'BTC', 'SOL', 'ARB', 'AVAX', 'MATIC', 'LINK', 'UNI', 'ATOM', 'LTC', 'XLM', 'ADA', 'DOT', 'DOGE']


def main(stdscr):
    menu = MenuSystem(stdscr)

    while True:
        # 存储已选择的项目
        selections = {}

        # 步骤1: 选择币种 (多选)
        coins = get_available_coins()
        selected_coins = menu.navigate_options(coins, "选择交易币种 [空格多选]", multi=True, selections=selections)
        if selected_coins is None:
            break
        if not selected_coins:
            continue
        selections['币种'] = ", ".join(selected_coins)

        # 步骤2: 选择策略 (多选) - 支持搜索
        strategies = list_strategies()
        selected_strategies = menu.navigate_options(strategies, "选择策略 [空格多选, 输入搜索]", multi=True, selections=selections, searchable=True)
        if selected_strategies is None:
            continue
        if not selected_strategies:
            continue
        selections['策略'] = ", ".join(selected_strategies)

        # 步骤3: 选择时间周期 (多选)
        intervals = ["1m", "5m", "15m", "1h", "4h"]
        selected_intervals = menu.navigate_options(intervals, "选择时间周期 [空格多选]", multi=True, selections=selections)
        if selected_intervals is None:
            continue
        if not selected_intervals:
            continue
        selections['周期'] = ", ".join(selected_intervals)

        # 步骤4: 回测时长
        days = menu.get_number("回测时长 (天数)", 1095, selections)
        if days is None:
            continue
        selections['时长'] = f"{days}天"

        # 步骤5: 是否启用 TTP
        enable_ttp = menu.get_yes_no("是否启用移动止盈 (TTP)", True, selections)
        if enable_ttp is None:
            continue
        selections['TTP'] = "开启" if enable_ttp else "关闭"

        # 步骤6: 是否启用自动提款
        enable_withdraw = menu.get_yes_no("是否启用自动提款", False, selections)
        if enable_withdraw is None:
            continue
        selections['提款'] = "开启" if enable_withdraw else "关闭"

        # 运行回测
        stdscr.clear()
        stdscr.addstr(0, 0, "正在运行回测，请稍候...")
        stdscr.refresh()

        from backtest.backtest import run_backtest
        results = []

        total = len(selected_coins) * len(selected_strategies) * len(selected_intervals)
        current = 0

        for coin in selected_coins:
            for strategy in selected_strategies:
                for interval in selected_intervals:
                    current += 1
                    stdscr.addstr(1, 0, f"进度: {current}/{total} ({coin} / {strategy} / {interval})")
                    stdscr.refresh()

                    try:
                        result = run_backtest(
                            coin=coin,
                            strategy_name=strategy,
                            interval=interval,
                            days=days,
                            initial_capital=1000,
                            enable_ttp=enable_ttp,
                            enable_withdraw=enable_withdraw,
                        )

                        results.append({
                            'coin': coin,
                            'strategy': strategy,
                            'interval': interval,
                            'total_trades': result.total_trades,
                            'win_rate': result.win_rate,
                            'total_return': result.total_return,
                            'balance': result.final_balance,
                            'sharpe': result.sharpe_ratio,
                            'drawdown': result.max_drawdown,
                        })
                    except Exception as e:
                        pass

        restart = menu.show_results(results)
        if not restart:
            break


if __name__ == "__main__":
    try:
        curses.wrapper(main)
    except Exception as e:
        print(f"错误: {e}")
        import traceback
        traceback.print_exc()
        input("按回车键退出...")
