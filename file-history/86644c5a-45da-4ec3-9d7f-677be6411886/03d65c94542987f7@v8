#!/usr/bin/env python3
"""
HyperLiquid Adapter

HyperLiquid 交易所适配器
实现交易所适配器基类的所有方法
集成 REST API + WebSocket
"""

import time
import logging
from typing import Dict, List, Optional

from exchange.base import (
    ExchangeAdapter,
    OrderRequest,
    OrderResult,
    OrderSide,
    OrderType,
    Position,
)

from .websocket import create_websocket


# ==================== 配置 ====================

HYPERLIQUID_MAINNET = "https://api.hyperliquid.xyz"
HYPERLIQUID_TESTNET = "https://api.hyperliquid-testnet.xyz"


# ==================== HyperLiquid 适配器 ====================

class HyperLiquidAdapter(ExchangeAdapter):
    """HyperLiquid 交易所适配器

    实现所有交易所适配器接口
    封装 HyperLiquid API 调用

    Usage:
        from config import config_manager

        config = config_manager.load()
        adapter = HyperLiquidAdapter(config['hyperliquid'])
        adapter.connect()
    """

    def __init__(self, config: Dict):
        """初始化

        Args:
            config: HyperLiquid 配置
                # 方式一：直接传入配置
                {
                    'wallet_address': '0x...',
                    'private_key': '0x...',
                    'endpoint': 'https://...',
                    'testnet': True/False,
                }
                # 方式二：使用账号管理（传入账号名称和网络）
                {
                    'account_name': 'default',  # 账号名称
                    'network': 'testnet',       # 网络类型
                }
        """
        super().__init__(config)

        # 支持从账号管理获取配置
        account_name = config.get('account_name')
        network = config.get('network', 'testnet')

        if account_name:
            # 从账号管理获取配置
            from .accounts import get_adapter_config
            account_config = get_adapter_config(account_name, network)
            self.wallet_address = account_config.get('wallet_address', '')
            self.private_key = account_config.get('private_key', '')
            self.testnet = account_config.get('testnet', True)
        else:
            # 直接使用配置
            self.wallet_address = config.get('wallet_address', '')
            self.private_key = config.get('private_key', '')
            self.testnet = config.get('testnet', True)

        # 设置 endpoint
        if self.testnet:
            self.endpoint = config.get('endpoint', HYPERLIQUID_TESTNET)
        else:
            self.endpoint = config.get('endpoint', HYPERLIQUID_MAINNET)

        # SDK 实例
        self._info = None
        self._exchange = None

        # WebSocket 实例
        self._ws = None

        # 日志
        self.logger = logging.getLogger("HyperLiquidAdapter")

    # ==================== 连接管理 ====================

    def connect(self) -> bool:
        """连接 HyperLiquid

        Returns:
            bool: 是否连接成功
        """
        try:
            from hyperliquid.info import Info
            from hyperliquid.exchange import Exchange
            from eth_account import Account

            # 创建 Info 实例
            self._info = Info(self.endpoint, skip_ws=True)

            if self.private_key:
                # 创建钱包账户
                wallet = Account.from_key(self.private_key)
                self._exchange = Exchange(wallet, self.endpoint)

            self._connected = True

            self.logger.info(f"连接 HyperLiquid: {self.endpoint}")

            # 启用 WebSocket
            self._init_websocket()

            return True

        except Exception as e:
            self.logger.error(f"连接失败: {e}")
            return False

            self._connected = True

            self.logger.info(f"连接 HyperLiquid: {self.endpoint}")

            # 启用 WebSocket
            self._init_websocket()

            return True

        except Exception as e:
            self.logger.error(f"连接失败: {e}")
            return False

    def disconnect(self) -> None:
        """断开连接"""
        # 关闭 WebSocket
        self._close_websocket()

        self._info = None
        self._exchange = None
        self._connected = False
        self.logger.info("已断开 HyperLiquid 连接")

    # ==================== WebSocket ====================

    def _init_websocket(self):
        """初始化 WebSocket"""
        from .websocket import create_websocket

        def on_message(data):
            self.logger.debug(f"WebSocket 消息: {data}")

        self._ws = create_websocket(
            testnet=self.testnet,
            on_message=on_message,
        )

        if self._ws.connect():
            self.logger.info(f"WebSocket 已连接: {'测试网' if self.testnet else '主网'}")
        else:
            self.logger.warning("WebSocket 连接失败，将使用 REST API")

    def _close_websocket(self):
        """关闭 WebSocket"""
        if self._ws:
            self._ws.disconnect()
            self._ws = None
            self.logger.info("WebSocket 已断开")

    def health_check(self) -> bool:
        """健康检查

        Returns:
            bool: 交易所是否健康
        """
        try:
            if not self._connected:
                return False

            # 尝试获取余额
            balance = self.get_balance()
            return 'usdc' in balance

        except Exception as e:
            self.logger.error(f"健康检查失败: {e}")
            return False

    # ==================== 行情数据 ====================

    def get_price(self, coin: str) -> float:
        """获取当前价格

        Args:
            coin: 币种名称（如 "ETH"）

        Returns:
            float: 当前价格
        """
        try:
            if not self._info:
                return 0.0

            meta = self._info.meta_and_asset_ctxs()
            if isinstance(meta, list) and len(meta) >= 2:
                universe = meta[0].get('universe', []) if isinstance(meta[0], dict) else []
                asset_ctxs = meta[1] if isinstance(meta[1], list) else []

                # 找到币种的索引
                coin_idx = None
                for i, item in enumerate(universe):
                    if isinstance(item, dict) and item.get('name') == coin:
                        coin_idx = i
                        break

                # 获取价格
                if coin_idx is not None and coin_idx < len(asset_ctxs):
                    ctx = asset_ctxs[coin_idx]
                    if ctx.get('midPx'):
                        return float(ctx['midPx'])

            return 0.0

        except Exception as e:
            self.logger.error(f"获取价格失败: {e}")
            return 0.0

    def get_klines(
        self,
        coin: str,
        interval: str = "1h",
        limit: int = 100
    ) -> List[Dict]:
        """获取 K 线数据

        Args:
            coin: 币种名称
            interval: K 线周期（1m, 5m, 15m, 1h, 4h）
            limit: 获取数量

        Returns:
            List[Dict]: K 线数据列表
        """
        try:
            if not self._info:
                return []

            end_time = int(time.time() * 1000)

            # 时间间隔映射
            interval_map = {
                '1m': 60,
                '5m': 5 * 60,
                '15m': 15 * 60,
                '1h': 60 * 60,
                '4h': 4 * 60 * 60,
            }

            seconds_per_candle = interval_map.get(interval, 60 * 60)
            start_time = end_time - (limit * seconds_per_candle * 1000)

            # 获取 K 线
            candles = self._info.candles_snapshot(
                coin,
                interval,
                start_time,
                end_time
            )

            # 转换为标准格式
            result = []
            for c in candles:
                result.append({
                    'timestamp': c['t'],
                    'time': c['t'],
                    'open': float(c['o']),
                    'high': float(c['h']),
                    'low': float(c['l']),
                    'close': float(c['c']),
                    'volume': float(c['v']),
                })

            return result[-limit:] if limit else result

        except Exception as e:
            self.logger.error(f"获取 K 线失败: {e}")
            return []

    def get_available_coins(self) -> List[Dict]:
        """获取所有可交易的币种

        Returns:
            List[Dict]: 币种信息列表
        """
        try:
            if not self._info:
                return []

            meta = self._info.meta_and_asset_ctxs()
            if isinstance(meta, list) and len(meta) > 0:
                universe = meta[0].get('universe', [])
                return [
                    {
                        'name': u.get('name', ''),
                        'max_leverage': u.get('maxLeverage', 10),
                        'sz_decimals': u.get('szDecimals', 2),
                    }
                    for u in universe if u.get('name')
                ]

            return []

        except Exception as e:
            self.logger.error(f"获取币种列表失败: {e}")
            return []

    def get_coin_names(self) -> List[str]:
        """获取所有可交易的币种名称

        Returns:
            List[str]: 币种名称列表
        """
        coins = self.get_available_coins()
        return [c['name'] for c in coins]

    # ==================== 订单操作 ====================

    def place_order(self, order: OrderRequest) -> OrderResult:
        """下单

        Args:
            order: 订单请求

        Returns:
            OrderResult: 订单结果

        Note:
            HyperLiquid 没有真正的市价单。
            市价单使用 IOC + 价格偏移实现：
            - 买单：当前价格 * (1 + offset)，offset 默认 1-3%
            - 卖单：当前价格 * (1 - offset)
        """
        try:
            if not self._exchange:
                # 模拟模式
                return OrderResult(
                    success=True,
                    order_id=f"sim_{int(time.time() * 1000)}",
                    message="模拟成交",
                    filled_price=order.price or self.get_price(order.coin),
                )

            # 构建订单参数
            is_buy = order.side == OrderSide.BUY

            # 导入 HyperLiquid 的 OrderType（使用别名避免冲突）
            from hyperliquid.utils.signing import OrderType as HLOrderType
            from hyperliquid.utils.signing import LimitOrderType, Order

            # 数量四舍五入到有效位数（HyperLiquid 要求）
            order.size = round(order.size, 4)

            # 计算价格
            current_price = self.get_price(order.coin)
            order_price = order.price

            # 如果是市价单，使用 IOC + 价格偏移
            if order.order_type == OrderType.MARKET:
                # 价格偏移比例 (1-3%)，默认 2%
                offset = getattr(order, 'ioc_offset', None) or 0.02

                if is_buy:
                    # 买单：当前价格 * (1 + offset)
                    order_price = current_price * (1 + offset)
                else:
                    # 卖单：当前价格 * (1 - offset)
                    order_price = current_price * (1 - offset)

                # 使用 IOC 立即成交或取消
                order_type = Order(
                    limit=LimitOrderType(tif='Ioc')
                )
                reduce_only = getattr(order, 'reduce_only', False)
            else:
                # 限价单使用 GTC
                order_type = Order(
                    limit=LimitOrderType(tif='Gtc')
                )
                reduce_only = getattr(order, 'reduce_only', False)

            if order.order_type == OrderType.MARKET:
                # IOC 市价单
                order_result = self._exchange.order(
                    name=order.coin,
                    is_buy=is_buy,
                    sz=order.size,
                    limit_px=order_price,
                    order_type=order_type,
                    reduce_only=reduce_only,
                )
            else:
                # 限价单
                order_result = self._exchange.order(
                    name=order.coin,
                    is_buy=is_buy,
                    sz=order.size,
                    limit_px=order_price or 0,
                    order_type=order_type,
                    reduce_only=reduce_only,
                )

            # 处理返回结果
            # IOC 订单可能立即成交，返回格式可能不同
            if isinstance(order_result, dict):
                if 'id' in order_result:
                    order_id = str(order_result['id'])
                    message = "下单成功"
                elif 'status' in order_result:
                    order_id = str(order_result.get('orderId', ''))
                    message = order_result.get('status', '已下单')
                else:
                    # 可能立即成交了
                    order_id = str(order_result.get('response', {}).get('type', ''))
                    message = f"订单响应: {order_result}"
            else:
                order_id = str(order_result)
                message = "下单成功"

            return OrderResult(
                success=True,
                order_id=order_id,
                message=message,
                filled_price=order_price,
            )

        except Exception as e:
            self.logger.error(f"下单失败: {e}")
            return OrderResult(
                success=False,
                message=str(e),
            )

    def cancel_order(self, order_id: str) -> bool:
        """取消订单

        Args:
            order_id: 订单 ID

        Returns:
            bool: 是否成功
        """
        try:
            if not self._exchange:
                return True

            self._exchange.cancel(order_id)
            return True

        except Exception as e:
            self.logger.error(f"取消订单失败: {e}")
            return False

    def get_order_status(self, order_id: str) -> Dict:
        """查询订单状态

        Args:
            order_id: 订单 ID

        Returns:
            Dict: 订单状态
        """
        try:
            if not self._info:
                return {}

            status = self._exchange.order_status(order_id)
            return status

        except Exception as e:
            self.logger.error(f"查询订单状态失败: {e}")
            return {}

    # ==================== 持仓管理 ====================

    def get_positions(self) -> List[Position]:
        """获取所有持仓

        Returns:
            List[Position]: 持仓列表
        """
        try:
            if not self._info:
                return []

            user_state = self._info.user_state(self.wallet_address)
            positions = []

            asset_positions = user_state.get("assetPositions", [])

            for pos in asset_positions:
                p = pos.get("position", {})
                coin = p.get("coin", "")
                size = float(p.get("szi", 0))

                if size != 0:
                    side = "LONG" if size > 0 else "SHORT"

                    positions.append(Position(
                        coin=coin,
                        side=side,
                        size=abs(size),
                        entry_price=float(p.get("entryPx", 0)),
                        unrealized_pnl=float(p.get("unrealizedPnl", 0)),
                    ))

            return positions

        except Exception as e:
            self.logger.error(f"获取持仓失败: {e}")
            return []

    def get_position(self, coin: str) -> Optional[Position]:
        """获取指定币种持仓

        Args:
            coin: 币种名称

        Returns:
            Optional[Position]: 持仓信息，不存在返回 None
        """
        positions = self.get_positions()
        for pos in positions:
            if pos.coin == coin:
                return pos
        return None

    # ==================== 账户管理 ====================

    def get_balance(self) -> Dict:
        """获取账户余额（统一账户，现货+合约合并）

        HyperLiquid 是统一账户，现货和合约共享资金。
        查询余额时自动合并，返回总余额。

        Returns:
            Dict: 余额信息
        """
        try:
            if not self._info:
                return {'usdc': 0.0, 'available': 0.0}

            # ===== 1. 现货余额 =====
            spot_state = self._info.spot_user_state(self.wallet_address)
            balances = spot_state.get("balances", [])

            spot_usdc = 0.0
            token_to_available = spot_state.get("tokenToAvailableAfterMaintenance", [])

            for balance in balances:
                if balance.get("coin") == "USDC":
                    spot_usdc = float(balance.get("total", 0))
                    break

            # ===== 2. 合约余额 =====
            perp_state = self._info.user_state(self.wallet_address)
            margin = perp_state.get("marginSummary", {})
            perp_usdc = float(margin.get("accountValue", 0))

            # ===== 3. 统一账户：合并余额 =====
            # HyperLiquid 是统一账户，现货和合约共享资金
            total_usdc = spot_usdc + perp_usdc
            total_available = total_usdc  # 可用等于总额

            return {
                'usdc': total_usdc,         # 总余额
                'available': total_available,  # 可用余额
            }

        except Exception as e:
            self.logger.error(f"获取余额失败: {e}")
            return {'usdc': 0.0, 'available': 0.0}

    def close_position(self, coin: str) -> OrderResult:
        """平仓

        Args:
            coin: 币种名称

        Returns:
            OrderResult: 平仓结果
        """
        try:
            if not self._exchange:
                return OrderResult(
                    success=True,
                    message="模拟平仓",
                )

            # 先获取当前持仓
            position = self.get_position(coin)
            if not position:
                return OrderResult(
                    success=False,
                    message="无持仓",
                )

            # 下反向订单平仓
            is_buy = position.side == "SHORT"  # 空头需要买入平仓

            # 使用 IOC + 价格偏移模拟市价单平仓
            order = OrderRequest(
                coin=coin,
                side=OrderSide.BUY if is_buy else OrderSide.SELL,
                order_type=OrderType.MARKET,
                size=position.size,
            )
            order.ioc_offset = 0.01  # 平仓用 1% 偏移
            order.reduce_only = True

            return self.place_order(order)

        except Exception as e:
            self.logger.error(f"平仓失败: {e}")
            return OrderResult(
                success=False,
                message=str(e),
            )

    def reverse_position(self, coin: str) -> OrderResult:
        """反手：平掉当前持仓并反向开仓

        HyperLiquid 没有真正的市价单，反手逻辑：
        1. 使用 reduceOnly 平仓
        2. 等待确认平仓
        3. 使用 IOC + 价格偏移开新仓

        Args:
            coin: 币种名称

        Returns:
            OrderResult: 反手结果

        Note:
            IOC 价格偏移比例默认 2%，即：
            - 买单：当前价格 * 1.02
            - 卖单：当前价格 * 0.98
        """
        try:
            # 1. 获取当前持仓
            position = self.get_position(coin)
            if not position:
                return OrderResult(
                    success=False,
                    message="无持仓，无法反手",
                )

            # 2. 平仓（使用 reduceOnly）
            self.logger.info(f"反手：平仓 {coin} {position.side} {position.size}")
            close_result = self.close_position(coin)

            if not close_result.success:
                return OrderResult(
                    success=False,
                    message=f"平仓失败: {close_result.message}",
                )

            # 等待平仓确认
            time.sleep(1)

            # 3. 获取余额计算新仓位
            balance = self.get_balance().get('usdc', 0)
            if balance <= 0:
                return OrderResult(
                    success=False,
                    message="余额不足，无法开仓",
                )

            # 4. 计算新仓位
            current_price = self.get_price(coin)
            if current_price <= 0:
                return OrderResult(
                    success=False,
                    message="无法获取当前价格",
                )

            # 使用配置的比例和杠杆
            position_pct = self.config.get('position_pct', 0.1)
            leverage = self.config.get('leverage', 10.0)
            trade_capital = balance * position_pct
            size = (trade_capital * leverage) / current_price

            # 5. 反向开仓
            new_side = OrderSide.SELL if position.side == "LONG" else OrderSide.BUY
            is_buy = new_side == OrderSide.BUY

            self.logger.info(
                f"反手：开仓 {'买入' if is_buy else '卖出'} {coin} "
                f"数量: {size:.4f} @ ${current_price:.2f}"
            )

            # 使用 IOC + 价格偏移下单
            order = OrderRequest(
                coin=coin,
                side=new_side,
                order_type=OrderType.MARKET,
                size=size,
            )
            # 设置 IOC 偏移比例
            order.ioc_offset = 0.02  # 2%

            open_result = self.place_order(order)

            if open_result.success:
                self.logger.info(f"反手成功: {coin}")
                return OrderResult(
                    success=True,
                    order_id=open_result.order_id,
                    message="反手成功",
                    filled_price=open_result.filled_price,
                    filled_size=size,
                )
            else:
                return OrderResult(
                    success=False,
                    message=f"开仓失败: {open_result.message}",
                )

        except Exception as e:
            self.logger.error(f"反手失败: {e}")
            return OrderResult(
                success=False,
                message=str(e),
            )

    def set_leverage(self, coin: str, leverage: int = 10) -> bool:
        """设置杠杆

        Args:
            coin: 币种名称
            leverage: 杠杆倍数

        Returns:
            bool: 是否成功
        """
        try:
            if not self._exchange:
                return True

            self._exchange.update_leverage(leverage, coin)
            return True

        except Exception as e:
            self.logger.error(f"设置杠杆失败: {e}")
            return False

    # ==================== 价格获取 ====================

    def get_price(self, coin: str) -> float:
        """获取当前价格

        优先用 WebSocket，如果没有就用 REST API

        Args:
            coin: 币种名称（如 "ETH"）

        Returns:
            float: 当前价格
        """
        # 1. 尝试用 WebSocket
        if self._ws and self._ws.is_connected:
            price = self._ws.get_price(coin)
            if price:
                return price

        # 2. 回退到 REST API
        return self._get_price_rest(coin)

    def _get_price_rest(self, coin: str) -> float:
        """REST API 获取价格"""
        try:
            if not self._info:
                return 0.0

            meta = self._info.meta_and_asset_ctxs()
            if isinstance(meta, list) and len(meta) >= 2:
                universe = meta[0].get('universe', []) if isinstance(meta[0], dict) else []
                asset_ctxs = meta[1] if isinstance(meta[1], list) else []

                # 找到币种的索引
                coin_idx = None
                for i, item in enumerate(universe):
                    if isinstance(item, dict) and item.get('name') == coin:
                        coin_idx = i
                        break

                # 获取价格
                if coin_idx is not None and coin_idx < len(asset_ctxs):
                    ctx = asset_ctxs[coin_idx]
                    if ctx.get('midPx'):
                        return float(ctx['midPx'])

            return 0.0

        except Exception as e:
            self.logger.error(f"获取价格失败: {e}")
            return 0.0

    # ==================== 工具方法 ====================

    def get_exchange_name(self) -> str:
        """获取交易所名称"""
        if self.testnet:
            return "HyperLiquid (Testnet)"
        return "HyperLiquid (Mainnet)"

    def __repr__(self) -> str:
        """字符串表示"""
        return f"<HyperLiquidAdapter: {self.get_exchange_name()}>"
