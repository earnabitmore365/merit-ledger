#!/usr/bin/env python3
"""
实盘监控 Bot — Mac Mini 上运行

SSH 读 Nitro 日志 → Telegram 推送
独立于交易进程，交易崩了监控还能报警。
⛔ 不调 BitMEX REST API（RUL-027：零 API 调用原则）

功能：
1. [TRADE] 事件推送（开仓/平仓/反手）
2. Regime 变盘 / TTP 触发 / HALT 熔断推送
3. 进程存活检测
4. 每小时摘要（从日志提取余额+持仓）

用法:
  python3 monitor_bot.py
"""

import os
import re
import json
import time
import subprocess
import urllib.request

# ==================== 配置 ====================

SSH_CMD = "ssh -p 2222 -o ConnectTimeout=10 -o StrictHostKeyChecking=no pc_heisi_claude@localhost"
NITRO_DIR = "/home/pc_heisi_claude/trading"
LOG_FILES = ['sol_1m_live', 'eth_1m_live', 'xrp_5m_live', 'gateway']
COIN_MAP = {'sol_1m_live': 'SOL', 'eth_1m_live': 'ETH',
            'xrp_5m_live': 'XRP', 'gateway': 'GW'}

CHECK_INTERVAL = 30      # 日志轮询间隔（秒）
SUMMARY_INTERVAL = 900   # 每15分钟摘要

TOKEN = os.getenv('TELEGRAM_BOT_TOKEN', '8626060346:AAFnkP2V7avxpmnFsO8DUsHEDB7SmqtMJhg')
CHAT_ID = os.getenv('TELEGRAM_CHAT_ID', '6506412244')


# ==================== Telegram ====================

def send_telegram(message):
    """纯 urllib 推送，零依赖，纯文本"""
    if not TOKEN or not CHAT_ID:
        return
    try:
        url = f"https://api.telegram.org/bot{TOKEN}/sendMessage"
        data = json.dumps({'chat_id': CHAT_ID, 'text': message}).encode()
        req = urllib.request.Request(
            url, data=data, headers={'Content-Type': 'application/json'})
        urllib.request.urlopen(req, timeout=5)
    except Exception:
        pass


# ==================== SSH ====================

def ssh_exec(cmd):
    """SSH 执行命令，返回 stdout"""
    full = f"{SSH_CMD} '{cmd}'"
    try:
        result = subprocess.run(
            full, shell=True, capture_output=True, text=True, timeout=20)
        return result.stdout.strip()
    except (subprocess.TimeoutExpired, Exception):
        return None


def poll_logs():
    """一次 SSH 获取全部日志 + 进程数"""
    cmd = (
        f'cd {NITRO_DIR} && '
        'echo "===PROC==="; '
        'ps aux | grep -E "python3.*(feed_gateway|bitmex_race)" | grep -v grep | wc -l; '
        'echo "===SOL==="; tail -50 logs/sol_1m_live.log 2>/dev/null; '
        'echo "===ETH==="; tail -50 logs/eth_1m_live.log 2>/dev/null; '
        'echo "===XRP==="; tail -50 logs/xrp_5m_live.log 2>/dev/null; '
        'echo "===GW==="; tail -50 logs/gateway.log 2>/dev/null'
    )
    out = ssh_exec(cmd)
    if out is None:
        return None
    sections = {}
    current = None
    for line in out.split('\n'):
        if line.startswith('===') and line.endswith('==='):
            current = line.strip('=')
            sections[current] = []
        elif current is not None:
            sections[current].append(line)
    return sections


# ==================== 事件解析 ====================

def parse_events(lines, coin):
    """解析日志行，提取关键事件"""
    events = []
    for line in lines:
        # [TRADE] 交易事件（开仓/平仓/反手）
        if '[TRADE]' in line:
            detail = line.split('[TRADE]')[1].strip()[:80]
            events.append(f"📌 {detail}")

        # Regime 变盘
        if '⚡变盘' in line:
            detail = line.split('⚡')[1].strip()[:60] if '⚡' in line else ''
            events.append(f"⚡ {coin} {detail}")

        # 智能平仓
        if '[Regime]' in line and ('平多仓' in line or '平空仓' in line):
            detail = line.split('[Regime]')[1].strip()[:80]
            events.append(f"🟡 {coin} {detail}")

        # TTP 触发（原始日志，TTP 自己打的）
        if 'TTP tick触发' in line or 'TTP触发' in line:
            events.append(f"📊 {coin} TTP触发!")

        # HALT 熔断
        if 'HALT' in line and '熔断' in line:
            events.append(f"🚨 {coin} HALT 熔断!")

        # Gateway 严重错误
        if coin == 'GW' and ('ERROR' in line or 'corrupted' in line):
            events.append(f"⚠️ Gateway ERROR: {line[-60:]}")

    return events


# ==================== 日志提取 ====================

def extract_balance_from_logs(sections):
    """从日志提取最新余额信息（Gateway 日志中的 balance 行）"""
    gw_lines = sections.get('GW', [])
    balance = None
    for line in reversed(gw_lines):
        # Gateway 广播的 balance 信息
        m = re.search(r'balance[:\s]+\$?([\d.]+)', line, re.IGNORECASE)
        if m:
            balance = float(m.group(1))
            break
    return balance


def extract_positions_from_logs(sections):
    """从策略日志提取最新持仓信息"""
    positions = []
    section_map = {'SOL': 'sol_1m_live', 'ETH': 'eth_1m_live', 'XRP': 'xrp_5m_live'}
    for section_key, log_name in section_map.items():
        coin = COIN_MAP[log_name]
        lines = sections.get(section_key, [])
        for line in reversed(lines):
            # 匹配持仓日志：side=LONG/SHORT, pnl=xxx
            side_m = re.search(r'side=(LONG|SHORT|long|short)', line)
            pnl_m = re.search(r'(?:unrealized_?pnl|pnl)[=:\s]+([-+]?[\d.]+)', line, re.IGNORECASE)
            if side_m:
                side = side_m.group(1).upper()
                pnl = float(pnl_m.group(1)) if pnl_m else 0.0
                positions.append(f"{coin} {side} ${pnl:+.2f}")
                break
    return positions


# ==================== 主循环 ====================

def main():
    print(f"Monitor Bot 启动: 日志每{CHECK_INTERVAL}s | Telegram @{CHAT_ID}")

    # 去重：初始化为 5 分钟前
    init_ts = time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(time.time() - 300))
    last_seen = {f: init_ts for f in LOG_FILES}

    last_summary = time.time()
    last_proc_alert = 0
    low_proc_streak = 0

    # 启动确认
    send_telegram("✅ 监控已启动\nMac Mini → Nitro SSH（纯日志，零API）\n交易事件+每小时摘要")

    while True:
        try:
            sections = poll_logs()

            if sections is None:
                if time.time() - last_proc_alert > 300:
                    send_telegram("⚠️ SSH 隧道断了！无法连接 Nitro")
                    last_proc_alert = time.time()
                time.sleep(CHECK_INTERVAL)
                continue

            # 1. 进程存活检测
            proc_lines = sections.get('PROC', ['0'])
            try:
                proc_count = int(proc_lines[0].strip())
            except (ValueError, IndexError):
                proc_count = 0

            if proc_count < 4:
                low_proc_streak += 1
                if low_proc_streak >= 2 and time.time() - last_proc_alert > 60:
                    send_telegram(f"🚨 进程异常: {proc_count}/4 存活!")
                    last_proc_alert = time.time()
            else:
                low_proc_streak = 0

            # 2. 读日志找新事件
            section_map = {'SOL': 'sol_1m_live', 'ETH': 'eth_1m_live',
                           'XRP': 'xrp_5m_live', 'GW': 'gateway'}

            for section_key, log_name in section_map.items():
                lines = sections.get(section_key, [])
                coin = COIN_MAP[log_name]
                new_lines = []
                for line in lines:
                    ts = re.match(r'(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})', line)
                    if ts and ts.group(1) > last_seen[log_name]:
                        new_lines.append(line)

                if new_lines:
                    last_ts = re.match(
                        r'(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})', new_lines[-1])
                    if last_ts:
                        last_seen[log_name] = last_ts.group(1)
                    events = parse_events(new_lines, coin)
                    for event in events:
                        send_telegram(event)

            # 3. 每小时摘要（从日志提取，零 API 调用）
            now = time.time()
            if now - last_summary > SUMMARY_INTERVAL:
                parts = [f"📊 每小时状态 | 进程: {proc_count}/4"]

                # 余额（从 Gateway 日志提取）
                bal = extract_balance_from_logs(sections)
                if bal is not None:
                    parts.append(f"余额: ${bal:.2f}")

                # 持仓（从策略日志提取）
                pos_info = extract_positions_from_logs(sections)
                for p in pos_info:
                    parts.append(p)

                # Regime（从策略日志提取）
                for sk, ln in section_map.items():
                    if ln == 'gateway':
                        continue
                    coin = COIN_MAP[ln]
                    for line in reversed(sections.get(sk, [])):
                        rm = re.search(r'regime=(\S+)', line)
                        if rm:
                            parts.append(f"{coin} regime={rm.group(1)}")
                            break

                send_telegram('\n'.join(parts))
                last_summary = now

        except Exception as e:
            print(f"监控异常: {e}")

        time.sleep(CHECK_INTERVAL)


if __name__ == '__main__':
    main()
