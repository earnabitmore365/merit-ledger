## 三、建议表结构（初版）

```sql
-- 每句对话原文
CREATE TABLE messages (
    id INTEGER PRIMARY KEY,
    time DATETIME,
    speaker TEXT,        -- '混沌' / '白纱' / '黑丝' / '太极'
    content TEXT,
    tags TEXT,           -- 关键词，逗号分隔
    project TEXT,        -- 'gate_v4' / 'comms' / 'intrabar' 等
    session_id TEXT      -- 哪次会话
);

-- 混沌决策库（最高优先级）
CREATE TABLE decisions (
    id INTEGER PRIMARY KEY,
    time DATETIME,
    speaker TEXT DEFAULT '混沌',
    decision TEXT,       -- 决策内容
    raw_quote TEXT,      -- 混沌原话，原文保留
    project TEXT,
    status TEXT          -- 'active' / 'superseded' / 'pending'
);

-- 任务状态
CREATE TABLE tasks (
    id INTEGER PRIMARY KEY,
    title TEXT,
    owner TEXT,          -- '黑丝' / '白纱'
    status TEXT,         -- 'pending' / 'in_progress' / 'done'
    updated_at DATETIME,
    detail TEXT
);

-- 会话摘要（每次会话结束后写入）
CREATE TABLE sessions (
    id TEXT PRIMARY KEY,  -- JSONL 文件 ID
    date DATE,
    participants TEXT,    -- '白纱' / '黑丝' / '混沌+白纱' 等
    summary TEXT,
    key_decisions TEXT    -- 该次会话的关键决策 ID 列表
);
```

**查询示例（恢复上下文用）：**
```sql
-- 最新决策
SELECT * FROM decisions WHERE status='active' ORDER BY time DESC LIMIT 10;

-- 最近5分钟对话
SELECT * FROM messages WHERE time > datetime('now', '-5 minutes') ORDER BY time;

-- 查某个项目的所有决策
SELECT * FROM decisions WHERE project='gate_v4' ORDER BY time DESC;

-- 当前任务状态
SELECT * FROM tasks WHERE status != 'done' ORDER BY updated_at DESC;
```

