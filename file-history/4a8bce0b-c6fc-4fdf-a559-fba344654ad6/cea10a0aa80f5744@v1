"""
评估器 — v0.8

v0.8: 删除多样性惩罚（不限制指标种类数量，让GP自由组合）
v0.4: 训练集切 WF_TRAIN_WINDOWS 段，取最低 t-stat 当适应度
"""
import numpy as np
from config import (LEVERAGE, FEE_RATE, SLIPPAGE_RATE, MIN_TRADES,
                    PARSIMONY_COEFF, WF_TRAIN_WINDOWS)
import tree as tree_mod


def compute_signals(root, data, direction='long'):
    """
    执行树，输出交易信号。

    direction='long':  树输出1 → 做多(+1)，树输出0 → 空仓(0)
    direction='short': 树输出1 → 做空(-1)，树输出0 → 空仓(0)
    """
    raw = tree_mod.evaluate(root, data)
    active = (raw > 0.5).astype(float)  # 1.0 或 0.0
    if direction == 'short':
        return -active  # 1.0 → -1.0（做空），0.0 不变
    return active


def signals_to_pnl(signals, close, leverage=LEVERAGE,
                   fee_rate=FEE_RATE, slippage_rate=SLIPPAGE_RATE):
    """
    信号 → PnL（全向量化，支持做多+做空）

    signals: +1=做多, -1=做空, 0=空仓
    """
    n = len(close)
    if n < 2:
        return _empty_result(n)

    # 信号延迟 1 根执行
    positions = np.zeros(n)
    positions[1:] = signals[:-1]

    # 每根 K 线的收益率
    bar_returns = np.zeros(n)
    bar_returns[1:] = (close[1:] - close[:-1]) / close[:-1]

    # 仓位收益 = 持仓方向 × 收益率 × 杠杆
    # 做空时 position=-1，价格下跌(负收益率) → 正收益
    portfolio_returns = positions * bar_returns * leverage

    # 手续费: 仓位变化时收取
    position_changes = np.abs(np.diff(positions, prepend=0))
    total_cost_rate = fee_rate + slippage_rate
    fees = position_changes * total_cost_rate * leverage

    # 净收益
    net_returns = portfolio_returns - fees

    # 交易统计: 找出所有持仓段
    in_trade = positions != 0
    trade_starts = np.where(np.diff(in_trade.astype(int), prepend=0) > 0)[0]
    trade_ends = np.where(np.diff(in_trade.astype(int), prepend=0) < 0)[0]
    if len(trade_starts) > len(trade_ends):
        trade_ends = np.append(trade_ends, n - 1)

    n_trades = len(trade_starts)
    trade_pnls = []
    for start, end in zip(trade_starts, trade_ends):
        trade_pnl = np.sum(net_returns[start:end + 1])
        trade_pnls.append(trade_pnl)

    wins = sum(1 for p in trade_pnls if p > 0)
    win_rate = wins / n_trades if n_trades > 0 else 0.0

    # Sharpe (per-bar, 只看有仓位的时段)
    active_returns = net_returns[in_trade]
    if len(active_returns) > 0 and np.std(active_returns) > 1e-10:
        sharpe = float(np.mean(active_returns) / np.std(active_returns))
    else:
        sharpe = 0.0

    # 最大回撤
    cum_returns = np.cumsum(net_returns)
    running_max = np.maximum.accumulate(cum_returns)
    drawdowns = running_max - cum_returns
    max_drawdown = float(np.max(drawdowns)) if len(drawdowns) > 0 else 0.0

    return {
        'total_return': float(np.sum(net_returns)),
        'n_trades': n_trades,
        'win_rate': win_rate,
        'returns': net_returns,
        'positions': positions,
        'trade_pnls': trade_pnls,
        'sharpe': sharpe,
        'max_drawdown': max_drawdown,
        'active_bars': int(np.sum(in_trade)),
    }


def _t_stat_on_window(root, data, close_raw, direction):
    """计算单个窗口的 t-stat，返回 t_stat 和 result"""
    signals = compute_signals(root, data, direction)
    result = signals_to_pnl(signals, close_raw)
    if result['n_trades'] < max(MIN_TRADES // WF_TRAIN_WINDOWS, 5):
        return None, result
    in_trade = result['positions'] != 0
    active_returns = result['returns'][in_trade]
    n_active = len(active_returns)
    if n_active < 2:
        return None, result
    mean_r = np.mean(active_returns)
    std_r = np.std(active_returns, ddof=1)
    if std_r < 1e-10:
        t_stat = 0.0 if mean_r <= 0 else 100.0
    else:
        t_stat = float(mean_r / std_r * np.sqrt(n_active))
    result['t_stat'] = t_stat
    return t_stat, result


def fitness(root, data, close_raw, direction='long'):
    """
    v0.4 适应度: 训练集内部 Walk-Forward t-statistic

    v0.2: 整个训练集算一次 t-stat → 容易靠某段行情过拟合
    v0.4: 训练集切成 WF_TRAIN_WINDOWS 段，每段独立算 t-stat，取最低分
          树必须在每个时段都稳定盈利，不能靠一段特殊行情蒙混
    """
    n = len(close_raw)
    window_size = n // WF_TRAIN_WINDOWS
    if window_size < MIN_TRADES * 2:
        # 数据太短，退化为单窗口
        t, r = _t_stat_on_window(root, data, close_raw, direction)
        t_stats = [t]
        all_results = [r]
    else:
        t_stats = []
        all_results = []
        for i in range(WF_TRAIN_WINDOWS):
            start = i * window_size
            end = start + window_size if i < WF_TRAIN_WINDOWS - 1 else n
            w_data = {k: v[start:end] for k, v in data.items()}
            w_close = close_raw[start:end]
            t, r = _t_stat_on_window(root, w_data, w_close, direction)
            t_stats.append(t)
            all_results.append(r)

    # 任一窗口无效 → 惩罚
    if any(t is None for t in t_stats):
        return -999.0, all_results[-1] if all_results else _empty_result(n)

    # 取最低 t-stat（最差时段的表现）
    min_t = float(min(t_stats))
    tree_size = tree_mod.size(root)
    # v0.8: 多样性惩罚已删除，只保留简洁性惩罚
    score = min_t - PARSIMONY_COEFF * tree_size

    # 聚合全部窗口的统计（不只报最后一段）
    total_trades = sum(r['n_trades'] for r in all_results)
    agg_result = {
        'total_return': sum(r['total_return'] for r in all_results),
        'n_trades': total_trades,
        'win_rate': (sum(r['win_rate'] * r['n_trades'] for r in all_results)
                     / total_trades) if total_trades > 0 else 0.0,
        'sharpe': min(r.get('sharpe', 0) for r in all_results),
        'max_drawdown': max(r['max_drawdown'] for r in all_results),
        'active_bars': sum(r['active_bars'] for r in all_results),
        'trade_pnls': [],
        'returns': np.array([]),
        'positions': np.array([]),
        't_stat': min_t,
        't_stats_all': t_stats,
    }
    return score, agg_result


def _empty_result(n):
    return {
        'total_return': 0.0,
        'n_trades': 0,
        'win_rate': 0.0,
        'returns': np.zeros(n),
        'positions': np.zeros(n),
        'trade_pnls': [],
        'sharpe': 0.0,
        'max_drawdown': 0.0,
        'active_bars': 0,
    }
