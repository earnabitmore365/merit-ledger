#!/usr/bin/env python3
"""
BitMEX Crypto Olympus 比赛启动脚本

@see lab/README.md#architecture — 指标统一调用 indicator_cache

轻量启动脚本，只做配置和调用，不包含任何交易逻辑。
逻辑全在 TradingSystem 和 TradingRunner 里。

用法:
  python3 bitmex_race.py                          # 默认策略，主网
  python3 bitmex_race.py --coin BTC --interval 30m
  python3 bitmex_race.py --strategy fvg --coin AVAX
  python3 bitmex_race.py --dry-run                # 只检查连通性，不跑主循环

比赛信息:
  - BitMEX Crypto Olympus（2026-03-12 ~ 2026-04-12）
  - $500K 奖池
  - $100K 交易量门槛
"""

import sys
import os
import time
import logging
import argparse
from datetime import datetime

# 添加 src 目录到路径
sys.path.insert(0, os.path.join(os.path.dirname(__file__), 'src'))

from dotenv import load_dotenv

from exchange.bitmex.adapter import BitMEXAdapter
from trading.system import TradingSystem
from core.strategy import get_strategy, list_strategies
from core.risk.position_sizing import FixedPercentSizing
from core.risk.combined import CombinedRiskManager, CombinedRiskConfig


# ==================== 配置 ====================

# 默认比赛策略（从 TTP Gate 冠军中选的）
# 30m 冠军候选（按 all_pnl 排序）:
#   matriple      XRP  30m  pnl=48.8  1.9笔/天
#   fvg           AVAX 30m  pnl=48.3  1.5笔/天
#   macross_slow  ADA  30m  pnl=47.7  2.1笔/天
#   order_block   AVAX 30m  pnl=39.5  2.4笔/天
DEFAULT_STRATEGY = 'matriple'
DEFAULT_COIN = 'XRP'
DEFAULT_INTERVAL = '30m'


def load_config():
    """从 .env 读取 BitMEX API 配置"""
    env_path = os.path.join(os.path.dirname(__file__), '.env')
    load_dotenv(env_path)

    api_key = os.getenv('BITMEX_API_KEY')
    api_secret = os.getenv('BITMEX_API_SECRET')
    testnet = os.getenv('BITMEX_TESTNET', 'false').lower() == 'true'

    if not api_key or not api_secret:
        print("错误: .env 里没有 BITMEX_API_KEY / BITMEX_API_SECRET")
        sys.exit(1)

    return {
        'api_key': api_key,
        'api_secret': api_secret,
        'testnet': testnet,
        'default_leverage': 10,
    }


def reconcile_positions(adapter, coin: str):
    """启动时从 BitMEX 拉真实持仓，对账

    Returns:
        tuple: (position, entry_price) — 如果有持仓则返回方向和开仓价
    """
    pos = adapter.get_position(coin)
    if pos and pos.size > 0:
        direction = 'BUY' if pos.side == 'LONG' else 'SELL'
        print(f"  已有持仓: {direction} {coin} @ ${pos.entry_price:.2f}"
              f"  数量={pos.size}  未实现盈亏=${pos.unrealized_pnl:.4f}")
        return direction, pos.entry_price
    else:
        print(f"  无 {coin} 持仓")
        return 'NO_POSITION', 0.0


def print_status(adapter, coin: str):
    """打印账户状态"""
    balance = adapter.get_balance()
    price = adapter.get_price(coin)
    funding = adapter.get_funding_rate(coin)

    print(f"\n{'='*50}")
    print(f"  BitMEX {'测试网' if adapter.testnet else '主网'}")
    print(f"  余额: ${balance.get('usdc', 0):.2f} USDT")
    print(f"  可用: ${balance.get('available', 0):.2f} USDT")
    print(f"  {coin} 价格: ${price:.4f}")
    print(f"  资金费率: {funding.get('rate', 0):.6f}")
    print(f"{'='*50}\n")


# K线周期 → 秒数
INTERVAL_SECONDS = {
    '1m': 60, '5m': 300, '15m': 900, '30m': 1800,
    '1h': 3600, '2h': 7200, '4h': 14400,
}


def wait_for_next_kline(interval: str, logger):
    """K 线整点对齐：sleep 到下一根 K 线收盘 + 10 秒"""
    import math
    interval_sec = INTERVAL_SECONDS.get(interval, 1800)
    now = time.time()
    next_close = math.ceil(now / interval_sec) * interval_sec
    wait = next_close - now + 10  # 多等 10 秒让数据稳定

    if wait > 0:
        logger.info(f"等待下一根 {interval} K 线: {wait:.0f}s")
        end_time = time.time() + wait
        while time.time() < end_time:
            time.sleep(min(5.0, end_time - time.time()))


def main():
    parser = argparse.ArgumentParser(description='BitMEX 比赛启动脚本')
    parser.add_argument('--strategy', type=str, default=DEFAULT_STRATEGY,
                        help=f'策略名称（默认: {DEFAULT_STRATEGY}）')
    parser.add_argument('--coin', type=str, default=DEFAULT_COIN,
                        help=f'交易币种（默认: {DEFAULT_COIN}）')
    parser.add_argument('--interval', type=str, default=DEFAULT_INTERVAL,
                        help=f'K线周期（默认: {DEFAULT_INTERVAL}）')
    parser.add_argument('--balance', type=float, default=500,
                        help='初始本金（默认: $500）')
    parser.add_argument('--bet-pct', type=float, default=0.10,
                        help='每笔下注比例（默认: 10%%）')
    parser.add_argument('--min-bet', type=float, default=100,
                        help='最低保证金（默认: $100）')
    parser.add_argument('--leverage', type=float, default=10,
                        help='杠杆倍数（默认: 10x）')
    parser.add_argument('--dry-run', action='store_true',
                        help='只检查连通性，不跑主循环')
    parser.add_argument('--mirror', action='store_true',
                        help='Mirror 模式：翻转 OHLCV + 反转信号（用于 mirror 冠军策略）')
    parser.add_argument('--list-strategies', action='store_true',
                        help='列出所有可用策略')
    args = parser.parse_args()

    # 日志
    logging.basicConfig(
        level=logging.INFO,
        format='%(asctime)s [%(name)s] %(levelname)s %(message)s',
    )
    logger = logging.getLogger('bitmex_race')

    # 列出策略
    if args.list_strategies:
        print("可用策略:")
        for name in sorted(list_strategies()):
            print(f"  {name}")
        return

    strategy_name = args.strategy + ('_mirror' if args.mirror else '')
    print(f"\n{'='*50}")
    print(f"  BitMEX Crypto Olympus 比赛")
    print(f"  策略: {strategy_name}")
    print(f"  币种: {args.coin}")
    print(f"  周期: {args.interval}")
    print(f"  杠杆: {args.leverage}x")
    print(f"  下注: {args.bet_pct:.0%} / 最低 ${args.min_bet}")
    print(f"{'='*50}\n")

    # 1. 加载 API 配置
    config = load_config()
    config['default_leverage'] = int(args.leverage)
    logger.info(f"API 配置: {'测试网' if config['testnet'] else '主网'}")

    # 2. 创建 BitMEX 适配器
    adapter = BitMEXAdapter(config)
    if not adapter.connect():
        logger.error("BitMEX 连接失败")
        sys.exit(1)
    logger.info("BitMEX 连接成功")

    # 3. 打印账户状态
    print_status(adapter, args.coin)

    # 4. 创建仓位管理
    sizing = FixedPercentSizing(
        balance=args.balance,
        bet_pct=args.bet_pct,
        min_bet=args.min_bet,
        leverage=int(args.leverage),
    )
    logger.info(f"仓位管理: {sizing}")

    # 5. 加载策略
    try:
        strategy = get_strategy(args.strategy)
    except ValueError as e:
        logger.error(f"策略加载失败: {e}")
        logger.info(f"可用策略: {list_strategies()}")
        adapter.disconnect()
        sys.exit(1)

    # Mirror 模式：翻转数据 + 反转信号
    if args.mirror:
        from core.strategy.mirror import MirrorStrategy
        strategy = MirrorStrategy(strategy)

    logger.info(f"策略: {strategy.name}")

    # 6. 创建风险管理（TTP + 无止损，让强平兜底）
    risk_config = CombinedRiskConfig(
        stop_loss_pct=1.0,  # 100% = 不设止损（逐仓强平兜底）
        ttp_enabled=True,
    )
    risk_manager = CombinedRiskManager(risk_config)

    # 7. 创建 TradingSystem
    trading_config = {
        'coin': args.coin,
        'interval': args.interval,
        'leverage': args.leverage,
        'kline_limit': 200,
    }
    system = TradingSystem(
        exchange=adapter,
        strategy=strategy,
        risk_manager=risk_manager,
        config=trading_config,
        position_sizing=sizing,
    )

    # 8. 对账：从 BitMEX 拉真实持仓
    print("\n对账:")
    pos_direction, pos_price = reconcile_positions(adapter, args.coin)
    if pos_direction != 'NO_POSITION':
        system.position = pos_direction
        system.entry_price = pos_price
        logger.info(f"已同步持仓: {pos_direction} @ ${pos_price:.2f}")

    # dry-run 到此为止
    if args.dry_run:
        print("\n--- dry-run 完成，连通性正常 ---")
        adapter.disconnect()
        return

    # 9. 启动 TTP tick 级监控（内置在 TradingSystem 里）
    system.start_ttp_monitor()

    # 10. 主循环
    print(f"\n开始交易主循环（{args.interval} 周期）")
    print("按 Ctrl+C 停止\n")

    try:
        while True:
            wait_for_next_kline(args.interval, logger)

            try:
                result = system.run_once()
                action = result.get('action', 'NONE')
                signal = result.get('signal', 'N/A')
                position = result.get('position', 'N/A')

                # 每次执行后打印状态
                balance = adapter.get_balance()
                bal_str = f"${balance.get('usdc', 0):.4f}"

                logger.info(
                    f"信号={signal} 操作={action} 持仓={position} "
                    f"余额={bal_str}"
                )

                # 有交易动作时打印详情
                if action != 'NONE':
                    print(f"\n  {'='*40}")
                    print(f"  交易! {action}")
                    print(f"  {args.coin} @ ${adapter.get_price(args.coin):.2f}")
                    print(f"  余额: {bal_str}")
                    print(f"  {'='*40}\n")

            except Exception as e:
                logger.error(f"run_once 异常: {e}", exc_info=True)
                time.sleep(60)  # 出错后等 1 分钟再试

    except KeyboardInterrupt:
        print("\n收到停止信号")
    finally:
        system.stop_ttp_monitor()
        adapter.disconnect()
        print("BitMEX 已断开，比赛脚本结束")


if __name__ == '__main__':
    main()
