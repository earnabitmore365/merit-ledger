#!/usr/bin/env python3
"""
每日自动更新管线 — 下载K线 → 增量回测 → 报告重算 → 生成看板

用法：
  python3 lab/daily_pipeline.py                      # 全量管线
  python3 lab/daily_pipeline.py --coins ETH XRP      # 只跑指定币种
  python3 lab/daily_pipeline.py --skip-download       # 跳过下载，只跑回测
  python3 lab/daily_pipeline.py --ttp                 # TTP 版本
  python3 lab/daily_pipeline.py --full                # 强制全量重跑
  python3 lab/daily_pipeline.py --skip-dashboard      # 跳过看板生成
"""

import sys
import os
import subprocess
import time
import logging
import argparse
from datetime import datetime

_lab_dir = os.path.dirname(os.path.abspath(__file__))
PROJECT_ROOT = _lab_dir

logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
logger = logging.getLogger(__name__)


def run_step(name: str, cmd: list, timeout: int = 7200) -> bool:
    """执行一个步骤，返回是否成功"""
    logger.info(f"\n{'='*60}")
    logger.info(f"阶段: {name}")
    logger.info(f"命令: {' '.join(cmd)}")
    t0 = time.time()

    try:
        result = subprocess.run(
            cmd, timeout=timeout,
            capture_output=True, text=True)
        elapsed = time.time() - t0

        if result.returncode == 0:
            logger.info(f"✅ {name} 完成 ({elapsed:.0f}s)")
            # 输出最后几行
            if result.stdout:
                for line in result.stdout.strip().split('\n')[-5:]:
                    logger.info(f"  {line}")
            return True
        else:
            logger.error(f"❌ {name} 失败 (exit={result.returncode}, {elapsed:.0f}s)")
            if result.stderr:
                for line in result.stderr.strip().split('\n')[-10:]:
                    logger.error(f"  {line}")
            return False

    except subprocess.TimeoutExpired:
        logger.error(f"❌ {name} 超时 ({timeout}s)")
        return False
    except Exception as e:
        logger.error(f"❌ {name} 异常: {e}")
        return False


def main():
    parser = argparse.ArgumentParser(description='每日自动更新管线')
    parser.add_argument('--coins', nargs='+', help='指定币种')
    parser.add_argument('--intervals', nargs='+', help='指定周期')
    parser.add_argument('--strategy', nargs='+', help='指定策略')
    parser.add_argument('--ttp', action='store_true', help='TTP 版本')
    parser.add_argument('--full', action='store_true', help='强制全量重跑')
    parser.add_argument('--skip-download', action='store_true', help='跳过下载')
    parser.add_argument('--skip-dashboard', action='store_true', help='跳过看板生成')
    parser.add_argument('--db', type=str, default=None, help='指定数据库路径')
    args = parser.parse_args()

    t_start = time.time()
    logger.info(f"每日管线启动: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")

    results = {}

    # ===== 阶段1: 下载最新K线 =====
    if not args.skip_download:
        download_script = os.path.join(os.path.dirname(_lab_dir), 'download_latest_coins_2.0.py')
        if not os.path.exists(download_script):
            # 尝试 lab 内路径
            download_script = os.path.join(_lab_dir, '..', 'download_latest_coins_2.0.py')

        if os.path.exists(download_script):
            cmd = ['python3', download_script]
            results['download'] = run_step('下载最新K线', cmd, timeout=1800)
        else:
            logger.warning(f"下载脚本不存在: {download_script}")
            results['download'] = False
    else:
        logger.info("跳过下载")
        results['download'] = True

    # ===== 阶段2: 增量回测 =====
    incr_script = os.path.join(_lab_dir, 'incremental_backtest.py')
    cmd = ['python3', incr_script]
    if args.coins:
        cmd += ['--coins'] + args.coins
    if args.intervals:
        cmd += ['--intervals'] + args.intervals
    if args.strategy:
        cmd += ['--strategy'] + args.strategy
    if args.ttp:
        cmd.append('--ttp')
    if args.full:
        cmd.append('--full')
    if args.db:
        cmd += ['--db', args.db]

    results['backtest'] = run_step('增量回测', cmd, timeout=7200)

    # ===== 阶段3: 报告种子重算 =====
    if results['backtest']:
        refresh_script = os.path.join(_lab_dir, 'refresh_summary.py')
        cmd = ['python3', refresh_script]
        if args.ttp:
            cmd.append('--ttp')
        if args.coins:
            cmd += ['--coins'] + args.coins
        if args.db:
            cmd += ['--db', args.db]

        results['summary'] = run_step('报告种子重算', cmd, timeout=600)
    else:
        logger.warning("增量回测失败，跳过报告重算")
        results['summary'] = False

    # ===== 阶段4: 生成 HTML 看板 =====
    if not args.skip_dashboard and results.get('summary', False):
        dashboard_script = os.path.join(_lab_dir, 'seed_dashboard.py')
        if os.path.exists(dashboard_script):
            cmd = ['python3', dashboard_script]
            if args.ttp:
                cmd.append('--ttp')
            if args.db:
                cmd += ['--db', args.db]
            results['dashboard'] = run_step('生成报告看板', cmd, timeout=300)
        else:
            logger.info("看板脚本尚未创建，跳过")
            results['dashboard'] = None
    else:
        results['dashboard'] = None

    # ===== 汇总 =====
    elapsed = time.time() - t_start
    logger.info(f"\n{'='*60}")
    logger.info(f"每日管线完成: {elapsed:.0f}s")
    for step, ok in results.items():
        status = "✅" if ok else ("⏭️ 跳过" if ok is None else "❌")
        logger.info(f"  {status} {step}")

    # 非零退出码（如果有失败）
    if any(v is False for v in results.values()):
        sys.exit(1)


if __name__ == '__main__':
    main()
