<script>
function showInterval(iv) {
  document.querySelectorAll('.controls button').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');

  document.querySelectorAll('.db-section.visible .section').forEach(s => {
    if (iv === 'all') {
      s.classList.add('visible');
    } else {
      s.classList.toggle('visible', s.dataset.interval === iv);
    }
  });
}

function showDb(db) {
  document.querySelectorAll('.db-tabs button').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');

  document.querySelectorAll('.db-section').forEach(s => s.classList.remove('visible'));
  document.getElementById('db-' + db).classList.add('visible');

  // re-apply interval filter
  const activeIv = document.querySelector('.controls button.active');
  if (activeIv) {
    const iv = activeIv.textContent.trim() === '全部' ? 'all' : activeIv.textContent.trim();
    document.querySelectorAll('#db-' + db + ' .section').forEach(s => {
      if (iv === 'all') {
        s.classList.add('visible');
      } else {
        s.classList.toggle('visible', s.dataset.interval === iv);
      }
    });
  }
}
</script>
