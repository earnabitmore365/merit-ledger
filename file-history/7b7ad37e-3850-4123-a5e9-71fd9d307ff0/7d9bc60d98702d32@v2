#!/usr/bin/env python3
"""
SQLite → DuckDB 转换 + seed_v3_ttp vs seed_v3_ttp_highlow 全量对比
"""

import duckdb
import time
import os
import sys
import json

REPORT_DIR = '/Users/allenbot/project/auto-trading/lab/reports'
SEEDS = ['seed_v3', 'seed_v3_ttp', 'seed_v3_ttp_highlow']
TABLES_TO_COPY = ['combo_summary', 'paired_trades', 'regime_timeline', 'run_metadata']

LOG = os.path.join(REPORT_DIR, 'convert_compare.log')

def log(msg):
    line = f"[{time.strftime('%H:%M:%S')}] {msg}"
    print(line, flush=True)
    with open(LOG, 'a') as f:
        f.write(line + '\n')


def convert_one(seed_name):
    sqlite_path = os.path.join(REPORT_DIR, f'{seed_name}.db')
    duckdb_path = os.path.join(REPORT_DIR, f'{seed_name}.duckdb')

    if os.path.exists(duckdb_path):
        size_mb = os.path.getsize(duckdb_path) / 1024 / 1024
        log(f'SKIP {seed_name}.duckdb already exists ({size_mb:.0f} MB)')
        return duckdb_path

    log(f'=== Converting {seed_name} ===')
    start = time.time()

    con = duckdb.connect(duckdb_path)
    con.execute("INSTALL sqlite; LOAD sqlite;")
    con.execute(f"ATTACH '{sqlite_path}' AS src (TYPE sqlite)")

    for table in TABLES_TO_COPY:
        t0 = time.time()
        log(f'  Copying {table}...')
        try:
            count = con.execute(f"SELECT COUNT(*) FROM src.{table}").fetchone()[0]
            log(f'    {count:,} rows to copy')
            con.execute(f"CREATE TABLE {table} AS SELECT * FROM src.{table}")
            elapsed = time.time() - t0
            log(f'    Done in {elapsed:.1f}s')
        except Exception as e:
            log(f'    ERROR: {e}')

    con.execute("DETACH src")

    # Create indexes for comparison
    log(f'  Creating indexes...')
    try:
        con.execute("CREATE INDEX idx_combo_key ON combo_summary(strategy, coin, interval)")
        con.execute("CREATE INDEX idx_pt_combo ON paired_trades(combo_id)")
    except Exception as e:
        log(f'    Index error (non-fatal): {e}')

    con.close()

    elapsed = time.time() - start
    size_mb = os.path.getsize(duckdb_path) / 1024 / 1024
    log(f'  {seed_name}.duckdb complete: {size_mb:.0f} MB in {elapsed:.1f}s')
    return duckdb_path


def compare_ttp_vs_highlow():
    """全量对比 seed_v3_ttp vs seed_v3_ttp_highlow"""
    log('\n' + '=' * 60)
    log('=== COMPARISON: seed_v3_ttp vs seed_v3_ttp_highlow ===')
    log('=' * 60)

    ttp_path = os.path.join(REPORT_DIR, 'seed_v3_ttp.duckdb')
    hl_path = os.path.join(REPORT_DIR, 'seed_v3_ttp_highlow.duckdb')

    con = duckdb.connect(':memory:')
    con.execute(f"ATTACH '{ttp_path}' AS ttp (READ_ONLY)")
    con.execute(f"ATTACH '{hl_path}' AS hl (READ_ONLY)")

    # --- 1. combo_summary 对比 ---
    log('\n--- 1. combo_summary 整体统计 ---')
    for label, schema in [('TTP', 'ttp'), ('HL', 'hl')]:
        r = con.execute(f"""
            SELECT COUNT(*) as combos,
                   SUM(total_trades) as trades,
                   AVG(total_return) as avg_return,
                   AVG(win_rate) as avg_winrate,
                   AVG(sharpe_ratio) as avg_sharpe,
                   AVG(max_drawdown) as avg_mdd
            FROM {schema}.combo_summary
        """).fetchone()
        log(f'  {label}: {r[0]:,} combos, {r[1]:,} trades, '
            f'avg_return={r[2]:.4f}, avg_wr={r[3]:.2f}%, '
            f'avg_sharpe={r[4]:.4f}, avg_mdd={r[5]:.4f}')

    # --- 2. 逐 combo 对比 ---
    log('\n--- 2. 逐 combo 对比 (strategy × coin × interval) ---')
    diff_df = con.execute("""
        SELECT
            t.strategy, t.coin, t.interval,
            t.total_trades AS ttp_trades,
            h.total_trades AS hl_trades,
            t.total_return AS ttp_return,
            h.total_return AS hl_return,
            t.win_rate AS ttp_wr,
            h.win_rate AS hl_wr,
            t.sharpe_ratio AS ttp_sharpe,
            h.sharpe_ratio AS hl_sharpe,
            ABS(t.total_return - h.total_return) AS return_diff,
            ABS(t.total_trades - h.total_trades) AS trade_diff
        FROM ttp.combo_summary t
        JOIN hl.combo_summary h
            ON t.strategy = h.strategy AND t.coin = h.coin AND t.interval = h.interval
    """).fetchdf()

    total = len(diff_df)
    identical_return = len(diff_df[diff_df['return_diff'] < 0.0001])
    identical_trades = len(diff_df[diff_df['trade_diff'] == 0])
    very_different = len(diff_df[diff_df['return_diff'] > 1.0])

    log(f'  总 combo 数: {total}')
    log(f'  回报完全相同 (diff < 0.0001): {identical_return} ({identical_return/total*100:.1f}%)')
    log(f'  交易数完全相同: {identical_trades} ({identical_trades/total*100:.1f}%)')
    log(f'  回报差异 > 1.0: {very_different} ({very_different/total*100:.1f}%)')

    # 按 coin 分组
    log('\n--- 3. 按 coin 分组 ---')
    for coin in sorted(diff_df['coin'].unique()):
        sub = diff_df[diff_df['coin'] == coin]
        same = len(sub[sub['return_diff'] < 0.0001])
        log(f'  {coin}: {len(sub)} combos, 回报相同={same} ({same/len(sub)*100:.1f}%)')

    # 按 interval 分组
    log('\n--- 4. 按 interval 分组 ---')
    for iv in ['1m', '5m', '15m', '1h', '4h', '12h', '1d']:
        sub = diff_df[diff_df['interval'] == iv]
        if len(sub) == 0:
            continue
        same = len(sub[sub['return_diff'] < 0.0001])
        log(f'  {iv}: {len(sub)} combos, 回报相同={same} ({same/len(sub)*100:.1f}%)')

    # --- 5. 差异最大的 combo ---
    log('\n--- 5. 差异最大的 10 个 combo ---')
    top_diff = diff_df.nlargest(10, 'return_diff')
    for _, row in top_diff.iterrows():
        log(f'  {row["strategy"]}/{row["coin"]}/{row["interval"]}: '
            f'TTP={row["ttp_return"]:.4f} vs HL={row["hl_return"]:.4f} '
            f'(diff={row["return_diff"]:.4f}, trades {int(row["ttp_trades"])} vs {int(row["hl_trades"])})')

    # --- 6. 差异最小的 combo (应该有完全相同的吗？) ---
    log('\n--- 6. 回报完全相同的 combo 样本 (前5个) ---')
    same_combos = diff_df[diff_df['return_diff'] < 0.0001].head(5)
    if len(same_combos) == 0:
        log('  没有完全相同的 combo')
    else:
        for _, row in same_combos.iterrows():
            log(f'  {row["strategy"]}/{row["coin"]}/{row["interval"]}: '
                f'TTP={row["ttp_return"]:.4f} vs HL={row["hl_return"]:.4f}')

    # --- 7. paired_trades 抽样对比 ---
    log('\n--- 7. paired_trades 抽样对比 (3个combo) ---')
    sample_combos = diff_df[diff_df['return_diff'] > 0.1].sample(min(3, len(diff_df)), random_state=42)

    for _, combo_row in sample_combos.iterrows():
        strat, coin, iv = combo_row['strategy'], combo_row['coin'], combo_row['interval']
        log(f'\n  Combo: {strat}/{coin}/{iv}')

        for label, schema in [('TTP', 'ttp'), ('HL', 'hl')]:
            trades = con.execute(f"""
                SELECT pt.open_time, pt.direction, pt.entry_price,
                       pt.exit_price, pt.pnl, pt.close_type
                FROM {schema}.paired_trades pt
                JOIN {schema}.combo_summary cs ON pt.combo_id = cs.id
                WHERE cs.strategy = ? AND cs.coin = ? AND cs.interval = ?
                ORDER BY pt.open_candle_idx
                LIMIT 5
            """, [strat, coin, iv]).fetchall()
            log(f'    {label} first 5 trades:')
            for t in trades:
                log(f'      {t[0]} {t[1]} entry={t[2]:.2f} exit={t[3]:.2f} pnl={t[4]:.6f} ({t[5]})')

    # --- 8. 汇总 ---
    log('\n' + '=' * 60)
    log('=== 汇总 ===')
    if identical_return == total:
        log('结论: 两个种子数据完全相同 → highlow 未生效')
    elif identical_return == 0:
        log('结论: 所有 combo 都不同 → highlow 全面生效')
    else:
        log(f'结论: {identical_return}/{total} combo 相同, '
            f'{total - identical_return}/{total} 不同 → highlow 部分生效')
    log('=' * 60)

    # Save comparison result as JSON
    result = {
        'total_combos': total,
        'identical_return': int(identical_return),
        'identical_trades': int(identical_trades),
        'very_different': int(very_different),
        'pct_identical': round(identical_return / total * 100, 1),
        'pct_different': round((total - identical_return) / total * 100, 1),
    }
    result_path = os.path.join(REPORT_DIR, 'ttp_vs_highlow_comparison.json')
    with open(result_path, 'w') as f:
        json.dump(result, f, indent=2)
    log(f'\n对比结果已保存: {result_path}')

    con.close()


if __name__ == '__main__':
    log('开始 SQLite → DuckDB 转换')
    log(f'目标种子: {SEEDS}')

    for seed in SEEDS:
        convert_one(seed)

    log('\n转换完成，开始对比...')
    compare_ttp_vs_highlow()

    log('\n全部完成。')
