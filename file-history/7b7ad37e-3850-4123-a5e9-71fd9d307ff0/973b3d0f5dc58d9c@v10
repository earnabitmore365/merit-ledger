INDICATOR_COOLDOWN_ROUNDS = 3  # v0.7: 触发后冷却 N 轮（冷就冷彻底）
COOLDOWN_THAW_CYCLE = 10       # 每N轮冷却后全部解冻（让GP自由探索）
COOLDOWN_THAW_ROUNDS = 2       # v0.7: 解冻持续轮数（第3轮恢复冷却）

# === v0.8: 弃权制毕业考 ===
