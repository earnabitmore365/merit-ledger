CROSSOVER_PROB = 0.7        # 交叉概率
MUTATION_PROB = 0.2         # 变异概率
ELITISM = 5                 # 每代保留最优 N 棵
PARSIMONY_COEFF = 0.02      # v0.5: 简洁性惩罚加大（逼GP找简单规则）
