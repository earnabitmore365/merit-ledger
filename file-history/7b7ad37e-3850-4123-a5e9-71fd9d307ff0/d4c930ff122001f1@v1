#!/usr/bin/env python3
"""UserPromptSubmit hook: 注入 rules.md 到上下文"""
import os, sys

project_dir = os.path.expanduser("~/.claude/projects/-Users-allenbot-project-auto-trading/memory")
global_dir = os.path.expanduser("~/.claude/projects/-Users-allenbot/memory")

parts = []

for label, path in [
    ("全局规则", os.path.join(global_dir, "rules.md")),
    ("auto-trading 规则", os.path.join(project_dir, "rules.md")),
]:
    if os.path.exists(path):
        with open(path, "r") as f:
            content = f.read().strip()
        if content:
            parts.append(f"=== {label} ===\n{content}")

if parts:
    print("\n---\n".join(parts))
