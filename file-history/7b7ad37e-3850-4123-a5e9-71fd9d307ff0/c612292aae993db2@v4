def enable_param_indicators(enabled=True):
    """开关参数化指标（哨兵营启动时关掉，自动恢复旧固定终端）"""
    global _param_enabled, FIXED_TERMINALS
    _param_enabled = enabled
    if not enabled:
        # 关掉参数化 → 把旧的 rsi_7/sma_5 等加回固定终端
        existing = {t[0] for t in FIXED_TERMINALS}
        for t in _LEGACY_TERMINALS:
            if t[0] not in existing:
                FIXED_TERMINALS.append(t)


# === v0.5: 指标冷却 ===
# v0.7: 冷却集合同时支持固定指标名('macd_hist')和参数化类型名('rsi')
# close/volume/const 不会出现在冷却集合中（冷却由 gp_evolve.py 管理冠军指标）
_cooled_indicators = set()


def set_cooled_indicators(cooled: set):
    """设置当前冷却中的指标（由 gp_evolve.py 每轮调用）"""
    global _cooled_indicators
    _cooled_indicators = cooled


def get_available_fixed_terminals():
    """返回可用的固定终端（排除冷却中的）"""
    if not _cooled_indicators:
        return [t for t in FIXED_TERMINALS if t[1] == NUMERIC]
    return [t for t in FIXED_TERMINALS if t[1] == NUMERIC and t[0] not in _cooled_indicators]


def get_available_param_types():
    """返回可用的参数化指标类型名列表（排除冷却中的，关闭时返回空）"""
    if not _param_enabled:
        return []
    if not _cooled_indicators:
        return list(PARAM_INDICATORS.keys())
    return [t for t in PARAM_INDICATORS if t not in _cooled_indicators]


def random_param(indicator_type):
    """为参数化指标随机选一个周期"""
    min_p, max_p = PARAM_INDICATORS[indicator_type]
    return random.randint(min_p, max_p)


# === v1.0: 岛屿指标偏好 ===
_island_bias = None  # None | 'volume' | 'momentum' | 'volatility' | 'trend' | 'free'
_island_categories = {}  # 从 config 加载

def set_island_bias(bias: str, categories: dict = None):
    """设置当前岛屿的指标偏好（由 engine.py 每岛进化前调用）

    bias='free' 或 None 表示无偏好。
    偏好类指标在随机选终端时权重 ×2。
    """
    global _island_bias, _island_categories
    _island_bias = bias if bias and bias != 'free' else None
    if categories:
        _island_categories = categories


def get_biased_param_types():
    """返回带偏好权重的参数化指标类型列表（可重复=权重高）"""
    available = get_available_param_types()
    if not available or not _island_bias or not _island_categories:
        return available

    preferred = _island_categories.get(_island_bias, set())
    # 偏好类出现 2 次（权重 ×2），非偏好类出现 1 次
    weighted = []
    for t in available:
        weighted.append(t)
        if t in preferred:
            weighted.append(t)  # 再加一次
    return weighted


def get_biased_fixed_terminals():
    """返回带偏好权重的固定终端列表"""
    available = get_available_fixed_terminals()
    if not available or not _island_bias or not _island_categories:
        return available

    preferred = _island_categories.get(_island_bias, set())
    weighted = []
    for t in available:
        weighted.append(t)
        if t[0] in preferred:
            weighted.append(t)
    return weighted


