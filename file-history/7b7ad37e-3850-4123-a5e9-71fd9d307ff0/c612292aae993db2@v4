# === 函数节点 ===

def _safe_div(a, b):
    """安全除法：除数为0时返回0"""
    with np.errstate(divide='ignore', invalid='ignore'):
        return np.where(np.abs(b) > 1e-10, a / b, 0.0)


FUNCTIONS = [
    # 算术 (numeric × numeric → numeric)
    ('add', 2, [NUMERIC, NUMERIC], NUMERIC, lambda a, b: a + b),
    ('sub', 2, [NUMERIC, NUMERIC], NUMERIC, lambda a, b: a - b),
    ('mul', 2, [NUMERIC, NUMERIC], NUMERIC, lambda a, b: a * b),
    ('div', 2, [NUMERIC, NUMERIC], NUMERIC, _safe_div),
    ('neg', 1, [NUMERIC],          NUMERIC, lambda a: -a),
    ('abs', 1, [NUMERIC],          NUMERIC, lambda a: np.abs(a)),
    # v0.2: min/max — 交易中常见的"取两个指标较大/较小者"
    ('min', 2, [NUMERIC, NUMERIC], NUMERIC, lambda a, b: np.minimum(a, b)),
    ('max', 2, [NUMERIC, NUMERIC], NUMERIC, lambda a, b: np.maximum(a, b)),
    # v0.2: if-then-else — "如果条件成立选A，否则选B"
    ('ite', 3, [BOOLEAN, NUMERIC, NUMERIC], NUMERIC,
     lambda c, a, b: np.where(c > 0.5, a, b)),

    # 比较 (numeric × numeric → boolean)
    ('gt',  2, [NUMERIC, NUMERIC], BOOLEAN, lambda a, b: (a > b).astype(float)),
    ('lt',  2, [NUMERIC, NUMERIC], BOOLEAN, lambda a, b: (a < b).astype(float)),
    ('gte', 2, [NUMERIC, NUMERIC], BOOLEAN, lambda a, b: (a >= b).astype(float)),

    # 逻辑 (boolean × boolean → boolean)
    ('and', 2, [BOOLEAN, BOOLEAN], BOOLEAN, lambda a, b: a * b),
    ('or',  2, [BOOLEAN, BOOLEAN], BOOLEAN, lambda a, b: np.clip(a + b, 0, 1)),
    ('not', 1, [BOOLEAN],          BOOLEAN, lambda a: 1.0 - a),
]

# 按输出类型分组
NUMERIC_FUNCTIONS = [f for f in FUNCTIONS if f[3] == NUMERIC]
BOOLEAN_FUNCTIONS = [f for f in FUNCTIONS if f[3] == BOOLEAN]

# 查找表
FUNC_LOOKUP = {f[0]: f for f in FUNCTIONS}


