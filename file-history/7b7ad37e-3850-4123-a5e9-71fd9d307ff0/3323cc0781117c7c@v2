#!/bin/bash
# Ralph Loop — MiniMax M2.7-highspeed 后台循环审查
#
# 用法：
#   bash ~/.claude/scripts/ralph_minimax.sh              # 前台跑（看输出）
#   nohup bash ~/.claude/scripts/ralph_minimax.sh > /tmp/ralph_minimax.log 2>&1 &  # 后台跑
#
# 停止：
#   touch /Volumes/BIWIN\ NV\ 7400\ 2TB/Loop/STOP

set -euo pipefail

LOOP_DIR="/Volumes/BIWIN NV 7400 2TB/Loop"
LOG="/tmp/ralph_minimax_rounds.log"
MINIMAX_KEY="$HOME/.claude/.minimax_key"
MODEL="MiniMax-M2.7-highspeed"
STALL=0
MAX_STALL=5
ROUND=0

cd "$LOOP_DIR"

# 初始化 git（如果没有）
if [ ! -d .git ]; then
    git init && git add -A && git commit -m "initial: 原始代码（loop 前）"
fi

# 清理残留 STOP
[ -f STOP ] && rm STOP

echo "============================================================"
echo "  Ralph Loop — MiniMax M2.7-highspeed"
echo "  时间: $(date '+%Y-%m-%d %H:%M:%S')"
echo "  停止: touch \"$LOOP_DIR/STOP\""
echo "  日志: $LOG"
echo "============================================================"
echo ""

while [ ! -f STOP ]; do
    ROUND=$((ROUND + 1))

    # 记录当前 HEAD
    BEFORE=$(git rev-parse HEAD 2>/dev/null || echo "none")

    echo "━━━ Round $ROUND ━━━ $(date '+%H:%M:%S')" | tee -a "$LOG"

    # 单轮调用 MiniMax
    ANTHROPIC_BASE_URL="https://api.minimax.io/anthropic" \
    ANTHROPIC_API_KEY="$(cat "$MINIMAX_KEY")" \
    claude -p "你是代码审查员。直接在 lab/ 目录上审查。

规则：
1. 读 PROGRESS.md 了解当前进度（第几遍、已修的问题）
2. 读 PROMPT.md 了解审查标准
3. 找一个新问题并修复（一轮只修一个问题或同文件同类问题）
4. 验证：python3 -m py_compile <文件>
5. 更新 PROGRESS.md（记录本轮修复）
6. git add -A && git commit -m \"第N遍：具体改了什么\"
7. 如果扫完所有文件没发现新问题，只输出：无新发现

禁止：不改业务逻辑、不删整个文件、不加新功能、不重构架构。" \
        --model "$MODEL" \
        --allowedTools "Read,Write,Edit,Bash,Glob,Grep" \
        --max-turns 30 \
        --output-format stream-json --verbose \
        2>&1 | while IFS= read -r line; do
            # 提取文字输出到日志
            echo "$line" | python3 -c "
import sys, json
for line in sys.stdin:
    try:
        ev = json.loads(line.strip())
        if ev.get('type') == 'assistant':
            for c in ev.get('message',{}).get('content',[]):
                if c.get('type') == 'text':
                    print(c['text'][:500])
    except: pass
" >> "$LOG" 2>/dev/null
        done

    # 检查有没有新改动（git diff 或新 commit）
    AFTER=$(git rev-parse HEAD 2>/dev/null || echo "none")

    # 也检查 working tree 有没有未 commit 的改动
    if [ "$BEFORE" != "$AFTER" ] || ! git diff --quiet 2>/dev/null; then
        # 有改动 — 如果有未 commit 的，帮它 commit
        if ! git diff --quiet 2>/dev/null; then
            git add -A
            git commit -m "loop $ROUND: MiniMax 自动修复（未 commit 补提交）" 2>/dev/null || true
        fi
        STALL=0
        echo "  ✅ 有改动（stall 重置）" | tee -a "$LOG"
    else
        STALL=$((STALL + 1))
        echo "  ⏸️  无新发现 ($STALL/$MAX_STALL)" | tee -a "$LOG"
    fi

    # 收尾条件
    if [ "$STALL" -ge "$MAX_STALL" ]; then
        echo "" | tee -a "$LOG"
        echo "🏁 连续 ${MAX_STALL} 轮无新发现，自动收尾" | tee -a "$LOG"

        # 收尾：复制到 Loop Done
        DONE_DIR="/Volumes/BIWIN NV 7400 2TB/Loop Done/$(date '+%Y%m%d-%H%M')"
        mkdir -p "$DONE_DIR"
        cp -r lab "$DONE_DIR/"
        cp PROGRESS.md README.md "$DONE_DIR/" 2>/dev/null || true

        # 最终报告
        TOTAL_COMMITS=$(git log --oneline | wc -l | tr -d ' ')
        echo "============================================================" | tee -a "$LOG"
        echo "  Ralph Loop 完成" | tee -a "$LOG"
        echo "  总轮次: $ROUND" | tee -a "$LOG"
        echo "  总 commits: $TOTAL_COMMITS" | tee -a "$LOG"
        echo "  输出: $DONE_DIR" | tee -a "$LOG"
        echo "============================================================" | tee -a "$LOG"

        touch STOP
        break
    fi

    echo "" | tee -a "$LOG"
    sleep 2
done
