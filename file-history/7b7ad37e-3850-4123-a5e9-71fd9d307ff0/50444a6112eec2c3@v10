"""
CMA-ES 参数精化器 — v1.0

@see lab/README.md#architecture — 指标统一调用 indicator_cache

GP 找到好的规则骨架后，用 CMA-ES 精调参数化节点的周期。
比 GP 的随机变异快一个数量级。

依赖：pip install cma

用法（内部调用，不单独跑）：
    from param_optimizer import optimize_params
    optimized_tree, best_score = optimize_params(tree, direction, data, close_raw)
"""

import copy
import math
import logging
import numpy as np

try:
    import cma
    HAS_CMA = True
except ImportError:
    HAS_CMA = False

import tree as tree_mod
from evaluator import fitness
from config import (
    CMAES_MAX_ITER, CMAES_SIGMA0, CMAES_POPSIZE_FACTOR,
)
from blocks import PARAM_INDICATORS

logger = logging.getLogger('GP.CMA-ES')


def _collect_param_nodes(node, result=None):
    """收集树中所有参数化节点（有 param 属性的）

    Returns:
        [(node_ref, indicator_name, current_param, min_p, max_p), ...]
    """
    if result is None:
        result = []
    if node.param is not None and node.name in PARAM_INDICATORS:
        min_p, max_p = PARAM_INDICATORS[node.name]
        result.append((node, node.name, node.param, min_p, max_p))
    for child in (node.children or []):
        _collect_param_nodes(child, result)
    return result


def _set_params(tree, param_nodes_info, param_vector):
    """将参数向量赋值回树的参数化节点

    param_vector 是浮点数，需要 round + clamp 到合法整数范围。
    """
    for i, (node, name, _, min_p, max_p) in enumerate(param_nodes_info):
        # round 到最近整数，clamp 到合法范围
        val = int(round(param_vector[i]))
        val = max(min_p, min(max_p, val))
        node.param = val


def optimize_params(tree, direction, data, close_raw, max_iter=None,
                    sigma0=None, verbose=True):
    """对一棵树的参数化节点进行 CMA-ES 优化

    Args:
        tree: 表达式树（Node）
        direction: 'long' | 'short'
        data: 归一化数据字典
        close_raw: 原始 close 数组
        max_iter: 最大迭代数（默认用 config）
        sigma0: 初始步长（默认用 config）
        verbose: 是否输出日志

    Returns:
        (optimized_tree, best_score) — 优化后的树和最优适应度
        如果没有参数化节点或 CMA 不可用，返回原树和原分数
    """
    if not HAS_CMA:
        logger.warning("pycma 未安装，跳过参数优化。安装：pip install cma")
        score, _ = fitness(tree, data, close_raw, direction)
        return tree, score

    # 收集参数化节点
    optimized_tree = copy.deepcopy(tree)
    param_nodes = _collect_param_nodes(optimized_tree)

    if not param_nodes:
        if verbose:
            logger.info("无参数化节点，跳过 CMA-ES")
        score, _ = fitness(optimized_tree, data, close_raw, direction)
        return optimized_tree, score

    n_params = len(param_nodes)
    if max_iter is None:
        max_iter = CMAES_MAX_ITER
    if sigma0 is None:
        sigma0 = CMAES_SIGMA0

    # 初始值：当前参数
    x0 = np.array([float(info[2]) for info in param_nodes])

    # 参数范围（用于 CMA-ES 边界）
    lower_bounds = np.array([float(info[3]) for info in param_nodes])
    upper_bounds = np.array([float(info[4]) for info in param_nodes])

    # CMA-ES 种群大小
    popsize = min(4 + int(CMAES_POPSIZE_FACTOR * math.log(n_params + 1)), 20)

    # 原始分数
    _set_params(optimized_tree, param_nodes, x0)
    original_score, _ = fitness(optimized_tree, data, close_raw, direction)

    if verbose:
        logger.info(f"CMA-ES 开始: {n_params} 参数, "
                    f"初始分数={original_score:+.4f}, "
                    f"popsize={popsize}, maxiter={max_iter}")
        param_desc = ', '.join(f"{info[1]}={info[2]}" for info in param_nodes)
        logger.info(f"  参数: {param_desc}")

    # 评估计数
    eval_count = 0

    def objective(x):
        """CMA-ES 目标函数（最小化，所以取负）"""
        nonlocal eval_count
        _set_params(optimized_tree, param_nodes, x)
        score, _ = fitness(optimized_tree, data, close_raw, direction)
        eval_count += 1
        return -score  # CMA-ES 最小化，我们要最大化 fitness

    # 运行 CMA-ES
    opts = {
        'popsize': popsize,
        'maxiter': max_iter,
        'bounds': [lower_bounds.tolist(), upper_bounds.tolist()],
        'verbose': -9,  # 静默
        'seed': 42,
    }

    try:
        es = cma.CMAEvolutionStrategy(x0.tolist(), sigma0, opts)
        while not es.stop():
            solutions = es.ask()
            objectives = [objective(x) for x in solutions]
            es.tell(solutions, objectives)

        best_x = es.result.xbest
        best_score = -es.result.fbest  # 转回正值

    except Exception as e:
        logger.error(f"CMA-ES 异常: {e}")
        # 恢复原参数
        _set_params(optimized_tree, param_nodes, x0)
        return optimized_tree, original_score

    # 应用最优参数
    _set_params(optimized_tree, param_nodes, best_x)

    if verbose:
        improvement = best_score - original_score
        # 重新收集优化后的参数值
        optimized_params = _collect_param_nodes(optimized_tree)
        new_desc = ', '.join(f"{info[1]}={info[2]}" for info in optimized_params)
        logger.info(f"CMA-ES 完成: {eval_count} 次评估, "
                    f"分数 {original_score:+.4f} → {best_score:+.4f} "
                    f"({'↑' if improvement > 0 else '↓'}{abs(improvement):.4f})")
        logger.info(f"  优化后参数: {new_desc}")

    return optimized_tree, best_score
