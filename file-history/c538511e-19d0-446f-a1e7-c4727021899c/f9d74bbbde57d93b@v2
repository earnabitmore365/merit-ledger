#!/usr/bin/env python3
"""Gateway 查询工具 — 通过 ZMQ REP 查询 Gateway

用法:
    python3 gw_query.py KLINES SOL 1m
    python3 gw_query.py PRICE SOL

@see CHECKPOINT.md#100 — 通讯部总机 Feed Gateway
"""
import sys
import json
import zmq

REP_PORT = 5556


def main():
    if len(sys.argv) < 2:
        print(json.dumps({"error": "用法: gw_query.py COMMAND [args...]"}))
        sys.exit(1)

    cmd = ' '.join(sys.argv[1:])
    ctx = zmq.Context()
    sock = ctx.socket(zmq.REQ)
    sock.setsockopt(zmq.RCVTIMEO, 5000)  # 5 秒超时
    sock.connect(f"tcp://127.0.0.1:{REP_PORT}")
    sock.send_string(cmd)

    try:
        reply = sock.recv_string()
        print(reply)
    except zmq.Again:
        print(json.dumps({"error": "Gateway 无响应（超时 5 秒）"}))
        sys.exit(1)
    finally:
        sock.close()
        ctx.term()


if __name__ == '__main__':
    main()
