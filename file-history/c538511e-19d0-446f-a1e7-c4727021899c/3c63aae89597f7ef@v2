#!/usr/bin/env python3
"""
Gate 统一入口 — 对一个种子库跑完整 Gate 管线

用途：
  1. --matrix 矩阵模式自动调用（generate_seed.py → _run_matrix → 本模块）
  2. 独立调用：python3 gate_runner.py --seed reports/seed_v3.db --report-dir results/gate_v41

做什么：
  1. 检查/生成 regime_fact_labels 表（BTC 已知事实标签）
  2. 检查/生成 sub_phase_labels 表（子阶段动量标签）
  3. 跑 Gate 四关（初考→专考→组考→MC照妖镜）
  4. 输出 Gate 报告到指定目录

关联：
  - 读取：种子库（seed_v3.db / seed_v3_ttp.db / seed_v3_ttp_highlow.db）
  - 调用：regime_fact_timeline.py, sub_phase_labels.py, gate1~gate_mc 模块
  - 输出：Gate 报告 DB（report.db）
  - 被调用：generate_seed.py _run_matrix()

@see generate_seed.py — 种子生成 + 矩阵调度
@see run_gate_v41.py — 原始独立 Gate 脚本（保留可用）
"""
import os
import sys
import time
import sqlite3
import argparse

LAB_DIR = os.path.dirname(os.path.abspath(__file__))
if LAB_DIR not in sys.path:
    sys.path.insert(0, LAB_DIR)


def _table_exists(db_path, table_name):
    """检查表是否存在于 DB 中"""
    conn = sqlite3.connect(db_path)
    row = conn.execute(
        "SELECT name FROM sqlite_master WHERE type='table' AND name=?",
        (table_name,)
    ).fetchone()
    conn.close()
    return row is not None


def _ensure_regime_labels(seed_db_path):
    """确保 regime_fact_labels 表存在，不存在就生成"""
    if _table_exists(seed_db_path, 'regime_fact_labels'):
        conn = sqlite3.connect(seed_db_path)
        count = conn.execute("SELECT COUNT(*) FROM regime_fact_labels").fetchone()[0]
        conn.close()
        print("  ✅ regime_fact_labels 已存在 (%d 条)" % count)
        return

    print("  ⏳ 生成 regime_fact_labels...")
    t0 = time.time()
    import regime_fact_timeline
    regime_fact_timeline.DB_PATH = seed_db_path
    regime_fact_timeline.main()
    print("  ✅ regime_fact_labels 完成 (%.1fs)" % (time.time() - t0))


def _ensure_sub_phase_labels(seed_db_path):
    """确保 sub_phase_labels 表存在，不存在就生成"""
    if _table_exists(seed_db_path, 'sub_phase_labels'):
        conn = sqlite3.connect(seed_db_path)
        count = conn.execute("SELECT COUNT(*) FROM sub_phase_labels").fetchone()[0]
        conn.close()
        print("  ✅ sub_phase_labels 已存在 (%d 条)" % count)
        return

    print("  ⏳ 生成 sub_phase_labels...")
    t0 = time.time()
    import sub_phase_labels
    sub_phase_labels.DB_PATH = seed_db_path
    sub_phase_labels.main()
    print("  ✅ sub_phase_labels 完成 (%.1fs)" % (time.time() - t0))


def _patch_and_run_gate(seed_db_path, report_db_path):
    """Patch Gate 模块全局变量 + 跑四关

    变量名映射（从源码确认）：
      gate1_threshold:    DB_PATH, REPORT_PATH
      gate2v41_scorecard: DB_PATH, REPORT_V4(Gate1来源), REPORT_V41(Gate2输出)
      gate3v41_team:      REPORT_PATH（无 DB_PATH，只读报告DB）
      gate_mcv41:         DB_PATH, REPORT_PATH

    关键：Gate2 会 os.remove(REPORT_V41) 再重建。Gate1 和 Gate2 不能共享同一个输出文件。
    所以 Gate1 先写临时文件，Gate2 从临时文件读 Gate1 结果，输出到最终 report_db。
    Gate3 和 MC 在 Gate2 输出的基础上追加。
    """
    report_dir = os.path.dirname(report_db_path)
    os.makedirs(report_dir, exist_ok=True)

    # Gate1 写临时文件（Gate2 会删最终文件再重建）
    gate1_temp = report_db_path + '.gate1_tmp'

    import gate1_threshold
    import gate2v41_scorecard
    import gate3v41_team
    import gate_mcv41

    # Patch Gate1: 种子库 → 临时报告
    gate1_threshold.DB_PATH = seed_db_path
    gate1_threshold.REPORT_PATH = gate1_temp

    # Patch Gate2: 种子库 + 从临时文件读Gate1 → 最终报告
    gate2v41_scorecard.DB_PATH = seed_db_path
    gate2v41_scorecard.REPORT_V4 = gate1_temp
    gate2v41_scorecard.REPORT_V41 = report_db_path

    # Patch Gate3 + MC: 在最终报告上追加
    gate3v41_team.REPORT_PATH = report_db_path
    gate_mcv41.DB_PATH = seed_db_path
    gate_mcv41.REPORT_PATH = report_db_path

    # 跑四关
    steps = [
        ('初考（交易数门槛）', gate1_threshold),
        ('专考（13维度成绩单）', gate2v41_scorecard),
        ('组考（组队）', gate3v41_team),
        ('照妖镜 MC', gate_mcv41),
    ]

    for i, (name, module) in enumerate(steps, 1):
        print("  [Gate %d/4] %s..." % (i, name))
        t0 = time.time()
        module.main()
        print("  [Gate %d/4] %s 完成 (%.1fs)" % (i, name, time.time() - t0))

    # 清理 Gate1 临时文件
    if os.path.exists(gate1_temp):
        os.remove(gate1_temp)


def run_gate_pipeline(seed_db_path, report_dir):
    """对一个种子库跑完整 Gate 管线

    Args:
        seed_db_path: 种子库绝对路径
        report_dir: Gate 报告输出目录

    Returns:
        report_db 绝对路径
    """
    os.makedirs(report_dir, exist_ok=True)
    report_db = os.path.join(report_dir, 'report.db')

    print("\n" + "─" * 60)
    print("  Gate 管线: %s" % os.path.basename(seed_db_path))
    print("  输出: %s" % report_db)
    print("─" * 60)

    # 1. Prerequisites
    _ensure_regime_labels(seed_db_path)
    _ensure_sub_phase_labels(seed_db_path)

    # 2. Gate 四关
    _patch_and_run_gate(seed_db_path, report_db)

    # 3. 汇总
    if os.path.exists(report_db):
        conn = sqlite3.connect(report_db)
        tables = [r[0] for r in conn.execute(
            "SELECT name FROM sqlite_master WHERE type='table'"
        ).fetchall()]
        if 'champions' in tables:
            n_champs = conn.execute("SELECT COUNT(*) FROM champions").fetchone()[0]
            print("  🏆 冠军: %d 个" % n_champs)
        conn.close()

    print("─" * 60)
    return report_db


def main():
    """独立运行入口"""
    parser = argparse.ArgumentParser(description='Gate 统一管线')
    parser.add_argument('--seed', required=True, help='种子库路径')
    parser.add_argument('--report-dir', required=True, help='Gate 报告输出目录')
    args = parser.parse_args()

    seed_db = os.path.abspath(args.seed)
    report_dir = os.path.abspath(args.report_dir)

    if not os.path.exists(seed_db):
        print("错误：种子库不存在: %s" % seed_db)
        return

    run_gate_pipeline(seed_db, report_dir)


if __name__ == '__main__':
    main()
