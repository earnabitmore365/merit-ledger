#!/usr/bin/env python3
"""
VWAP Strategy

Simple VWAP strategy.
- Price above VWAP = BUY
- Price below VWAP = SELL
- Otherwise = HOLD
"""

from typing import Dict, List
from src.core.strategy.base import Strategy, Signal


class VWAPStrategy(Strategy):
    """VWAP trading strategy"""
    
    def __init__(self):
        super().__init__("vwap")
    
    def __init__(self):
        self.name = "vwap"
        self.exchange = None
        self.period = 20
    
    def set_exchange(self, exchange):
        """Set exchange adapter"""
        self.exchange = exchange
    
    def calculate_vwap(self, candles: List[Dict]) -> float:
        """Calculate VWAP"""
        if len(candles) < self.period:
            return sum(c["close"] for c in candles) / len(candles)
        
        tp_sum = 0.0
        vol_sum = 0.0
        
        for c in candles[-self.period:]:
            typical_price = (c["high"] + c["low"] + c["close"]) / 3
            volume = c.get("volume", 1000)
            tp_sum += typical_price * volume
            vol_sum += volume
        
        return tp_sum / vol_sum if vol_sum else 0
    
    def generate_signal(self, coin: str, candles: List[Dict] = None) -> Signal:
        """Generate VWAP trading signal
        
        Args:
            coin: Trading pair
            candles: OHLCV data
            
        Returns:
            Signal: BUY, SELL, or HOLD
        """
        # Validate candles
        if not candles or len(candles) < self.period:
            return Signal.HOLD
        
        vwap = self.calculate_vwap(candles)
        current_price = candles[-1]["close"]
        
        # Simple conditions
        if current_price > vwap:
            return Signal.BUY
        elif current_price < vwap:
            return Signal.SELL
        return Signal.HOLD
