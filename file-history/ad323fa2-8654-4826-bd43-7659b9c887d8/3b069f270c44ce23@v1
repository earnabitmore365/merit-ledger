#!/usr/bin/env python3
"""
MA RSI Strategy

MA + RSI simple strategy.

Features:
- Simple MA crossover
- RSI filter
- Auto-migrated from echo-auto-trading project
"""

from typing import Dict, List
from src.core.strategy import Signal


class MARSIStrategy:
    """MA + RSI simple trading strategy"""
    
    def __init__(self):
        self.name = "ma_rsi"
        self.ma_period = 20
        self.rsi_period = 14
    
    def calculate_ma(self, closes: List[float]) -> float:
        """Calculate Simple Moving Average"""
        if len(closes) < self.ma_period:
            return sum(closes) / len(closes)
        return sum(closes[-self.ma_period:]) / self.ma_period
    
    def calculate_rsi(self, closes: List[float]) -> float:
        """Calculate Simple RSI"""
        if len(closes) < self.rsi_period + 1:
            return 50.0
        
        gains = 0.0
        losses = 0.0
        
        for i in range(1, len(closes)):
            change = closes[i] - closes[i - 1]
            if change > 0:
                gains += change
            else:
                losses += abs(change)
        
        if losses == 0:
            return 100.0
        
        rs = gains / losses
        rsi = 100 - (100 / (1 + rs))
        return rsi
    
    def generate_signal(self, coin: str, candles: List[Dict] = None) -> Signal:
        """Generate MA RSI trading signal
        
        Args:
            coin: Trading pair
            candles: OHLCV data
            
        Returns:
            Signal: BUY, SELL, or HOLD
        """
        # Validate candles
        if not candles or len(candles) < 30:
            return Signal.HOLD
        
        closes = [c["close"] for c in candles]
        
        # Calculate indicators
        ma = self.calculate_ma(closes)
        rsi = self.calculate_rsi(closes)
        
        # Simple conditions
        if closes[-1] > ma and rsi < 50:
            return Signal.BUY
        if closes[-1] < ma and rsi > 50:
            return Signal.SELL
        return Signal.HOLD
