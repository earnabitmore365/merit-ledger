#!/usr/bin/env python3
import sys, json, numpy as np
sys.path.insert(0, '/home/pc_heisi_claude/trading/gp_engine')
sys.path.insert(0, '/home/pc_heisi_claude/trading/src/core')
import config, indicators

with open(config.DATA_DIR + '/BTC/1h.json') as f:
    candles = json.load(f)

ohlcv = {
    'open': np.array([c['open'] for c in candles], dtype=float),
    'high': np.array([c['high'] for c in candles], dtype=float),
    'low': np.array([c['low'] for c in candles], dtype=float),
    'close': np.array([c['close'] for c in candles], dtype=float),
    'volume': np.array([c['volume'] for c in candles], dtype=float),
}
mirror = indicators.mirror_ohlcv(ohlcv)
sma200 = indicators.sma(ohlcv['close'], 200)
i = 500
orig_close = ohlcv['close'][i]
sma_val = sma200[i]
mir_close = mirror['close'][i]
expected = 2 * sma_val - orig_close
print(f"翻转验证 (i={i}):")
print(f"  原始 close: {orig_close:.2f}")
print(f"  SMA200: {sma_val:.2f}")
print(f"  翻转 close: {mir_close:.2f}")
print(f"  公式 2*SMA200-close: {expected:.2f}")
print(f"  匹配: {abs(mir_close - expected) < 0.01}")
print(f"  volume不变: {ohlcv['volume'][i] == mirror['volume'][i]}")
