#!/bin/bash
# 清掉旧 scheduler 和 watchdog，只留新的 4-worker scheduler
pkill -f "watchdog.sh" 2>/dev/null

# 杀 2-worker 的旧 scheduler (PID 28317)
kill 28317 2>/dev/null
# 等它的子进程也退出
sleep 2
pkill -f "gp_evolve.*--workers 2" 2>/dev/null

echo "=== 剩余进程 ==="
ps aux | grep -E "gp_scheduler|gp_evolve|watchdog" | grep -v grep
