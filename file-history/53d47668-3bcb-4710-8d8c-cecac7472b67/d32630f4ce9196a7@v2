#!/usr/bin/env python3
"""清除 git 历史中的敏感文件"""
import subprocess, os

repo = os.path.expanduser("~/.claude")
files = ".comm_pass,testnet_secrets.py,testnet_secrets.cpython-311.pyc,settings.json.save"

print("1. bfg 清除敏感文件...")
r = subprocess.run(["bfg", "--delete-files", f"{{{files}}}"], cwd=repo, capture_output=True, text=True)
print(r.stdout[-500:] if r.stdout else "")
if r.stderr: print(r.stderr[-300:])

print("\n2. reflog expire...")
subprocess.run(["git", "reflog", "expire", "--expire=now", "--all"], cwd=repo)

print("\n3. git gc...")
subprocess.run(["git", "gc", "--prune=now", "--aggressive"], cwd=repo, timeout=120)

print("\n4. force push...")
r = subprocess.run(["git", "push", "origin", "main", "--force"], cwd=repo, capture_output=True, text=True)
print(r.stdout if r.stdout else "")
if r.returncode == 0:
    print("✅ 清除完成，已推送")
else:
    print(f"push 失败: {r.stderr[-300:]}")
