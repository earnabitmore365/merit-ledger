ssh root@100.122.227.7 "ps aux | grep -E 'feed_gateway|unified_trader' | grep -v grep"

# Gateway 健康检查
ssh root@100.122.227.7 "grep -c ERROR /opt/auto-trading/lab/logs/gateway.log"

# ZMQ 监听测试（TICK + HEARTBEAT）
ssh root@100.122.227.7 "python3 -c \"
import zmq, time
ctx = zmq.Context()
sub = ctx.socket(zmq.SUB)
sub.connect('tcp://127.0.0.1:5555')
sub.setsockopt_string(zmq.SUBSCRIBE, '')
