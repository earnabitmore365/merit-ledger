#!/usr/bin/env python3
"""test_adapter.py — 测试网 adapter 行为验证

在测试网上逐个调 adapter 的每个函数，记录真实返回值和单位。
用于校准 adapter 和 unified_trader 的对接。

用法: python3 test_adapter.py
"""
import os
import sys
import time

# 强制测试网
os.environ['BITMEX_TESTNET'] = 'true'

# 添加路径
sys.path.insert(0, os.path.dirname(__file__))
sys.path.insert(0, os.path.join(os.path.dirname(__file__), 'src'))

from dotenv import load_dotenv
load_dotenv(os.path.join(os.path.dirname(__file__), '.env'))

from exchange.bitmex.adapter import BitMEXAdapter
from exchange.base import OrderRequest, OrderSide, OrderType

# 使用测试网 API key
config = {
    'api_key': os.getenv('BITMEX_TESTNET_API_KEY', ''),
    'api_secret': os.getenv('BITMEX_TESTNET_API_SECRET', ''),
    'testnet': True,
    'default_leverage': 10,
}

if not config['api_key']:
    print("错误: .env 里没有 BITMEX_TESTNET_API_KEY")
    sys.exit(1)

adapter = BitMEXAdapter(config)
adapter.connect()

print("=" * 60)
print("Adapter API 行为验证 — 测试网")
print("=" * 60)

# ========== 1. 余额 ==========
print("\n--- 1. get_balance() ---")
balance = adapter.get_balance()
print(f"  原始返回: {balance}")
print(f"  available 单位: {'微美元(需÷1e6)' if balance.get('available', 0) > 100000 else '美元'}")
avail = balance.get('available', 0)
print(f"  available 美元: {avail / 1e6 if avail > 100000 else avail}")

# ========== 2. 仓位 ==========
print("\n--- 2. get_positions() ---")
positions = adapter.get_positions()
print(f"  原始返回: {positions}")
print(f"  数量: {len(positions)} 个仓位")
for p in positions:
    print(f"    {p}")

# ========== 3. 合约参数 ==========
print("\n--- 3. get_instrument_info() ---")
for coin in ['BTC', 'ETH', 'SOL', 'XRP']:
    info = adapter.get_instrument_info(coin)
    u2p = info.get('underlyingToPositionMultiplier', 'N/A')
    lot = info.get('lotSize', 'N/A')
    tick = info.get('tickSize', 'N/A')
    print(f"  {coin}: u2p={u2p}, lotSize={lot}, tickSize={tick}")

# ========== 4. 最优买卖价 ==========
print("\n--- 4. get_best_bid_ask() ---")
for coin in ['BTC', 'ETH', 'SOL']:
    bid, ask = adapter.get_best_bid_ask(coin)
    spread = (ask - bid) if bid and ask else 0
    print(f"  {coin}: bid={bid}, ask={ask}, spread={spread:.4f}")

# ========== 5. 下单（市价买入最小量）==========
print("\n--- 5. place_order() 市价开多 SOL 最小量 ---")
order = OrderRequest(
    coin='SOL', side=OrderSide.BUY,
    order_type=OrderType.MARKET, size=0.01  # 最小量
)
result = adapter.place_order(order)
print(f"  success: {result.success}")
print(f"  order_id: {result.order_id}")
print(f"  filled_price: {result.filled_price}")
print(f"  filled_size: {result.filled_size} (这是币数量还是合约数？)")
print(f"  message: {result.message}")

# ========== 6. 查刚才的订单状态 ==========
if result.order_id:
    print(f"\n--- 6. get_order_status('{result.order_id}') ---")
    status = adapter.get_order_status(result.order_id)
    print(f"  原始返回: {status}")
    print(f"  cumQty: {status.get('cumQty')} (合约数还是币数量？)")
    print(f"  avgPx: {status.get('avgPx')}")
    print(f"  ordStatus: {status.get('ordStatus')}")

# ========== 7. 查仓位（刚开了 SOL）==========
print("\n--- 7. get_positions() 开仓后 ---")
positions = adapter.get_positions()
for p in positions:
    print(f"  {p}")
    print(f"  size 是币数量还是合约数？")

# ========== 8. 止损单 ==========
print("\n--- 8. place_stop_loss() ---")
sl_result = adapter.place_stop_loss(
    coin='SOL', stop_price=50.0,  # 远离当前价的止损
    size=0.01, side=OrderSide.SELL
)
print(f"  success: {sl_result.success}")
print(f"  order_id: {sl_result.order_id}")
print(f"  message: {sl_result.message}")

# ========== 9. 止盈单 ==========
print("\n--- 9. place_take_profit() ---")
tp_result = adapter.place_take_profit(
    coin='SOL', tp_price=200.0,  # 远离当前价的止盈
    size=0.01, side=OrderSide.SELL
)
print(f"  success: {tp_result.success}")
print(f"  order_id: {tp_result.order_id}")
print(f"  message: {tp_result.message}")

# ========== 10. 查所有挂单 ==========
print("\n--- 10. 查所有挂单 ---")
open_orders = adapter._get('/api/v1/order', query={'filter': '{"open": true}'})
if isinstance(open_orders, list):
    print(f"  挂单数: {len(open_orders)}")
    for o in open_orders:
        print(f"    {o.get('symbol')} {o.get('side')} {o.get('ordType')} qty={o.get('orderQty')} stop={o.get('stopPx')} status={o.get('ordStatus')} strategy={o.get('strategy')}")
else:
    print(f"  返回异常: {open_orders}")

# ========== 11. 撤所有挂单 ==========
print("\n--- 11. cancel_all_orders() ---")
adapter.cancel_all_orders()
print("  已撤")

# ========== 12. 平仓 ==========
print("\n--- 12. 平仓 SOL ---")
close_order = OrderRequest(
    coin='SOL', side=OrderSide.SELL,
    order_type=OrderType.MARKET, size=0.01,
    reduce_only=True
)
close_result = adapter.place_order(close_order)
print(f"  success: {close_result.success}")
print(f"  message: {close_result.message}")

# ========== 13. 确认零仓位 ==========
print("\n--- 13. 最终确认 ---")
final_positions = adapter.get_positions()
final_balance = adapter.get_balance()
print(f"  仓位: {len(final_positions)}")
print(f"  余额: {final_balance}")

print("\n" + "=" * 60)
print("完成。把完整输出贴给顾问。")

adapter.disconnect()
