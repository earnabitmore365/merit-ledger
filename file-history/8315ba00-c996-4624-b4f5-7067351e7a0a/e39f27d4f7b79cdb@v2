#!/usr/bin/env python3
"""test_full_chain.py — 业务逻辑层完整链路验证（测试网）

模拟 unified_trader 的每一步，逐步验证。
不启动主循环，手动触发每个环节。

每一步打印完整返回值。跑完把整个输出贴给顾问。
"""
import os, sys, time, json

os.environ['BITMEX_TESTNET'] = 'true'

_lab = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, _lab)
sys.path.insert(0, os.path.join(_lab, 'src'))

from dotenv import load_dotenv
load_dotenv(os.path.join(_lab, '.env'))

from exchange.bitmex.adapter import BitMEXAdapter
from exchange.base import OrderRequest, OrderSide, OrderType
from team_config import (TEAM, get_bet_amount, LEVERAGE,
                         WITHDRAW_THRESHOLD, WITHDRAW_AMOUNT, TOTAL_STRATEGIES)
from strategy_runner import StrategyRunner
from limit_executor import LimitOrderExecutor

# ==================== 初始化 ====================

config = {
    'api_key': os.getenv('BITMEX_TESTNET_API_KEY', ''),
    'api_secret': os.getenv('BITMEX_TESTNET_API_SECRET', ''),
    'testnet': True,
    'default_leverage': 10,
}

adapter = BitMEXAdapter(config)
adapter.connect()
time.sleep(1)

executor = LimitOrderExecutor()

def header(n, title):
    print(f"\n{'='*60}")
    print(f"  场景 {n}: {title}")
    print(f"{'='*60}")

def pause():
    time.sleep(1)

# ========== 场景 1：SOL 多头完整链路 ==========
header(1, "SOL 多头完整链路")

# 1a. 算注码
print("\n--- 1a. 注码计算 ---")
balance = adapter.get_balance()
available = balance.get('available', 0)
margin = get_bet_amount(available)
nominal = margin * LEVERAGE
bid, ask = adapter.get_best_bid_ask('SOL')
price = bid
coin_qty = nominal / price if price > 0 else 0
print(f"  余额: ${available:.2f}")
print(f"  保证金: ${margin}, 名义: ${nominal}, 币数量: {coin_qty:.4f} SOL")
print(f"  当前 bid={bid}, ask={ask}")
pause()

# 1b. 创建 StrategyRunner
print("\n--- 1b. 创建 StrategyRunner ---")
# 找一个 SOL 策略
sol_cfg = None
for cfg in TEAM:
    if cfg.coin == 'SOL':
        sol_cfg = cfg
        break
if not sol_cfg:
    print("  ❌ 找不到 SOL 策略配置")
    sys.exit(1)
runner = StrategyRunner(sol_cfg, adapter)
print(f"  策略: {runner.id}, state={runner.state}")
pause()

# 1c. 限价开多（通过 executor）
print("\n--- 1c. 限价开多 (executor) ---")
result = executor.execute_limit(runner, 'BUY', coin_qty, adapter)
print(f"  success={result['success']}")
print(f"  price={result.get('price')}")
print(f"  actual_size={result.get('actual_size')} (应该是币数量，不是微量)")
print(f"  attempts={result.get('attempts')}")
print(f"  fallback={result.get('fallback', 'N/A')}")

if result['success']:
    # 更新内部状态（模拟 unified_trader._execute）
    actual_size = result.get('actual_size', 0)
    runner.position = 'BUY'
    runner.entry_price = result['price']
    runner.position_size = actual_size if actual_size > 0 else coin_qty
    runner.state = 'active'
    print(f"  position_size={runner.position_size} (应该≈{coin_qty:.4f}，不是微量)")
    print(f"  验证: position_size > 0.001? {runner.position_size > 0.001}")
pause()

# 1d. 挂 SL
print("\n--- 1d. 挂 SL ---")
if runner.position:
    runner.after_open(adapter)
    print(f"  sl_order_id: {runner.sl_order_id}")
    # 查挂单
    open_orders = adapter._get('/api/v1/order',
                                query={'filter': json.dumps({"open": True})})
    if isinstance(open_orders, list):
        for o in open_orders:
            print(f"    {o.get('symbol')} {o.get('side')} {o.get('ordType')} "
                  f"strategy={o.get('strategy')} execInst={o.get('execInst')}")
pause()

# 1e. 查交易所仓位
print("\n--- 1e. 查交易所仓位 ---")
positions = adapter.get_positions()
print(f"  仓位数: {len(positions)}")
for p in positions:
    print(f"    {p.coin} {p.side} size={p.size}")
pause()

# 1f. 限价平仓（Close，通过 executor + reduce_only=True）
print("\n--- 1f. 限价平仓 (reduce_only=True) ---")
if runner.position:
    runner.before_close(adapter)
    print(f"  before_close: sl={runner.sl_order_id}, tp={runner.tp_order_id} "
          f"(应该都是 None)")
    close_result = executor.execute_limit(
        runner, 'SELL', runner.position_size, adapter,
        reduce_only=True,
    )
    print(f"  success={close_result['success']}")
    print(f"  price={close_result.get('price')}")
    print(f"  actual_size={close_result.get('actual_size')}")
pause()

# 1g. 确认清零
print("\n--- 1g. 确认清零 ---")
time.sleep(2)
positions = adapter.get_positions()
open_orders = adapter._get('/api/v1/order',
                            query={'filter': json.dumps({"open": True})})
oo_count = len(open_orders) if isinstance(open_orders, list) else 0
print(f"  仓位: {len(positions)} (应该 0)")
print(f"  挂单: {oo_count} (应该 0，Close 自动取消 SL/TP)")
for p in positions:
    print(f"    残留: {p.coin} {p.side} size={p.size}")
if isinstance(open_orders, list):
    for o in open_orders:
        print(f"    残留挂单: {o.get('symbol')} {o.get('ordType')} "
              f"{o.get('ordStatus')}")
pause()


# ========== 场景 2：SOL 空头完整链路 ==========
header(2, "SOL 空头完整链路")

# 2a. 限价开空
print("\n--- 2a. 限价开空 ---")
runner2 = StrategyRunner(sol_cfg, adapter)
result2 = executor.execute_limit(runner2, 'SELL', coin_qty, adapter)
print(f"  success={result2['success']}")
print(f"  actual_size={result2.get('actual_size')}")

if result2['success']:
    actual_size2 = result2.get('actual_size', 0)
    runner2.position = 'SELL'
    runner2.entry_price = result2['price']
    runner2.position_size = actual_size2 if actual_size2 > 0 else coin_qty
    runner2.state = 'active'
    print(f"  position_size={runner2.position_size}")
pause()

# 2b. 挂空头 SL
print("\n--- 2b. 挂空头 SL ---")
if runner2.position:
    runner2.after_open(adapter)
    print(f"  sl_order_id: {runner2.sl_order_id}")
    open_orders = adapter._get('/api/v1/order',
                                query={'filter': json.dumps({"open": True})})
    if isinstance(open_orders, list):
        for o in open_orders:
            print(f"    {o.get('side')} {o.get('ordType')} "
                  f"strategy={o.get('strategy')} execInst={o.get('execInst')}")
pause()

# 2c. 限价平空（reduce_only=True）
print("\n--- 2c. 限价平空 (reduce_only=True) ---")
if runner2.position:
    runner2.before_close(adapter)
    close_result2 = executor.execute_limit(
        runner2, 'BUY', runner2.position_size, adapter,
        reduce_only=True,
    )
    print(f"  success={close_result2['success']}")
    print(f"  price={close_result2.get('price')}")
pause()

# 2d. 确认清零
print("\n--- 2d. 确认清零 ---")
time.sleep(2)
positions = adapter.get_positions()
open_orders = adapter._get('/api/v1/order',
                            query={'filter': json.dumps({"open": True})})
oo_count = len(open_orders) if isinstance(open_orders, list) else 0
print(f"  仓位: {len(positions)} (应该 0)")
print(f"  挂单: {oo_count} (应该 0)")
pause()


# ========== 场景 3：注码递增验证 ==========
header(3, "注码递增验证")

print(f"  TOTAL_STRATEGIES={TOTAL_STRATEGIES}, LEVERAGE={LEVERAGE}")
print(f"  WITHDRAW_THRESHOLD=${WITHDRAW_THRESHOLD}, WITHDRAW_AMOUNT=${WITHDRAW_AMOUNT}")
print()
for test_bal in [2100, 5000, 10500, 21000, 27000]:
    bet = get_bet_amount(test_bal)
    nom = bet * LEVERAGE
    print(f"  余额 ${test_bal}: 保证金=${bet}, 名义=${nom}")
pause()


# ========== 场景 4：崩溃恢复模拟 ==========
header(4, "崩溃恢复模拟")

# 4a. 开仓
print("\n--- 4a. 开仓 ---")
r = adapter.place_order(OrderRequest(
    coin='SOL', side=OrderSide.BUY, order_type=OrderType.MARKET, size=0.01))
print(f"  开仓: success={r.success}, filled_size={r.filled_size}")
pause()

# 4b. 模拟保存状态
print("\n--- 4b. 保存状态到 JSON ---")
runner_cr = StrategyRunner(sol_cfg, adapter)
runner_cr.position = 'BUY'
runner_cr.entry_price = r.filled_price
runner_cr.position_size = r.filled_size
runner_cr.state = 'active'
state_dict = runner_cr.to_dict()
test_state_file = '/tmp/test_states.json'
with open(test_state_file, 'w') as f:
    json.dump({runner_cr.id: state_dict}, f, indent=2)
print(f"  保存: position_size={runner_cr.position_size}")
print(f"  序列化: {json.dumps(state_dict, indent=2)}")
pause()

# 4c. 模拟恢复
print("\n--- 4c. 从 JSON 恢复 ---")
runner_restored = StrategyRunner(sol_cfg, adapter)
with open(test_state_file) as f:
    saved = json.load(f)
runner_restored.from_dict(saved[runner_cr.id])
print(f"  恢复: position={runner_restored.position}, "
      f"size={runner_restored.position_size}, "
      f"state={runner_restored.state}")
print(f"  前后一致? {runner_cr.position_size == runner_restored.position_size}")
pause()

# 4d. 用恢复状态平仓
print("\n--- 4d. 用恢复状态平仓 ---")
close_r = adapter.place_order(OrderRequest(
    coin='SOL', side=OrderSide.SELL, order_type=OrderType.MARKET,
    size=runner_restored.position_size, reduce_only=True))
print(f"  平仓: success={close_r.success}")
pause()

# 4e. 确认清零
print("\n--- 4e. 确认清零 ---")
time.sleep(1)
positions = adapter.get_positions()
print(f"  仓位: {len(positions)} (应该 0)")
pause()


# ========== 场景 5：熔断模拟 ==========
header(5, "熔断模拟")

# 5a. 开仓 + 挂 SL
print("\n--- 5a. 开仓 + 挂 SL ---")
r1 = adapter.place_order(OrderRequest(
    coin='SOL', side=OrderSide.BUY, order_type=OrderType.MARKET, size=0.01))
print(f"  开 SOL 多: success={r1.success}")
adapter.place_stop_loss(coin='SOL', stop_price=50.0, size=0.01,
                        side=OrderSide.SELL)
print(f"  挂 SL")
time.sleep(1)

pos = adapter.get_positions()
open_orders = adapter._get('/api/v1/order',
                            query={'filter': json.dumps({"open": True})})
oo_count = len(open_orders) if isinstance(open_orders, list) else 0
print(f"  熔断前: {len(pos)} 仓位, {oo_count} 挂单")
pause()

# 5b. 熔断：cancel_all + 全平
print("\n--- 5b. 熔断：cancel_all + 全平 ---")
adapter.cancel_all_orders()
print(f"  cancel_all_orders() 完成")
time.sleep(1)

for p in adapter.get_positions():
    close_side = OrderSide.SELL if p.side == 'LONG' else OrderSide.BUY
    r = adapter.place_order(OrderRequest(
        coin=p.coin, side=close_side, order_type=OrderType.MARKET,
        size=abs(p.size), reduce_only=True))
    print(f"  平 {p.coin}: success={r.success}")
pause()

# 5c. 确认清零
print("\n--- 5c. 确认清零 ---")
time.sleep(1)
final_pos = adapter.get_positions()
final_orders = adapter._get('/api/v1/order',
                             query={'filter': json.dumps({"open": True})})
fo_count = len(final_orders) if isinstance(final_orders, list) else 0
final_bal = adapter.get_balance()
print(f"  仓位: {len(final_pos)} (应该 0)")
print(f"  挂单: {fo_count} (应该 0)")
print(f"  余额: ${final_bal.get('available', 0):.2f}")


# ========== 最终确认 ==========
print(f"\n{'='*60}")
print(f"  5 场景全链路测试完成")
print(f"{'='*60}")
print(f"  仓位: {len(final_pos)} (应该 0)")
print(f"  挂单: {fo_count} (应该 0)")
print(f"  余额: ${final_bal.get('available', 0):.2f}")

print(f"\n--- 6 个关键验证点 ---")
print(f"  1. 注码链路: 保证金→名义→币数量 正确？(场景 1a/3 看)")
print(f"  2. position_size 全程是币数量？(场景 1c: 应该≈{coin_qty:.4f})")
print(f"  3. SL/TP 挂单方向和 strategy 正确？(场景 1d/2b 看)")
print(f"  4. Close 平仓自动取消 SL/TP？(场景 1g/2d: 挂单=0?)")
print(f"  5. 崩溃恢复后能正确平仓？(场景 4d: success?)")
print(f"  6. 熔断后零仓位零挂单？(场景 5c 看)")

adapter.disconnect()
