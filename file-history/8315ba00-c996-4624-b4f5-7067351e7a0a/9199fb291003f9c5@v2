#!/usr/bin/env python3
"""test_recovery.py — 补测 2 个崩溃恢复场景（测试网）

场景 A：杀进程 + 清 JSON + 重启（孤儿仓位检测）
场景 B：杀进程 + JSON 还在 + 重启（不重复开仓）

每一步打印 position / state / 交易所仓位数。原样贴输出。
"""
import os, sys, time, json, shutil

os.environ['BITMEX_TESTNET'] = 'true'

_lab = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, _lab)
sys.path.insert(0, os.path.join(_lab, 'src'))

from dotenv import load_dotenv
load_dotenv(os.path.join(_lab, '.env'))

from exchange.bitmex.adapter import BitMEXAdapter
from exchange.base import OrderRequest, OrderSide, OrderType
from team_config import TEAM, get_active_team, get_bet_amount, LEVERAGE
from strategy_runner import StrategyRunner

STATE_FILE = os.path.join(_lab, 'strategy_states.json')
STATE_BACKUP = STATE_FILE + '.bak_test'

# ==================== 初始化 adapter ====================

config = {
    'api_key': os.getenv('BITMEX_TESTNET_API_KEY', ''),
    'api_secret': os.getenv('BITMEX_TESTNET_API_SECRET', ''),
    'testnet': True,
    'default_leverage': 10,
}

adapter = BitMEXAdapter(config)
adapter.connect()
time.sleep(1)

# 备份现有 state file（如果有的话）
if os.path.exists(STATE_FILE):
    shutil.copy2(STATE_FILE, STATE_BACKUP)
    print(f"已备份现有 {STATE_FILE} → {STATE_BACKUP}")


def header(title):
    print(f"\n{'='*60}")
    print(f"  {title}")
    print(f"{'='*60}")


def show_exchange_state():
    """打印交易所仓位和挂单"""
    positions = adapter.get_positions()
    open_orders = adapter._get('/api/v1/order',
                                query={'filter': json.dumps({"open": True})})
    oo_count = len(open_orders) if isinstance(open_orders, list) else 0
    print(f"  交易所仓位: {len(positions)}")
    for p in positions:
        print(f"    {p.coin} {p.side} size={p.size}")
    print(f"  交易所挂单: {oo_count}")
    return positions


def clean_exchange():
    """清空交易所所有仓位和挂单"""
    adapter.cancel_all_orders()
    for p in adapter.get_positions():
        close_side = OrderSide.SELL if p.side == 'LONG' else OrderSide.BUY
        adapter.place_order(OrderRequest(
            coin=p.coin, side=close_side, order_type=OrderType.MARKET,
            size=abs(p.size), reduce_only=True))
    time.sleep(1)


def pause():
    time.sleep(1)


# ==================== 先清空 ====================
header("准备：清空交易所 + 删 JSON")
clean_exchange()
if os.path.exists(STATE_FILE):
    os.remove(STATE_FILE)
print("  已清空")
show_exchange_state()
pause()


# ============================================================
# 场景 A：杀进程 + 清 JSON + 重启（孤儿仓位检测）
# ============================================================
header("场景 A：杀进程 + 清 JSON + 重启")

# A1. 开 SOL 多仓
print("\n--- A1. 开 SOL 多仓 ---")
r = adapter.place_order(OrderRequest(
    coin='SOL', side=OrderSide.BUY, order_type=OrderType.MARKET, size=0.01))
print(f"  开仓: success={r.success}, filled_size={r.filled_size}")
show_exchange_state()
pause()

# A2. 保存 JSON（模拟正常运行时的状态）
print("\n--- A2. 保存 JSON ---")
sol_cfg = None
for cfg in TEAM:
    if cfg.coin == 'SOL':
        sol_cfg = cfg
        break
runner_a = StrategyRunner(sol_cfg, adapter)
runner_a.position = 'BUY'
runner_a.entry_price = r.filled_price
runner_a.position_size = r.filled_size
runner_a.state = 'active'
states = {runner_a.id: runner_a.to_dict()}
with open(STATE_FILE, 'w') as f:
    json.dump(states, f, indent=2)
print(f"  已保存: {runner_a.id} state=active position=BUY size={runner_a.position_size}")
pause()

# A3. 删 JSON（模拟杀进程后清了状态）
print("\n--- A3. 删 JSON（模拟清状态）---")
os.remove(STATE_FILE)
print(f"  已删 {STATE_FILE}")
print(f"  交易所仍有仓位:")
show_exchange_state()
pause()

# A4. 模拟重启 → 创建新 UnifiedTrader → _startup_recovery()
print("\n--- A4. 模拟重启 → _startup_recovery() ---")
# 不能直接实例化 UnifiedTrader（会启动 FeedClient 等），
# 手动模拟 _startup_recovery 的关键步骤

# 4a. _load_states() — JSON 不存在，全部 idle
active_team = get_active_team()
strategies = [StrategyRunner(cfg, adapter) for cfg in active_team]
print(f"  加载 {len(strategies)} 个策略，全部 idle")

# 4b. 查交易所挂单
open_orders = adapter._get('/api/v1/order',
                            query={'filter': json.dumps({"open": True})})
if not isinstance(open_orders, list):
    open_orders = []
print(f"  交易所挂单: {len(open_orders)}")

# 4c. 处理 pending_open / pending_close（全 idle，跳过）
for s in strategies:
    print(f"  策略 {s.id}: state={s.state}, position={s.position}")
    # 都是 idle，不进入 pending_open/pending_close 分支

# 4d. 撤无主挂单（如有）
known_ids = set()
for s in strategies:
    if s.sl_order_id:
        known_ids.add(s.sl_order_id)
    if s.tp_order_id:
        known_ids.add(s.tp_order_id)
for o in open_orders:
    oid = o.get('orderID', '')
    if oid and oid not in known_ids:
        adapter.cancel_order(oid)
        print(f"  撤无主挂单: {oid}")

# 4e. 孤儿仓位扫描（Bug 5 修复）
print("\n--- A4e. 孤儿仓位扫描 ---")
exchange_positions = adapter.get_positions()
internal_coins = {s.coin for s in strategies if s.position and s.position_size > 0}
print(f"  内部有仓位的币种: {internal_coins} (应该为空)")
print(f"  交易所仓位数: {len(exchange_positions)}")
for pos in exchange_positions:
    if pos.coin not in internal_coins:
        print(f"  ⚠️ 孤儿仓位: {pos.coin} {pos.side} size={pos.size} → 市价平仓")
        close_side = OrderSide.SELL if pos.side == 'LONG' else OrderSide.BUY
        cr = adapter.place_order(OrderRequest(
            coin=pos.coin, side=close_side, order_type=OrderType.MARKET,
            size=pos.size, reduce_only=True))
        print(f"    平仓: success={cr.success}")
pause()

# A5. 确认零仓位
print("\n--- A5. 确认零仓位 ---")
time.sleep(1)
positions = adapter.get_positions()
print(f"  仓位: {len(positions)} (应该 0)")
for p in positions:
    print(f"    残留: {p.coin} {p.side} size={p.size}")
pause()

# A6. 模拟信号 BUY → 只开 1 个仓
print("\n--- A6. 模拟 BUY 信号 → 只开 1 个仓 ---")
# 找 SOL 策略
sol_strategies = [s for s in strategies if s.coin == 'SOL']
sol_s = sol_strategies[0] if sol_strategies else None
if sol_s:
    print(f"  策略 {sol_s.id}: state={sol_s.state}, position={sol_s.position}")
    # 模拟 _execute 的判断：signal='BUY' and not strategy.position
    if sol_s.state == 'idle' and not sol_s.position:
        print(f"  → state=idle, 无仓位 → 允许开仓")
        r2 = adapter.place_order(OrderRequest(
            coin='SOL', side=OrderSide.BUY, order_type=OrderType.MARKET,
            size=0.01))
        print(f"  开仓: success={r2.success}")
        show_exchange_state()
        # 清掉
        adapter.place_order(OrderRequest(
            coin='SOL', side=OrderSide.SELL, order_type=OrderType.MARKET,
            size=0.01, reduce_only=True))
        print(f"  已清掉测试仓位")
    else:
        print(f"  → 不应该到这里")
else:
    print(f"  ❌ 没找到 SOL 策略")
pause()


# ============================================================
# 场景 B：杀进程 + JSON 还在 + 重启
# ============================================================
header("场景 B：杀进程 + JSON 还在 + 重启")

# 先清空
clean_exchange()
if os.path.exists(STATE_FILE):
    os.remove(STATE_FILE)

# B1. 开 SOL 多仓
print("\n--- B1. 开 SOL 多仓 ---")
r = adapter.place_order(OrderRequest(
    coin='SOL', side=OrderSide.BUY, order_type=OrderType.MARKET, size=0.01))
print(f"  开仓: success={r.success}, filled_size={r.filled_size}")
show_exchange_state()
pause()

# B2. 保存 JSON（state=active, position=BUY）
print("\n--- B2. 保存 JSON (state=active, position=BUY) ---")
runner_b = StrategyRunner(sol_cfg, adapter)
runner_b.position = 'BUY'
runner_b.entry_price = r.filled_price
runner_b.position_size = r.filled_size
runner_b.state = 'active'
states = {runner_b.id: runner_b.to_dict()}
with open(STATE_FILE, 'w') as f:
    json.dump(states, f, indent=2)
print(f"  已保存: state=active position=BUY size={runner_b.position_size}")
pause()

# B3. 模拟重启 → 从 JSON 恢复
print("\n--- B3. 从 JSON 恢复 ---")
strategies_b = [StrategyRunner(cfg, adapter) for cfg in active_team]

# _load_states
with open(STATE_FILE) as f:
    saved_states = json.load(f)
for s in strategies_b:
    if s.id in saved_states:
        s.from_dict(saved_states[s.id])
        print(f"  恢复: {s.id} state={s.state} position={s.position} "
              f"size={s.position_size}")

# _startup_recovery 后续步骤（pending_open/pending_close 处理）
for s in strategies_b:
    if s.state == 'active':
        print(f"  {s.id}: state=active → 正常持仓，不需要恢复操作")
pause()

# B4. 模拟 BUY 信号 → 应该跳过（已有仓位）
print("\n--- B4. 模拟 BUY 信号 → 应该跳过 ---")
sol_strategies_b = [s for s in strategies_b if s.coin == 'SOL' and s.position]
if sol_strategies_b:
    s = sol_strategies_b[0]
    print(f"  策略 {s.id}: state={s.state}, position={s.position}")
    # 模拟 _execute 的判断
    signal = 'BUY'
    if signal in ('BUY', 'SELL') and not s.position:
        print(f"  → 开仓分支 (不应该到这里!)")
    elif s.position:
        close_side = 'SELL' if s.position == 'BUY' else 'BUY'
        if signal == close_side or signal == 'CLOSE':
            print(f"  → 平仓分支")
        else:
            print(f"  → 信号={signal} 同方向，已有 {s.position} 仓位 → 跳过 ✅")
    print(f"  交易所仓位数确认:")
    show_exchange_state()
else:
    print(f"  ❌ 没找到有仓位的 SOL 策略")
pause()

# B5. 模拟 SELL 信号 → 应该平仓
print("\n--- B5. 模拟 SELL 信号 → 应该平仓 ---")
if sol_strategies_b:
    s = sol_strategies_b[0]
    signal = 'SELL'
    close_side = 'SELL' if s.position == 'BUY' else 'BUY'
    if signal == close_side:
        print(f"  → 平仓分支: {signal} == close_side({close_side}) ✅")
        # 实际平仓
        cr = adapter.place_order(OrderRequest(
            coin='SOL', side=OrderSide.SELL, order_type=OrderType.MARKET,
            size=s.position_size, reduce_only=True))
        print(f"  平仓: success={cr.success}")
        s.position = None
        s.position_size = 0
        s.state = 'idle'
pause()

# B6. 确认零仓位
print("\n--- B6. 确认零仓位 ---")
time.sleep(1)
positions = adapter.get_positions()
print(f"  仓位: {len(positions)} (应该 0)")
for p in positions:
    print(f"    残留: {p.coin} {p.side} size={p.size}")
pause()


# ============================================================
# 清理 + 恢复
# ============================================================
header("清理")
clean_exchange()
if os.path.exists(STATE_FILE):
    os.remove(STATE_FILE)
if os.path.exists(STATE_BACKUP):
    shutil.move(STATE_BACKUP, STATE_FILE)
    print(f"  已恢复原始 {STATE_FILE}")
else:
    print(f"  无需恢复（原来没有 state file）")

final_pos = adapter.get_positions()
final_bal = adapter.get_balance()
print(f"  最终仓位: {len(final_pos)} (应该 0)")
print(f"  最终余额: ${final_bal.get('available', 0):.2f}")

print(f"\n{'='*60}")
print(f"  补测 2 场景完成")
print(f"{'='*60}")
print(f"  场景 A: 杀进程+清JSON → 孤儿扫描触发？")
print(f"  场景 B: JSON恢复 → BUY跳过？SELL平仓？")

adapter.disconnect()
