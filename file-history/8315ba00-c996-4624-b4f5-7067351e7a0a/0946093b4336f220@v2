#!/usr/bin/env python3
"""test_adapter_full.py — adapter 完整 23 项验证（测试网）

每一步打印完整返回值。跑完把整个输出贴给顾问。
"""
import os, sys, time, json

os.environ['BITMEX_TESTNET'] = 'true'

_lab = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, _lab)
sys.path.insert(0, os.path.join(_lab, 'src'))

from dotenv import load_dotenv
load_dotenv(os.path.join(_lab, '.env'))

from exchange.bitmex.adapter import BitMEXAdapter
from exchange.base import OrderRequest, OrderSide, OrderType

config = {
    'api_key': os.getenv('BITMEX_TESTNET_API_KEY', ''),
    'api_secret': os.getenv('BITMEX_TESTNET_API_SECRET', ''),
    'testnet': True,
    'default_leverage': 10,
}

adapter = BitMEXAdapter(config)
adapter.connect()
time.sleep(1)

def header(n, title):
    print(f"\n{'='*60}")
    print(f"  TEST {n}: {title}")
    print(f"{'='*60}")

def pause():
    time.sleep(1)

# ============================================================
# 查询类（不下单）
# ============================================================

header(1, "get_balance()")
bal = adapter.get_balance()
print(f"  原始: {bal}")
print(f"  available: {bal.get('available')} (应该是美元)")
pause()

header(2, "get_positions() — 应该是空")
pos = adapter.get_positions()
print(f"  仓位数: {len(pos)}")
for p in pos:
    print(f"    {p}")
pause()

header(3, "get_instrument_info() — 9 币种")
for coin in ['BTC','ETH','SOL','XRP','BNB','ADA','AVAX','LINK','DOT']:
    info = adapter.get_instrument_info(coin)
    print(f"  {coin}: u2p={info.get('underlyingToPositionMultiplier')}, lotSize={info.get('lotSize')}, tickSize={info.get('tickSize')}")
pause()

header(4, "get_best_bid_ask() — 3 币种")
for coin in ['SOL', 'ETH', 'BTC']:
    bid, ask = adapter.get_best_bid_ask(coin)
    print(f"  {coin}: bid={bid}, ask={ask}, spread={ask-bid if bid and ask else 'N/A'}")
pause()

# ============================================================
# 开仓类
# ============================================================

header(5, "市价开多 SOL (MARKET BUY)")
r = adapter.place_order(OrderRequest(coin='SOL', side=OrderSide.BUY, order_type=OrderType.MARKET, size=0.01))
print(f"  success={r.success}, order_id={r.order_id}")
print(f"  filled_price={r.filled_price}, filled_size={r.filled_size}")
print(f"  message={r.message}")
print(f"  filled_size 应该是 0.01 币（不是 100 合约）")
pause()

header(6, "查仓位 — 应该有 SOL 多仓")
pos = adapter.get_positions()
for p in pos:
    print(f"  {p}")
pause()

header(7, "市价平多 SOL (MARKET SELL reduce_only)")
r = adapter.place_order(OrderRequest(coin='SOL', side=OrderSide.SELL, order_type=OrderType.MARKET, size=0.01, reduce_only=True))
print(f"  success={r.success}, filled_size={r.filled_size}, message={r.message}")
# 查刚才的平仓单 execInst
if r.order_id:
    status = adapter.get_order_status(r.order_id)
    print(f"  execInst={status.get('execInst')} (应该是 Close)")
pause()

header(8, "确认零仓位")
pos = adapter.get_positions()
print(f"  仓位数: {len(pos)}")
pause()

header(9, "市价开空 SOL (MARKET SELL)")
r = adapter.place_order(OrderRequest(coin='SOL', side=OrderSide.SELL, order_type=OrderType.MARKET, size=0.01))
print(f"  success={r.success}, order_id={r.order_id}")
print(f"  filled_price={r.filled_price}, filled_size={r.filled_size}")
print(f"  message={r.message}")
pause()

header(10, "市价平空 SOL (MARKET BUY reduce_only)")
r = adapter.place_order(OrderRequest(coin='SOL', side=OrderSide.BUY, order_type=OrderType.MARKET, size=0.01, reduce_only=True))
print(f"  success={r.success}, filled_size={r.filled_size}, message={r.message}")
if r.order_id:
    status = adapter.get_order_status(r.order_id)
    print(f"  execInst={status.get('execInst')} (应该是 Close)")
pause()

header(11, "限价开多 SOL (LIMIT BUY PostOnly)")
bid, ask = adapter.get_best_bid_ask('SOL')
print(f"  当前 bid={bid}, ask={ask}")
r = adapter.place_order(OrderRequest(coin='SOL', side=OrderSide.BUY, order_type=OrderType.LIMIT, size=0.01, price=bid))
print(f"  success={r.success}, order_id={r.order_id}")
print(f"  filled_size={r.filled_size}, message={r.message}")
limit_order_id = r.order_id
pause()

header(12, "查限价单状态")
if limit_order_id:
    status = adapter.get_order_status(limit_order_id)
    print(f"  ordStatus={status.get('ordStatus')}")
    print(f"  cumQty={status.get('cumQty')} (合约数)")
    print(f"  leavesQty={status.get('leavesQty')} (剩余合约数)")
pause()

header(13, "撤限价单")
if limit_order_id:
    adapter.cancel_order(limit_order_id)
    print(f"  已撤 {limit_order_id}")
pause()

header(14, "限价开空 SOL (LIMIT SELL PostOnly)")
bid, ask = adapter.get_best_bid_ask('SOL')
r = adapter.place_order(OrderRequest(coin='SOL', side=OrderSide.SELL, order_type=OrderType.LIMIT, size=0.01, price=ask))
print(f"  success={r.success}, order_id={r.order_id}")
print(f"  filled_size={r.filled_size}, message={r.message}")
if r.order_id:
    adapter.cancel_order(r.order_id)
    print(f"  已撤")
pause()

# ============================================================
# 止损止盈类
# ============================================================

header(15, "开多 → 挂多头止损 (Sell + Long)")
r = adapter.place_order(OrderRequest(coin='SOL', side=OrderSide.BUY, order_type=OrderType.MARKET, size=0.01))
print(f"  开多: success={r.success}, filled_size={r.filled_size}")
sl = adapter.place_stop_loss(coin='SOL', stop_price=50.0, size=0.01, side=OrderSide.SELL)
print(f"  SL: success={sl.success}, order_id={sl.order_id}, message={sl.message}")
pause()

header(16, "挂多头止盈 (Sell + Long)")
tp = adapter.place_take_profit(coin='SOL', tp_price=200.0, size=0.01, side=OrderSide.SELL)
print(f"  TP: success={tp.success}, order_id={tp.order_id}, message={tp.message}")
pause()

header(17, "查挂单 — 应该有 SL + TP 两单")
open_orders = adapter._get('/api/v1/order', query={'filter': json.dumps({"open": True})})
if isinstance(open_orders, list):
    print(f"  挂单数: {len(open_orders)}")
    for o in open_orders:
        print(f"    {o.get('symbol')} {o.get('side')} {o.get('ordType')} qty={o.get('orderQty')} stop={o.get('stopPx')} strategy={o.get('strategy')} execInst={o.get('execInst')} status={o.get('ordStatus')}")
pause()

header(18, "市价平多 (Close) — SL/TP 应该被自动取消")
r = adapter.place_order(OrderRequest(coin='SOL', side=OrderSide.SELL, order_type=OrderType.MARKET, size=0.01, reduce_only=True))
print(f"  平仓: success={r.success}, message={r.message}")
time.sleep(2)
open_orders = adapter._get('/api/v1/order', query={'filter': json.dumps({"open": True})})
if isinstance(open_orders, list):
    print(f"  平仓后挂单数: {len(open_orders)} (应该是 0，Close 自动取消 SL/TP)")
    for o in open_orders:
        print(f"    残留: {o.get('symbol')} {o.get('ordType')} {o.get('ordStatus')}")
pause()

# ============================================================
# 空头方向
# ============================================================

header(19, "开空 → 挂空头止损 (Buy + Short)")
r = adapter.place_order(OrderRequest(coin='SOL', side=OrderSide.SELL, order_type=OrderType.MARKET, size=0.01))
print(f"  开空: success={r.success}, filled_size={r.filled_size}")
sl = adapter.place_stop_loss(coin='SOL', stop_price=200.0, size=0.01, side=OrderSide.BUY)
print(f"  SL: success={sl.success}, order_id={sl.order_id}, message={sl.message}")
pause()

header(20, "挂空头止盈 (Buy + Short)")
tp = adapter.place_take_profit(coin='SOL', tp_price=50.0, size=0.01, side=OrderSide.BUY)
print(f"  TP: success={tp.success}, order_id={tp.order_id}, message={tp.message}")
pause()

header(21, "查挂单 — 确认空头 SL/TP strategy=Short")
open_orders = adapter._get('/api/v1/order', query={'filter': json.dumps({"open": True})})
if isinstance(open_orders, list):
    print(f"  挂单数: {len(open_orders)}")
    for o in open_orders:
        print(f"    {o.get('symbol')} {o.get('side')} {o.get('ordType')} strategy={o.get('strategy')} execInst={o.get('execInst')}")
pause()

header(22, "平空 (Close) — 空头 SL/TP 应该被自动取消")
r = adapter.place_order(OrderRequest(coin='SOL', side=OrderSide.BUY, order_type=OrderType.MARKET, size=0.01, reduce_only=True))
print(f"  平仓: success={r.success}, message={r.message}")
time.sleep(2)
open_orders = adapter._get('/api/v1/order', query={'filter': json.dumps({"open": True})})
if isinstance(open_orders, list):
    print(f"  平仓后挂单数: {len(open_orders)} (应该是 0)")
    for o in open_orders:
        print(f"    残留: {o.get('symbol')} {o.get('ordType')} {o.get('ordStatus')}")
pause()

# ============================================================
# 熔断场景
# ============================================================

header(23, "熔断模拟 — 开 2 仓 → cancel_all → 市价全平")
r1 = adapter.place_order(OrderRequest(coin='SOL', side=OrderSide.BUY, order_type=OrderType.MARKET, size=0.01))
print(f"  开 SOL 多: success={r1.success}")
r2 = adapter.place_order(OrderRequest(coin='ETH', side=OrderSide.SELL, order_type=OrderType.MARKET, size=0.001))
print(f"  开 ETH 空: success={r2.success}")
adapter.place_stop_loss(coin='SOL', stop_price=50.0, size=0.01, side=OrderSide.SELL)
adapter.place_stop_loss(coin='ETH', stop_price=3000.0, size=0.001, side=OrderSide.BUY)
print(f"  挂了 2 个 SL")

time.sleep(1)
pos = adapter.get_positions()
open_orders = adapter._get('/api/v1/order', query={'filter': json.dumps({"open": True})})
oo_count = len(open_orders) if isinstance(open_orders, list) else 0
print(f"  熔断前: {len(pos)} 仓位, {oo_count} 挂单")

adapter.cancel_all_orders()
print(f"  cancel_all_orders() 完成")
time.sleep(1)

for p in adapter.get_positions():
    coin = p.coin
    side = OrderSide.SELL if p.side == 'LONG' else OrderSide.BUY
    size = abs(p.size)
    r = adapter.place_order(OrderRequest(coin=coin, side=side, order_type=OrderType.MARKET, size=size, reduce_only=True))
    print(f"  平 {coin}: success={r.success}")

time.sleep(1)
final_pos = adapter.get_positions()
final_orders = adapter._get('/api/v1/order', query={'filter': json.dumps({"open": True})})
fo_count = len(final_orders) if isinstance(final_orders, list) else 0
final_bal = adapter.get_balance()
print(f"\n  熔断后: {len(final_pos)} 仓位, {fo_count} 挂单")
print(f"  余额: {final_bal}")

# ============================================================
# 最终确认
# ============================================================

print(f"\n{'='*60}")
print(f"  23 项测试完成")
print(f"{'='*60}")
print(f"  仓位: {len(final_pos)} (应该 0)")
print(f"  挂单: {fo_count} (应该 0)")
print(f"  余额: {final_bal.get('available')}")

print(f"\n--- 关键验证点 ---")
print(f"  filled_size 单位 = 币数量？(TEST 5/9/10 看)")
print(f"  平仓 execInst = Close？(TEST 7/10 看)")
print(f"  SL strategy = Long/Short？(TEST 17/21 看)")
print(f"  TP strategy = Long/Short？(TEST 17/21 看)")
print(f"  Close 自动取消 SL/TP？(TEST 18/22 挂单数=0?)")
print(f"  熔断全平干净？(TEST 23 仓位=0 挂单=0?)")

adapter.disconnect()
