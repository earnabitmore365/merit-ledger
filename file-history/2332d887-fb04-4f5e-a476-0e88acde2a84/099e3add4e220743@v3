## 7. 数据导入：Parquet

### 基础用法

```sql
-- 直接查询
SELECT * FROM 'test.parquet';

-- 扩展名不是 .parquet 时用函数
SELECT * FROM read_parquet('data.parq');

-- 建表
CREATE TABLE klines AS SELECT * FROM 'klines.parquet';

-- 建视图（延迟读取，省内存）
CREATE VIEW klines_view AS SELECT * FROM read_parquet('klines.parquet');
```

### read_parquet() 参数

```sql
SELECT * FROM read_parquet('data.parquet',
    binary_as_string = false,   -- 二进制列转字符串
    filename = false,           -- 结果中包含文件名列（v1.3.0+ 自动）
    file_row_number = false,    -- 包含行号列
    hive_partitioning = true,   -- 自动识别 Hive 分区路径
    union_by_name = false       -- 多文件合并时按列名对齐（列不一致时必开）
);
```

### 多文件读取

```sql
-- 通配符
SELECT * FROM 'data/klines_*.parquet';
SELECT * FROM read_parquet('data/*.parquet');

-- 列表
SELECT * FROM read_parquet(['2024_q1.parquet', '2024_q2.parquet']);

-- Hive 分区（如 symbol=BTCUSDT/date=2024-01-01/data.parquet）
SELECT * FROM read_parquet('data/**/*.parquet', hive_partitioning = true);

-- 包含文件名
SELECT *, filename FROM read_parquet('data/*.parquet');
```

### 导出为 Parquet

```sql
-- 基础导出（默认 Snappy 压缩）
COPY (SELECT * FROM klines) TO 'output.parquet' (FORMAT parquet);

-- 指定压缩（量化推荐 zstd：压缩率高，解压快）
COPY klines TO 'klines_zstd.parquet' (FORMAT parquet, COMPRESSION zstd);

-- 自定义行组大小（推荐 100k-1M 行）
COPY (FROM klines) TO 'klines.parquet' (
    FORMAT parquet,
    COMPRESSION zstd,
    ROW_GROUP_SIZE 100000
);

-- 整个数据库导出
EXPORT DATABASE 'backup_dir' (FORMAT parquet);
```

### 查看 Parquet 元数据

```sql
SELECT * FROM parquet_metadata('test.parquet');
SELECT * FROM parquet_schema('test.parquet');
SELECT * FROM parquet_file_metadata('test.parquet');

-- 检查结构
DESCRIBE SELECT * FROM 'test.parquet';
```

