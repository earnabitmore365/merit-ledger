import duckdb
import pandas as pd

con = duckdb.connect("market_data.duckdb")

# 建表（先不加主键）
con.execute("""
    CREATE TABLE IF NOT EXISTS klines_1m (
        symbol   VARCHAR NOT NULL,
        ts       BIGINT  NOT NULL,   -- Unix 毫秒时间戳
        open     DOUBLE,
        high     DOUBLE,
        low      DOUBLE,
        close    DOUBLE,
        volume   DOUBLE,
        quote_vol DOUBLE
    )
""")

# 批量写入 DataFrame
def upsert_klines(con, df: pd.DataFrame):
    con.sql("""
        INSERT INTO klines_1m BY NAME
        SELECT * FROM df
        ON CONFLICT (symbol, ts) DO UPDATE SET
            open  = EXCLUDED.open,
            high  = EXCLUDED.high,
            low   = EXCLUDED.low,
            close = EXCLUDED.close,
            volume = EXCLUDED.volume
    """)
```

