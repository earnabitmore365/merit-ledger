#!/usr/bin/env python3
"""种子报告生成器 — 4 个种子 SQLite → 1 个 DuckDB 统一报告 + 14 字段后算。

将 seed_signal.db / seed_ttp_close.db / seed_ttp_hl.db / seed_dual.db
的 combo_summary（36列） + paired_trades（11列） 导入 DuckDB，
然后从 paired_trades 后算 14 个字段（sharpe/drawdown/calmar 等）。

用法：
  cd wuji-auto-trading
  python3 backtest/build_seed_report.py

输出：
  reports/seed_report.duckdb

代码段落索引（行号随改动更新）：
  SEED_TYPES/REPORT_DB    行 33   种子路径配置
  固定参数                行 43   INITIAL_CAPITAL/LEVERAGE/FEE_RATE 等
  import_sqlite_to_duckdb 行 64   Step 1 导入（ATTACH + INSERT SELECT）
  compute_post_metrics    行 187  Step 2 后算14字段（pnl推算+余额曲线+Sharpe等）
  run_post_calc           行 348  逐 combo 后算调度
  create_indexes          行 401  Step 3 索引
  print_summary           行 410  统计汇总+抽查
  build_report            行 454  主入口（3步流程）
  argparse                行 479  CLI 参数化（--report-dir/--output）
"""

from __future__ import annotations

import os
import sys
import time
import statistics
from datetime import datetime

_p = os.path.dirname(os.path.abspath(__file__))
while _p != os.path.dirname(_p) and not os.path.exists(os.path.join(_p, '.wuji-root')):
    _p = os.path.dirname(_p)
if _p not in sys.path:
    sys.path.insert(0, _p)
from path_config import ROOT, REPORT_DIR

# ==================== 配置 ====================

SEED_TYPES = [
    ("signal_only", os.path.join(REPORT_DIR, "seed_signal.db")),
    ("ttp_close", os.path.join(REPORT_DIR, "seed_ttp_close.db")),
    ("ttp_highlow", os.path.join(REPORT_DIR, "seed_ttp_hl.db")),
    ("dual_hold", os.path.join(REPORT_DIR, "seed_dual.db")),
]

REPORT_DB = os.path.join(REPORT_DIR, "seed_report.duckdb")

# 后算固定参数（与 generate_seed.py 一致，可从 run_metadata 校验）
INITIAL_CAPITAL = 500.0
LEVERAGE = 10.0
FEE_RATE = 0.00035        # 每侧
SLIPPAGE_PCT = 0.0002     # 每侧
FUNDING_RATE_8H = 0.0001
FIXED_BET_AMOUNT = 1.0    # $1 固定注码

# interval → bars_per_funding（8h / bar_minutes）
_BARS_PER_FUNDING = {
    "1m": 480, "5m": 96, "15m": 32, "30m": 16,
    "1h": 8, "2h": 4, "4h": 2, "8h": 1, "12h": 1, "1d": 1,
}

_BARS_PER_DAY = {
    "1m": 1440, "5m": 288, "15m": 96, "30m": 48,
    "1h": 24, "2h": 12, "4h": 6, "8h": 3, "12h": 2, "1d": 1,
}


# ==================== Step 1: 导入 ====================

def import_sqlite_to_duckdb(con) -> tuple[int, int]:
    """ATTACH 4 个 SQLite → DuckDB，用 CTAS 导入。返回 (combo数, trade数)。"""

    # combo_summary: 全 36 列 + seed_type
    con.execute("""
        CREATE TABLE combo_summary (
            seed_type             VARCHAR,
            id                    INTEGER,
            strategy              VARCHAR,
            coin                  VARCHAR,
            interval              VARCHAR,
            total_return          DOUBLE,
            final_balance         DOUBLE,
            max_drawdown          DOUBLE,
            sharpe_ratio          DOUBLE,
            sortino_ratio         DOUBLE,
            calmar_ratio          DOUBLE,
            total_trades          INTEGER,
            winning_trades        INTEGER,
            losing_trades         INTEGER,
            win_rate              DOUBLE,
            avg_win_pct           DOUBLE,
            avg_loss_pct          DOUBLE,
            profit_factor         DOUBLE,
            ttp_count             INTEGER,
            double_count          INTEGER,
            fastest_double_days   DOUBLE,
            avg_double_days       DOUBLE,
            daily_open_positions  DOUBLE,
            cagr                  DOUBLE,
            max_daily_dd          DOUBLE,
            reward_risk           DOUBLE,
            max_consec_loss_amt   DOUBLE,
            total_fees            DOUBLE,
            max_balance           DOUBLE,
            min_balance           DOUBLE,
            max_win               DOUBLE,
            max_loss              DOUBLE,
            expectancy_ratio      DOUBLE,
            longest_win_streak    INTEGER,
            longest_loss_streak   INTEGER,
            signal_close_count    INTEGER,
            backtest_time         VARCHAR
        )
    """)

    # paired_trades: 原 11 列 + seed_type + strategy/coin/interval
    con.execute("""
        CREATE TABLE paired_trades (
            seed_type         VARCHAR,
            combo_id          INTEGER,
            strategy          VARCHAR,
            coin              VARCHAR,
            interval          VARCHAR,
            open_candle_idx   INTEGER,
            close_candle_idx  INTEGER,
            open_time         VARCHAR,
            close_time        VARCHAR,
            direction         VARCHAR,
            entry_price       DOUBLE,
            exit_price        DOUBLE,
            close_type        VARCHAR,
            mfe               DOUBLE,
            mae               DOUBLE
        )
    """)

    total_combos = 0
    total_trades = 0

    for seed_type, db_path in SEED_TYPES:
        if not os.path.exists(db_path):
            print(f"  [跳过] {seed_type}: {db_path} 不存在")
            continue

        t0 = time.time()
        print(f"  导入 {seed_type}...", flush=True)

        con.execute(f"ATTACH '{db_path}' AS src (TYPE sqlite)")

        n_combos = con.execute("SELECT COUNT(*) FROM src.combo_summary").fetchone()[0]
        con.execute(f"""
            INSERT INTO combo_summary
            SELECT '{seed_type}',
                   id, strategy, coin, interval,
                   total_return, final_balance, max_drawdown,
                   sharpe_ratio, sortino_ratio, calmar_ratio,
                   total_trades, winning_trades, losing_trades, win_rate,
                   avg_win_pct, avg_loss_pct, profit_factor, ttp_count,
                   double_count, fastest_double_days, avg_double_days,
                   daily_open_positions, cagr, max_daily_dd,
                   reward_risk, max_consec_loss_amt, total_fees,
                   max_balance, min_balance, max_win, max_loss,
                   expectancy_ratio, longest_win_streak, longest_loss_streak,
                   signal_close_count, backtest_time
            FROM src.combo_summary
        """)

        n_trades = con.execute("SELECT COUNT(*) FROM src.paired_trades").fetchone()[0]
        con.execute(f"""
            INSERT INTO paired_trades
            SELECT '{seed_type}', pt.combo_id,
                   cs.strategy, cs.coin, cs.interval,
                   pt.open_candle_idx, pt.close_candle_idx,
                   pt.open_time, pt.close_time,
                   pt.direction, pt.entry_price, pt.exit_price,
                   pt.close_type, pt.mfe, pt.mae
            FROM src.paired_trades pt
            JOIN src.combo_summary cs ON cs.id = pt.combo_id
        """)

        con.execute("DETACH src")

        elapsed = time.time() - t0
        print(f"    {seed_type}: {n_combos:,} combos, {n_trades:,} trades ({elapsed:.1f}s)")
        total_combos += n_combos
        total_trades += n_trades

    return total_combos, total_trades


# ==================== Step 2: 后算 ====================

def compute_post_metrics(trades: list[tuple], interval: str) -> dict:
    """从 paired_trades 的 11 字段后算 14+1 个指标。

    trades: [(open_candle_idx, close_candle_idx, open_time, close_time,
              direction, entry_price, exit_price, close_type), ...]
    """
    if not trades:
        return {
            "final_balance": INITIAL_CAPITAL, "max_drawdown": 0,
            "sharpe_ratio": 0, "sortino_ratio": 0, "calmar_ratio": 0,
            "cagr": 0, "double_count": 0, "fastest_double_days": 0,
            "avg_double_days": 0, "daily_open_positions": 0,
            "total_fees": 0, "max_balance": INITIAL_CAPITAL,
            "min_balance": INITIAL_CAPITAL, "expectancy_ratio": 0,
            "total_return": 0,
        }

    bpf = _BARS_PER_FUNDING.get(interval, 999999)
    bpd = _BARS_PER_DAY.get(interval, 24)

    # ── 推算 pnl ──
    pnls = []
    total_fee_cost = 0.0
    for t in trades:
        open_idx, close_idx, open_time, close_time, direction, entry, exit_p, close_type = t
        if entry <= 0:
            pnls.append(0.0)
            continue
        if direction == "long":
            raw = (exit_p - entry) / entry * LEVERAGE
        else:
            raw = (entry - exit_p) / entry * LEVERAGE

        holding = close_idx - open_idx
        fee = FEE_RATE * 2
        slip = SLIPPAGE_PCT * 2
        funding_count = holding // bpf if bpf > 0 else 0
        funding = FUNDING_RATE_8H * funding_count
        net_pnl = raw - fee - slip - funding
        pnl_amount = net_pnl * FIXED_BET_AMOUNT
        pnls.append(pnl_amount)
        total_fee_cost += (fee + slip + funding) * FIXED_BET_AMOUNT

    # ── 余额曲线 ──
    balance_curve = [INITIAL_CAPITAL]
    for p in pnls:
        balance_curve.append(balance_curve[-1] + p)

    final_balance = balance_curve[-1]
    max_balance = max(balance_curve)
    min_balance = min(balance_curve)

    # ── 总收益率（覆盖，确保与 final_balance 一致）──
    total_return = (final_balance - INITIAL_CAPITAL) / INITIAL_CAPITAL * 100

    # ── 最大回撤 ──
    max_eq = INITIAL_CAPITAL
    max_dd = 0.0
    for e in balance_curve:
        if e > max_eq:
            max_eq = e
        if max_eq > 0:
            dd = (max_eq - e) / max_eq * 100
            if dd > max_dd:
                max_dd = dd

    # ── Sharpe / Sortino ──
    returns = []
    for i in range(1, len(balance_curve)):
        if balance_curve[i - 1] > 0:
            returns.append((balance_curve[i] - balance_curve[i - 1]) / balance_curve[i - 1])

    sharpe = 0.0
    sortino = 0.0
    if len(returns) > 1:
        std = statistics.stdev(returns)
        if std > 0:
            risk_free = 0.02 / 252
            sharpe = (statistics.mean(returns) - risk_free) / std * (252 ** 0.5)
            neg_returns = [r for r in returns if r < 0]
            if len(neg_returns) > 1:
                neg_std = statistics.stdev(neg_returns)
                if neg_std > 0:
                    sortino = (statistics.mean(returns) - risk_free) / neg_std * (252 ** 0.5)

    # ── Calmar ──
    calmar = total_return / max_dd if max_dd > 0 else 0.0

    # ── 翻倍统计 ──
    double_times = []
    next_target = INITIAL_CAPITAL * 2
    prev_time = None
    if trades:
        prev_time = trades[0][2]  # open_time（第一笔）

    for i, t in enumerate(trades):
        bal = balance_curve[i + 1]
        if bal >= next_target and prev_time is not None:
            hit_time = t[3]  # close_time
            try:
                if isinstance(prev_time, (int, float)) and isinstance(hit_time, (int, float)):
                    days_diff = max(0, (int(hit_time) - int(prev_time)) / (1000 * 86400))
                else:
                    d1 = datetime.strptime(str(prev_time), '%Y-%m-%d %H:%M')
                    d2 = datetime.strptime(str(hit_time), '%Y-%m-%d %H:%M')
                    days_diff = max(0, (d2 - d1).days)
            except (ValueError, TypeError):
                days_diff = 0
            double_times.append(days_diff)
            prev_time = hit_time
            next_target *= 2

    double_count = len(double_times)
    fastest_double_days = min(double_times) if double_times else 0
    avg_double_days = round(sum(double_times) / double_count, 1) if double_count > 0 else 0

    # ── 日均开仓量 ──
    total_trades = len(trades)
    if trades:
        try:
            t0_time = int(trades[0][2])
            tN_time = int(trades[-1][3])
            trading_days = max(1, (tN_time - t0_time) / (1000 * 86400))
        except (ValueError, TypeError):
            trading_days = max(1, total_trades / bpd)
    else:
        trading_days = 1
    daily_open = total_trades / trading_days

    # ── CAGR ──
    cagr = 0.0
    if final_balance > 0 and trading_days > 0:
        cagr = (final_balance / INITIAL_CAPITAL) ** (365.0 / trading_days) - 1

    # ── 期望比率 ──
    wins = [p for p in pnls if p > 0]
    losses = [abs(p) for p in pnls if p < 0]
    avg_win = sum(wins) / len(wins) if wins else 0
    avg_loss = sum(losses) / len(losses) if losses else 0
    wr = len(wins) / total_trades if total_trades > 0 else 0
    expectancy = (wr * avg_win) - ((1 - wr) * avg_loss)

    return {
        "final_balance": final_balance,
        "max_drawdown": max_dd,
        "sharpe_ratio": sharpe,
        "sortino_ratio": sortino,
        "calmar_ratio": calmar,
        "cagr": cagr,
        "double_count": double_count,
        "fastest_double_days": fastest_double_days,
        "avg_double_days": avg_double_days,
        "daily_open_positions": daily_open,
        "total_fees": total_fee_cost,
        "max_balance": max_balance,
        "min_balance": min_balance,
        "expectancy_ratio": expectancy,
        "total_return": total_return,
    }


def run_post_calc(con) -> int:
    """逐 combo 后算 14+1 个字段。返回更新数量。"""
    combos = con.execute(
        "SELECT seed_type, id, interval FROM combo_summary"
    ).fetchall()

    print(f"  后算 {len(combos):,} 个 combo...", flush=True)

    updated = 0
    t0 = time.time()

    for i, (seed_type, combo_id, interval) in enumerate(combos):
        trades = con.execute(
            "SELECT open_candle_idx, close_candle_idx, open_time, close_time, "
            "direction, entry_price, exit_price, close_type "
            "FROM paired_trades "
            "WHERE seed_type=? AND combo_id=? "
            "ORDER BY open_candle_idx, close_candle_idx",
            [seed_type, combo_id],
        ).fetchall()

        m = compute_post_metrics(trades, interval)

        con.execute(
            """UPDATE combo_summary SET
               total_return=?, final_balance=?, max_drawdown=?,
               sharpe_ratio=?, sortino_ratio=?, calmar_ratio=?,
               cagr=?, double_count=?, fastest_double_days=?, avg_double_days=?,
               daily_open_positions=?, total_fees=?,
               max_balance=?, min_balance=?, expectancy_ratio=?
               WHERE seed_type=? AND id=?""",
            (m["total_return"], m["final_balance"], m["max_drawdown"],
             m["sharpe_ratio"], m["sortino_ratio"], m["calmar_ratio"],
             m["cagr"], m["double_count"], m["fastest_double_days"],
             m["avg_double_days"], m["daily_open_positions"], m["total_fees"],
             m["max_balance"], m["min_balance"], m["expectancy_ratio"],
             seed_type, combo_id),
        )
        updated += 1

        if (i + 1) % 1000 == 0:
            elapsed = time.time() - t0
            rate = (i + 1) / elapsed
            eta = (len(combos) - i - 1) / rate if rate > 0 else 0
            print(f"    进度: {i+1:,}/{len(combos):,} ({rate:.0f}/s, ETA {eta:.0f}s)", flush=True)

    elapsed = time.time() - t0
    print(f"    后算完成: {updated:,} 个 combo, {elapsed:.1f}s")
    return updated


# ==================== Step 3: 索引 + 统计 ====================

def create_indexes(con) -> None:
    """建索引。"""
    con.execute("CREATE INDEX IF NOT EXISTS idx_cs_strat ON combo_summary(strategy, coin, interval)")
    con.execute("CREATE INDEX IF NOT EXISTS idx_cs_seed ON combo_summary(seed_type)")
    con.execute("CREATE INDEX IF NOT EXISTS idx_pt_seed ON paired_trades(seed_type)")
    con.execute("CREATE INDEX IF NOT EXISTS idx_pt_strat ON paired_trades(strategy, coin, interval)")
    con.execute("CREATE INDEX IF NOT EXISTS idx_pt_combo ON paired_trades(seed_type, combo_id)")


def print_summary(con) -> None:
    """打印统计摘要。"""
    total_combos = con.execute("SELECT COUNT(*) FROM combo_summary").fetchone()[0]
    total_trades = con.execute("SELECT COUNT(*) FROM paired_trades").fetchone()[0]

    print(f"\n{'='*60}")
    print(f"  种子报告生成完成")
    print(f"  combo_summary: {total_combos:,} 行")
    print(f"  paired_trades: {total_trades:,} 行")

    # 按种子类型
    print(f"\n  按种子类型:")
    for row in con.execute(
            "SELECT seed_type, COUNT(*) as combos, SUM(total_trades) as trades "
            "FROM combo_summary GROUP BY seed_type ORDER BY seed_type").fetchall():
        print(f"    {row[0]:<15s}: {row[1]:>6,} combos, {row[2]:>12,} trades")

    # 后算字段抽查
    print(f"\n  后算字段抽查（signal_only, BTC, 1m, 前5）:")
    for row in con.execute(
            "SELECT strategy, sharpe_ratio, max_drawdown, final_balance, calmar_ratio "
            "FROM combo_summary "
            "WHERE seed_type='signal_only' AND coin='BTC' AND interval='1m' "
            "ORDER BY sharpe_ratio DESC LIMIT 5").fetchall():
        print(f"    {row[0]:<25s} sharpe={row[1]:>7.2f}  dd={row[2]:>6.1f}%  "
              f"bal={row[3]:>8.1f}  calmar={row[4]:>7.2f}")

    # 非零检查
    zero_count = con.execute(
        "SELECT COUNT(*) FROM combo_summary "
        "WHERE total_trades > 0 AND final_balance = 0 AND sharpe_ratio = 0"
    ).fetchone()[0]
    if zero_count > 0:
        print(f"\n  !! {zero_count} 个有交易但后算字段仍为 0 的 combo")
    else:
        print(f"\n  后算字段非零检查: 全部通过")

    db_size = os.path.getsize(REPORT_DB)
    print(f"\n  报告: {REPORT_DB} ({db_size/1024/1024:.1f} MB)")
    print(f"{'='*60}")


# ==================== Main ====================

def build_report() -> None:
    import duckdb

    if os.path.exists(REPORT_DB):
        os.remove(REPORT_DB)

    con = duckdb.connect(REPORT_DB)
    con.execute("SET memory_limit = '4GB'")

    # Step 1: 导入
    print("\n[Step 1] 导入 4 个 SQLite → DuckDB")
    n_combos, n_trades = import_sqlite_to_duckdb(con)

    # Step 2: 后算
    print(f"\n[Step 2] 后算 14 字段")
    run_post_calc(con)

    # Step 3: 索引 + 统计
    print(f"\n[Step 3] 建索引")
    create_indexes(con)

    print_summary(con)
    con.close()


