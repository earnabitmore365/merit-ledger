        ("ttp_highlow", os.path.join(report_dir, "seed_ttp_hl.db")),
        ("dual_hold", os.path.join(report_dir, "seed_dual.db")),
    ]
    REPORT_DB = args.output or os.path.join(report_dir, "seed_report.duckdb")

    print("种子报告生成器 v2（合并 + 后算）")
    print(f"输入: {len(SEED_TYPES)} 个种子 SQLite（{report_dir}）")
    print(f"输出: {REPORT_DB}")
    build_report()
