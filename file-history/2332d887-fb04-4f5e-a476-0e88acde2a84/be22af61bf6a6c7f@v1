#!/usr/bin/env python3
"""
Gate v4.1 管线 — TTP 版种子
与 run_gate_v41.py 完全相同的流程，但用 seed_v3_ttp.db 作为输入。
输出到 results/gate_v41_ttp/gate_v41_ttp_report.db
"""
import sqlite3
import os, sys
import time
_p = os.path.dirname(os.path.abspath(__file__))
while _p != os.path.dirname(_p) and not os.path.exists(os.path.join(_p, '.wuji-root')):
    _p = os.path.dirname(_p)
if _p not in sys.path:
    sys.path.insert(0, _p)
from path_config import ROOT, DATA_DIR, REPORT_DIR, RESULT_DIR, SRC_DIR  # noqa: E402

TTP_DB = os.path.join(REPORT_DIR, 'seed_v3_ttp.db')
TTP_REPORT_DIR = os.path.join(RESULT_DIR, 'gate_v41_ttp')
TTP_REPORT = os.path.join(TTP_REPORT_DIR, 'gate_v41_ttp_report.db')


def patch_db_paths():
    """把所有 Gate 脚本的 DB_PATH 指向 TTP 种子库"""
    import gate1_threshold
    import gate2v41_scorecard
    import gate3v41_team
    import gate_mcv41

    gate1_threshold.DB_PATH = TTP_DB
    gate2v41_scorecard.DB_PATH = TTP_DB
    gate3v41_team.DB_PATH = TTP_DB
    gate_mcv41.DB_PATH = TTP_DB

    # 报告输出路径
    os.makedirs(TTP_REPORT_DIR, exist_ok=True)
    gate2v41_scorecard.REPORT_DB = TTP_REPORT
    gate3v41_team.REPORT_DB = TTP_REPORT
    gate_mcv41.REPORT_DB = TTP_REPORT

    # gate1 输出到 TTP 报告
    if hasattr(gate1_threshold, 'REPORT_DB'):
        gate1_threshold.REPORT_DB = TTP_REPORT


def check_prerequisites():
    if not os.path.exists(TTP_DB):
        raise FileNotFoundError(f"TTP 种子库不存在: {TTP_DB}")

    conn = sqlite3.connect(TTP_DB)
    for table in ['regime_fact_labels', 'sub_phase_labels']:
        check = conn.execute(
            f"SELECT name FROM sqlite_master WHERE type='table' AND name='{table}'"
        ).fetchone()
        if not check:
            conn.close()
            raise RuntimeError(f"{table} 表不存在! 请先运行 regime_fact_timeline.py 和 sub_phase_labels.py")
        count = conn.execute(f"SELECT COUNT(*) FROM {table}").fetchone()[0]
        print(f"✅ {table}: {count:,} 条")
    conn.close()


def main():
    print("=" * 60)
    print("Gate v4.1 管线 — TTP 版 (seed_v3_ttp.db)")
    print("=" * 60)

    print("\n[Step 0] 检查前置条件...")
    check_prerequisites()

    print("\n[Step 0.5] 修改路径指向 TTP 种子库...")
    patch_db_paths()
    print(f"  数据源: {TTP_DB}")
    print(f"  报告: {TTP_REPORT}")

    print("\n[Step 1] 初考（交易数门槛）...")
    t0 = time.time()
    import gate1_threshold
    gate1_threshold.main()
    print(f"  耗时: {time.time()-t0:.1f}s")

    print("\n[Step 2] 专考（13维度成绩单）...")
    t0 = time.time()
    import gate2v41_scorecard
    gate2v41_scorecard.main()
    print(f"  耗时: {time.time()-t0:.1f}s")

    print("\n[Step 3] 组考（组队）...")
    t0 = time.time()
    import gate3v41_team
    gate3v41_team.main()
    print(f"  耗时: {time.time()-t0:.1f}s")

    print("\n[Step 4] 照妖镜 MC...")
    t0 = time.time()
    import gate_mcv41
    gate_mcv41.main()
    print(f"  耗时: {time.time()-t0:.1f}s")

    # 最终汇总
    print("\n" + "=" * 60)
    print("Gate v4.1 TTP 版管线完成!")
    print("=" * 60)

    rpt = sqlite3.connect(TTP_REPORT)
    rpt.row_factory = sqlite3.Row

    tables = rpt.execute("SELECT name FROM sqlite_master WHERE type='table'").fetchall()
    if any(t['name'] == 'gate_index' for t in tables):
        print("\n报告目录:")
        for row in rpt.execute("SELECT * FROM gate_index ORDER BY table_name").fetchall():
            print(f"  {row['table_name']:>20s} | {row['record_count']:>6d} | {row['description']}")

    if any(t['name'] == 'champions' for t in tables):
        champs = rpt.execute('''
            SELECT * FROM champions ORDER BY team, all_pnl DESC
        ''').fetchall()

        if champs:
            print(f"\nTTP 版冠军队 ({len(champs)} 个):")
            print(f"{'队伍':>6s}  {'策略':<20s}  {'币种':<6s}  {'周期':<4s}  {'PnL(R)':>8s}  {'翻倍率':>6s}  {'d2d_p50':>8s}")
            print("-" * 75)
            for c in champs:
                d2d = c['d2d_p50'] if c['d2d_p50'] else 0
                print(f"{c['team']:>6s}  {c['strategy']:<20s}  {c['coin']:<6s}  {c['interval']:<4s}  "
                      f"{c['all_pnl']:>+8.1f}  {c['double_rate']:>5.1f}%  {d2d:>8.1f}")

    rpt.close()
    print(f"\n输出: {TTP_REPORT}")


if __name__ == '__main__':
    main()
