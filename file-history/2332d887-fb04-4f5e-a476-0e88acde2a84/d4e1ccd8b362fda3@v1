class TTPTracker:
    """简化版 TTP 追踪器（不依赖 TTPManager）。

    激活条件：浮盈 >= activation_pct（默认5%，含杠杆）
    追踪：记录最高浮盈，回撤 >= trailing_pct 触发平仓
    """

    def __init__(self, activation_pct: float = 0.05, trailing_pct: float = 0.02):
        self.activation_pct = activation_pct  # 激活阈值（杠杆后的收益率）
        self.trailing_pct = trailing_pct      # 回撤阈值
        self.active = False
        self.peak_pnl = 0.0

    def reset(self) -> None:
        self.active = False
        self.peak_pnl = 0.0

    def check(self, best_pnl_pct: float, worst_pnl_pct: float | None = None) -> bool:
        """检查是否触发TTP平仓（双价格版）。

        同一根 K 线内分两步：
          1. 用 best_pnl_pct（有利价格）激活/更新峰值
          2. 用 worst_pnl_pct（不利价格）检查回撤触发

        做多：best = high 算的浮盈, worst = low 算的浮盈
        做空：best = low 算的浮盈, worst = high 算的浮盈

        Args:
            best_pnl_pct: 有利价格的浮盈比例（用于激活+追踪峰值）
            worst_pnl_pct: 不利价格的浮盈比例（用于检查回撤）。
                           None 时退化为单价格模式（close 价）。

        Returns:
            True = 触发平仓
        """
        if worst_pnl_pct is None:
            worst_pnl_pct = best_pnl_pct  # 单价格模式（ttp_close 用）

        # Step 1: 用有利价格激活/更新峰值
        if not self.active:
            if best_pnl_pct >= self.activation_pct:
                self.active = True
                self.peak_pnl = best_pnl_pct
            return False

        if best_pnl_pct > self.peak_pnl:
            self.peak_pnl = best_pnl_pct

        # Step 2: 用不利价格检查回撤
        drawdown = self.peak_pnl - worst_pnl_pct
        if drawdown >= self.trailing_pct:
            return True  # 触发平仓

        return False


class TradeSimulator:
    """信号序列 → 交易列表（4种执行模式）。

    4种模式：
      signal_only  — 无TTP，信号反转才平仓
      ttp_close    — 信号反转 或 close价触发TTP（单价格）
      ttp_highlow  — 信号反转 或 high/low双价格TTP（更精确）
      dual_hold    — TTP激活期间反向信号不平原仓，另开新仓

    TTP 双价格（ttp_highlow / dual_hold）：
      做多：high 激活/更新峰值，low 检查回撤触发
      做空：low 激活/更新峰值，high 检查回撤触发
    """

    def __init__(
        self,
        candles: list[dict[str, Any]],
        signals: list[str],
        mode: str = "signal_only",
        leverage: float = 10.0,
        stop_loss_pct: float = 1.0,
        ttp_activation: float = 0.05,
        ttp_trailing: float = 0.02,
    ):
        self.candles = candles
        self.signals = signals
        self.mode = mode
        self.leverage = leverage
        self.stop_loss_pct = stop_loss_pct  # MAE >= 此值则强平
        self.ttp_activation = ttp_activation
        self.ttp_trailing = ttp_trailing

        # 预提取价格数组
        self.closes = [c["close"] for c in candles]
        self.highs = [c["high"] for c in candles]
        self.lows = [c["low"] for c in candles]
        self.times = [str(c.get("time", "")) for c in candles]

    def run(self) -> list[SimTrade]:
        """执行模拟，返回交易列表。"""
        if self.mode == "dual_hold":
            return self._run_dual_hold()
        else:
            return self._run_single_position()

    def _calc_pnl_pct(self, direction: str, entry: float, price: float) -> float:
        """计算浮盈比例（含杠杆）。"""
        if entry <= 0:
            return 0.0
        if direction == "long":
            return (price - entry) / entry * self.leverage
        else:
            return (entry - price) / entry * self.leverage

    def _update_mfe_mae(self, direction: str, entry: float,
                        high: float, low: float) -> tuple[float, float]:
        """计算单根K线的 favorable/adverse 偏移。"""
        if entry <= 0:
            return 0.0, 0.0
        if direction == "long":
            favorable = (high - entry) / entry * self.leverage
            adverse = (entry - low) / entry * self.leverage
        else:
            favorable = (entry - low) / entry * self.leverage
            adverse = (high - entry) / entry * self.leverage
        return max(0.0, favorable), max(0.0, adverse)

    def _get_ttp_prices(self, i: int, direction: str) -> tuple[float, float]:
        """根据模式获取 TTP 检查价格（best, worst）。

        ttp_close: best=worst=close（单价格）
        ttp_highlow: best=有利价格（激活/追踪），worst=不利价格（回撤触发）
        """
        if self.mode == "ttp_close":
            return self.closes[i], self.closes[i]
        elif self.mode in ("ttp_highlow", "dual_hold"):
            if direction == "long":
                return self.highs[i], self.lows[i]   # best=high, worst=low
            else:
                return self.lows[i], self.highs[i]    # best=low, worst=high
        return self.closes[i], self.closes[i]

    def _run_single_position(self) -> list[SimTrade]:
        """单仓模式（signal_only / ttp_close / ttp_highlow）。"""
        trades: list[SimTrade] = []
        ttp = TTPTracker(self.ttp_activation, self.ttp_trailing)
        enable_ttp = self.mode in ("ttp_close", "ttp_highlow")

        position = ""       # "" / "long" / "short"
        entry_price = 0.0
        open_idx = 0
        mfe = 0.0
        mae = 0.0

        n = min(len(self.candles), len(self.signals))

        for i in range(n):
            signal = self.signals[i]
            close = self.closes[i]

            # ── 持仓中：更新 MFE/MAE ──
            if position:
                fav, adv = self._update_mfe_mae(
                    position, entry_price, self.highs[i], self.lows[i])
                mfe = max(mfe, fav)
                mae = max(mae, adv)

                # 止损检查（逐仓爆仓：MAE >= stop_loss_pct）
                if mae >= self.stop_loss_pct:
                    if position == "long":
                        sl_price = entry_price * (1 - self.stop_loss_pct / self.leverage)
                    else:
                        sl_price = entry_price * (1 + self.stop_loss_pct / self.leverage)
                    trades.append(SimTrade(
                        open_candle_idx=open_idx, close_candle_idx=i,
                        open_time=self.times[open_idx], close_time=self.times[i],
                        direction=position, entry_price=entry_price,
                        exit_price=sl_price, close_type="stop_loss",
                        mfe=round(mfe, 6), mae=round(mae, 6),
                    ))
                    position = ""
                    entry_price = 0.0
                    mfe = mae = 0.0
                    ttp.reset()
                    continue

                # TTP 检查（双价格：best 激活/追踪，worst 回撤触发）
                if enable_ttp:
                    best_p, worst_p = self._get_ttp_prices(i, position)
                    best_pnl = self._calc_pnl_pct(position, entry_price, best_p)
                    worst_pnl = self._calc_pnl_pct(position, entry_price, worst_p)
                    if ttp.check(best_pnl, worst_pnl):
                        trades.append(SimTrade(
                            open_candle_idx=open_idx, close_candle_idx=i,
                            open_time=self.times[open_idx], close_time=self.times[i],
                            direction=position, entry_price=entry_price,
                            exit_price=worst_p, close_type="ttp",
                            mfe=round(mfe, 6), mae=round(mae, 6),
                        ))
                        position = ""
                        entry_price = 0.0
                        mfe = mae = 0.0
                        ttp.reset()
                        continue

            # ── 信号处理 ──
            if signal == "BUY":
                if position == "short":
                    trades.append(SimTrade(
                        open_candle_idx=open_idx, close_candle_idx=i,
                        open_time=self.times[open_idx], close_time=self.times[i],
                        direction="short", entry_price=entry_price,
                        exit_price=close, close_type="signal",
                        mfe=round(mfe, 6), mae=round(mae, 6),
                    ))
                    ttp.reset()
                    mfe = mae = 0.0
                if position != "long":
                    position = "long"
                    entry_price = close
                    open_idx = i
                    mfe = mae = 0.0

            elif signal == "SELL":
                if position == "long":
                    trades.append(SimTrade(
                        open_candle_idx=open_idx, close_candle_idx=i,
                        open_time=self.times[open_idx], close_time=self.times[i],
                        direction="long", entry_price=entry_price,
                        exit_price=close, close_type="signal",
                        mfe=round(mfe, 6), mae=round(mae, 6),
                    ))
                    ttp.reset()
                    mfe = mae = 0.0
                if position != "short":
                    position = "short"
                    entry_price = close
                    open_idx = i
                    mfe = mae = 0.0

        # 数据结束，强制平仓
        if position:
            trades.append(SimTrade(
                open_candle_idx=open_idx, close_candle_idx=n - 1,
                open_time=self.times[open_idx], close_time=self.times[n - 1],
                direction=position, entry_price=entry_price,
                exit_price=self.closes[n - 1], close_type="end_of_data",
                mfe=round(mfe, 6), mae=round(mae, 6),
            ))

        return trades

    def _run_dual_hold(self) -> list[SimTrade]:
        """双持仓模式：TTP激活期间反向信号不平原仓，另开新仓。

        规则：
        - TTP 未激活时来反向信号 → 跟 ttp_highlow 一样：平仓+反手
        - TTP 已激活追踪中来反向信号 → 保留原仓继续TTP + 另开新仓
        - 同时最多一多一空，两个仓位独立（各自TTP/止损）
        - 原仓TTP平了之后不做特殊处理
        """
        trades: list[SimTrade] = []

        # 最多2个仓位
        positions: list[dict] = []  # 每个: {direction, entry_price, open_idx, mfe, mae, ttp}

        n = min(len(self.candles), len(self.signals))

        for i in range(n):
            signal = self.signals[i]

            # ── 更新所有持仓的 MFE/MAE + 止损/TTP 检查 ──
            closed_indices = []
            for pi, pos in enumerate(positions):
                fav, adv = self._update_mfe_mae(
                    pos["direction"], pos["entry_price"],
                    self.highs[i], self.lows[i])
                pos["mfe"] = max(pos["mfe"], fav)
                pos["mae"] = max(pos["mae"], adv)

                # 止损
                if pos["mae"] >= self.stop_loss_pct:
                    if pos["direction"] == "long":
                        sl_price = pos["entry_price"] * (1 - self.stop_loss_pct / self.leverage)
                    else:
                        sl_price = pos["entry_price"] * (1 + self.stop_loss_pct / self.leverage)
                    trades.append(SimTrade(
                        open_candle_idx=pos["open_idx"], close_candle_idx=i,
                        open_time=self.times[pos["open_idx"]], close_time=self.times[i],
                        direction=pos["direction"], entry_price=pos["entry_price"],
                        exit_price=sl_price, close_type="stop_loss",
                        mfe=round(pos["mfe"], 6), mae=round(pos["mae"], 6),
                    ))
                    closed_indices.append(pi)
                    continue

                # TTP（双价格：best 激活/追踪，worst 回撤触发）
                best_p, worst_p = self._get_ttp_prices(i, pos["direction"])
                best_pnl = self._calc_pnl_pct(pos["direction"], pos["entry_price"], best_p)
                worst_pnl = self._calc_pnl_pct(pos["direction"], pos["entry_price"], worst_p)
                if pos["ttp"].check(best_pnl, worst_pnl):
                    trades.append(SimTrade(
                        open_candle_idx=pos["open_idx"], close_candle_idx=i,
                        open_time=self.times[pos["open_idx"]], close_time=self.times[i],
                        direction=pos["direction"], entry_price=pos["entry_price"],
                        exit_price=worst_p, close_type="ttp",
                        mfe=round(pos["mfe"], 6), mae=round(pos["mae"], 6),
                    ))
                    closed_indices.append(pi)

            # 移除已平仓位
            for pi in sorted(closed_indices, reverse=True):
                positions.pop(pi)

            # ── 信号处理 ──
            if signal in ("BUY", "SELL"):
                target_dir = "long" if signal == "BUY" else "short"
                opposite_dir = "short" if signal == "BUY" else "long"

                # 已有同向仓 → 忽略
                if any(p["direction"] == target_dir for p in positions):
                    continue

                # 有反向仓？
                opposite_pos = [p for p in positions if p["direction"] == opposite_dir]
                if opposite_pos:
                    opp = opposite_pos[0]
                    if opp["ttp"].active:
                        # TTP 已激活 → 保留原仓，另开新仓（双持）
                        pass  # 不平原仓，下面开新仓
                    else:
                        # TTP 未激活 → 平仓反手
                        trades.append(SimTrade(
                            open_candle_idx=opp["open_idx"], close_candle_idx=i,
                            open_time=self.times[opp["open_idx"]], close_time=self.times[i],
                            direction=opp["direction"], entry_price=opp["entry_price"],
                            exit_price=self.closes[i], close_type="signal",
                            mfe=round(opp["mfe"], 6), mae=round(opp["mae"], 6),
                        ))
                        positions.remove(opp)

                # 开新仓（如果还没有同向仓）
                if not any(p["direction"] == target_dir for p in positions):
                    positions.append({
                        "direction": target_dir,
                        "entry_price": self.closes[i],
                        "open_idx": i,
                        "mfe": 0.0,
                        "mae": 0.0,
                        "ttp": TTPTracker(self.ttp_activation, self.ttp_trailing),
                    })

        # 数据结束，强制平所有仓位
        for pos in positions:
            trades.append(SimTrade(
                open_candle_idx=pos["open_idx"], close_candle_idx=n - 1,
                open_time=self.times[pos["open_idx"]], close_time=self.times[n - 1],
                direction=pos["direction"], entry_price=pos["entry_price"],
                exit_price=self.closes[n - 1], close_type="end_of_data",
                mfe=round(pos["mfe"], 6), mae=round(pos["mae"], 6),
            ))

        return trades


