# ==================== 1m 分段加速 ====================

_SEGMENT_WARMUP = 2000   # 预热 K 线数（最长窗口 SMA(200) 的 10 倍冗余）
_SEGMENT_COUNT = 4        # 分段数
_SEGMENT_MIN_CANDLES = 100_000  # 低于此阈值不分段（信号并行+交易全量，已验证零差异）


def _split_segments(n_candles: int, n_segments: int = _SEGMENT_COUNT,
                    warmup: int = _SEGMENT_WARMUP) -> list[tuple[int, int, int]]:
    """将 K 线分段。返回 [(start, end, actual_start), ...]。

    每段前面多取 warmup 根做指标预热，有效区从 actual_start 开始。
    段0 无预热（从头开始），段1-3 各有 warmup 根预热。
    验证：3 策略 × ADA 1m 210万根，信号 100% 一致，交易 100% 吻合。
    """
    seg_size = n_candles // n_segments
    return [
        (max(0, i * seg_size - warmup),
         (i + 1) * seg_size if i < n_segments - 1 else n_candles,
         i * seg_size)
        for i in range(n_segments)
    ]


def _worker_segment(args: tuple) -> list[str]:
    """子进程：处理 1m 一个分段的信号生成（top-level 函数，供 ProcessPoolExecutor 调用）。

    信号是无状态的（只依赖 candles + indicators），分段不影响正确性。
    交易是有状态的（持仓状态机），必须全量串行，不在此处运行。

    Args: (coin, interval, candle_slice, warmup_n, global_offset,
           strategy_name)

    Returns: 有效区信号列表（预热区已过滤）
    """
    (coin, interval, candle_slice, warmup_n, global_offset,
     strategy_name) = args

    # spawn 模式下子进程需要重新设置 path + import
    import os as _os, sys as _sys
    _p = _os.path.dirname(_os.path.abspath(__file__))
    while _p != _os.path.dirname(_p) and not _os.path.exists(_os.path.join(_p, '.wuji-root')):
        _p = _os.path.dirname(_p)
    if _p not in _sys.path:
        _sys.path.insert(0, _p)
    _src = _os.path.join(_p, 'src')
    if _src not in _sys.path:
        _sys.path.insert(0, _src)

    from core.indicator_cache import init_cache as _ic
    from backtest.backtest import BacktestEngine as _BE

    _ic(coin, interval, candle_slice, db_path=":memory:")
    engine = _BE(coin=coin, interval=interval, days=0, candles=candle_slice)
    signals = engine.generate_signals(strategy_name)

    if not signals:
        return []

    # 只返回有效区信号（跳过预热区）
    return signals[warmup_n:]


def _run_strategy_segmented(coin: str, interval: str, all_candles: list,
                            strategy_name: str, seed_mode_names: list[str],
                            leverage: float, stop_loss_pct: float,
                            bars_per_day: int = 1440,
                            n_segments: int = _SEGMENT_COUNT,
                            warmup: int = _SEGMENT_WARMUP,
                            executor: ProcessPoolExecutor | None = None,
                            ) -> dict[str, list]:
    """1m 分段加速：信号 4 段并行 + 交易全量串行。

    信号是无状态的（只依赖 candles + indicators），可分段并行。
    交易是有状态的（持仓状态机），必须全量串行保证正确性。

    验证：BTC 1m × 3策略 × 4模式，全量 vs 分段合并零差异。

    传入 executor 复用进程池（避免每策略重建池的 spawn+import 开销）。
    不传则内部创建（兼容旧调用）。

    Returns: {mode: [SimTrade, ...]} 每种模式的完整交易列表
    """
    N = len(all_candles)
    segments = _split_segments(N, n_segments, warmup)

    # ── 信号分段并行 ──
    task_args = []
    for start, end, actual_start in segments:
        seg_candles = all_candles[start:end]
        warmup_n = actual_start - start
        task_args.append((
            coin, interval, seg_candles, warmup_n, start,
            strategy_name,
        ))

    seg_signals_list: list[list[str]] = [[] for _ in range(n_segments)]

    def _submit_and_collect(exc: ProcessPoolExecutor) -> None:
        futures = [(i, exc.submit(_worker_segment, args))
                   for i, args in enumerate(task_args)]
        for i, f in futures:
            seg_signals_list[i] = f.result()

    if executor is not None:
        _submit_and_collect(executor)
    else:
        with ProcessPoolExecutor(max_workers=n_segments) as exc:
            _submit_and_collect(exc)

    # 合并信号（保持段顺序）
    merged_signals: list[str] = []
    for seg_sigs in seg_signals_list:
        merged_signals.extend(seg_sigs)

    if not merged_signals or all(s == 'HOLD' for s in merged_signals):
        return {m: [] for m in seed_mode_names}

    # ── 交易全量串行 ──
    mode_trades: dict[str, list] = {}
    for mode in seed_mode_names:
        sim = TradeSimulator(all_candles, merged_signals, mode=mode,
                             leverage=leverage, stop_loss_pct=stop_loss_pct)
        mode_trades[mode] = sim.run()

    return mode_trades


# ==================== 并行 Worker ====================

_BARS_PER_DAY_MAP = {
    "1m": 1440, "5m": 288, "15m": 96, "30m": 48,
    "1h": 24, "2h": 12, "4h": 6, "8h": 3, "12h": 2, "1d": 1,
}


def _worker_coin_interval(coin: str, interval: str, strategies: list[str],
                          db_path: str | None = None,
                          seed_modes: list[tuple[str, str]] | None = None) -> dict[str, Any]:
    """Worker: 处理一个 (coin, interval) 的所有策略。.

    每个 worker 打开自己的 DB 连接，跑完所有策略后关闭。
    用于 ProcessPoolExecutor 并行或单线程直接调用。

    Args:
        coin: 交易对名称
        interval: K线周期
        strategies: 策略名列表
        db_path: 指定写入的 DB 路径（并行模式用临时 DB，单线程用主库）
        seed_modes: 多种子模式列表，每个元素为 (mode, db_path)。
                    传入时走新流程（generate_signals + TradeSimulator），
                    不传时走旧流程（向后兼容）。

    Returns:
        {'coin', 'interval', 'completed', 'skipped',
         'failed', 'elapsed', 'details': [...]}

    """
    if db_path is None:
        db_path = DB_PATH
    conn = init_db(db_path)

    # ── 预过滤：跳过已完成的策略 ──
    existing = set()
    for row in conn.execute(
        "SELECT strategy FROM combo_summary WHERE coin=? AND interval=?",
        (coin, interval)
    ):
        existing.add(row[0])
    if _worker_completed_set:
        existing.update(
            s for s, c, i in _worker_completed_set if c == coin and i == interval
        )

    pending_strategies = []
    skipped_early = 0
    for sname in strategies:
        db_name = sname
        if db_name in existing:
            skipped_early += 1
        else:
            pending_strategies.append(sname)

    if not pending_strategies:
        conn.close()
        return {"coin": coin, "interval": interval, "completed": 0,
                "skipped": len(strategies), "failed": 0,
                "elapsed": 0, "details": [],
                "msg": f"全部 {len(strategies)} 策略已完成（快速跳过）"}

    t0 = time.time()
    all_candles = load_candles(coin, interval)
    if not all_candles:
        conn.close()
        return {"coin": coin, "interval": interval, "completed": 0,
                "skipped": 0, "failed": len(strategies), "elapsed": 0,
                "details": [], "msg": "数据不存在"}

    if len(all_candles) < MIN_KLINES:
        conn.close()
        return {"coin": coin, "interval": interval, "completed": 0,
                "skipped": len(strategies), "failed": 0, "elapsed": 0,
                "details": [], "msg": f"K线数 {len(all_candles)} < {MIN_KLINES}"}

    bars_per_day = _BARS_PER_DAY_MAP.get(interval, 24)

    # ── Regime 时间线 ──
    if check_regime_exists(conn, coin, interval):
        cur = conn.execute(
            "SELECT candle_idx, candle_time_ms, regime, adx, sma_direction "
            "FROM regime_timeline WHERE coin=? AND interval=? ORDER BY candle_idx",
            (coin, interval))
        regime_timeline = [
            {"candle_idx": r[0], "candle_time_ms": r[1],
             "regime": r[2], "adx": r[3], "sma_direction": r[4]}
            for r in cur.fetchall()]
    else:
        regime_timeline = compute_regime_timeline(all_candles, interval, DAYS)
        save_regime_timeline(conn, coin, interval, regime_timeline)
        conn.commit()

    # ── 预加载已禁用（preload 产出错误数据，验证不通过） ──
    # BTC 1h 5策略抽检：preload 交易数与无 preload 全部不一致。
    # 根因待查（DuckDB 指标与 indicator_cache 实时计算值不匹配）。
    # 禁用前保留分段判断供 1m 使用。
    use_segments = (interval == "1m" and len(all_candles) >= _SEGMENT_MIN_CANDLES
                    and seed_modes)

    # ── 逐策略回测 ──
    completed = 0
    skipped = skipped_early
    failed = 0
    details = []

    # 如果指定了多种子模式，走新流程（generate_signals + TradeSimulator）
    if seed_modes:
        # 打开每个种子的 DB 连接
        seed_conns: dict[str, sqlite3.Connection] = {}
        for mode, spath in seed_modes:
            seed_conns[mode] = init_db(spath)
            # regime 也要存到每个 DB
            if not check_regime_exists(seed_conns[mode], coin, interval):
                save_regime_timeline(seed_conns[mode], coin, interval, regime_timeline)
                seed_conns[mode].commit()

        use_segments = (interval == "1m"
                        and len(all_candles) >= _SEGMENT_MIN_CANDLES)
        seed_mode_names = [m for m, _ in seed_modes]
        # bars_per_funding 需要从引擎获取（创建一个临时引擎取值）
        _tmp_eng = BacktestEngine(coin=coin, interval=interval, days=0,
                                  candles=all_candles[:1])
        _bpf = _tmp_eng._bars_per_funding

        # 1m 分段：进程池创建一次，复用给 105 策略（避免 spawn+import 开销）
        _seg_pool = (ProcessPoolExecutor(max_workers=_SEGMENT_COUNT)
                     if use_segments else None)

        for strategy_name in pending_strategies:
            try:
                if use_segments:
                    # 1m 分段加速：切 4 段各自跑，合并交易
                    mode_trades = _run_strategy_segmented(
                        coin, interval, all_candles, strategy_name,
                        seed_mode_names, LEVERAGE, STOP_LOSS_PCT,
                        bars_per_day=bars_per_day,
                        executor=_seg_pool)
                    first_mode_trades = 0
                    for mode, _ in seed_modes:
                        save_sim_combo(
                            seed_conns[mode], strategy_name, coin, interval,
                            mode_trades[mode], leverage=LEVERAGE,
                            fee_rate=FEE_RATE, slippage_pct=SLIPPAGE_PCT,
                            funding_rate_8h=FUNDING_RATE_8H,
                            bars_per_funding=_bpf,
                            actual_candle_count=len(all_candles),
                            bars_per_day=bars_per_day)
                        seed_conns[mode].commit()
                        if first_mode_trades == 0:
                            first_mode_trades = len(mode_trades[mode])
                else:
                    # 非 1m：正常流程
                    engine = BacktestEngine(
                        coin=coin, interval=interval, days=DAYS,
                        candles=all_candles)
                    signals = engine.generate_signals(strategy_name)

                    if not signals or all(s == 'HOLD' for s in signals):
                        failed += 1
                        details.append((strategy_name, "NO_SIGNAL", 0, 0))
                        continue

                    first_mode_trades = 0
                    for mode, _ in seed_modes:
                        sim = TradeSimulator(
                            all_candles, signals, mode=mode,
                            leverage=LEVERAGE, stop_loss_pct=STOP_LOSS_PCT)
                        sim_trades = sim.run()

                        save_sim_combo(
                            seed_conns[mode], strategy_name, coin, interval,
                            sim_trades, leverage=LEVERAGE, fee_rate=FEE_RATE,
                            slippage_pct=SLIPPAGE_PCT,
                            funding_rate_8h=FUNDING_RATE_8H,
                            bars_per_funding=engine._bars_per_funding,
                            actual_candle_count=len(engine.candles),
                            bars_per_day=bars_per_day)
                        seed_conns[mode].commit()

                        if first_mode_trades == 0:
                            first_mode_trades = len(sim_trades)

                completed += 1
                details.append((strategy_name, "OK", 0, first_mode_trades))
            except Exception as e:
                failed += 1
                details.append((strategy_name, f"ERROR: {e}", 0, 0))

        if _seg_pool is not None:
            _seg_pool.shutdown(wait=False)

        for sconn in seed_conns.values():
            sconn.close()

    else:
        # 旧流程（向后兼容）
        for strategy_name in pending_strategies:
            db_name = strategy_name

            try:
                engine = BacktestEngine(
                    coin=coin, interval=interval, days=DAYS,
                    initial_capital=INITIAL_CAPITAL, enable_ttp=ENABLE_TTP,
                    stop_loss_pct=STOP_LOSS_PCT, leverage=LEVERAGE,
                    enable_withdraw=False, fixed_bet=FIXED_BET,
                    candles=all_candles, fixed_bet_amount=FIXED_BET_AMOUNT,
                    fee_rate=FEE_RATE, slippage_pct=SLIPPAGE_PCT,
                    funding_rate_8h=FUNDING_RATE_8H,
                    margin_mode=MARGIN_MODE,
                    ttp_highlow=TTP_HIGHLOW)
                result = engine.run_backtest(strategy_name)

                if result is None:
                    failed += 1
                    details.append((db_name, "FAIL", 0, 0))
                    continue

                paired = pair_trades(
                    engine.trades, engine.trade_candle_indices,
                    regime_timeline, LEVERAGE,
                    candles=engine.candles,
                    bars_per_funding=engine._bars_per_funding)

                save_combo(conn, db_name, coin, interval, result, paired,
                           initial_capital=INITIAL_CAPITAL, days=DAYS,
                           actual_candle_count=len(engine.candles),
                           bars_per_day=bars_per_day)
                conn.commit()
                completed += 1
                details.append((db_name, "OK", result.total_return, len(paired)))

            except Exception as e:
                failed += 1
                details.append((db_name, f"ERROR: {e}", 0, 0))

    elapsed = time.time() - t0
    conn.close()

    return {"coin": coin, "interval": interval, "completed": completed,
            "skipped": skipped, "failed": failed, "elapsed": elapsed,
            "details": details}




def _init_worker(config: dict[str, Any]) -> None:
    """ProcessPoolExecutor initializer — 在每个 worker 进程里设置全局变量."""
    global ENABLE_TTP, DAYS, INITIAL_CAPITAL, LEVERAGE, STOP_LOSS_PCT
    global FIXED_BET, FIXED_BET_AMOUNT, FEE_RATE, SLIPPAGE_PCT
    global FUNDING_RATE_8H, MIN_KLINES, DATA_DIR, _worker_completed_set, MARGIN_MODE
    ENABLE_TTP = config["enable_ttp"]
    DAYS = config["days"]
    INITIAL_CAPITAL = config["initial_capital"]
    LEVERAGE = config["leverage"]
    STOP_LOSS_PCT = config["stop_loss_pct"]
    FIXED_BET = config["fixed_bet"]
    FIXED_BET_AMOUNT = config["fixed_bet_amount"]
    FEE_RATE = config["fee_rate"]
    SLIPPAGE_PCT = config["slippage_pct"]
    FUNDING_RATE_8H = config["funding_rate_8h"]
    MIN_KLINES = config["min_klines"]
    DATA_DIR = config["data_dir"]
    _worker_completed_set = config.get("completed_set", set())
    MARGIN_MODE = config.get("margin_mode", "linear")
    global TTP_HIGHLOW
    TTP_HIGHLOW = config.get("ttp_highlow", True)


def merge_worker_db(main_db_path: str, temp_db_path: str) -> tuple[int, int]:
    """合并 worker 临时 DB 到主库。.

    逐条搬运 combo_summary + paired_trades（ID 重映射），
    regime_timeline 用 INSERT OR IGNORE 天然去重。

    Returns: (merged_count, skipped_count)
    """
    if not os.path.exists(temp_db_path):
        return 0, 0

    conn = sqlite3.connect(main_db_path)
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("PRAGMA busy_timeout=120000")
    conn.execute("PRAGMA synchronous=NORMAL")
    conn.execute("ATTACH DATABASE ? AS tmp", (temp_db_path,))

    # 读临时库所有 combo
    combos = conn.execute(
        "SELECT id, strategy, coin, interval, total_return, final_balance, "
        "max_drawdown, sharpe_ratio, sortino_ratio, calmar_ratio, "
        "total_trades, winning_trades, losing_trades, win_rate, "
        "avg_win_pct, avg_loss_pct, profit_factor, ttp_count, "
        "double_count, fastest_double_days, avg_double_days, daily_open_positions, "
        "cagr, max_daily_dd, reward_risk, max_consec_loss_amt, total_fees, "
        "max_balance, min_balance, max_win, max_loss, "
        "expectancy_ratio, longest_win_streak, "
        "longest_loss_streak, signal_close_count, "
        "backtest_time FROM tmp.combo_summary",
    ).fetchall()

    merged = 0
    skipped = 0

    for combo in combos:
        old_id = combo[0]
        strategy, coin, interval = combo[1], combo[2], combo[3]

        # 断点恢复：主库已有就跳过
        if conn.execute(
            "SELECT 1 FROM combo_summary WHERE strategy=? AND coin=? AND interval=?",
            (strategy, coin, interval),
        ).fetchone():
            skipped += 1
            continue

        # 插入 combo（去掉 old_id，让主库 autoincrement）
        cur = conn.execute(
            "INSERT INTO combo_summary "
            "(strategy, coin, interval, total_return, final_balance, "
            "max_drawdown, sharpe_ratio, sortino_ratio, calmar_ratio, "
            "total_trades, winning_trades, losing_trades, win_rate, "
            "avg_win_pct, avg_loss_pct, profit_factor, ttp_count, "
            "double_count, fastest_double_days, avg_double_days, daily_open_positions, "
            "cagr, max_daily_dd, reward_risk, max_consec_loss_amt, total_fees, "
            "max_balance, min_balance, max_win, max_loss, "
            "expectancy_ratio, longest_win_streak, "
            "longest_loss_streak, signal_close_count, "
            "backtest_time) "
            "VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,"
            "?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
            combo[1:],
        )
        new_id = cur.lastrowid

        # 搬 paired_trades（combo_id 从 old_id 映射到 new_id）
        conn.execute(
            "INSERT INTO paired_trades "
            "(combo_id, open_candle_idx, close_candle_idx, open_time, close_time, "
            "direction, entry_price, exit_price, close_type, mfe, mae) "
            "SELECT ?, open_candle_idx, close_candle_idx, open_time, close_time, "
            "direction, entry_price, exit_price, close_type, mfe, mae "
            "FROM tmp.paired_trades WHERE combo_id=?",
            (new_id, old_id),
        )
        merged += 1

    # regime_timeline：UNIQUE INDEX 天然去重
    conn.execute(
        "INSERT OR IGNORE INTO regime_timeline "
        "SELECT * FROM tmp.regime_timeline",
    )

    conn.commit()
    conn.execute("DETACH DATABASE tmp")
    conn.close()

    # 合并完删临时文件
    try:
        os.remove(temp_db_path)
        wal = temp_db_path + "-wal"
        shm = temp_db_path + "-shm"
        if os.path.exists(wal):
            os.remove(wal)
        if os.path.exists(shm):
            os.remove(shm)
    except OSError:
        pass

    return merged, skipped


def _recover_orphaned_temps(main_db_path: str, temp_dir: str) -> int:
    """恢复上次崩溃遗留的临时 DB — 合并后删除."""
    if not os.path.isdir(temp_dir):
        return 0
    recovered = 0
    for f in sorted(os.listdir(temp_dir)):
        if f.startswith("seed_tmp_") and f.endswith(".db"):
            temp_path = os.path.join(temp_dir, f)
            m, _ = merge_worker_db(main_db_path, temp_path)
            if m > 0:
                print(f"  ♻️  恢复临时文件 {f}: {m} 组合并")
                recovered += m
    return recovered


def _run_seed_parallel(_args: argparse.Namespace, coins: list[str],
                       intervals: list[str], strategies: list[str],
                       all_coins: list[str], all_intervals: list[str],
                       n_workers: int = 4) -> tuple[int, int, int]:
    """并行执行种子生成（分库写 → 合并）."""
    total = len(strategies) * len(coins) * len(intervals)
    n_regime = len(coins) * len(intervals)

    print("=" * 90)
    print(f"  种子报告生成器（{n_workers} 并行）")
    print(f"  检测到: {len(all_coins)} 币种 {len(all_intervals)} 周期"
          f" | 本次运行: {len(coins)} 币种 {len(intervals)} 周期")
    print(f"  币种: {', '.join(coins)}")
    print(f"  周期: {', '.join(intervals)}")
    print(f"  {len(strategies)} 策略 × {len(coins)} 币种"
          f" × {len(intervals)} 周期 = {total} 组回测")
    print(f"  + {n_regime} 组 regime 时间线")
    days_str = "全量数据" if DAYS == 0 else f"{DAYS}天"
    ttp_str = "开" if ENABLE_TTP else "关"
    print(f"  参数：{days_str} · ${INITIAL_CAPITAL}"
          f" · {LEVERAGE:.0f}x · 止损{STOP_LOSS_PCT * 100:.0f}%"
          f" · TTP{ttp_str} · 固定注码${FIXED_BET_AMOUNT}")
    print(f"  成本：手续费{FEE_RATE * 100:.3f}%/侧"
          f" · 滑点{SLIPPAGE_PCT * 100:.2f}%/侧"
          f" · 资金费{FUNDING_RATE_8H * 100:.2f}%/8h")
    print(f"  输出：{DB_PATH}")
    print(f"  内存上限：{_MEM_LIMIT_MB} MB | 1m 最多同时 1 个")
    print("=" * 90)
    print()

    # 初始化主库
    conn = init_db(DB_PATH)

    # 保存运行元数据
    save_metadata(conn, {
        "days": DAYS, "initial_capital": INITIAL_CAPITAL,
        "leverage": LEVERAGE, "stop_loss_pct": STOP_LOSS_PCT,
        "enable_ttp": ENABLE_TTP, "fixed_bet": FIXED_BET,
        "fixed_bet_amount": FIXED_BET_AMOUNT, "fee_rate": FEE_RATE,
        "slippage_pct": SLIPPAGE_PCT, "funding_rate_8h": FUNDING_RATE_8H,
        "coins": coins, "intervals": intervals, "strategies": strategies,
        "total_combos": total,
        "start_time": datetime.now(timezone.utc).isoformat(),
        "schema_version": "v2",
    })

    # 读取主库已完成的 combo（断点恢复用）
    completed_set = set()
    for row in conn.execute("SELECT strategy, coin, interval FROM combo_summary"):
        completed_set.add((row[0], row[1], row[2]))
    if completed_set:
        print(f"  📋 主库已有 {len(completed_set)} 组（断点恢复跳过）")

    conn.close()

    # 恢复上次崩溃遗留的临时 DB
    temp_dir = os.path.join(os.path.dirname(DB_PATH), "seed_tmp")
    os.makedirs(temp_dir, exist_ok=True)
    recovered = _recover_orphaned_temps(DB_PATH, temp_dir)
    if recovered > 0:
        # 恢复后重新读取已完成集合
        conn = sqlite3.connect(DB_PATH)
        completed_set = set()
        for row in conn.execute("SELECT strategy, coin, interval FROM combo_summary"):
            completed_set.add((row[0], row[1], row[2]))
        conn.close()

    # Worker 初始化配置
    worker_config = {
        "enable_ttp": ENABLE_TTP, "days": DAYS,
        "initial_capital": INITIAL_CAPITAL, "leverage": LEVERAGE,
        "stop_loss_pct": STOP_LOSS_PCT, "fixed_bet": FIXED_BET,
        "fixed_bet_amount": FIXED_BET_AMOUNT, "fee_rate": FEE_RATE,
        "slippage_pct": SLIPPAGE_PCT, "funding_rate_8h": FUNDING_RATE_8H,
        "min_klines": MIN_KLINES, "data_dir": DATA_DIR,
        "completed_set": completed_set,
        "ttp_highlow": TTP_HIGHLOW,
    }

    # 构建任务列表（小周期优先，跑完快释放内存）
    # 预过滤：跳过所有策略都已完成的 coin/interval，避免白白加载K线
    interval_order = ["1d", "12h", "8h", "4h", "2h", "1h", "30m", "15m", "5m", "1m"]
    task_list = []
    pre_skipped = 0
    for iv in interval_order:
        if iv in intervals:
            for coin in coins:
                # 检查该 coin/interval 下是否所有策略都已跑完
                all_done = all(
                    (s, coin, iv) in completed_set
                    for s in strategies
                )
                if all_done:
                    pre_skipped += len(strategies)
                else:
                    task_list.append((coin, iv))
    if pre_skipped:
        print(f"  ⏭️  预过滤跳过 {pre_skipped} 组（coin/interval 全部已完成）")

    n_tasks = len(task_list)
    start_all = time.time()
    total_completed = 0
    total_skipped = pre_skipped
    total_failed = 0
    done_count = 0

    with ProcessPoolExecutor(max_workers=n_workers,
                             initializer=_init_worker,
                             initargs=(worker_config,)) as executor:
        pending = list(task_list)
        active: dict[Any, Any] = {}  # future -> (coin, iv, temp_db, mem_mb)

        while pending or active:
            # 提交新任务（检查内存+1m限制）
            submitted = True
            while submitted and pending and len(active) < n_workers:
                submitted = False
                current_mem = sum(m for _, _, _, m in active.values())
                has_1m = any(i == "1m" for _, i, _, _ in active.values())

                for idx, (coin, iv) in enumerate(pending):
                    mem = _MEM_ESTIMATE.get(iv, 100)

                    # 内存超限
                    if current_mem + mem > _MEM_LIMIT_MB and active:
                        continue
                    # 不允许同时跑 2 个 1m
                    if iv == "1m" and has_1m:
                        continue

                    # 提交任务
                    pending.pop(idx)
                    temp_db = os.path.join(
                        temp_dir,
                        f"seed_tmp_{coin}_{iv}.db",
                    )
                    future = executor.submit(
                        _worker_coin_interval, coin, iv, strategies,
                        temp_db,
                    )
                    active[future] = (coin, iv, temp_db, mem)
                    submitted = True
                    print(f"  🚀 {coin}/{iv} (~{mem}MB) 开始")
                    break

            # 等待任意一个完成
            if not active:
                break

            done_futures = [f for f in active if f.done()]
            if not done_futures:
                time.sleep(0.5)
                continue

            for future in done_futures:
                coin, iv, temp_db, mem = active.pop(future)
                try:
                    result = future.result()
                except Exception as e:
                    print(f"  ❌ {coin}/{iv} 进程异常: {e}")
                    total_failed += len(strategies)
                    done_count += 1
                    continue

                if result.get("msg"):
                    print(f"  [!] {coin}/{iv}: {result['msg']}，跳过")
                else:
                    # 打印各策略结果
                    for sname, status, ret, n_paired in result["details"]:
                        symbol = "+" if ret > 0 else ""
                        if status == "OK":
                            print(f"  [{coin}/{iv}] {sname:<22s}"
                                  f" -> {symbol}{ret:.1f}% | {n_paired}笔")
                        else:
                            print(f"  [{coin}/{iv}] {sname:<22s} -> {status}")

                # 合并到主库
                if os.path.exists(temp_db):
                    m, _ = merge_worker_db(DB_PATH, temp_db)
                    result["merged"] = m

                comp = result["completed"]
                skip = result["skipped"]
                fail = result["failed"]
                total_completed += comp
                total_skipped += skip
                total_failed += fail
                done_count += 1

                elapsed = time.time() - start_all
                if done_count > 0:
                    avg = elapsed / done_count
                    eta = avg * (n_tasks - done_count)
                    active_str = ", ".join(f"{c}/{i}"
                                          for _, (c, i, _, _) in
                                          [(0, v) for v in active.values()])
                    el = result.get("elapsed", 0)
                    print(f"    → {coin}/{iv} 完成 ({comp}新 {skip}跳过)"
                          f" {el:.1f}s | 进度 {done_count}/{n_tasks}"
                          f" | ETA {eta / 60:.0f}min | 并行: [{active_str}]")
                    print()

    elapsed_all = time.time() - start_all

    # 保存结束元数据
    meta_conn = init_db(DB_PATH)
    save_metadata(meta_conn, {
        "end_time": datetime.now(timezone.utc).isoformat(),
        "elapsed_minutes": round(elapsed_all / 60, 1),
    })
    meta_conn.close()

    print("\n" + "=" * 90)
    print(f"  普通 完成 (耗时 {elapsed_all / 60:.1f} 分钟, {n_workers} 并行)")
    print(f"  新增: {total_completed} | 跳过(已有): {total_skipped}"
          f" | 失败: {total_failed}")
    print("=" * 90)

    return total_completed, total_skipped, total_failed


def _run_seed(
    args: argparse.Namespace, coins: list[str], intervals: list[str],
    strategies: list[str],
    all_coins: list[str], all_intervals: list[str],
    seed_modes: list[tuple[str, str]] | None = None,
) -> tuple[int, int, int]:
    """执行一轮种子生成."""
    total = len(strategies) * len(coins) * len(intervals)
    n_regime = len(coins) * len(intervals)

    print("=" * 90)
    print("  种子报告生成器")
    print(f"  检测到: {len(all_coins)} 币种 {len(all_intervals)} 周期"
          f" | 本次运行: {len(coins)} 币种 {len(intervals)} 周期")
    print(f"  币种: {', '.join(coins)}")
    print(f"  周期: {', '.join(intervals)}")
    print(f"  {len(strategies)} 策略 × {len(coins)} 币种"
          f" × {len(intervals)} 周期 = {total} 组回测")
    print(f"  + {n_regime} 组 regime 时间线")
    days_str = "全量数据" if DAYS == 0 else f"{DAYS}天"
    ttp_str = "开" if ENABLE_TTP else "关"
    print(f"  参数：{days_str} · ${INITIAL_CAPITAL}"
          f" · {LEVERAGE:.0f}x · 止损{STOP_LOSS_PCT * 100:.0f}%"
          f" · TTP{ttp_str} · 固定注码${FIXED_BET_AMOUNT}")
    print(f"  成本：手续费{FEE_RATE * 100:.3f}%/侧"
          f" · 滑点{SLIPPAGE_PCT * 100:.2f}%/侧"
          f" · 资金费{FUNDING_RATE_8H * 100:.2f}%/8h")
    if seed_modes:
        print(f"  模式：4种子")
        for _m, _sp in seed_modes:
            print(f"    {_m}: {_sp}")
    else:
        print(f"  输出：{DB_PATH}")
    print("=" * 90)
    print()

    conn = init_db(DB_PATH)

    # --strategy 指定策略时，先清除旧数据（重跑用）
    if args.strategy:
        dbs_to_clean = [(m, init_db(sp)) for m, sp in seed_modes] if seed_modes else [("main", conn)]
        for db_label, db_conn in dbs_to_clean:
            for s in strategies:
                combo_ids = [r[0] for r in db_conn.execute(
                    "SELECT id FROM combo_summary WHERE strategy=?", (s,)).fetchall()]
                if combo_ids:
                    placeholders = ",".join("?" * len(combo_ids))
                    db_conn.execute(
                        f"DELETE FROM paired_trades WHERE combo_id IN ({placeholders})",
                        combo_ids)
                    db_conn.execute("DELETE FROM combo_summary WHERE strategy=?", (s,))
                    db_conn.commit()
                    print(f"  🗑  清除 [{db_label}]: {s} ({len(combo_ids)} 组)")
        if seed_modes:
            for _, db_conn in dbs_to_clean:
                db_conn.close()

    # 保存运行元数据
    save_metadata(conn, {
        "days": DAYS,
        "initial_capital": INITIAL_CAPITAL,
        "leverage": LEVERAGE,
        "stop_loss_pct": STOP_LOSS_PCT,
        "enable_ttp": ENABLE_TTP,
        "fixed_bet": FIXED_BET,
        "fixed_bet_amount": FIXED_BET_AMOUNT,
        "fee_rate": FEE_RATE,
        "slippage_pct": SLIPPAGE_PCT,
        "funding_rate_8h": FUNDING_RATE_8H,
        "coins": coins,
        "intervals": intervals,
        "strategies": strategies,
        "total_combos": total,
        "start_time": datetime.now(timezone.utc).isoformat(),
        "schema_version": "v2",
    })
    # 读取已完成集合，用于预过滤
    completed_set = set()
    conn2 = sqlite3.connect(DB_PATH)
    for row in conn2.execute("SELECT strategy, coin, interval FROM combo_summary"):
        completed_set.add((row[0], row[1], row[2]))
    conn2.close()

    # 预过滤：跳过所有策略都已完成的 coin/interval
    # 周期优先排序（大周期先跑，1m最后）：快速出结果 + 早发现问题
    _iv_order = ["1d", "12h", "8h", "4h", "2h", "1h", "30m", "15m", "5m", "1m"]
    task_list = []
    pre_skipped = 0
    for iv in _iv_order:
        if iv not in intervals:
            continue
        for coin in coins:
            all_done = all(
                (s, coin, iv) in completed_set
                for s in strategies
            )
            if all_done:
                pre_skipped += len(strategies)
            else:
                task_list.append((coin, iv))
    if pre_skipped:
        print(f"  ⏭️  预过滤跳过 {pre_skipped} 组（coin/interval 全部已完成）")

    n_tasks = len(task_list)

    start_all = time.time()
    total_completed = 0
    total_skipped = pre_skipped
    total_failed = 0

    for i, (coin, iv) in enumerate(task_list):
        result = _worker_coin_interval(coin, iv, strategies, seed_modes=seed_modes)

        if result.get("msg"):
            print(f"  [!] {coin}/{iv}: {result['msg']}，跳过")
        else:
            for sname, status, ret, n_paired in result["details"]:
                symbol = "+" if ret > 0 else ""
                if status == "OK":
                    print(f"  [{coin}/{iv}] {sname:<22s}"
                          f" -> {symbol}{ret:.1f}% | {n_paired}笔")
                else:
                    print(f"  [{coin}/{iv}] {sname:<22s} -> {status}")

        total_completed += result["completed"]
        total_skipped += result["skipped"]
        total_failed += result["failed"]

        done = i + 1
        elapsed = time.time() - start_all
        if total_completed > 0:
            avg_per_group = elapsed / done
            eta = avg_per_group * (n_tasks - done)
            el = result.get("elapsed", 0)
            print(f"    → {coin}/{iv} 完成"
                  f" ({result['completed']}新 {result['skipped']}跳过)"
                  f" {el:.1f}s | ETA {eta / 60:.0f}min\n")

    elapsed_all = time.time() - start_all

    meta_conn = init_db(DB_PATH)
    save_metadata(meta_conn, {
        "end_time": datetime.now(timezone.utc).isoformat(),
        "elapsed_minutes": round(elapsed_all / 60, 1),
    })

    print("\n" + "=" * 90)
    print(f"  普通 完成 (耗时 {elapsed_all / 60:.1f} 分钟)")
    print(f"  新增: {total_completed} | 跳过(已有): {total_skipped}"
          f" | 失败: {total_failed}")
    print("=" * 90)

    meta_conn.close()
    return total_completed, total_skipped, total_failed


def main() -> None:
    global ENABLE_TTP, DB_PATH, MARGIN_MODE, TTP_HIGHLOW
    args = parse_args()

    # --ttp: 开启追踪止盈
    if args.ttp:
        ENABLE_TTP = True

    # --ttp-close: 改用 close 价触发（覆盖默认的 high/low）
    if args.ttp_close:
        TTP_HIGHLOW = False

    # --inverse: 币本位模式
    if args.inverse:
        MARGIN_MODE = "inverse"

    # --db: 自定义数据库路径（优先级最高）
    if args.db:
        DB_PATH = args.db
    elif args.ttp:
        DB_PATH = os.path.join(REPORT_DIR, "seed_v3_ttp.db")

    # 4种子模式
    seed_modes = None
    if getattr(args, 'seed4', False):
        seed_modes = [
            ("signal_only", os.path.join(REPORT_DIR, "seed_signal.db")),
            ("ttp_close", os.path.join(REPORT_DIR, "seed_ttp_close.db")),
            ("ttp_highlow", os.path.join(REPORT_DIR, "seed_ttp_hl.db")),
            ("dual_hold", os.path.join(REPORT_DIR, "seed_dual.db")),
        ]
        DB_PATH = seed_modes[0][1]  # 管理DB = 第一个种子
        if args.workers > 1:
            print("  ⚠️  4种子模式暂不支持并行，切换为单线程")
            args.workers = 1

    # 自动检测
    all_coins, all_intervals = detect_coins_and_intervals()
    if not all_coins:
        print("错误：未检测到任何数据")
        return

    coins = args.coins or all_coins
    intervals = args.intervals or all_intervals
    coins = [c for c in coins if c in all_coins]
    intervals = [iv for iv in intervals if iv in all_intervals]

    if not coins or not intervals:
        print("错误：过滤后无可用的币种或周期")
        return

    strategies = get_strategies()
    if args.strategy:
        strategies = [s for s in args.strategy if s in strategies]
        if not strategies:
            print("错误：过滤后无可用策略")
            return

    # 选择执行函数（单线程 vs 并行）
    if args.workers > 1:
        def _run_fn(a: argparse.Namespace, c: list[str], i: list[str],
                    s: list[str], ac: list[str], ai: list[str]) -> tuple[int, int, int]:
            return _run_seed_parallel(
                a, c, i, s, ac, ai,
                n_workers=args.workers)
    else:
        def _run_fn(a: argparse.Namespace, c: list[str], i: list[str],
                    s: list[str], ac: list[str], ai: list[str]) -> tuple[int, int, int]:
            return _run_seed(a, c, i, s, ac, ai, seed_modes=seed_modes)

    _run_fn(args, coins, intervals, strategies, all_coins, all_intervals)

    # 数据写完后建索引 + 最终统计
    if seed_modes:
        for mode, spath in seed_modes:
            if not os.path.exists(spath):
                continue
            print(f"\n  建索引: {mode}...")
            _ic = sqlite3.connect(spath)
            create_indexes(_ic)
            n_c = _ic.execute("SELECT COUNT(*) FROM combo_summary").fetchone()[0]
            n_p = _ic.execute("SELECT COUNT(*) FROM paired_trades").fetchone()[0]
            n_r = _ic.execute("SELECT COUNT(*) FROM regime_timeline").fetchone()[0]
            _ic.close()
            sz = os.path.getsize(spath) / 1024 / 1024
            print(f"    {mode}: {n_c} combos, {n_p} trades, {n_r} regime ({sz:.1f} MB)")

        # 平仓类型分布（用第一个种子DB）
        _fc = sqlite3.connect(seed_modes[0][1])
        print("\n  平仓类型分布 (signal_only):")
        for row in _fc.execute(
                "SELECT close_type, COUNT(*) FROM paired_trades "
                "GROUP BY close_type ORDER BY close_type"):
            print(f"    {row[0]:<15s} {row[1]} 笔")
        _fc.close()
    else:
        print("  建索引...")
        _idx_conn = sqlite3.connect(DB_PATH)
        create_indexes(_idx_conn)
        _idx_conn.close()

        conn = sqlite3.connect(DB_PATH)
        n_combos = conn.execute("SELECT COUNT(*) FROM combo_summary").fetchone()[0]
        n_paired = conn.execute("SELECT COUNT(*) FROM paired_trades").fetchone()[0]
        n_regime = conn.execute("SELECT COUNT(*) FROM regime_timeline").fetchone()[0]
        print(f"\n  combo_summary:  {n_combos} 行")
        print(f"  paired_trades:  {n_paired} 行")
        print(f"  regime_timeline: {n_regime} 行")

        print("\n  Regime 分布总览:")
        for row in conn.execute(
                "SELECT regime, COUNT(*) FROM regime_timeline "
                "GROUP BY regime ORDER BY regime"):
            print(f"    {row[0]:<10s} {row[1]} 条")

        print("\n  平仓类型分布:")
        for row in conn.execute(
                "SELECT close_type, COUNT(*) FROM paired_trades "
                "GROUP BY close_type ORDER BY close_type"):
            print(f"    {row[0]:<15s} {row[1]} 笔")

        conn.close()
        db_size = os.path.getsize(DB_PATH)
        print(f"\n  数据库: {DB_PATH} ({db_size / 1024 / 1024:.1f} MB)")

    print("\n  ✅ generate_seed 完成，正常退出。")
    return


if __name__ == "__main__":
    main()
