SKIP_STRATEGIES = {"_base"}
VALID_INTERVALS = {
    "1m", "5m", "15m", "30m", "1h",
    "2h", "4h", "8h", "12h", "1d",
}


def detect_coins_and_intervals() -> tuple[list[str], list[str]]:
    """自动扫描 data/historical/ 目录，检测可用的币种和周期."""
    # 搜索多个可能的 historical 目录
    hist_candidates = [
        os.path.join(DATA_DIR, "historical"),
        os.path.join(PROJECT_ROOT, "data", "historical"),
    ]
    hist_dir = ""
    for hd in hist_candidates:
        if os.path.isdir(hd):
            hist_dir = hd
            break
    coins: list[str] = []
    interval_set: set[str] = set()
    if not hist_dir:
        return coins, sorted(interval_set)
    for name in sorted(os.listdir(hist_dir)):
        coin_dir = os.path.join(hist_dir, name)
        if not os.path.isdir(coin_dir) or name.startswith("."):
            continue
        # 检查目录下是否有有效的周期数据文件
        has_data = False
        for f in os.listdir(coin_dir):
            if f.endswith(".json"):
                iv = f.replace(".json", "")
                if iv in VALID_INTERVALS:
                    interval_set.add(iv)
                    has_data = True
        if has_data:
            coins.append(name)
    # 补充：从 DuckDB 检测币种（mirror 币种只在 DuckDB 里）
    for search_dir in [DATA_DIR, os.path.join(PROJECT_ROOT, "data")]:
        for db_name in ("klines.duckdb",):
            db_path = os.path.join(search_dir, db_name)
            if os.path.exists(db_path):
                try:
                    import duckdb
                    con = duckdb.connect(db_path, read_only=True)
                    db_coins = [r[0] for r in con.execute(
                        "SELECT DISTINCT coin FROM klines ORDER BY coin"
                    ).fetchall()]
                    db_ivs = [r[0] for r in con.execute(
                        "SELECT DISTINCT interval FROM klines ORDER BY interval"
                    ).fetchall()]
                    con.close()
                    for c in db_coins:
                        if c not in coins:
                            coins.append(c)
                    for iv in db_ivs:
                        if iv in VALID_INTERVALS:
                            interval_set.add(iv)
                except Exception:
                    pass
    coins.sort()
    # 按周期从小到大排序
    order = ["1m", "5m", "15m", "30m", "1h", "2h", "4h", "8h", "12h", "1d"]
    intervals = [iv for iv in order if iv in interval_set]
    return coins, intervals


def parse_args() -> argparse.Namespace:
    """解析命令行参数."""
    parser = argparse.ArgumentParser(description="种子报告生成器")
    parser.add_argument(
        "--coins", nargs="+",
        help="指定币种（默认自动检测全部）")
    parser.add_argument(
        "--intervals", nargs="+",
        help="指定周期（默认自动检测全部）")
    parser.add_argument(
        "--strategy", nargs="+",
        help="指定策略（默认全部）")
    parser.add_argument(
        "--workers", type=int, default=1,
        help="并行 worker 数（默认1=单线程，推荐4）")
    parser.add_argument(
        "--ttp", action="store_true",
        help="TTP模式：开启追踪止盈"
             "（默认关闭），输出到 seed_v3_ttp.db")
    parser.add_argument(
        "--db", type=str, default=None,
        help="指定输出数据库路径（覆盖默认路径）")
    parser.add_argument(
        "--inverse", action="store_true",
        help="币本位模式：使用反向合约PnL公式"
             "（分母entry×exit）")
    parser.add_argument('--ttp-close', action='store_true', dest='ttp_close',
                        help='TTP Close模式：--ttp 时改用 close 价触发（默认 high/low），输出到 seed_v3_ttp.db')
    parser.add_argument('--seed4', action='store_true',
