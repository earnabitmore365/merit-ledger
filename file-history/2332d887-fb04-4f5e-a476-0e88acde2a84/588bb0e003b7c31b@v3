#!/usr/bin/env python3
"""验证 generate_seed_lab.py 融合后的分段回测正确性。

对比 _run_strategy_segmented 输出 vs test_seeds/ 基准种子 DB。
BTC 1m × 3 策略 × 4 模式 = 12 组合，全部零差异 = 通过。

用法：
    cd /Volumes/SSD-2TB/project/wuji-auto-trading
    python3 lab/seed_fix/test_fused.py
"""

from __future__ import annotations

import os
import sys
import time
import sqlite3

# ==================== 路径设置 ====================
# 1. 让子进程能 import generate_seed_lab
_lab_dir = os.path.dirname(os.path.abspath(__file__))
os.environ['PYTHONPATH'] = _lab_dir + ':' + os.environ.get('PYTHONPATH', '')

# 2. 项目路径
_p = _lab_dir
while _p != os.path.dirname(_p) and not os.path.exists(os.path.join(_p, '.wuji-root')):
    _p = os.path.dirname(_p)
if _p not in sys.path:
    sys.path.insert(0, _p)
sys.path.insert(0, os.path.join(_p, 'src'))
# lab 目录也要加（import generate_seed_lab）
if _lab_dir not in sys.path:
    sys.path.insert(0, _lab_dir)

# ==================== Import ====================
from generate_seed_lab import (  # noqa: E402
    _run_strategy_segmented, load_candles, SimTrade,
    LEVERAGE, STOP_LOSS_PCT,
)

# ==================== 配置 ====================
MODES = ['signal_only', 'ttp_close', 'ttp_highlow', 'dual_hold']
TEST_SEEDS_DIR = os.path.join(_lab_dir, 'test_seeds')

DB_MAP = {
    'signal_only': os.path.join(TEST_SEEDS_DIR, 'seed_signal.db'),
    'ttp_close': os.path.join(TEST_SEEDS_DIR, 'seed_ttp_close.db'),
    'ttp_highlow': os.path.join(TEST_SEEDS_DIR, 'seed_ttp_hl.db'),
    'dual_hold': os.path.join(TEST_SEEDS_DIR, 'seed_dual.db'),
}

def get_all_strategies() -> list[str]:
    """从 seed_signal.db 读取所有有基准的策略名。"""
    db_path = DB_MAP['signal_only']
    c = sqlite3.connect(f'file:{db_path}?mode=ro', uri=True)
    rows = c.execute(
        'SELECT strategy FROM combo_summary WHERE coin="BTC" AND interval="1m" '
        'ORDER BY strategy').fetchall()
    c.close()
    return [r[0] for r in rows]


def load_baseline(strategy: str, mode: str, coin: str, interval: str) -> list[tuple]:
    """从种子 DB 读取基准 paired_trades。"""
    db_path = DB_MAP[mode]
    if not os.path.exists(db_path):
        return []
    c = sqlite3.connect(f'file:{db_path}?mode=ro', uri=True)
    cid = c.execute(
        'SELECT id FROM combo_summary WHERE strategy=? AND coin=? AND interval=?',
        (strategy, coin, interval)).fetchone()
    if not cid:
        c.close()
        return []
    rows = c.execute(
        'SELECT open_candle_idx, close_candle_idx, direction, '
        'entry_price, exit_price, close_type '
        'FROM paired_trades WHERE combo_id=? '
        'ORDER BY open_candle_idx, close_candle_idx',
        (cid[0],)).fetchall()
    c.close()
    return rows


def compare(baseline: list[tuple], seg_trades: list, strategy: str, mode: str) -> bool:
    """对比基准 vs 分段输出，返回是否一致。"""
    seg_list = [(t.open_candle_idx, t.close_candle_idx, t.direction,
                 t.entry_price, t.exit_price, t.close_type) for t in seg_trades]

    if len(baseline) != len(seg_list):
        print(f"    !! [{strategy}][{mode}] 笔数不符: "
              f"基准={len(baseline)}, 分段={len(seg_list)}")
        # 打印前 3 笔帮助调试
        for label, lst in [("基准", baseline[:3]), ("分段", seg_list[:3])]:
            for t in lst:
                print(f"       {label}: open={t[0]} close={t[1]} "
                      f"dir={t[2]} entry={t[3]:.6f} type={t[5]}")
        return False

    mismatch = []
    for j in range(len(baseline)):
        b = baseline[j]
        s = seg_list[j]
        if (b[0] != s[0] or b[2] != s[2]
                or abs(b[3] - s[3]) > 1e-8
                or abs(b[4] - s[4]) > 1e-8
                or b[5] != s[5]):
            mismatch.append((j, b, s))

    if mismatch:
        print(f"    !! [{strategy}][{mode}] {len(mismatch)} 笔不符"
              f"（共 {len(baseline)} 笔）")
        for j, b, s in mismatch[:5]:
            print(f"       第{j}笔: "
                  f"open={b[0]}vs{s[0]} "
                  f"dir={b[2]}vs{s[2]} "
                  f"entry={b[3]:.6f}vs{s[3]:.6f} "
                  f"exit={b[4]:.6f}vs{s[4]:.6f} "
                  f"type={b[5]}vs{s[5]}")
        return False

    print(f"    OK [{strategy}][{mode}] 共 {len(baseline)} 笔，全部一致")
    return True


# ==================== 主程序 ====================
if __name__ == "__main__":
    coin, interval = 'BTC', '1m'

    print(f"加载 {coin} {interval} K线...")
    candles = load_candles(coin, interval)
    print(f"K线: {len(candles):,} 根")

    total_pass = 0
    total_fail = 0
    total_skip = 0
    total_fallback = 0

    strategies = get_all_strategies()
    print(f"策略数: {len(strategies)}")

    for idx, strat in enumerate(strategies):
        print(f"\n[{idx+1}/{len(strategies)}] {strat}")

        t0 = time.time()
        mode_trades = _run_strategy_segmented(
            coin, interval, candles, strat,
            MODES, LEVERAGE, STOP_LOSS_PCT,
        )
        elapsed = time.time() - t0
        print(f"  分段耗时: {elapsed:.1f}s")

        all_ok = True
        strat_modes_checked = 0
        for mode in MODES:
            baseline = load_baseline(strat, mode, coin, interval)
            if not baseline:
                total_skip += 1
                continue
            strat_modes_checked += 1
            ok = compare(baseline, mode_trades[mode], strat, mode)
            if ok:
                total_pass += 1
            else:
                total_fail += 1
                all_ok = False

        status = "PASS" if all_ok else "FAIL"
        print(f"  [{status}] {strat} ({strat_modes_checked} modes checked, {elapsed:.1f}s)")

        # 每 10 个策略打印汇总
        if (idx + 1) % 10 == 0:
            print(f"\n  --- 进度: {idx+1}/{len(strategies)} | "
                  f"通过={total_pass} 失败={total_fail} 跳过={total_skip} ---")

    print(f"\n{'='*60}")
    print(f"  策略数: {len(strategies)}")
    print(f"  通过: {total_pass} | 失败: {total_fail} | 跳过(无基准): {total_skip}")
    if total_fail == 0:
        print("  结论: 融合后分段回测与种子DB基准 100% 吻合")
    else:
        print("  结论: 存在差异，需排查")
    print('=' * 60)
