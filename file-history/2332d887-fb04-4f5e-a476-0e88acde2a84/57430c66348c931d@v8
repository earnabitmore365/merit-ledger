#!/usr/bin/env python3
"""种子报告生成器 v2 — 4 SQLite → 1 DuckDB（paired_trades 26列 + combo_summary 38列）。

按顾问 Handoff 完整实现：
  Step 1: 导入 4 SQLite（combo_summary + paired_trades + regime_timeline）
  Step 2a: paired_trades 逐笔后算 15 字段 → 26 列
  Step 2b: combo_summary 汇总后算 28 字段 → 38 列
  Step 3: 索引 + 验证

参考文档：文档/种子/seed_report_field_reference.md

用法：
  cd wuji-auto-trading
  python3 backtest/build_seed_report.py
  python3 backtest/build_seed_report.py --report-dir /path/to/reports

输出：
  reports/seed_report.duckdb

代码段落索引（行号随改动更新）：
  配置+常量              行 38    SEED_TYPES/参数/bars_per_funding
  import_sqlite_to_duckdb 行 70   Step 1 导入（含 regime_timeline）
  add_paired_trade_cols   行 160  Step 2a 逐笔后算 15 字段
  compute_combo_metrics   行 280  Step 2b 汇总后算 28 字段（单 combo）
  run_combo_post_calc     行 480  Step 2b 调度（逐 combo 循环）
  create_indexes          行 530  Step 3 索引
  print_summary           行 540  统计+验证
  build_report            行 590  主入口
  argparse                行 620  CLI 参数化
"""

from __future__ import annotations

import math
import os
import sys
import time
from datetime import datetime

_p = os.path.dirname(os.path.abspath(__file__))
while _p != os.path.dirname(_p) and not os.path.exists(os.path.join(_p, '.wuji-root')):
    _p = os.path.dirname(_p)
if _p not in sys.path:
    sys.path.insert(0, _p)
from path_config import ROOT, REPORT_DIR

# ==================== 配置 ====================

SEED_TYPES = [
    ("signal_only", os.path.join(REPORT_DIR, "seed_signal.db")),
    ("ttp_close", os.path.join(REPORT_DIR, "seed_ttp_close.db")),
    ("ttp_highlow", os.path.join(REPORT_DIR, "seed_ttp_hl.db")),
    ("dual_hold", os.path.join(REPORT_DIR, "seed_dual.db")),
]

REPORT_DB = os.path.join(REPORT_DIR, "seed_report.duckdb")

INITIAL_CAPITAL = 500.0
LEVERAGE = 10.0
FEE_RATE = 0.00035
SLIPPAGE_PCT = 0.0002
FUNDING_RATE_8H = 0.0001
FIXED_BET_AMOUNT = 1.0

_BARS_PER_FUNDING = {
    "1m": 480, "5m": 96, "15m": 32, "30m": 16,
    "1h": 8, "2h": 4, "4h": 2, "8h": 1, "12h": 1, "1d": 1,
}
_BAR_MINUTES = {
    "1m": 1, "5m": 5, "15m": 15, "30m": 30,
    "1h": 60, "2h": 120, "4h": 240, "8h": 480, "12h": 720, "1d": 1440,
}
_BARS_PER_DAY = {
    "1m": 1440, "5m": 288, "15m": 96, "30m": 48,
    "1h": 24, "2h": 12, "4h": 6, "8h": 3, "12h": 2, "1d": 1,
}

INTERVALS = list(_BARS_PER_FUNDING.keys())

FEE_DOUBLE = FEE_RATE * 2
SLIP_DOUBLE = SLIPPAGE_PCT * 2


# ==================== Step 1: 导入 ====================

def import_sqlite_to_duckdb(con) -> tuple[int, int]:
    """ATTACH 4 个 SQLite → DuckDB。导入 combo_summary + paired_trades + regime_timeline。"""

    con.execute("""
        CREATE TABLE combo_summary (
            seed_type VARCHAR, id INTEGER, strategy VARCHAR, coin VARCHAR, interval VARCHAR,
            total_return DOUBLE, final_balance DOUBLE, max_drawdown DOUBLE,
            sharpe_ratio DOUBLE, sortino_ratio DOUBLE, calmar_ratio DOUBLE,
            total_trades INTEGER, winning_trades INTEGER, losing_trades INTEGER, win_rate DOUBLE,
            avg_win_pct DOUBLE, avg_loss_pct DOUBLE, profit_factor DOUBLE, ttp_count INTEGER,
            double_count INTEGER, fastest_double_days DOUBLE, avg_double_days DOUBLE,
            daily_open_positions DOUBLE, cagr DOUBLE, max_daily_dd DOUBLE,
            reward_risk DOUBLE, max_consec_loss_amt DOUBLE, total_fees DOUBLE,
            max_balance DOUBLE, min_balance DOUBLE, max_win DOUBLE, max_loss DOUBLE,
            expectancy_ratio DOUBLE, longest_win_streak INTEGER, longest_loss_streak INTEGER,
            signal_close_count INTEGER, backtest_time VARCHAR,
            -- 新增后算列（Step 2b 填充）
            drawdown_duration_bars INTEGER, recovery_factor DOUBLE, ulcer_index DOUBLE,
            avg_win_pnl DOUBLE, avg_loss_pnl DOUBLE, best_trade_pnl DOUBLE, worst_trade_pnl DOUBLE,
            max_consecutive_wins INTEGER, max_consecutive_losses INTEGER,
            avg_holding_bars DOUBLE, skewness DOUBLE, kurtosis DOUBLE, tail_ratio DOUBLE
        )
    """)

    con.execute("""
        CREATE TABLE paired_trades (
            seed_type VARCHAR, combo_id INTEGER,
            strategy VARCHAR, coin VARCHAR, interval VARCHAR,
            open_candle_idx INTEGER, close_candle_idx INTEGER,
            open_time VARCHAR, close_time VARCHAR,
            direction VARCHAR, entry_price DOUBLE, exit_price DOUBLE,
            close_type VARCHAR, mfe DOUBLE, mae DOUBLE
        )
    """)

    con.execute("""
        CREATE TABLE regime_timeline (
            seed_type VARCHAR, coin VARCHAR, interval VARCHAR,
            candle_idx INTEGER, candle_time_ms BIGINT,
            regime VARCHAR, adx DOUBLE, sma_direction VARCHAR
        )
    """)

    total_combos = 0
    total_trades = 0

    for seed_type, db_path in SEED_TYPES:
        if not os.path.exists(db_path):
            print(f"  [跳过] {seed_type}: 不存在")
            continue

        t0 = time.time()
        print(f"  导入 {seed_type}...", flush=True)
        con.execute(f"ATTACH '{db_path}' AS src (TYPE sqlite)")

        n_combos = con.execute("SELECT COUNT(*) FROM src.combo_summary").fetchone()[0]
        con.execute(f"""
            INSERT INTO combo_summary (
                seed_type, id, strategy, coin, interval,
                total_return, final_balance, max_drawdown,
                sharpe_ratio, sortino_ratio, calmar_ratio,
                total_trades, winning_trades, losing_trades, win_rate,
                avg_win_pct, avg_loss_pct, profit_factor, ttp_count,
                double_count, fastest_double_days, avg_double_days,
                daily_open_positions, cagr, max_daily_dd,
                reward_risk, max_consec_loss_amt, total_fees,
                max_balance, min_balance, max_win, max_loss,
                expectancy_ratio, longest_win_streak, longest_loss_streak,
                signal_close_count, backtest_time)
            SELECT '{seed_type}',
                   id, strategy, coin, interval,
                   total_return, final_balance, max_drawdown,
                   sharpe_ratio, sortino_ratio, calmar_ratio,
                   total_trades, winning_trades, losing_trades, win_rate,
                   avg_win_pct, avg_loss_pct, profit_factor, ttp_count,
                   double_count, fastest_double_days, avg_double_days,
                   daily_open_positions, cagr, max_daily_dd,
                   reward_risk, max_consec_loss_amt, total_fees,
                   max_balance, min_balance, max_win, max_loss,
                   expectancy_ratio, longest_win_streak, longest_loss_streak,
                   signal_close_count, backtest_time
            FROM src.combo_summary
        """)

        n_trades = con.execute("SELECT COUNT(*) FROM src.paired_trades").fetchone()[0]
        con.execute(f"""
            INSERT INTO paired_trades
            SELECT '{seed_type}', pt.combo_id,
                   cs.strategy, cs.coin, cs.interval,
                   pt.open_candle_idx, pt.close_candle_idx,
                   pt.open_time, pt.close_time,
                   pt.direction, pt.entry_price, pt.exit_price,
                   pt.close_type, pt.mfe, pt.mae
            FROM src.paired_trades pt
            JOIN src.combo_summary cs ON cs.id = pt.combo_id
        """)

        # regime_timeline（如果存在）
        src_tables = [r[0] for r in con.execute("SHOW TABLES FROM src").fetchall()]
        if 'regime_timeline' in src_tables:
            con.execute(f"""
                INSERT INTO regime_timeline
                SELECT '{seed_type}', coin, interval, candle_idx, candle_time_ms,
                       regime, adx, sma_direction
                FROM src.regime_timeline
            """)

        con.execute("DETACH src")
        elapsed = time.time() - t0
        print(f"    {seed_type}: {n_combos:,} combos, {n_trades:,} trades ({elapsed:.1f}s)")
        total_combos += n_combos
        total_trades += n_trades

    return total_combos, total_trades


# ==================== Step 2a: paired_trades 逐笔后算 ====================

def add_paired_trade_cols(con) -> None:
    """给 paired_trades 加 15 列逐笔后算字段。"""

    # 加列
    new_cols = [
        ("holding_bars", "INTEGER"), ("holding_hours", "DOUBLE"),
        ("capital", "DOUBLE"), ("position_size", "DOUBLE"),
        ("raw_pnl_pct", "DOUBLE"), ("fee", "DOUBLE"), ("slippage_cost", "DOUBLE"),
        ("funding_count", "INTEGER"), ("funding_cost", "DOUBLE"),
        ("pnl", "DOUBLE"), ("pnl_amount", "DOUBLE"), ("r_value", "DOUBLE"),
        ("risk_reward_ratio", "DOUBLE"),  # balance_after 由 CTAS 窗口函数加
        ("regime_at_open", "VARCHAR"),
    ]
    for col, dtype in new_cols:
        con.execute(f"ALTER TABLE paired_trades ADD COLUMN {col} {dtype}")

    # ── 第一次 UPDATE：不依赖其他新列的字段 ──
    for iv in INTERVALS:
        bpf = _BARS_PER_FUNDING[iv]
        bar_min = _BAR_MINUTES[iv]
        print(f"    逐笔后算 {iv} (bpf={bpf})...", flush=True)
        t0 = time.time()

        con.execute(f"""
            UPDATE paired_trades SET
                holding_bars = close_candle_idx - open_candle_idx,
                holding_hours = (close_candle_idx - open_candle_idx) * {bar_min} / 60.0,
                capital = {FIXED_BET_AMOUNT},
                position_size = {FIXED_BET_AMOUNT * LEVERAGE},
                raw_pnl_pct = CASE WHEN direction = 'long'
                    THEN (exit_price - entry_price) / NULLIF(entry_price, 0) * {LEVERAGE}
                    ELSE (entry_price - exit_price) / NULLIF(entry_price, 0) * {LEVERAGE} END,
                fee = {FEE_DOUBLE},
                slippage_cost = {SLIP_DOUBLE},
                funding_count = (close_candle_idx - open_candle_idx) / {bpf},
                funding_cost = {FUNDING_RATE_8H} * ((close_candle_idx - open_candle_idx) / {bpf}),
                risk_reward_ratio = CASE WHEN mae > 0 THEN mfe / mae ELSE NULL END
            WHERE interval = '{iv}'
        """)
        print(f"      第一次 UPDATE: {time.time()-t0:.1f}s")

    # ── 第二次 UPDATE：依赖第一次算好的 raw_pnl_pct/fee/slippage/funding ──
    t0 = time.time()
    con.execute(f"""
        UPDATE paired_trades SET
            pnl = raw_pnl_pct - fee - slippage_cost - funding_cost,
            pnl_amount = (raw_pnl_pct - fee - slippage_cost - funding_cost) * capital,
            r_value = raw_pnl_pct - fee - slippage_cost - funding_cost
    """)
    print(f"    第二次 UPDATE (pnl): {time.time()-t0:.1f}s")

    # ── balance_after：CTAS + 窗口函数（DuckDB UPDATE 不支持窗口函数，用 CTAS 重建） ──
    print("    计算 balance_after（CTAS + 窗口函数）...", flush=True)
    t0 = time.time()
    con.execute(f"""
        CREATE TABLE paired_trades_with_bal AS
        SELECT *,
            {INITIAL_CAPITAL} + SUM(pnl_amount) OVER (
                PARTITION BY seed_type, combo_id
                ORDER BY open_candle_idx, close_candle_idx
                ROWS UNBOUNDED PRECEDING
            ) AS balance_after
        FROM paired_trades
    """)
    con.execute("DROP TABLE paired_trades")
    con.execute("ALTER TABLE paired_trades_with_bal RENAME TO paired_trades")
    print(f"    balance_after 完成: {time.time()-t0:.1f}s")

    # ── regime_at_open：CTAS + ASOF JOIN（不用子查询 UPDATE，16亿行会极慢） ──
    print("    计算 regime_at_open（CTAS + ASOF JOIN）...", flush=True)
    t0 = time.time()
    con.execute("""
        CREATE TABLE paired_trades_with_regime AS
        SELECT pt.*,
               rt.regime AS regime_at_open
        FROM paired_trades pt
        ASOF JOIN regime_timeline rt
          ON pt.seed_type = rt.seed_type
         AND pt.coin = rt.coin
         AND pt.interval = rt.interval
         AND pt.open_candle_idx >= rt.candle_idx
    """)
    con.execute("DROP TABLE paired_trades")
    con.execute("ALTER TABLE paired_trades_with_regime RENAME TO paired_trades")
    print(f"    regime_at_open 完成: {time.time()-t0:.1f}s")


# ==================== Step 2b: combo_summary 汇总后算 ====================

def compute_combo_metrics(trades: list[tuple]) -> dict:
    """从 paired_trades 26 列计算 combo_summary 的 28 个汇总字段。

    trades: [(pnl, pnl_amount, holding_bars, open_time, close_time, mfe, mae), ...]
    已排序。
    """
    n = len(trades)
    if n == 0:
        return _empty_combo_metrics()

    pnls = [t[0] or 0.0 for t in trades]
    pnl_amounts = [t[1] or 0.0 for t in trades]
    holdings = [t[2] or 0 for t in trades]

    # ── 余额曲线 ──
    balance = [INITIAL_CAPITAL]
    for pa in pnl_amounts:
        balance.append(balance[-1] + pa)

    final_bal = balance[-1]
    max_bal = max(balance)
    min_bal = min(balance)
    total_return = (final_bal - INITIAL_CAPITAL) / INITIAL_CAPITAL * 100

    # ── 最大回撤 + 回撤持续时间 ──
    peak = INITIAL_CAPITAL
    max_dd = 0.0
    dd_start = 0
    max_dd_duration = 0
    cur_dd_start = 0
    in_dd = False

    for i, b in enumerate(balance):
        if b > peak:
            if in_dd:
                max_dd_duration = max(max_dd_duration, i - cur_dd_start)
                in_dd = False
            peak = b
        if peak > 0:
            dd = (peak - b) / peak * 100
            if dd > max_dd:
                max_dd = dd
            if dd > 0 and not in_dd:
                cur_dd_start = i
                in_dd = True
    if in_dd:
        max_dd_duration = max(max_dd_duration, len(balance) - cur_dd_start)

    # ── Sharpe / Sortino ──
    returns = []
    for i in range(1, len(balance)):
        if balance[i - 1] > 0:
            returns.append((balance[i] - balance[i - 1]) / balance[i - 1])

    sharpe = sortino = 0.0
    mean_ret = 0.0
    if len(returns) > 1:
        mean_ret = sum(returns) / len(returns)
        variance = sum((r - mean_ret) ** 2 for r in returns) / (len(returns) - 1)
        std = math.sqrt(variance) if variance > 0 else 0
        if std > 0:
            rf = 0.02 / 252
            sharpe = (mean_ret - rf) / std * math.sqrt(252)
            neg = [r for r in returns if r < 0]
            if len(neg) > 1:
                neg_var = sum((r - mean_ret) ** 2 for r in neg) / (len(neg) - 1)
                neg_std = math.sqrt(neg_var) if neg_var > 0 else 0
                if neg_std > 0:
                    sortino = (mean_ret - rf) / neg_std * math.sqrt(252)

    # ── Calmar / Recovery factor ──
    calmar = total_return / max_dd if max_dd > 0 else 0.0
    net_profit = final_bal - INITIAL_CAPITAL
    recovery_factor = net_profit / (max_dd / 100 * INITIAL_CAPITAL) if max_dd > 0 else 0.0

    # ── Ulcer Index ──
    dd_squares = []
    peak2 = INITIAL_CAPITAL
    for b in balance:
        if b > peak2:
            peak2 = b
        dd_pct = ((peak2 - b) / peak2 * 100) if peak2 > 0 else 0
        dd_squares.append(dd_pct ** 2)
    ulcer = math.sqrt(sum(dd_squares) / len(dd_squares)) if dd_squares else 0.0

    # ── CAGR ──
    trading_days = 1
    try:
        t0_ms = int(trades[0][3])
        tN_ms = int(trades[-1][4])
        trading_days = max(1, (tN_ms - t0_ms) / (1000 * 86400))
    except (ValueError, TypeError):
        trading_days = max(1, n)
    cagr = (final_bal / INITIAL_CAPITAL) ** (365.0 / trading_days) - 1 if final_bal > 0 else 0.0

    # ── 翻倍 ──
    double_times = []
    next_target = INITIAL_CAPITAL * 2
    prev_ms = None
    try:
        prev_ms = int(trades[0][3])
    except (ValueError, TypeError):
        pass
    for i in range(n):
        if balance[i + 1] >= next_target and prev_ms is not None:
            try:
                hit_ms = int(trades[i][4])
                days = max(0, (hit_ms - prev_ms) / (1000 * 86400))
                double_times.append(days)
                prev_ms = hit_ms
                next_target *= 2
            except (ValueError, TypeError):
                pass
    double_count = len(double_times)
    fastest_double = min(double_times) if double_times else 0
    avg_double = round(sum(double_times) / double_count, 1) if double_count > 0 else 0

    # ── 盈亏分析 ──
    wins = [p for p in pnls if p > 0]
    losses = [p for p in pnls if p < 0]
    win_count = len(wins)
    loss_count = len(losses)
    win_rate = win_count / n * 100 if n > 0 else 0
    avg_win = sum(wins) / win_count if wins else 0
    avg_loss = sum(losses) / loss_count if losses else 0
    profit_factor = sum(wins) / abs(sum(losses)) if losses else 0
    best_pnl = max(pnls) if pnls else 0
    worst_pnl = min(pnls) if pnls else 0
    wr_frac = win_count / n if n > 0 else 0
    expectancy = (wr_frac * avg_win) - ((1 - wr_frac) * abs(avg_loss))

    total_fees = sum(
        ((t[5] or 0) + (t[6] or 0)) for t in trades  # fee_val + slip_val approximation
    )
    # 实际费用从 pnl 字段推算更准确
    total_fees = n * (FEE_DOUBLE + SLIP_DOUBLE + FUNDING_RATE_8H * sum(
        (h // _BARS_PER_FUNDING.get('1m', 480)) for h in holdings
    ) / max(n, 1)) * FIXED_BET_AMOUNT

    # ── 连续胜败 ──
    max_cw = max_cl = cw = cl = 0
    for p in pnls:
        if p > 0:
            cw += 1; cl = 0; max_cw = max(max_cw, cw)
        else:
            cl += 1; cw = 0; max_cl = max(max_cl, cl)

    # ── 日均开仓 ──
    daily_open = n / trading_days

    # ── 平均持仓 ──
    avg_hold = sum(holdings) / n if n > 0 else 0

    # ── Skewness / Kurtosis（手算，不用 scipy） ──
    skewness = kurtosis_val = 0.0
    if len(returns) > 2 and mean_ret != 0:
        variance = sum((r - mean_ret) ** 2 for r in returns) / len(returns)
        std_pop = math.sqrt(variance) if variance > 0 else 0
        if std_pop > 0:
            m3 = sum((r - mean_ret) ** 3 for r in returns) / len(returns)
            m4 = sum((r - mean_ret) ** 4 for r in returns) / len(returns)
            skewness = m3 / (std_pop ** 3)
            kurtosis_val = m4 / (std_pop ** 4) - 3  # excess kurtosis

    # ── Tail ratio ──
    tail_ratio = 0.0
    if len(returns) >= 20:
        sorted_r = sorted(returns)
        idx_5 = max(0, int(len(sorted_r) * 0.05))
        idx_95 = min(len(sorted_r) - 1, int(len(sorted_r) * 0.95))
        p5 = abs(sorted_r[idx_5])
        p95 = abs(sorted_r[idx_95])
        tail_ratio = p95 / p5 if p5 > 0 else 0

    # ── 信号平仓数 / TTP 数（从原始 combo_summary 保留） ──

    return {
        "total_return": total_return, "final_balance": final_bal,
        "max_drawdown": max_dd, "sharpe_ratio": sharpe, "sortino_ratio": sortino,
        "calmar_ratio": calmar, "cagr": cagr,
        "total_trades": n, "winning_trades": win_count, "losing_trades": loss_count,
        "win_rate": win_rate, "avg_win_pct": avg_win * 100, "avg_loss_pct": abs(avg_loss) * 100,
        "profit_factor": profit_factor, "expectancy_ratio": expectancy,
        "double_count": double_count, "fastest_double_days": fastest_double,
        "avg_double_days": avg_double, "daily_open_positions": daily_open,
        "total_fees": total_fees, "max_balance": max_bal, "min_balance": min_bal,
        "max_win": best_pnl, "max_loss": worst_pnl,
        "reward_risk": avg_win / abs(avg_loss) if avg_loss != 0 else 0,
        "max_consec_loss_amt": 0,  # 会在下面单独算
        "longest_win_streak": max_cw, "longest_loss_streak": max_cl,
        # 新增 28 列中之前没有的
        "drawdown_duration_bars": max_dd_duration,
        "recovery_factor": recovery_factor, "ulcer_index": ulcer,
        "avg_win_pnl": avg_win, "avg_loss_pnl": avg_loss,
        "best_trade_pnl": best_pnl, "worst_trade_pnl": worst_pnl,
        "max_consecutive_wins": max_cw, "max_consecutive_losses": max_cl,
        "avg_holding_bars": avg_hold,
        "skewness": skewness, "kurtosis": kurtosis_val, "tail_ratio": tail_ratio,
    }


def _empty_combo_metrics() -> dict:
    return {k: 0 for k in [
        "total_return", "final_balance", "max_drawdown", "sharpe_ratio", "sortino_ratio",
        "calmar_ratio", "cagr", "total_trades", "winning_trades", "losing_trades",
        "win_rate", "avg_win_pct", "avg_loss_pct", "profit_factor", "expectancy_ratio",
        "double_count", "fastest_double_days", "avg_double_days", "daily_open_positions",
        "total_fees", "max_balance", "min_balance", "max_win", "max_loss",
        "reward_risk", "max_consec_loss_amt", "longest_win_streak", "longest_loss_streak",
        "drawdown_duration_bars", "recovery_factor", "ulcer_index",
        "avg_win_pnl", "avg_loss_pnl", "best_trade_pnl", "worst_trade_pnl",
        "max_consecutive_wins", "max_consecutive_losses", "avg_holding_bars",
        "skewness", "kurtosis", "tail_ratio",
    ]}


def run_combo_post_calc(con) -> int:
    """逐 combo 汇总后算 combo_summary 的 28 个字段。"""
    combos = con.execute(
        "SELECT seed_type, id, interval FROM combo_summary"
    ).fetchall()
    print(f"  汇总后算 {len(combos):,} 个 combo...", flush=True)

    updated = 0
    t0 = time.time()

    for i, (seed_type, combo_id, interval) in enumerate(combos):
        trades = con.execute(
            "SELECT pnl, pnl_amount, holding_bars, open_time, close_time, mfe, mae "
            "FROM paired_trades "
            "WHERE seed_type=? AND combo_id=? "
            "ORDER BY open_candle_idx, close_candle_idx",
            [seed_type, combo_id],
        ).fetchall()

        m = compute_combo_metrics(trades)

        con.execute(
            """UPDATE combo_summary SET
               total_return=?, final_balance=?, max_drawdown=?,
               sharpe_ratio=?, sortino_ratio=?, calmar_ratio=?, cagr=?,
               total_trades=?, winning_trades=?, losing_trades=?, win_rate=?,
               avg_win_pct=?, avg_loss_pct=?, profit_factor=?, expectancy_ratio=?,
               double_count=?, fastest_double_days=?, avg_double_days=?,
               daily_open_positions=?, total_fees=?, max_balance=?, min_balance=?,
               max_win=?, max_loss=?, reward_risk=?,
               longest_win_streak=?, longest_loss_streak=?,
               drawdown_duration_bars=?, recovery_factor=?, ulcer_index=?,
               avg_win_pnl=?, avg_loss_pnl=?, best_trade_pnl=?, worst_trade_pnl=?,
               max_consecutive_wins=?, max_consecutive_losses=?,
               avg_holding_bars=?, skewness=?, kurtosis=?, tail_ratio=?
               WHERE seed_type=? AND id=?""",
            (m["total_return"], m["final_balance"], m["max_drawdown"],
             m["sharpe_ratio"], m["sortino_ratio"], m["calmar_ratio"], m["cagr"],
             m["total_trades"], m["winning_trades"], m["losing_trades"], m["win_rate"],
             m["avg_win_pct"], m["avg_loss_pct"], m["profit_factor"], m["expectancy_ratio"],
             m["double_count"], m["fastest_double_days"], m["avg_double_days"],
             m["daily_open_positions"], m["total_fees"], m["max_balance"], m["min_balance"],
             m["max_win"], m["max_loss"], m["reward_risk"],
             m["longest_win_streak"], m["longest_loss_streak"],
             m["drawdown_duration_bars"], m["recovery_factor"], m["ulcer_index"],
             m["avg_win_pnl"], m["avg_loss_pnl"], m["best_trade_pnl"], m["worst_trade_pnl"],
             m["max_consecutive_wins"], m["max_consecutive_losses"],
             m["avg_holding_bars"], m["skewness"], m["kurtosis"], m["tail_ratio"],
             seed_type, combo_id),
        )
        updated += 1

        if (i + 1) % 1000 == 0:
            elapsed = time.time() - t0
            rate = (i + 1) / elapsed
            eta = (len(combos) - i - 1) / rate if rate > 0 else 0
            print(f"    进度: {i+1:,}/{len(combos):,} ({rate:.0f}/s, ETA {eta:.0f}s)", flush=True)

    print(f"    汇总后算完成: {updated:,} combos, {time.time()-t0:.1f}s")
    return updated


# ==================== Step 3: 索引 + 验证 ====================

def create_indexes(con) -> None:
    con.execute("CREATE INDEX IF NOT EXISTS idx_cs_strat ON combo_summary(strategy, coin, interval)")
    con.execute("CREATE INDEX IF NOT EXISTS idx_cs_seed ON combo_summary(seed_type)")


def print_summary(con) -> None:
    n_combos = con.execute("SELECT COUNT(*) FROM combo_summary").fetchone()[0]
    n_trades = con.execute("SELECT COUNT(*) FROM paired_trades").fetchone()[0]
    n_cols = len(con.execute("SELECT * FROM paired_trades LIMIT 1").description)

    print(f"\n{'='*60}")
    print(f"  种子报告 v2 生成完成")
    print(f"  combo_summary: {n_combos:,} 行")
    print(f"  paired_trades: {n_trades:,} 行, {n_cols} 列")

    for row in con.execute(
            "SELECT seed_type, COUNT(*) FROM combo_summary GROUP BY seed_type ORDER BY seed_type").fetchall():
        print(f"    {row[0]:<15s}: {row[1]:>6,} combos")

    # 抽查
    print(f"\n  抽查（signal_only, BTC, 1m, 前3）:")
    for row in con.execute("""
            SELECT strategy, sharpe_ratio, max_drawdown, final_balance, skewness, tail_ratio
            FROM combo_summary
            WHERE seed_type='signal_only' AND coin='BTC' AND interval='1m'
            ORDER BY sharpe_ratio DESC LIMIT 3""").fetchall():
        print(f"    {row[0]:<25s} sharpe={row[1]:>7.2f} dd={row[2]:>5.1f}% "
              f"bal={row[3]:>7.1f} skew={row[4]:>6.2f} tail={row[5]:>5.2f}")

    # paired_trades 新列抽查
    print(f"\n  paired_trades 新列抽查:")
    row = con.execute("""
        SELECT r_value, holding_bars, balance_after, regime_at_open, pnl_amount
        FROM paired_trades
        WHERE seed_type='signal_only' AND strategy='rsi_reversal' AND coin='BTC' AND interval='1m'
        LIMIT 1""").fetchone()
    if row:
        print(f"    r_value={row[0]:.6f} hold={row[1]} bal={row[2]:.1f} regime={row[3]} pnl_amt={row[4]:.4f}")

    db_size = os.path.getsize(REPORT_DB)
    print(f"\n  报告: {REPORT_DB} ({db_size/1024/1024/1024:.1f} GB)")
    print(f"{'='*60}")


# ==================== Main ====================

def build_report() -> None:
    import duckdb

    if os.path.exists(REPORT_DB):
        os.remove(REPORT_DB)

    con = duckdb.connect(REPORT_DB)
    con.execute("SET memory_limit = '4GB'")

    print("\n[Step 1] 导入 4 SQLite → DuckDB（含 regime_timeline）")
    import_sqlite_to_duckdb(con)

    print(f"\n[Step 2a] paired_trades 逐笔后算 15 字段")
    add_paired_trade_cols(con)

    print(f"\n[Step 2b] combo_summary 汇总后算 28 字段")
    run_combo_post_calc(con)

    print(f"\n[Step 3] 索引")
    create_indexes(con)

    print_summary(con)
    con.close()


