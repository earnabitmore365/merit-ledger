    # ── 输入组件 ──
    navigate_options(options, title, multi, searchable, disabled_indices, selections)
    get_yes_no(title, default, selections)
    get_number(title, default, min_val, max_val, selections)
    show_form(title, fields, selections)     # 新：多字段表单页
    show_loading(title, task_fn)             # spinner + 后台线程
    show_confirm(summary, selections)        # 新：确认页

