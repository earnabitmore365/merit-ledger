#!/usr/bin/env python3
"""
HyperLiquid 账号管理

集中管理 HyperLiquid 的 API 配置
支持多账号（测试网/主网）
"""

import os
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, Optional

# 自动加载项目根目录的 .env 文件
_env_path = Path(__file__).resolve().parents[3] / ".env"
if _env_path.exists():
    with open(_env_path) as f:
        for line in f:
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                key, _, value = line.partition("=")
                os.environ.setdefault(key.strip(), value.strip())


@dataclass
class HLAccount:
    """HyperLiquid 账号"""
    name: str                    # 账号名称
    wallet_address: str          # 钱包地址
    private_key: str            # 私钥
    api_address: str = ""       # API 地址（可选）
    testnet: bool = True        # 是否测试网
    enabled: bool = True        # 是否启用


# ==================== 账号配置 ====================

def _load_accounts() -> tuple:
    """从环境变量加载账号配置"""
    testnet: Dict[str, HLAccount] = {}
    mainnet: Dict[str, HLAccount] = {}

    # 测试网默认账号（从环境变量读取）
    testnet_wallet = os.environ.get("HL_TESTNET_WALLET", "")
    testnet_key = os.environ.get("HL_TESTNET_PRIVATE_KEY", "")
    testnet_api = os.environ.get("HL_TESTNET_API_ADDRESS", "")
    if testnet_wallet and testnet_key:
        testnet["default"] = HLAccount(
            name="默认测试账号",
            wallet_address=testnet_wallet,
            api_address=testnet_api,
            private_key=testnet_key,
            testnet=True,
        )

    # 主网默认账号（从环境变量读取）
    mainnet_wallet = os.environ.get("HL_MAINNET_WALLET", "")
    mainnet_key = os.environ.get("HL_MAINNET_PRIVATE_KEY", "")
    mainnet_api = os.environ.get("HL_MAINNET_API_ADDRESS", "")
    if mainnet_wallet and mainnet_key:
        mainnet["default"] = HLAccount(
            name="默认主网账号",
            wallet_address=mainnet_wallet,
            api_address=mainnet_api,
            private_key=mainnet_key,
            testnet=False,
        )

    return testnet, mainnet

HL_TESTNET_ACCOUNTS, HL_MAINNET_ACCOUNTS = _load_accounts()


# ==================== 工厂函数 ====================

def get_account(
    name: str = "default",
    network: str = "testnet",
) -> Optional[HLAccount]:
    """获取账号配置

    Args:
        name: 账号名称
        network: 网络类型 ("testnet" 或 "mainnet")

    Returns:
        HLAccount: 账号配置，找不到返回 None
    """
    if network.lower() == "testnet":
        return HL_TESTNET_ACCOUNTS.get(name)
    else:
        return HL_MAINNET_ACCOUNTS.get(name)


def list_accounts(network: str = "testnet") -> Dict[str, HLAccount]:
    """列出所有账号

    Args:
        network: 网络类型 ("testnet" 或 "mainnet")

    Returns:
        Dict[str, HLAccount]: 账号字典
    """
    if network.lower() == "testnet":
        return HL_TESTNET_ACCOUNTS.copy()
    else:
        return HL_MAINNET_ACCOUNTS.copy()


def add_account(
    name: str,
    wallet_address: str,
    private_key: str,
    api_address: str = "",
    network: str = "testnet",
) -> bool:
    """添加账号

    Args:
        name: 账号名称
        wallet_address: 钱包地址
        private_key: 私钥
        api_address: API 地址（可选）
        network: 网络类型

    Returns:
        bool: 是否添加成功
    """
    account = HLAccount(
        name=name,
        wallet_address=wallet_address,
        private_key=private_key,
        api_address=api_address,
        testnet=(network.lower() == "testnet"),
    )

    if network.lower() == "testnet":
        HL_TESTNET_ACCOUNTS[name] = account
    else:
        HL_MAINNET_ACCOUNTS[name] = account

    return True


def remove_account(name: str, network: str = "testnet") -> bool:
    """删除账号

    Args:
        name: 账号名称
        network: 网络类型

    Returns:
        bool: 是否删除成功
    """
    if network.lower() == "testnet":
        if name in HL_TESTNET_ACCOUNTS:
            del HL_TESTNET_ACCOUNTS[name]
            return True
    else:
        if name in HL_MAINNET_ACCOUNTS:
            del HL_MAINNET_ACCOUNTS[name]
            return True
    return False


def get_adapter_config(
    name: str = "default",
    network: str = "testnet",
) -> Dict:
    """获取适配器配置（用于创建 Adapter）

    Args:
        name: 账号名称
        network: 网络类型

    Returns:
        Dict: 适配器配置字典
    """
    account = get_account(name, network)
    if not account:
        raise ValueError(f"账号不存在: {name} ({network})")

    return {
        "wallet_address": account.wallet_address,
        "private_key": account.private_key,
        "api_address": account.api_address,
        "testnet": account.testnet,
    }


# ==================== 导出 ====================

__all__ = [
    'HLAccount',
    'HL_TESTNET_ACCOUNTS',
    'HL_MAINNET_ACCOUNTS',
    'get_account',
    'list_accounts',
    'add_account',
    'remove_account',
    'get_adapter_config',
]
