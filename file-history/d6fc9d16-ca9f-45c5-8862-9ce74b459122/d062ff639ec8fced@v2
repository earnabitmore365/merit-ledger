    position_pct: float     # 仓位比例 (0.0-1.0)
    stop_loss_pct: float    # 止损比例 (0.0-1.0, 0=不设)
    enable_ttp: bool        # 是否启用 TTP
    network: str = "testnet"  # 网络
    account: str = "default"  # 账号


