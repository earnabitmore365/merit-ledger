#!/usr/bin/env python3
"""
全矩阵回测：5 策略 × 10 币种 × 3 周期 = 150 组

策略: proc, demandindex_short, demandindex_long, cci_short, cci_long
币种: BTC, ETH, XRP, BNB, SOL, ADA, TRX, AVAX, LINK, DOT
周期: 5m, 15m, 1h

结果保存到 reports/backtest/summary_150_backtests.json
"""

import sys
import os
import time
import json

sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..'))

from backtest.backtest import BacktestEngine


# ==================== 配置 ====================

COINS = ['BTC', 'ETH', 'XRP', 'BNB', 'SOL', 'ADA', 'TRX', 'AVAX', 'LINK', 'DOT']
INTERVALS = ['5m', '15m', '1h']
STRATEGIES = [
    {"strategy": "proc",               "tag": "双向"},
    {"strategy": "demandindex_short",   "tag": "做空"},
    {"strategy": "demandindex_long",    "tag": "做多"},
    {"strategy": "cci_short",           "tag": "做空"},
    {"strategy": "cci_long",            "tag": "做多"},
]

# 回测参数
DAYS = 1095          # 3年
INITIAL_CAPITAL = 500
LEVERAGE = 10.0
STOP_LOSS_PCT = 0.1  # 10%
ENABLE_TTP = True

# 生成全部组合
ALL_COMBOS = []
for strat in STRATEGIES:
    for interval in INTERVALS:
        for coin in COINS:
            ALL_COMBOS.append({
                "coin": coin,
                "strategy": strat["strategy"],
                "interval": interval,
                "tag": strat["tag"],
            })


def run_all():
    """运行全矩阵回测"""
    total = len(ALL_COMBOS)
    print("=" * 80)
    print("  全矩阵回测")
    print(f"  {len(STRATEGIES)} 策略 × {len(COINS)} 币种 × {len(INTERVALS)} 周期 = {total} 组")
    print(f"  参数：{DAYS}天 · ${INITIAL_CAPITAL} · {LEVERAGE}x杠杆 · 止损{STOP_LOSS_PCT*100:.0f}% · TTP{'开' if ENABLE_TTP else '关'}")
    print("=" * 80)
    print()

    results = []
    start_all = time.time()

    for i, cfg in enumerate(ALL_COMBOS, 1):
        coin = cfg["coin"]
        strategy = cfg["strategy"]
        interval = cfg["interval"]
        tag = cfg["tag"]

        elapsed_total = time.time() - start_all
        if i > 1:
            avg_per = elapsed_total / (i - 1)
            eta = avg_per * (total - i + 1)
            eta_str = f" | ETA {eta/60:.0f}min"
        else:
            eta_str = ""

        print(f"  [{i:>3}/{total}] [{tag}] {coin:<5} {strategy:<20} {interval:<4}{eta_str}", end="", flush=True)

        start = time.time()

        try:
            engine = BacktestEngine(
                coin=coin,
                interval=interval,
                days=DAYS,
                initial_capital=INITIAL_CAPITAL,
                enable_ttp=ENABLE_TTP,
                stop_loss_pct=STOP_LOSS_PCT,
                leverage=LEVERAGE,
                enable_withdraw=False,
            )
            result = engine.run_backtest(strategy)

            if result is None:
                results.append({**cfg, "status": "FAIL", "return": 0, "sharpe": 0, "win_rate": 0, "trades": 0, "max_dd": 0, "final": 0})
                print(f" → FAIL")
                continue

            engine.save_report(strategy, prefix="矩阵")

            elapsed = time.time() - start

            results.append({
                **cfg,
                "status": "OK",
                "return": result.total_return,
                "sharpe": result.sharpe_ratio,
                "win_rate": result.win_rate,
                "max_dd": result.max_drawdown,
                "trades": result.total_trades,
                "final": result.final_balance,
                "time": elapsed,
            })

            ret = result.total_return
            symbol = "+" if ret > 0 else ""
            print(f" → {symbol}{ret:.1f}% | S {result.sharpe_ratio:.2f} | {elapsed:.1f}s")

        except Exception as e:
            print(f" → ERROR: {e}")
            results.append({**cfg, "status": "ERROR", "return": 0, "sharpe": 0, "win_rate": 0, "trades": 0, "max_dd": 0, "final": 0, "error": str(e)})

    elapsed_all = time.time() - start_all

    # ====== 汇总表 ======
    print(f"\n\n{'=' * 100}")
    print(f"  全矩阵回测汇总 ({total} 组, 耗时 {elapsed_all/60:.1f} 分钟)")
    print(f"{'=' * 100}")

    ok_results = [r for r in results if r.get("status") == "OK"]
    profitable = [r for r in ok_results if r["return"] > 0]
    print(f"  成功: {len(ok_results)}/{total} | 盈利: {len(profitable)}/{len(ok_results)} ({len(profitable)*100/max(len(ok_results),1):.0f}%)")

    # ====== 按策略+周期分组 ======
    print(f"\n{'=' * 100}")
    print("  按 策略×周期 分组统计")
    print(f"{'=' * 100}")
    print(f"  {'策略':<20} {'周期':<5} {'盈利':>6} {'平均收益':>10} {'最高':>10} {'最低':>10} {'平均Sharpe':>12} {'平均胜率':>10}")
    print(f"  {'─'*20} {'─'*5} {'─'*6} {'─'*10} {'─'*10} {'─'*10} {'─'*12} {'─'*10}")

    for strat in STRATEGIES:
        for interval in INTERVALS:
            s_name = strat["strategy"]
            s_results = [r for r in ok_results if r["strategy"] == s_name and r["interval"] == interval]
            if not s_results:
                continue
            returns = [r["return"] for r in s_results]
            sharpes = [r["sharpe"] for r in s_results]
            win_rates = [r["win_rate"] for r in s_results]
            n_profit = sum(1 for r in returns if r > 0)
            print(f"  {s_name:<20} {interval:<5} {n_profit:>2}/{len(s_results):<3} "
                  f"{sum(returns)/len(returns):>+9.1f}% {max(returns):>+9.1f}% {min(returns):>+9.1f}% "
                  f"{sum(sharpes)/len(sharpes):>11.2f} {sum(win_rates)/len(win_rates):>9.1f}%")

    # ====== 每个策略的最优周期 ======
    print(f"\n{'=' * 100}")
    print("  每个策略 × 币种的最优周期")
    print(f"{'=' * 100}")

    for strat in STRATEGIES:
        s_name = strat["strategy"]
        s_tag = strat["tag"]
        print(f"\n  [{s_tag}] {s_name}")
        print(f"  {'币种':<6} {'最优周期':<8} {'收益':>10} {'Sharpe':>8} | {'5m':>10} {'15m':>10} {'1h':>10}")
        print(f"  {'─'*6} {'─'*8} {'─'*10} {'─'*8} | {'─'*10} {'─'*10} {'─'*10}")

        for coin in COINS:
            coin_results = [r for r in ok_results if r["strategy"] == s_name and r["coin"] == coin]
            if not coin_results:
                continue

            best = max(coin_results, key=lambda r: r["return"])
            returns_by_tf = {}
            for r in coin_results:
                returns_by_tf[r["interval"]] = r["return"]

            r5m = returns_by_tf.get("5m", 0)
            r15m = returns_by_tf.get("15m", 0)
            r1h = returns_by_tf.get("1h", 0)

            print(f"  {coin:<6} {best['interval']:<8} {best['return']:>+9.1f}% {best['sharpe']:>7.2f}  | {r5m:>+9.1f}% {r15m:>+9.1f}% {r1h:>+9.1f}%")

    # ====== TOP 20 ======
    print(f"\n{'=' * 100}")
    print("  TOP 20 最佳组合（按收益排序）")
    print(f"{'=' * 100}")
    print(f"  {'#':>3} {'币种':<6} {'策略':<20} {'周期':<5} {'收益':>10} {'Sharpe':>8} {'胜率':>8} {'回撤':>8} {'交易数':>6}")
    print(f"  {'─'*3} {'─'*6} {'─'*20} {'─'*5} {'─'*10} {'─'*8} {'─'*8} {'─'*8} {'─'*6}")

    top20 = sorted(ok_results, key=lambda r: r["return"], reverse=True)[:20]
    for rank, r in enumerate(top20, 1):
        print(f"  {rank:>3} {r['coin']:<6} {r['strategy']:<20} {r['interval']:<5} "
              f"{r['return']:>+9.1f}% {r['sharpe']:>7.2f} {r['win_rate']:>7.1f}% {r['max_dd']:>7.1f}% {r['trades']:>6}")

    # ====== TOP 20 按 Sharpe ======
    print(f"\n{'=' * 100}")
    print("  TOP 20 最佳组合（按 Sharpe 排序 — 风险调整收益）")
    print(f"{'=' * 100}")
    print(f"  {'#':>3} {'币种':<6} {'策略':<20} {'周期':<5} {'Sharpe':>8} {'收益':>10} {'胜率':>8} {'回撤':>8} {'交易数':>6}")
    print(f"  {'─'*3} {'─'*6} {'─'*20} {'─'*5} {'─'*8} {'─'*10} {'─'*8} {'─'*8} {'─'*6}")

    top20_sharpe = sorted([r for r in ok_results if r["return"] > 0], key=lambda r: r["sharpe"], reverse=True)[:20]
    for rank, r in enumerate(top20_sharpe, 1):
        print(f"  {rank:>3} {r['coin']:<6} {r['strategy']:<20} {r['interval']:<5} "
              f"{r['sharpe']:>7.2f} {r['return']:>+9.1f}% {r['win_rate']:>7.1f}% {r['max_dd']:>7.1f}% {r['trades']:>6}")

    # ====== 保存 JSON ======
    report_dir = os.path.join(os.path.dirname(__file__), '..', '..', 'reports', 'backtest')
    os.makedirs(report_dir, exist_ok=True)
    summary_file = os.path.join(report_dir, 'summary_150_backtests.json')

    summary = {
        "config": {
            "days": DAYS,
            "initial_capital": INITIAL_CAPITAL,
            "leverage": LEVERAGE,
            "stop_loss_pct": STOP_LOSS_PCT,
            "enable_ttp": ENABLE_TTP,
            "coins": COINS,
            "intervals": INTERVALS,
            "strategies": [s["strategy"] for s in STRATEGIES],
            "total_combos": total,
            "elapsed_minutes": elapsed_all / 60,
        },
        "results": [
            {
                "coin": r["coin"],
                "strategy": r["strategy"],
                "interval": r["interval"],
                "tag": r["tag"],
                "status": r.get("status", "?"),
                "total_return": r.get("return", 0),
                "sharpe_ratio": r.get("sharpe", 0),
                "win_rate": r.get("win_rate", 0),
                "max_drawdown": r.get("max_dd", 0),
                "total_trades": r.get("trades", 0),
                "final_balance": r.get("final", 0),
            }
            for r in results
        ],
    }

    with open(summary_file, 'w', encoding='utf-8') as f:
        json.dump(summary, f, ensure_ascii=False, indent=2)

    print(f"\n  汇总报告: {summary_file}")
    print()


if __name__ == "__main__":
    run_all()
