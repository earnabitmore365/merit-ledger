#!/usr/bin/env python3
"""
Ichimoku Strategy

Multi-component trend system.

Features:
- Tenkan-sen (Conversion line)
- Kijun-sen (Base line)
- Senkou Span (Leading span)

Migrated from echo-auto-trading project.
"""

from typing import Dict, List, Optional
from dataclasses import dataclass

from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class IchimokuConfig:
    """Ichimoku configuration"""
    tenkan_period: int = 9
    kijun_period: int = 26
    senkou_period: int = 52


class Ichimoku(Strategy):
    """Ichimoku Cloud trading strategy"""
    
    def __init__(self, exchange=None, config: Optional[IchimokuConfig] = None):
        """Initialize Ichimoku strategy
        
        Args:
            exchange: Exchange adapter
            config: Strategy configuration
        """
        self.exchange = exchange
        self.config = config or IchimokuConfig()
    
    @property
    def name(self) -> str:
        return "ichimoku"
    
    def calculate_tenkan(self, closes: List[float]) -> float:
        """Calculate Tenkan-sen (Conversion Line)
        
        Args:
            closes: Close prices
            
        Returns:
            Tenkan-sen value
        """
        period = self.config.tenkan_period
        if len(closes) < period:
            return sum(closes) / len(closes) if closes else 0.0
        
        return sum(closes[-period:]) / period
    
    def calculate_kijun(self, closes: List[float]) -> float:
        """Calculate Kijun-sen (Base Line)
        
        Args:
            closes: Close prices
            
        Returns:
            Kijun-sen value
        """
        period = self.config.kijun_period
        if len(closes) < period:
            return sum(closes) / len(closes) if closes else 0.0
        
        return sum(closes[-period:]) / period
    
    def generate_signal(
        self, coin: str, klines: List[Dict] = None
    ) -> TradingSignal:
        """Generate Ichimoku signal
        
        Args:
            coin: Trading pair
            klines: OHLCV data
            
        Returns:
            TradingSignal with Ichimoku analysis
        """
        # Validate klines
        min_required = self.config.senkou_period
        if not klines or len(klines) < min_required:
            return TradingSignal(
                signal=Signal.HOLD,
                confidence=0.0,
                coin=coin,
                timestamp=klines[-1]["time"] if klines else 0,
                metadata={"reason": "Insufficient klines"},
            )
        
        # Extract closes
        closes = [c["close"] for c in klines]
        current = closes[-1]
        
        # Calculate components
        tenkan = self.calculate_tenkan(closes)
        kijun = self.calculate_kijun(closes)
        
        # Generate signal
        if current > tenkan > kijun:
            signal = Signal.BUY
            trend = "strong_uptrend"
        elif current < tenkan < kijun:
            signal = Signal.SELL
            trend = "strong_downtrend"
        elif tenkan > kijun:
            signal = Signal.BUY
            trend = "uptrend"
        elif tenkan < kijun:
            signal = Signal.SELL
            trend = "downtrend"
        else:
            signal = Signal.HOLD
            trend = "neutral"
        
        return TradingSignal(
            signal=signal,
            confidence=0.6,
            coin=coin,
            timestamp=klines[-1]["time"],
            metadata={
                "tenkan": tenkan,
                "kijun": kijun,
                "current": current,
                "trend": trend,
            },
        )
