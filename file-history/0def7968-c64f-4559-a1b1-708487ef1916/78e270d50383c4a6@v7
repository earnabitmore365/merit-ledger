<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<title>策略成绩单</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Menlo', 'Monaco', monospace; font-size: 12px; background: #1a1a2e; color: #e0e0e0; overflow-x: auto; }
.toolbar { padding: 12px 16px; background: #16213e; border-bottom: 1px solid #0f3460; display: flex; gap: 12px; align-items: center; flex-wrap: wrap; position: sticky; top: 0; left: 0; z-index: 100; min-width: max-content; }
.toolbar label { color: #a0a0b0; font-size: 11px; }
input, select { background: #0f3460; color: #e0e0e0; border: 1px solid #1a4a8a; border-radius: 4px; padding: 4px 8px; font-size: 12px; font-family: inherit; }
.stats { color: #6080a0; font-size: 11px; margin-left: auto; }
table { border-collapse: collapse; min-width: 100%; }
thead { position: sticky; top: 49px; z-index: 50; }
th { background: #0f3460; color: #80b0e0; padding: 7px 10px; text-align: right; cursor: pointer; white-space: nowrap; border: 1px solid #1a4a8a; user-select: none; }
th:hover { background: #1a4a8a; }
th.sort-asc::after { content: " ▲"; color: #ffd700; }
th.sort-desc::after { content: " ▼"; color: #ffd700; }
th:first-child, th:nth-child(2), th:nth-child(3), th:nth-child(4) { text-align: left; }
td { padding: 5px 10px; border: 1px solid #1a2a4a; text-align: right; white-space: nowrap; }
td:first-child, td:nth-child(2), td:nth-child(3), td:nth-child(4) { text-align: left; }
tr:hover td { background: #1a2a4a; }
.pos { color: #4caf50; }
.neg { color: #f44336; }
.wf { color: #ffd700; text-align: center !important; }
.sep { border-left: 2px solid #2a3a6a; }
.dim { color: #5a6a8a; }
</style>
</head>
<body>
<div class="toolbar">
