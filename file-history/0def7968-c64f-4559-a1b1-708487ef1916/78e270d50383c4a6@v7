let sortCol = 'all_pnl', sortDir = -1;
let filtered = [...RAW];

function fmt(v) {
  if (v === null || v === undefined) return '<span class="dim">-</span>';
  const cls = v > 0 ? 'pos' : v < 0 ? 'neg' : '';
  const s = v > 0 ? '+' + v : '' + v;
  return cls ? `<span class="${cls}">${s}</span>` : s;
}

function applyFilters() {
  const fs = document.getElementById('f-strategy').value;
  const fc = document.getElementById('f-coin').value;
  const fi = document.getElementById('f-interval').value;
  const fw = document.getElementById('f-wf').checked;
  const lim = parseInt(document.getElementById('f-limit').value) || 0;
  filtered = RAW.filter(r =>
    (!fs || r.strategy === fs) &&
    (!fc || r.coin === fc) &&
    (!fi || r.interval === fi) &&
    (!fw || r.wf === '✅')
  );
  render(lim);
}

const ASC_FIRST = ['days_to_1r', 'total_days'];
function sortBy(col) {
  if (sortCol === col) { sortDir *= -1; } else { sortCol = col; sortDir = ASC_FIRST.includes(col) ? 1 : -1; }
  document.querySelectorAll('th').forEach(th => th.className = th.className.replace(/ sort-(asc|desc)/g,''));
  const cols = ['strategy','coin','interval','wf','total_days','days_to_1r','all_pnl','all_trades','all_wr','all_avg_r','bull_pnl','bull_trades','bear_pnl','bear_trades','ranging_pnl','ranging_trades','ebull_pnl','ebull_trades','ebear_pnl','ebear_trades'];
  const idx = cols.indexOf(col);
  if (idx >= 0) document.querySelectorAll('th')[idx].classList.add(sortDir === -1 ? 'sort-desc' : 'sort-asc');
  applyFilters();
}

function render(lim) {
  const sorted = [...filtered].sort((a,b) => {
    const av = a[sortCol] ?? Infinity;
    const bv = b[sortCol] ?? Infinity;
    return av < bv ? sortDir : av > bv ? -sortDir : 0;
  });
  const shown = lim ? sorted.slice(0, lim) : sorted;
  document.getElementById('stats').textContent = `显示 ${shown.length} / ${filtered.length} 条（共 ${RAW.length} 条）`;
  document.getElementById('tbody').innerHTML = shown.map(r => `<tr>
    <td>${r.strategy}</td><td>${r.coin}</td><td>${r.interval}</td>
    <td class="wf">${r.wf}</td>
    <td class="sep">${r.total_days ?? '<span class=dim>-</span>'}天</td>
    <td>${r.days_to_1r !== null && r.days_to_1r !== undefined ? r.days_to_1r+'天' : '<span class=dim>未到</span>'}</td>
    <td class="sep">${fmt(r.all_pnl)}</td><td>${r.all_trades??'-'}</td><td>${r.all_wr??'-'}</td><td>${r.all_avg_r??'-'}</td>
    <td class="sep">${fmt(r.bull_pnl)}</td><td>${r.bull_trades??'-'}</td>
    <td class="sep">${fmt(r.bear_pnl)}</td><td>${r.bear_trades??'-'}</td>
    <td class="sep">${fmt(r.ranging_pnl)}</td><td>${r.ranging_trades??'-'}</td>
    <td class="sep">${fmt(r.ebull_pnl)}</td><td>${r.ebull_trades??'-'}</td>
    <td class="sep">${fmt(r.ebear_pnl)}</td><td>${r.ebear_trades??'-'}</td>
  </tr>`).join('');
}

const strategies = [...new Set(RAW.map(r => r.strategy))].sort();
const coins = [...new Set(RAW.map(r => r.coin))].sort();
const sSel = document.getElementById('f-strategy');
const cSel = document.getElementById('f-coin');
strategies.forEach(s => { const o = document.createElement('option'); o.value = o.textContent = s; sSel.appendChild(o); });
coins.forEach(c => { const o = document.createElement('option'); o.value = o.textContent = c; cSel.appendChild(o); });

sortBy('all_pnl');
</script>
