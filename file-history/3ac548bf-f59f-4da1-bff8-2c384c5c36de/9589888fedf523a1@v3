[server]
port = 8300
host = "127.0.0.1"
data_dir = "./data"

# 黑丝 = Claude Opus（执行工程师），白纱 = Claude Sonnet（方案架构师）
# 启动方式见 start_heisi.sh / start_baisha.sh

[agents.heisi]
command = "claude"
cwd = "/Users/allenbot/project/cashflowAPP"
color = "#1a1a2e"
label = "黑丝"

[agents.baisha]
command = "claude"
cwd = "/Users/allenbot/project/cashflowAPP"
