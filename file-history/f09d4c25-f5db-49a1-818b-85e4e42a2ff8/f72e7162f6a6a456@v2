#!/usr/bin/env python3
"""
trader_bot.py — Telegram 命令查询 bot

通过 Telegram 命令查询交易状态、PnL、历史交易。
长轮询 getUpdates，在 Trader Report thread 里响应命令。

命令：
    /status [name]  — 全部策略状态 / 模糊匹配
    /pnl            — 按策略类型查今日 PnL（按钮选择）
    /trades         — 按策略类型查最近交易（按钮选择）
    /summary        — 总体统计
    /win            — 策略 PnL 排名
    /help           — 帮助

@see trader_report.py — 自动通知（开仓/平仓/TTP/熔断）
@see trade_logger.py — SQLite 数据源
"""

import os
import sys
import json
import time
import sqlite3
import logging
import urllib.request
from datetime import datetime, timezone
from typing import Optional

sys.path.insert(0, os.path.dirname(__file__))

logger = logging.getLogger('TraderBot')

# 从 .env 读取
BOT_TOKEN = os.getenv('TELEGRAM_BOT_TOKEN', '')
CHAT_ID = os.getenv('TELEGRAM_CHAT_ID', '')
THREAD_ID = int(os.getenv('TELEGRAM_TRADER_THREAD_ID', '12030'))

# 数据文件路径
_lab_dir = os.path.dirname(__file__)
DB_PATH = os.path.join(_lab_dir, 'reports', 'live_trades.db')
STATES_PATH = os.path.join(_lab_dir, 'strategy_states.json')

# 策略类型（从 team_config 动态获取）
try:
    from team_config import TEAM
    STRATEGY_TYPES = sorted(set(cfg.strategy for cfg in TEAM))
except Exception:
    STRATEGY_TYPES = ['mean_reversion', 'bb_squeeze', 'order_block', 'proc',
                      'rsi_reversal', 'williams_fast', 'advanced_kline_echo', 'smc_real']


class TraderBot:
    """Telegram 命令查询 bot"""

    def __init__(self):
        self._last_update_id = 0

    def run(self):
        """主循环：长轮询"""
        logger.info("TraderBot 启动，等待命令...")
        while True:
            try:
                updates = self._get_updates()
                for u in updates:
                    self._handle_update(u)
            except Exception as e:
                logger.error(f"轮询异常: {e}")
            time.sleep(1)

    # ========== Telegram API ==========

    def _get_updates(self):
        """获取新消息"""
        url = (f"https://api.telegram.org/bot{BOT_TOKEN}/getUpdates"
               f"?offset={self._last_update_id + 1}&timeout=30"
               f"&allowed_updates=[\"message\",\"callback_query\"]")
        try:
            req = urllib.request.Request(url)
            with urllib.request.urlopen(req, timeout=35) as resp:
                data = json.loads(resp.read().decode())
                return data.get('result', [])
        except Exception:
            return []

    def _send(self, text, chat_id=None, thread_id=None):
        """发送纯文本消息"""
        payload = {
            'chat_id': chat_id or CHAT_ID,
            'text': text,
            'parse_mode': 'HTML',
        }
        tid = thread_id or THREAD_ID
        if tid:
            payload['message_thread_id'] = tid
        try:
            url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
            data = json.dumps(payload).encode()
            req = urllib.request.Request(
                url, data=data,
                headers={'Content-Type': 'application/json'},
                method='POST')
            urllib.request.urlopen(req, timeout=10)
        except Exception as e:
            logger.error(f"发送失败: {e}")

    def _send_with_buttons(self, text, buttons, chat_id=None, thread_id=None):
        """发送带按钮的消息"""
        keyboard = []
        row = []
        for label, callback_data in buttons:
            row.append({'text': label, 'callback_data': callback_data})
            if len(row) >= 3:
                keyboard.append(row)
                row = []
        if row:
            keyboard.append(row)

        payload = {
            'chat_id': chat_id or CHAT_ID,
            'text': text,
            'parse_mode': 'HTML',
            'reply_markup': json.dumps({'inline_keyboard': keyboard}),
        }
        tid = thread_id or THREAD_ID
        if tid:
            payload['message_thread_id'] = tid
        try:
            url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
            data = json.dumps(payload).encode()
            req = urllib.request.Request(
                url, data=data,
                headers={'Content-Type': 'application/json'},
                method='POST')
            urllib.request.urlopen(req, timeout=10)
        except Exception as e:
            logger.error(f"发送失败: {e}")

    def _answer_callback(self, callback_id):
        """告诉 Telegram 我们已处理这个回调"""
        url = f"https://api.telegram.org/bot{BOT_TOKEN}/answerCallbackQuery"
        data = json.dumps({'callback_query_id': callback_id}).encode()
        req = urllib.request.Request(url, data=data,
            headers={'Content-Type': 'application/json'}, method='POST')
        try:
            urllib.request.urlopen(req, timeout=5)
        except Exception:
            pass

    # ========== 消息路由 ==========

    def _handle_update(self, update):
        self._last_update_id = update.get('update_id', 0)

        # 按钮回调
        if 'callback_query' in update:
            self._handle_callback(update['callback_query'])
            return

        # 文字命令
        msg = update.get('message', {})
        text = msg.get('text', '').strip()
        chat_id = msg.get('chat', {}).get('id')
        thread_id = msg.get('message_thread_id')

        if not text.startswith('/'):
            return

        parts = text.split(maxsplit=1)
        cmd = parts[0].lower().split('@')[0]  # 去掉 @bot_name
        args = parts[1] if len(parts) > 1 else ''

        reply = None
        if cmd == '/status':
            reply = self._cmd_status(args)
        elif cmd == '/pnl':
            self._cmd_pnl(chat_id, thread_id)
            return
        elif cmd == '/trades':
            self._cmd_trades(chat_id, thread_id)
            return
        elif cmd == '/summary':
            reply = self._cmd_summary()
        elif cmd == '/win':
            reply = self._cmd_win()
        elif cmd == '/help':
            reply = self._cmd_help()

        if reply:
            self._send(reply, chat_id, thread_id)

    def _handle_callback(self, callback):
        """处理按钮点击"""
        data = callback.get('data', '')
        chat_id = callback.get('message', {}).get('chat', {}).get('id')
        thread_id = callback.get('message', {}).get('message_thread_id')

        self._answer_callback(callback.get('id'))

        parts = data.split(':')
        cmd = parts[0]
        arg = parts[1] if len(parts) > 1 else ''

        reply = None
        if cmd == 'pnl':
            reply = self._cmd_pnl_by_strategy(arg)
        elif cmd == 'trades':
            reply = self._cmd_trades_by_strategy(arg)

        if reply:
            self._send(reply, chat_id, thread_id)

    # ========== 命令实现 ==========

    def _cmd_status(self, args):
        """/status [name] — 策略状态"""
        try:
            with open(STATES_PATH) as f:
                states = json.load(f)
        except Exception:
            return "❌ strategy_states.json 未找到"

        if args:
            # 模糊匹配
            keyword = args.lower()
            states = {k: v for k, v in states.items() if keyword in k.lower()}
            if not states:
                return f"❌ 没有匹配 '{args}' 的策略"

        active = {k: v for k, v in states.items() if v.get('position')}
        idle = {k: v for k, v in states.items() if not v.get('position')}

        lines = [f"📋 <b>策略状态</b> ({len(active)} 持仓 / {len(idle)} 空闲)\n"]

        if active:
            for sid, s in active.items():
                direction = "🟢" if s.get('position') == 'BUY' else "🔴"
                entry = s.get('entry_price', 0)
                size = s.get('position_size', 0)
                ttp = s.get('_last_ttp_level', 0)
                ttp_str = f" TTP={ttp:,.2f}" if ttp > 0 else ""
                lines.append(f"{direction} {sid}: ${entry:,.2f} x{size:.4f}{ttp_str}")

        if idle and not args:
            lines.append(f"\n⏸ 空闲: {len(idle)} 个策略等待信号")
        elif idle:
            for sid in idle:
                lines.append(f"⏸ {sid}: 空闲")

        return "\n".join(lines)

    def _cmd_pnl(self, chat_id, thread_id):
        """/pnl — 出按钮让用户选策略类型"""
        buttons = [(t, f"pnl:{t}") for t in STRATEGY_TYPES]
        buttons.append(("📊 全部", "pnl:ALL"))
        self._send_with_buttons("📊 选择策略类型：", buttons, chat_id, thread_id)

    def _cmd_pnl_by_strategy(self, strategy_type):
        """按钮回调：按策略类型查今日 PnL"""
        conn = self._get_db()
        if not conn:
            return "❌ 数据库未找到"

        today = datetime.now(timezone.utc).strftime('%Y-%m-%d')

        if strategy_type == 'ALL':
            where = "WHERE close_time LIKE ?"
            params = (f"{today}%",)
        else:
            where = "WHERE close_time LIKE ? AND strategy_id LIKE ?"
            params = (f"{today}%", f"%{strategy_type}%")

        rows = conn.execute(f"""
            SELECT strategy_id, COUNT(*) as trades,
                   SUM(pnl) as total_pnl, SUM(fee) as total_fee
            FROM live_trades
            {where}
            GROUP BY strategy_id
            ORDER BY total_pnl DESC
        """, params).fetchall()
        conn.close()

        if not rows:
            label = strategy_type if strategy_type != 'ALL' else '全部'
            return f"📊 今日 {label} 无交易"

        total_pnl = sum(r[2] or 0 for r in rows)
        total_fee = sum(r[3] or 0 for r in rows)
        total_trades = sum(r[1] or 0 for r in rows)

        lines = [f"📊 <b>今日 PnL</b> ({total_trades} 笔)\n"]
        for r in rows:
            pnl = r[2] or 0
            fee = r[3] or 0
            emoji = "💰" if pnl >= 0 else "💸"
            lines.append(f"{emoji} {r[0]}: {r[1]}笔 {'+'if pnl>=0 else ''}{pnl:,.2f} (费{fee:,.2f})")

        lines.append(f"\n<b>合计: {'+'if total_pnl>=0 else ''}{total_pnl:,.2f} USD (手续费 {total_fee:,.2f})</b>")
        return "\n".join(lines)

    def _cmd_trades(self, chat_id, thread_id):
        """/trades — 出按钮让用户选策略类型"""
        buttons = [(t, f"trades:{t}") for t in STRATEGY_TYPES]
        buttons.append(("📋 全部", "trades:ALL"))
        self._send_with_buttons("📋 选择策略类型：", buttons, chat_id, thread_id)

    def _cmd_trades_by_strategy(self, strategy_type):
        """按钮回调：按策略类型查最近交易"""
        conn = self._get_db()
        if not conn:
            return "❌ 数据库未找到"

        if strategy_type == 'ALL':
            rows = conn.execute("""
                SELECT strategy_id, side, entry_price, exit_price, pnl, fee, close_reason, close_time
                FROM live_trades ORDER BY id DESC LIMIT 10
            """).fetchall()
        else:
            rows = conn.execute("""
                SELECT strategy_id, side, entry_price, exit_price, pnl, fee, close_reason, close_time
                FROM live_trades WHERE strategy_id LIKE ?
                ORDER BY id DESC LIMIT 10
            """, (f"%{strategy_type}%",)).fetchall()
        conn.close()

        if not rows:
            return f"📋 {strategy_type} 无交易记录"

        lines = [f"📋 <b>最近交易</b> ({strategy_type})\n"]
        for r in rows:
            pnl = r[4] or 0
            fee = r[5] or 0
            emoji = "💰" if pnl >= 0 else "💸"
            close_time = (r[7] or "")[:16]
            lines.append(
                f"{emoji} {r[0]} {r[1]} ${r[2]:,.2f}→${r[3]:,.2f} "
                f"{'+'if pnl>=0 else ''}{pnl:,.2f} ({r[6]}) {close_time}"
            )
        return "\n".join(lines)

    def _cmd_summary(self):
        """/summary — 总体统计"""
        conn = self._get_db()
        if not conn:
            return "❌ 数据库未找到"

        row = conn.execute("""
            SELECT COUNT(*), SUM(pnl), SUM(fee),
                   SUM(CASE WHEN pnl > 0 THEN 1 ELSE 0 END),
                   SUM(CASE WHEN pnl < 0 THEN 1 ELSE 0 END)
            FROM live_trades
        """).fetchone()
        conn.close()

        if not row or not row[0]:
            return "📊 暂无交易记录"

        total, pnl, fee, wins, losses = row[0], row[1] or 0, row[2] or 0, row[3] or 0, row[4] or 0
        win_rate = wins / total * 100 if total > 0 else 0

        return (
            f"📊 <b>总体统计</b>\n\n"
            f"总交易: {total} 笔\n"
            f"胜率: {win_rate:.1f}% ({wins}胜 {losses}负)\n"
            f"总 PnL: {'+'if pnl>=0 else ''}{pnl:,.2f} USD\n"
            f"总手续费: {fee:,.2f} USD\n"
            f"净利润: {'+'if (pnl-fee)>=0 else ''}{pnl-fee:,.2f} USD"
        )

    def _cmd_win(self):
        """/win — 策略 PnL 排名"""
        conn = self._get_db()
        if not conn:
            return "❌ 数据库未找到"

        rows = conn.execute("""
            SELECT strategy_id, COUNT(*), SUM(pnl), SUM(fee)
            FROM live_trades
            GROUP BY strategy_id
            ORDER BY SUM(pnl) DESC
        """).fetchall()
        conn.close()

        if not rows:
            return "🏆 暂无交易记录"

        lines = ["🏆 <b>策略排名</b>\n"]
        for i, r in enumerate(rows):
            pnl = r[2] or 0
            fee = r[3] or 0
            medal = ["🥇", "🥈", "🥉"][i] if i < 3 else f"{i+1}."
            lines.append(f"{medal} {r[0]}: {r[1]}笔 {'+'if pnl>=0 else ''}{pnl:,.2f} (费{fee:,.2f})")

        return "\n".join(lines)

    def _cmd_help(self):
        """/help — 帮助"""
        return (
            "🤖 <b>Trader Bot 命令</b>\n\n"
            "/status — 全部策略状态\n"
            "/status mean — 模糊匹配\n"
            "/pnl — 今日 PnL（按策略类型）\n"
            "/trades — 最近交易（按策略类型）\n"
            "/summary — 总体统计\n"
            "/win — 策略排名\n"
            "/help — 帮助"
        )

    # ========== 数据库 ==========

    def _get_db(self) -> Optional[sqlite3.Connection]:
        if not os.path.exists(DB_PATH):
            return None
        return sqlite3.connect(DB_PATH)


# ========== 主程序 ==========

def main():
    from dotenv import load_dotenv
    load_dotenv(os.path.join(_lab_dir, '.env'))

    # 重新读 .env（load_dotenv 后全局变量已过期）
    global BOT_TOKEN, CHAT_ID, THREAD_ID
    BOT_TOKEN = os.getenv('TELEGRAM_BOT_TOKEN', '')
    CHAT_ID = os.getenv('TELEGRAM_CHAT_ID', '')
    THREAD_ID = int(os.getenv('TELEGRAM_TRADER_THREAD_ID', '12030'))

    logging.basicConfig(
        level=logging.INFO,
        format='%(asctime)s [%(name)s] %(levelname)s %(message)s',
    )

    if not BOT_TOKEN:
        print("❌ TELEGRAM_BOT_TOKEN 未配置")
        sys.exit(1)

    bot = TraderBot()
    bot.run()


if __name__ == '__main__':
    main()
