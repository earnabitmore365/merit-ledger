#!/usr/bin/env python3
"""POC: 预算指标 → 切片 → 分段不重算，验证加速效果"""
import sys, os, time
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from backtest.generate_seed import _split_candles, load_candles
from core import indicator_cache as ic


def worker_precomputed(candles_slice, indicator_data, coin, interval, strat):
    """Worker: 用预算指标跑回测，不重算"""
    from core import indicator_cache as ic
    from backtest.backtest import BacktestEngine

    # 1. 先调 init_cache 设上下文（会清空缓存，没关系）
    ic.init_cache(coin, interval, candles_slice, db_path=':memory:')

    # 2. 填充内存缓存（init_cache 之后）
    ic._memory_caches['normal'].update(indicator_data)

    # 3. BacktestEngine 内部 init_cache 幂等检查：
    #    ctx['candles'] is candles_slice → True → 跳过 → 不清空缓存
    engine = BacktestEngine(
        coin=coin, interval=interval, days=0,
        initial_capital=500, enable_ttp=False, ttp_highlow=False,
        stop_loss_pct=0.1, leverage=10.0,
        fixed_bet=True, fixed_bet_amount=1,
        fee_rate=0.00035, slippage_pct=0.0002, funding_rate_8h=0.0001,
        candles=candles_slice
    )
    result = engine.run_backtest(strat)
    return result.total_trades


def worker_no_precompute(candles_slice, coin, interval, strat):
    """Worker: 不预算，每段独立重算指标（当前行为）"""
    from backtest.backtest import BacktestEngine

    engine = BacktestEngine(
        coin=coin, interval=interval, days=0,
        initial_capital=500, enable_ttp=False, ttp_highlow=False,
        stop_loss_pct=0.1, leverage=10.0,
        fixed_bet=True, fixed_bet_amount=1,
        fee_rate=0.00035, slippage_pct=0.0002, funding_rate_8h=0.0001,
        candles=candles_slice
    )
    result = engine.run_backtest(strat)
    return result.total_trades


def main():
    from concurrent.futures import ProcessPoolExecutor

    coin, interval, strat = 'ADA', '1m', 'bb_squeeze'
    all_candles = load_candles(coin, interval)
    print(f"K线: {len(all_candles)} 根")

    # ── 基准（串行完整）──
    from backtest.backtest import BacktestEngine
    t0 = time.time()
    engine = BacktestEngine(
        coin=coin, interval=interval, days=0,
        initial_capital=500, enable_ttp=False, ttp_highlow=False,
        stop_loss_pct=0.1, leverage=10.0,
        fixed_bet=True, fixed_bet_amount=1,
        fee_rate=0.00035, slippage_pct=0.0002, funding_rate_8h=0.0001,
        candles=all_candles
    )
    result_base = engine.run_backtest(strat)
    base_time = time.time() - t0
    print(f"基准: trades={result_base.total_trades} return={result_base.total_return:.2f}% ({base_time:.1f}s)")

    # 收集指标快照
    snapshot = dict(ic._memory_caches['normal'])
    n_indicators = len(snapshot)
    print(f"指标快照: {n_indicators} 条")

    # ── 分段准备 ──
    segments = _split_candles(all_candles, n_segments=4, warmup=2000)
    for i, seg in enumerate(segments):
        print(f"  段{i}: {len(seg['candles'])}根 (预热{seg['warmup_count']}根)")

    # 对每段切片指标
    seg_indicator_datas = []
    for seg in segments:
        warmup_start = seg['seg_start'] - seg['warmup_count']
        seg_end = seg['seg_end']
        sliced = {}
        for key, data in snapshot.items():
            if isinstance(data, dict):
                sliced[key] = {k: v[warmup_start:seg_end] for k, v in data.items()}
            elif isinstance(data, list):
                sliced[key] = data[warmup_start:seg_end]
            else:
                sliced[key] = data
        seg_indicator_datas.append(sliced)
        # 验证切片长度
        for key, data in sliced.items():
            if isinstance(data, list):
                assert len(data) == len(seg['candles']), \
                    f"切片长度不匹配: {len(data)} vs {len(seg['candles'])}"
                break

    # ── 分段（预算指标）──
    print(f"\n--- 分段（预算指标，4 worker）---")
    t0 = time.time()
    with ProcessPoolExecutor(max_workers=4) as executor:
        futures = []
        for seg_idx, seg in enumerate(segments):
            future = executor.submit(
                worker_precomputed,
                seg['candles'],
                seg_indicator_datas[seg_idx],
                coin, interval, strat
            )
            futures.append(future)
        results_pre = [f.result() for f in futures]
    pre_time = time.time() - t0
    total_pre = sum(results_pre)
    print(f"  每段: {results_pre}")
    print(f"  合计: {total_pre} ({pre_time:.1f}s)")

    # ── 分段（不预算，重算指标）──
    print(f"\n--- 分段（不预算，4 worker）---")
    t0 = time.time()
    with ProcessPoolExecutor(max_workers=4) as executor:
        futures = []
        for seg_idx, seg in enumerate(segments):
            future = executor.submit(
                worker_no_precompute,
                seg['candles'],
                coin, interval, strat
            )
            futures.append(future)
        results_no = [f.result() for f in futures]
    no_time = time.time() - t0
    total_no = sum(results_no)
    print(f"  每段: {results_no}")
    print(f"  合计: {total_no} ({no_time:.1f}s)")

    # ── 对比 ──
    print(f"\n{'='*60}")
    print(f"基准（串行）:      trades={result_base.total_trades:>8}  耗时={base_time:.1f}s")
    print(f"分段（预算指标）:  trades={total_pre:>8}  耗时={pre_time:.1f}s  加速={base_time/pre_time:.1f}x")
    print(f"分段（不预算）:    trades={total_no:>8}  耗时={no_time:.1f}s  加速={base_time/no_time:.1f}x")
    print(f"预算 vs 不预算:    {pre_time:.1f}s vs {no_time:.1f}s = {no_time/pre_time:.1f}x 快")
    print(f"trades 吻合:       {'完全吻合' if total_pre == total_no == result_base.total_trades else '不吻合'}")


if __name__ == '__main__':
    main()
