#!/usr/bin/env python3
"""
limit_executor.py — 限价挂单 + 重试 + 转市价

规则：
- 挂 best bid/ask 限价单 → 等 10 秒 → 没成交撤单重挂
- 最多重试 5 次
- 1m/5m 策略：每次重挂前重算信号，信号没了就放弃
- 15m 及以上策略：直接排队重挂，信号来之不易
- 5 次都没成交 → 转市价
- 部分成交 → 市价补齐
- 止损/TTP 由交易所挂单自动执行，不走限价重试

@see lab/src/exchange/bitmex/adapter.py — place_order / cancel_order / get_order_status
@see lab/src/exchange/base.py — OrderRequest / OrderResult / OrderSide / OrderType
@see lab/strategy_runner.py — StrategyRunner 实例
@see lab/kline_dispatcher.py — KlineDispatcher.get_window()
"""

import time
import logging

import os
import sys

_lab_dir = os.path.dirname(os.path.abspath(__file__))
_src_dir = os.path.join(_lab_dir, 'src')
if _src_dir not in sys.path:
    sys.path.insert(0, _src_dir)

from exchange.base import OrderRequest, OrderSide, OrderType

logger = logging.getLogger(__name__)


class LimitOrderExecutor:
    """限价挂单执行器：挂单 → 等待 → 重试 → 转市价"""

    MAX_RETRIES = 5
    RETRY_INTERVAL = 10  # 秒
    SMALL_TF = {'1m', '5m'}  # 小周期：重挂前重算信号

    def execute_limit(self, strategy, side, size, adapter, dispatcher=None, reduce_only=False):
        """限价挂单 + 重试 + 转市价

        Args:
            strategy: StrategyRunner 实例
            side: 'BUY' / 'SELL'
            size: 名义敞口（币数量）
            adapter: BitMEXAdapter
            dispatcher: KlineDispatcher（小周期重算信号用）

        Returns:
            dict: {
                'success': bool,
                'price': float,        # 成交价
                'attempts': int,       # 尝试次数
                'partial_fill': bool,  # 是否部分成交后市价补齐
                'fallback': str,       # 'market' 如果 5 次失败转市价
                'reason': str,         # 失败原因（如 'signal_gone'）
            }
        """
        order_side = OrderSide.BUY if side == 'BUY' else OrderSide.SELL

        for attempt in range(self.MAX_RETRIES):
            # 获取最优价格
            bid, ask = adapter.get_best_bid_ask(strategy.coin)
            if bid <= 0 or ask <= 0:
                logger.warning(f"[{strategy.id}] 无法获取 bid/ask，等待重试")
                time.sleep(self.RETRY_INTERVAL)
                continue

            # 挂限价单：BUY 挂 bid 价，SELL 挂 ask 价（Maker 单）
            price = bid if side == 'BUY' else ask

            order = OrderRequest(
                coin=strategy.coin,
                side=order_side,
                order_type=OrderType.LIMIT,
                size=size,
                price=price,
                reduce_only=reduce_only,
            )
            result = adapter.place_order(order)

            if not result.success:
                logger.error(f"[{strategy.id}] 限价单失败: {result.message}")
                time.sleep(self.RETRY_INTERVAL)
                continue

            order_id = result.order_id
            logger.info(f"[{strategy.id}] 限价单已挂: {side} {size} @ {price} "
                        f"(attempt {attempt + 1}/{self.MAX_RETRIES})")

            # 等待成交
            time.sleep(self.RETRY_INTERVAL)

            # 查询订单状态
            status = adapter.get_order_status(order_id)
            ord_status = status.get('ordStatus', '')
            filled_contracts = float(status.get('cumQty', 0) or 0)
            # cumQty 是合约数，转回币数量（和 size 同单位）
            u2p = adapter._get_u2p(strategy.coin)
            filled_qty = filled_contracts / u2p if u2p > 0 else 0

            if ord_status == 'Filled':
                avg_price = float(status.get('avgPx', 0) or 0)
                logger.info(f"[{strategy.id}] 限价单成交: {avg_price} "
                            f"(attempt {attempt + 1})")
                return {
                    'success': True,
                    'price': avg_price,
                    'actual_size': filled_qty if filled_qty > 0 else size,
                    'attempts': attempt + 1,
                    'order_id': order_id,
                }

            # 部分成交 → 撤单 + 市价补齐
            if filled_qty > 0:
                adapter.cancel_order(order_id)
                remaining = size - filled_qty
                avg_price = float(status.get('avgPx', 0) or 0)

                if remaining > 0:
                    logger.info(f"[{strategy.id}] 部分成交 {filled_qty}/{size}，"
                                f"市价补齐 {remaining}")
                    mkt_order = OrderRequest(
                        coin=strategy.coin,
                        side=order_side,
                        order_type=OrderType.MARKET,
                        size=remaining,
                        reduce_only=reduce_only,
                    )
                    mkt_result = adapter.place_order(mkt_order)
                    if mkt_result.success:
                        # 混合价格估算
                        mkt_price = mkt_result.filled_price or price
                        blended = (avg_price * filled_qty + mkt_price * remaining) / size
                        return {
                            'success': True,
                            'price': blended,
                            'actual_size': size,
                            'attempts': attempt + 1,
                            'partial_fill': True,
                            'order_id': mkt_result.order_id or order_id,
                        }

                return {
                    'success': True,
                    'price': avg_price,
                    'actual_size': filled_qty,
                    'attempts': attempt + 1,
                    'partial_fill': True,
                    'order_id': order_id,
                }

            # 完全未成交 → 撤单
            adapter.cancel_order(order_id)

            # 小周期（1m/5m）：重挂前重算信号，信号没了就放弃
            if strategy.interval in self.SMALL_TF and dispatcher:
                klines = dispatcher.get_window(strategy.coin, strategy.interval)
                if klines and len(klines) >= 2:
                    new_signal = strategy.on_bar(klines[-1], klines)
                    if new_signal != side:
                        logger.info(f"[{strategy.id}] 信号已变({side}→{new_signal})，放弃")
                        return {
                            'success': False,
                            'reason': 'signal_gone',
                            'attempts': attempt + 1,
                        }

            # 大周期（15m+）：直接重挂，不重算信号
            logger.info(f"[{strategy.id}] 未成交，重挂 (attempt {attempt + 1})")

        # 5 次都没成交 → 转市价
        logger.warning(f"[{strategy.id}] {self.MAX_RETRIES} 次未成交，转市价")
        mkt_order = OrderRequest(
            coin=strategy.coin,
            side=order_side,
            order_type=OrderType.MARKET,
            size=size,
            reduce_only=reduce_only,
        )
        mkt_result = adapter.place_order(mkt_order)

        if mkt_result.success:
            # filled_size 已是币数量（adapter 内部已 cumQty / u2p）
            mkt_filled_coins = mkt_result.filled_size or 0
            if mkt_filled_coins <= 0:
                mkt_filled_coins = size
            return {
                'success': True,
                'price': mkt_result.filled_price or 0,
                'actual_size': mkt_filled_coins,
                'attempts': self.MAX_RETRIES,
                'fallback': 'market',
                'order_id': mkt_result.order_id or '',
            }

        return {
            'success': False,
            'reason': f'market_order_failed: {mkt_result.message}',
            'attempts': self.MAX_RETRIES,
        }
