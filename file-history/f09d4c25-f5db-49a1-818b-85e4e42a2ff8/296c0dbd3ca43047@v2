#!/usr/bin/env python3
"""
sim_21_team.py — 21 策略联合回测 · 资金模拟

用 seed_v3_ttp.db 里的历史交易记录（paired_trades），
模拟 $398 共享资金池、21 策略抢注码、看最后剩多少钱。

用法：
    cd lab && python3 sim_21_team.py

数据源：seed_v3_ttp.db（TTP 种子，含 mirror 变体）
不依赖任何交易系统代码，只需 sqlite3。
"""

import os
import sqlite3
from collections import defaultdict
from datetime import datetime

# ==================== 常量 ====================

INITIAL_BALANCE = 2100.0
LEVERAGE = 10
CIRCUIT_BREAKER = 100.0
TEAM_SIZE = 5
MAX_BET = 1000              # 名义敞口上限

# 提款规则
WITHDRAW_THRESHOLD = 27000
WITHDRAW_AMOUNT = 6000

DB_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)),
                       'reports', 'seed_v3.db')

# 5 个原版策略（不受 mirror/maxprice 影响）→ combo_id（纯信号种子）
COMBO_MAP = {
    'SOL_bb_squeeze_1h': 5395,
    'AVAX_bb_squeeze_1h': 1169,
    'AVAX_smc_real_1h': 1240,
    'LINK_bb_squeeze_1h': 5198,
    'DOT_bb_squeeze_1h': 3449,
}


def load_events(db_path, start_date=None):
    """从种子数据库加载交易，拆成 OPEN/CLOSE 事件

    Args:
        db_path: 种子数据库路径
        start_date: 起始日期 'YYYY-MM-DD'（只加载该日期之后的交易）
    """
    conn = sqlite3.connect(db_path)

    events = []
    for sid, combo_id in COMBO_MAP.items():
        if start_date:
            rows = conn.execute("""
                SELECT open_time, close_time, direction, entry_price, exit_price,
                       pnl, position_size, fee, close_type
                FROM paired_trades
                WHERE combo_id = ? AND open_time >= ?
                ORDER BY open_time
            """, (combo_id, start_date)).fetchall()
        else:
            rows = conn.execute("""
                SELECT open_time, close_time, direction, entry_price, exit_price,
                       pnl, position_size, fee, close_type
                FROM paired_trades
                WHERE combo_id = ?
                ORDER BY open_time
            """, (combo_id,)).fetchall()

        for row in rows:
            open_time, close_time, direction, entry_price, exit_price, \
                pnl, position_size, fee, close_type = row

            # pnl_pct = 价格变动百分比（不含手续费）
            if direction == 'long':
                pnl_pct = (exit_price - entry_price) / entry_price
            else:
                pnl_pct = (entry_price - exit_price) / entry_price

            # 手续费百分比（种子里 fee 基于 $10 名义）
            fee_pct = fee / position_size if position_size > 0 else 0

            trade_id = f"{sid}_{open_time}"

            events.append({
                'time': open_time,
                'type': 'OPEN',
                'strategy_id': sid,
                'trade_id': trade_id,
                'direction': direction,
                'pnl_pct': pnl_pct,
                'fee_pct': fee_pct,
                'close_type': close_type,
            })
            events.append({
                'time': close_time,
                'type': 'CLOSE',
                'strategy_id': sid,
                'trade_id': trade_id,
                'direction': direction,
                'pnl_pct': pnl_pct,
                'fee_pct': fee_pct,
                'close_type': close_type,
            })

    conn.close()

    # 按时间排序（同一时间 CLOSE 先于 OPEN，先释放资金再占用）
    events.sort(key=lambda e: (e['time'], 0 if e['type'] == 'CLOSE' else 1))
    return events


def run_simulation(years=None):
    """运行资金模拟

    Args:
        years: 只回测最近 N 年（默认全量）
    """
    start_date = None
    if years:
        from datetime import timedelta
        cutoff = datetime.now() - timedelta(days=years * 365)
        start_date = cutoff.strftime('%Y-%m-%d')

    print("=" * 68)
    print("21 策略联合回测 — 资金模拟")
    print("=" * 68)
    print(f"数据源: {DB_PATH}")
    if start_date:
        print(f"时间范围: {start_date} ~ 至今（{years}年）")
    print(f"初始余额: ${INITIAL_BALANCE:.2f}")
    print(f"杠杆: {LEVERAGE}x | 熔断: ${CIRCUIT_BREAKER:.2f}")
    print()

    # 加载事件
    print("加载交易数据...")
    events = load_events(DB_PATH, start_date=start_date)
    print(f"  总事件数: {len(events)} ({len(events) // 2} 笔交易)")
    print()

    # 模拟
    balance = INITIAL_BALANCE
    peak_balance = INITIAL_BALANCE
    max_drawdown_balance = 0.0     # 余额口径回撤
    max_dd_bal_date = ''
    peak_total_assets = INITIAL_BALANCE
    max_drawdown_total = 0.0       # 总资产口径回撤（真实回撤）
    max_dd_total_date = ''
    peak_date = ''
    min_balance = INITIAL_BALANCE
    min_balance_date = ''
    max_concurrent = 0
    circuit_breaker_count = 0
    total_withdrawn = 0.0
    withdraw_count = 0
    first_max_bet_date = ''        # 余额首次到 $21,000 的日期

    active_positions = {}  # trade_id → {'margin', 'nominal', 'open_time'}
    skipped = defaultdict(int)  # strategy_id → skip count
    total_trades = defaultdict(int)  # strategy_id → trade count
    strategy_pnl = defaultdict(float)  # strategy_id → total pnl
    strategy_wins = defaultdict(int)
    strategy_losses = defaultdict(int)
    monthly_pnl = defaultdict(float)  # 'YYYY-MM' → pnl

    for event in events:
        if event['type'] == 'OPEN':
            sid = event['strategy_id']
            tid = event['trade_id']

            # 这个策略已经有持仓？跳过（同时只能持一笔）
            active_for_strategy = [k for k in active_positions if k.startswith(sid + '_')]
            if active_for_strategy:
                skipped[sid] += 1
                continue

            # 算可用保证金
            used_margin = sum(p['margin'] for p in active_positions.values())
            available = balance - used_margin

            # 注码：available ÷ 21，取整 $10，最低 $100，最高 MAX_BET
            # bet = 保证金（不是名义！名义 = bet × LEVERAGE）
            bet = max(100, (int(available) // TEAM_SIZE // 10) * 10)
            bet = min(bet, MAX_BET)
            margin = bet                    # bet 本身就是保证金
            nominal = bet * LEVERAGE        # 名义 = 保证金 × 杠杆

            if available < margin:
                skipped[sid] += 1
                continue

            # 熔断检查
            if balance < CIRCUIT_BREAKER:
                circuit_breaker_count += 1
                break

            # 开仓
            active_positions[tid] = {
                'margin': margin,
                'nominal': nominal,
                'open_time': event['time'],
                'strategy_id': sid,
            }
            total_trades[sid] += 1

            # 最大同时持仓
            if len(active_positions) > max_concurrent:
                max_concurrent = len(active_positions)

        elif event['type'] == 'CLOSE':
            tid = event['trade_id']
            sid = event['strategy_id']

            if tid not in active_positions:
                continue  # 被跳过的交易

            pos = active_positions.pop(tid)

            # 实际 PnL = 名义 × pnl_pct - 名义 × fee_pct
            actual_pnl = pos['nominal'] * event['pnl_pct'] - pos['nominal'] * event['fee_pct']

            # 止损限制：最大亏损 = 保证金
            if actual_pnl < -pos['margin']:
                actual_pnl = -pos['margin']

            balance += actual_pnl
            strategy_pnl[sid] += actual_pnl

            if actual_pnl > 0:
                strategy_wins[sid] += 1
            else:
                strategy_losses[sid] += 1

            # 月度收益
            month = event['time'][:7]  # 'YYYY-MM'
            monthly_pnl[month] += actual_pnl

            # 更新峰值和回撤（余额口径）
            if balance > peak_balance:
                peak_balance = balance
                peak_date = event['time'][:10]
            dd_bal = (peak_balance - balance) / peak_balance if peak_balance > 0 else 0
            if dd_bal > max_drawdown_balance:
                max_drawdown_balance = dd_bal
                max_dd_bal_date = event['time'][:10]

            # 总资产口径回撤（余额 + 已提款 = 真实总资产）
            total_assets = balance + total_withdrawn
            if total_assets > peak_total_assets:
                peak_total_assets = total_assets
            dd_total = (peak_total_assets - total_assets) / peak_total_assets if peak_total_assets > 0 else 0
            if dd_total > max_drawdown_total:
                max_drawdown_total = dd_total
                max_dd_total_date = event['time'][:10]

            if balance < min_balance:
                min_balance = balance
                min_balance_date = event['time'][:10]

            # 首次 MAX_BET 到顶
            if not first_max_bet_date and balance >= TEAM_SIZE * MAX_BET:
                first_max_bet_date = event['time'][:10]

            # 提款
            if balance >= WITHDRAW_THRESHOLD:
                balance -= WITHDRAW_AMOUNT
                total_withdrawn += WITHDRAW_AMOUNT
                withdraw_count += 1

            # 熔断
            if balance < CIRCUIT_BREAKER:
                circuit_breaker_count += 1
                break

    # ==================== 输出 ====================

    total_return = (balance - INITIAL_BALANCE) / INITIAL_BALANCE * 100
    total_opened = sum(total_trades.values())
    total_skipped = sum(skipped.values())
    skip_rate = total_skipped / (total_opened + total_skipped) * 100 if (total_opened + total_skipped) > 0 else 0

    actual_profit = balance + total_withdrawn - INITIAL_BALANCE

    print("=" * 68)
    print(f"21 策略联合回测 — 修正版（MAX_BET=${MAX_BET} + 提款）")
    print("=" * 68)
    print()
    print(f"初始余额:         ${INITIAL_BALANCE:.2f}")
    print(f"最终余额:         ${balance:,.2f}")
    print(f"总收益率:         {total_return:+.1f}%")
    print(f"余额口径回撤:    {max_drawdown_balance * 100:.1f}% ({max_dd_bal_date})")
    print(f"总资产口径回撤:  {max_drawdown_total * 100:.1f}% ({max_dd_total_date})  ← 真实回撤")
    print(f"最高余额:         ${peak_balance:,.2f} ({peak_date})")
    print(f"最低余额:         ${min_balance:.2f} ({min_balance_date})")
    print()
    print(f"提款次数:         {withdraw_count}")
    print(f"总提款金额:       ${total_withdrawn:,.0f}")
    print(f"实际总收益:       ${actual_profit:,.2f}（余额 + 提款 - 本金）")
    print()
    print(f"总交易笔数:       {total_opened}")
    print(f"余额不足跳过:     {total_skipped} ({skip_rate:.1f}%)")
    print(f"熔断触发:         {circuit_breaker_count} 次")
    print(f"最大同时持仓:     {max_concurrent}")
    if first_max_bet_date:
        print(f"MAX_BET到顶:     {first_max_bet_date}（余额首次 >= ${TEAM_SIZE * MAX_BET:,}）")

    # 各策略贡献
    print()
    print("--- 各策略贡献 ---")
    print(f"{'策略':<45} {'开仓':>6} {'跳过':>6} {'总PnL':>10} {'胜率':>6}")
    print("-" * 75)
    for sid in sorted(COMBO_MAP.keys()):
        trades = total_trades[sid]
        skip = skipped[sid]
        pnl = strategy_pnl[sid]
        wins = strategy_wins[sid]
        losses = strategy_losses[sid]
        wr = wins / (wins + losses) * 100 if (wins + losses) > 0 else 0
        flag = "📈" if pnl > 0 else "📉"
        print(f"{flag} {sid:<43} {trades:>6} {skip:>6} {pnl:>+10.2f} {wr:>5.1f}%")

    # 年度收益
    print()
    print("--- 年度收益 ---")
    yearly_pnl = defaultdict(float)
    yearly_withdrawals = defaultdict(float)
    for month, mpnl in monthly_pnl.items():
        yearly_pnl[month[:4]] += mpnl
    running = INITIAL_BALANCE
    for year in sorted(yearly_pnl.keys()):
        ypnl = yearly_pnl[year]
        running += ypnl
        print(f"{year}: {ypnl:>+10.2f}  余额: ${running:,.2f}")

    # 月度收益（详细）
    print()
    print("--- 月度收益 ---")
    running_balance = INITIAL_BALANCE
    for month in sorted(monthly_pnl.keys()):
        mpnl = monthly_pnl[month]
        running_balance += mpnl
        print(f"{month}:  {mpnl:>+10.2f}  余额: ${running_balance:,.2f}")

    # 之前"亏钱"的 7 个策略修正后
    print()
    print("--- 之前'拖后腿'的 7 个策略修正后 ---")
    prev_losers = [
        'AVAX_bb_squeeze_1h', 'LINK_bb_squeeze_1h', 'DOT_bb_squeeze_1h',
        'XRP_rsi_reversal_1h', 'ADA_mean_reversion_1h',
        'SOL_bb_squeeze_1h', 'DOT_bb_squeeze_30m',
    ]
    for sid in prev_losers:
        pnl = strategy_pnl.get(sid, 0)
        trades = total_trades.get(sid, 0)
        flag = "✅ 转正" if pnl > 0 else "❌ 仍亏"
        print(f"  {sid}: {pnl:>+10.2f} ({trades}笔) → {flag}")

    # 拖后腿的策略
    print()
    print("--- 仍在拖后腿的策略（净 PnL < 0）---")
    losers = [(sid, strategy_pnl[sid], total_trades[sid])
              for sid in COMBO_MAP if strategy_pnl[sid] < 0]
    losers.sort(key=lambda x: x[1])
    if losers:
        for sid, pnl, trades in losers:
            print(f"  {sid}: {pnl:+.2f} ({trades}笔)")
    else:
        print("  全部正贡献!")

    print()
    print("=" * 68)


if __name__ == '__main__':
    import argparse
    parser = argparse.ArgumentParser(description='21策略联合回测 · 资金模拟')
    parser.add_argument('--years', type=int, default=None,
                        help='只回测最近N年（默认全量）')
    args = parser.parse_args()
    run_simulation(years=args.years)
