#!/usr/bin/env python3
"""正式验证：预算指标 + _worker_segment + _merge_segment_trades
对比基准（串行）和分段（预算指标 vs 不预算）
"""
import sys, os, time
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from backtest.generate_seed import (
    _split_candles, _worker_segment, _merge_segment_trades,
    _init_worker, load_candles, DATA_DIR,
)
from backtest.backtest import BacktestEngine
from core import indicator_cache as ic
from concurrent.futures import ProcessPoolExecutor


def main():
    coin = 'ADA'
    interval = '1m'
    strategies = ['ichimoku', 'kama', 'keltner']

    worker_config = {
        'enable_ttp': True, 'ttp_highlow': False,
        'days': 0, 'initial_capital': 500, 'leverage': 10.0,
        'stop_loss_pct': 0.1, 'fixed_bet': True, 'fixed_bet_amount': 1,
        'fee_rate': 0.00035, 'slippage_pct': 0.0002, 'funding_rate_8h': 0.0001,
        'min_klines': 500, 'data_dir': DATA_DIR,
        'completed_set': set(), 'margin_mode': 'linear',
    }

    all_candles = load_candles(coin, interval)
    print(f"K线: {len(all_candles)} 根")

    # ── 基准（串行）──
    print("\n=== 基准（串行） ===")
    baselines = {}
    t0_all = time.time()
    for s in strategies:
        t0 = time.time()
        engine = BacktestEngine(
            coin=coin, interval=interval, days=0,
            initial_capital=500, enable_ttp=True, ttp_highlow=False,
            stop_loss_pct=0.1, leverage=10.0,
            fixed_bet=True, fixed_bet_amount=1,
            fee_rate=0.00035, slippage_pct=0.0002, funding_rate_8h=0.0001,
            candles=all_candles
        )
        result = engine.run_backtest(s)
        elapsed = time.time() - t0
        ttp_count = len([t for t in result.trades if 'TTP' in t.order_type])
        baselines[s] = {'trades': result.total_trades, 'return': result.total_return, 'ttp': ttp_count}
        print(f"  {s}: trades={result.total_trades} return={result.total_return:.2f}% ttp={ttp_count} ({elapsed:.1f}s)")
    baseline_time = time.time() - t0_all
    print(f"  串行总耗时: {baseline_time:.1f}s")

    # 收集指标快照（3个策略跑完后所有指标都在内存缓存里）
    snapshot = dict(ic._memory_caches['normal'])
    print(f"\n指标快照: {len(snapshot)} 条")
    for key in list(snapshot.keys())[:5]:
        data = snapshot[key]
        dtype = type(data).__name__
        size = len(data) if isinstance(data, list) else f"dict({len(data)} keys)"
        print(f"  {key[2]}({key[3]}): {dtype} {size}")
    if len(snapshot) > 5:
        print(f"  ... 共 {len(snapshot)} 条")

    # ── 分段准备 ──
    segments = _split_candles(all_candles, n_segments=4, warmup=2000)

    # 切片指标
    seg_indicator_datas = []
    for seg in segments:
        warmup_start = seg['seg_start'] - seg['warmup_count']
        seg_end = seg['seg_end']
        sliced = {}
        for key, data in snapshot.items():
            if isinstance(data, dict):
                sliced[key] = {k: v[warmup_start:seg_end] for k, v in data.items()}
            elif isinstance(data, list):
                sliced[key] = data[warmup_start:seg_end]
            else:
                sliced[key] = data
        seg_indicator_datas.append(sliced)

    # ── 分段（预算指标）──
    print("\n=== 分段（预算指标，4 worker） ===")
    t0 = time.time()
    with ProcessPoolExecutor(max_workers=4, initializer=_init_worker, initargs=(worker_config,)) as executor:
        futures = {}
        for seg_idx, seg in enumerate(segments):
            future = executor.submit(
                _worker_segment, coin, interval, strategies,
                seg['candles'], seg['warmup_count'],
                seg['seg_start'], seg['seg_end'],
                mirror=False, cache_db_path=None,
                precomputed_indicators=seg_indicator_datas[seg_idx]
            )
            futures[future] = seg_idx
        seg_results_pre = [None] * 4
        for future in futures:
            seg_idx = futures[future]
            try:
                seg_results_pre[seg_idx] = future.result()
            except Exception as e:
                print(f"  段{seg_idx} 异常: {e}")
    pre_time = time.time() - t0

    seg_results_pre = [r for r in seg_results_pre if r is not None]
    merged_pre = _merge_segment_trades(seg_results_pre)

    # ── 分段（不预算）──
    print("\n=== 分段（不预算，4 worker） ===")
    t0 = time.time()
    with ProcessPoolExecutor(max_workers=4, initializer=_init_worker, initargs=(worker_config,)) as executor:
        futures = {}
        for seg_idx, seg in enumerate(segments):
            future = executor.submit(
                _worker_segment, coin, interval, strategies,
                seg['candles'], seg['warmup_count'],
                seg['seg_start'], seg['seg_end'],
                mirror=False, cache_db_path=None
            )
            futures[future] = seg_idx
        seg_results_no = [None] * 4
        for future in futures:
            seg_idx = futures[future]
            try:
                seg_results_no[seg_idx] = future.result()
            except Exception as e:
                print(f"  段{seg_idx} 异常: {e}")
    no_time = time.time() - t0

    seg_results_no = [r for r in seg_results_no if r is not None]
    merged_no = _merge_segment_trades(seg_results_no)

    # ── 对比 ──
    print(f"\n{'='*90}")
    print(f"{'策略':<15} {'基准trades':>10} {'预算trades':>10} {'不预算trades':>12} {'预算匹配':>8} {'基准ttp':>8} {'预算ttp':>8}")
    print(f"{'='*90}")

    all_match = True
    for s in strategies:
        base = baselines[s]

        pre_data = merged_pre.get(s, {'trades': [], 'validation': []})
        pre_trades = len(pre_data['trades'])
        pre_ttp = len([t for t in pre_data['trades'] if t.get('close_type', '') == 'ttp'])

        no_data = merged_no.get(s, {'trades': [], 'validation': []})
        no_trades = len(no_data['trades'])

        match = "OK" if pre_trades == base['trades'] else f"差{pre_trades - base['trades']}"
        if pre_trades != base['trades']:
            all_match = False

        print(f"{s:<15} {base['trades']:>10} {pre_trades:>10} {no_trades:>12} {match:>8} {base['ttp']:>8} {pre_ttp:>8}")

        for v in pre_data.get('validation', []):
            print(f"  边界{v['boundary']}: {v['status']}")

    print(f"\n{'='*90}")
    print(f"串行基准:        {baseline_time:.1f}s")
    print(f"分段（预算指标）: {pre_time:.1f}s  加速={baseline_time/pre_time:.1f}x")
    print(f"分段（不预算）:   {no_time:.1f}s  加速={baseline_time/no_time:.1f}x")
    print(f"预算 vs 不预算:   {pre_time:.1f}s vs {no_time:.1f}s = {no_time/pre_time:.1f}x")
    print(f"全部吻合:         {'YES' if all_match else 'NO'}")


if __name__ == '__main__':
    main()
