def _run_matrix(args, coins, intervals, strategies, all_coins, all_intervals, run_fn):
    """矩阵模式：按 SEED_MATRIX 定义顺序跑每个种子的 普通+镜像 两轮

    @see SEED_MATRIX — 种子定义表
    @see _run_seed / _run_seed_parallel — 单轮执行函数
    """
    global ENABLE_TTP, TTP_HIGHLOW, DB_PATH

    mode_str = "%d 并行" % args.workers if args.workers > 1 else "单线程"
    n_seeds = len(SEED_MATRIX)

    print("\n" + "█" * 90)
    print("  矩阵模式：%d 个种子 ×（原版+镜像）= %d 轮（%s）" % (
        n_seeds, n_seeds * 2, mode_str))
    for i, seed in enumerate(SEED_MATRIX, 1):
        ttp_mode = '关' if not seed['ttp'] else ('High/Low' if seed['ttp_highlow'] else 'Close')
        print("    %d. %s → %s (TTP=%s)" % (
            i, seed['name'], seed['db_name'], ttp_mode))
    print("  断点恢复，中断不丢进度")
    print("█" * 90 + "\n")

    matrix_start = time.time()
    all_results = []
    orig_ttp, orig_highlow, orig_db = ENABLE_TTP, TTP_HIGHLOW, DB_PATH

    try:
        for seed_idx, seed_cfg in enumerate(SEED_MATRIX, 1):
            # 切换全局配置
            ENABLE_TTP = seed_cfg['ttp']
            TTP_HIGHLOW = seed_cfg['ttp_highlow']
            DB_PATH = os.path.join(REPORT_DIR, seed_cfg['db_name'])

            ttp_mode = '关' if not seed_cfg['ttp'] else ('High/Low' if seed_cfg['ttp_highlow'] else 'Close')
            print("\n" + "▓" * 90)
            print("  [%d/%d] %s — %s (TTP=%s)" % (
                seed_idx, n_seeds, seed_cfg['name'],
                seed_cfg['db_name'], ttp_mode))
            print("▓" * 90)

            seed_start = time.time()

            try:
                # 第一轮：普通
                c1, s1, f1 = run_fn(args, coins, intervals, strategies,
                                     all_coins, all_intervals, False)
                # 第二轮：镜像
                c2, s2, f2 = run_fn(args, coins, intervals, strategies,
                                     all_coins, all_intervals, True)
            except Exception as e:
                seed_elapsed = time.time() - seed_start
                print("\n  [ERROR] 种子 %s 失败: %s，跳过继续下一个" % (
                    seed_cfg['name'], e))
                all_results.append({
                    'name': seed_cfg['name'], 'db': DB_PATH,
                    'normal': (0, 0, -1), 'mirror': (0, 0, -1),
                    'elapsed': seed_elapsed,
                })
                continue

            seed_elapsed = time.time() - seed_start

            all_results.append({
                'name': seed_cfg['name'],
                'db': DB_PATH,
                'normal': (c1, s1, f1),
                'mirror': (c2, s2, f2),
                'elapsed': seed_elapsed,
            })

            # 单种子统计（DB 可能不存在或表为空，安全处理）
            try:
                _print_seed_stats(DB_PATH, "%s 完成 (%.1f 分钟)" % (
                    seed_cfg['name'], seed_elapsed / 60))
            except Exception as e:
                print("  ⚠️ 统计读取失败: %s" % e)

            # Parquet 转换
            _convert_to_parquet(DB_PATH)

            # Gate 选拔
            try:
                results_dir = os.path.join(PROJECT_ROOT, 'results', seed_cfg['gate_dir'])
                gate_report = _run_gate_for_seed(DB_PATH, results_dir)
                all_results[-1]['gate_report'] = gate_report
            except Exception as e:
                print("  ⚠️ Gate 失败: %s，跳过" % e)
                all_results[-1]['gate_report'] = None
    finally:
        ENABLE_TTP, TTP_HIGHLOW, DB_PATH = orig_ttp, orig_highlow, orig_db

    # ── 矩阵总汇报 ──
    total_elapsed = time.time() - matrix_start
    print("\n" + "█" * 90)
    print("  矩阵全部完成! (总耗时 %.1f 分钟)" % (total_elapsed / 60))
    print("█" * 90)

    for r in all_results:
        c1, s1, f1 = r['normal']
        c2, s2, f2 = r['mirror']
        db_size = os.path.getsize(r['db']) if os.path.exists(r['db']) else 0
        gate_str = ""
        if r.get('gate_report') and os.path.exists(r['gate_report']):
            try:
                gc = sqlite3.connect(r['gate_report'])
                n_champs = gc.execute("SELECT COUNT(*) FROM champions").fetchone()[0]
                gc.close()
                gate_str = " | 冠军: %d" % n_champs
            except Exception:
                pass
        print("\n  ■ %s (%s, %.1f GB, %.0fmin%s)" % (
            r['name'], os.path.basename(r['db']),
            db_size / 1024**3, r['elapsed'] / 60, gate_str))
        print("    普通: %d新 %d跳 %d败 | 镜像: %d新 %d跳 %d败" % (
            c1, s1, f1, c2, s2, f2))

    # ── DuckDB 三种子对比报告 ──
    _generate_comparison_report(all_results)

    print("\n" + "█" * 90)
    print("\n⚠️  待办：验证 Gate 冠军数量与旧报告一致后，删除旧脚本：")
    print("    rm lab/run_gate_v41.py lab/run_gate_v41_ttp.py")
    print("    （已被 lab/gate_runner.py 替代）")


def main():
    global ENABLE_TTP, TTP_HIGHLOW, DB_PATH
    args = parse_args()

    # --inverse: 币本位模式（matrix 和非 matrix 都生效）
    if args.inverse:
        MARGIN_MODE = "inverse"

    # 自动检测
    all_coins, all_intervals = detect_coins_and_intervals()
    if not all_coins:
        print("错误：未检测到任何数据")
        return

    coins = args.coins if args.coins else all_coins
    intervals = args.intervals if args.intervals else all_intervals
    coins = [c for c in coins if c in all_coins]
    intervals = [iv for iv in intervals if iv in all_intervals]

    if not coins or not intervals:
        print("错误：过滤后无可用的币种或周期")
        return

    strategies = get_strategies()
    if args.strategy:
        strategies = [s for s in args.strategy if s in strategies]
        if not strategies:
            print("错误：过滤后无可用策略")
            return

    # 选择执行函数（单线程 vs 并行）
    if args.workers > 1:
        _run_fn = lambda a, c, i, s, ac, ai, m=False: _run_seed_parallel(
            a, c, i, s, ac, ai, mirror=m, n_workers=args.workers)
    else:
        _run_fn = lambda a, c, i, s, ac, ai, m=False: _run_seed(
            a, c, i, s, ac, ai, mirror=m)

    # ── 矩阵模式：一条命令跑完所有种子 ──
    if args.matrix:
        if args.ttp or args.mirror or args.db:
            print("⚠️  --matrix 模式忽略 --ttp/--mirror/--db（矩阵内部自动管理）")
        _run_matrix(args, coins, intervals, strategies,
                    all_coins, all_intervals, _run_fn)
        return

    # ── 非矩阵模式：单种子运行 ──
    # --ttp: 开启追踪止盈
    if args.ttp:
        ENABLE_TTP = True

    # --db: 自定义数据库路径（优先级最高）
    if args.db:
        DB_PATH = args.db
    elif args.ttp:
        DB_PATH = os.path.join(REPORT_DIR, 'seed_v3_ttp.db')

    # --ttp 自动跑 普通 + 镜像 两轮
    if args.ttp and not args.mirror:
        mode_str = "%d 并行" % args.workers if args.workers > 1 else "单线程"
        print("\n" + "█" * 90)
        print("  TTP 全量模式：普通 + 镜像 一条过（%s）" % mode_str)
        print("  断点恢复，中断不丢进度")
        print("█" * 90 + "\n")

        # 第一轮：普通
        c1, s1, f1 = _run_fn(args, coins, intervals, strategies,
                              all_coins, all_intervals, False)
        # 第二轮：镜像
        c2, s2, f2 = _run_fn(args, coins, intervals, strategies,
                              all_coins, all_intervals, True)

        # 最终汇总
        print("\n" + "█" * 90)
        print("  TTP 全量完成!")
        _print_seed_stats(DB_PATH)
        print("  普通: %d新 %d跳 %d败 | 镜像: %d新 %d跳 %d败" % (
            c1, s1, f1, c2, s2, f2))
        print("█" * 90)
        return

    # 非TTP模式 或 --ttp --mirror（手动指定镜像）：原始单轮行为
    mirror = args.mirror
    _run_fn(args, coins, intervals, strategies,
            all_coins, all_intervals, mirror)

    # 最终数据库统计
    conn = sqlite3.connect(DB_PATH)
    n_combos = conn.execute("SELECT COUNT(*) FROM combo_summary").fetchone()[0]
    n_paired = conn.execute("SELECT COUNT(*) FROM paired_trades").fetchone()[0]
    n_regime = conn.execute("SELECT COUNT(*) FROM regime_timeline").fetchone()[0]
    print("\n  combo_summary:  %d 行" % n_combos)
    print("  paired_trades:  %d 行" % n_paired)
    print("  regime_timeline: %d 行" % n_regime)

    print("\n  Regime 分布总览:")
    for row in conn.execute(
            "SELECT regime, COUNT(*) FROM regime_timeline GROUP BY regime ORDER BY regime"):
        print("    %-10s %d 条" % (row[0], row[1]))

    print("\n  平仓类型分布:")
    for row in conn.execute(
            "SELECT close_type, COUNT(*) FROM paired_trades GROUP BY close_type ORDER BY close_type"):
        print("    %-15s %d 笔" % (row[0], row[1]))

    print("\n  按 Regime 分组的平均 R 值:")
    for row in conn.execute(
            "SELECT regime_at_open, ROUND(AVG(r_value), 4), COUNT(*) "
            "FROM paired_trades GROUP BY regime_at_open ORDER BY regime_at_open"):
        print("    %-10s avg_r=%.4f  (%d 笔)" % (row[0], row[1], row[2]))

    conn.close()
    db_size = os.path.getsize(DB_PATH)
    print("\n  数据库: %s (%.1f MB)" % (DB_PATH, db_size / 1024 / 1024))

    # SQLite → Parquet 自动转换
    _convert_to_parquet(DB_PATH)


if __name__ == "__main__":
    main()
