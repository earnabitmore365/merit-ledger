def get_strategies() -> List[str]:
    """获取所有可用策略"""
    all_names = sorted(list_strategies())
    return [name for name in all_names if name not in SKIP_STRATEGIES]


# ==================== 并行 Worker ====================

_BARS_PER_DAY_MAP = {
    '1m': 1440, '5m': 288, '15m': 96, '30m': 48,
    '1h': 24, '2h': 12, '4h': 6, '8h': 3, '12h': 2, '1d': 1,
}


def _worker_coin_interval(coin: str, interval: str, strategies: List[str],
                          mirror: bool = False, db_path: str = None) -> Dict:
    """Worker: 处理一个 (coin, interval) 的所有策略。

    每个 worker 打开自己的 DB 连接，跑完所有策略后关闭。
    用于 ProcessPoolExecutor 并行或单线程直接调用。

    Args:
        mirror: 镜像模式 — 翻转OHLCV，策略名加_mirror后缀
        db_path: 指定写入的 DB 路径（并行模式用临时 DB，单线程用主库）

    Returns:
        {'coin', 'interval', 'completed', 'skipped', 'failed', 'elapsed', 'details': [...]}
    """
    if db_path is None:
        db_path = DB_PATH
    conn = init_db(db_path)

    t0 = time.time()
    all_candles = load_candles(coin, interval)
    if not all_candles:
        conn.close()
        return {'coin': coin, 'interval': interval, 'completed': 0,
                'skipped': 0, 'failed': len(strategies), 'elapsed': 0,
                'details': [], 'msg': '数据不存在'}

    if len(all_candles) < MIN_KLINES:
        conn.close()
        return {'coin': coin, 'interval': interval, 'completed': 0,
                'skipped': len(strategies), 'failed': 0, 'elapsed': 0,
                'details': [], 'msg': 'K线数 %d < %d' % (len(all_candles), MIN_KLINES)}

    # ── 镜像模式：翻转价格数据 ──
    if mirror:
        all_candles = mirror_candles(all_candles)

    bars_per_day = _BARS_PER_DAY_MAP.get(interval, 24)
    n_candles = len(all_candles)

    # ── Regime 时间线 ──
    if mirror:
        # 镜像数据：每次重新计算（不存DB，避免污染原始regime）
        regime_timeline = compute_regime_timeline(all_candles, interval, DAYS)
    elif check_regime_exists(conn, coin, interval):
        cur = conn.execute(
            "SELECT candle_idx, candle_time_ms, regime, adx, sma_direction "
            "FROM regime_timeline WHERE coin=? AND interval=? ORDER BY candle_idx",
            (coin, interval))
        regime_timeline = [
            {'candle_idx': r[0], 'candle_time_ms': r[1],
             'regime': r[2], 'adx': r[3], 'sma_direction': r[4]}
            for r in cur.fetchall()]
    else:
        regime_timeline = compute_regime_timeline(all_candles, interval, DAYS)
        save_regime_timeline(conn, coin, interval, regime_timeline)
        conn.commit()

    # ── 逐策略回测 ──
    completed = 0
    skipped = 0
    failed = 0
    details = []

    for strategy_name in strategies:
        # 镜像模式：DB里存 xxx_mirror，类加载用原名
        db_name = strategy_name + "_mirror" if mirror else strategy_name

        if check_combo_exists(conn, db_name, coin, interval):
            skipped += 1
            continue

        # 并行模式：检查主库已完成集合（避免重算已合并的）
        if _worker_completed_set and (db_name, coin, interval) in _worker_completed_set:
            skipped += 1
            continue

        try:
            engine = BacktestEngine(
                coin=coin, interval=interval, days=DAYS,
                initial_capital=INITIAL_CAPITAL, enable_ttp=ENABLE_TTP,
                ttp_highlow=TTP_HIGHLOW,
                stop_loss_pct=STOP_LOSS_PCT, leverage=LEVERAGE,
                enable_withdraw=False, fixed_bet=FIXED_BET,
                candles=all_candles, fixed_bet_amount=FIXED_BET_AMOUNT,
                fee_rate=FEE_RATE, slippage_pct=SLIPPAGE_PCT,
                funding_rate_8h=FUNDING_RATE_8H,
                margin_mode=MARGIN_MODE)
            result = engine.run_backtest(strategy_name)

            if result is None:
                failed += 1
                details.append((db_name, 'FAIL', 0, 0))
                continue

            paired = pair_trades(
                engine.trades, engine.trade_candle_indices,
                regime_timeline, LEVERAGE,
                candles=engine.candles,
                bars_per_funding=engine._bars_per_funding)

            save_combo(conn, db_name, coin, interval, result, paired,
                       initial_capital=INITIAL_CAPITAL, days=DAYS,
                       actual_candle_count=len(engine.candles),
                       bars_per_day=bars_per_day)
            conn.commit()
            completed += 1
            details.append((db_name, 'OK', result.total_return, len(paired)))

        except Exception as e:
            failed += 1
            details.append((db_name, 'ERROR: %s' % e, 0, 0))

    elapsed = time.time() - t0
    conn.close()

    return {'coin': coin, 'interval': interval, 'completed': completed,
            'skipped': skipped, 'failed': failed, 'elapsed': elapsed,
            'details': details}


def _split_candles(candles, n_segments=4, warmup=2000):
    """拆 K 线为 n 段，后续段前加 warmup 预热

    Returns: list of dict, 每个 dict 包含：
        'candles': 切片（含预热）
        'warmup_count': 前多少根是预热（不产生有效交易）
        'seg_start': 该段正式数据在全局的起始索引
        'seg_end': 该段正式数据在全局的结束索引（exclusive）
    """
    total = len(candles)
    seg_size = total // n_segments
    segments = []
    for i in range(n_segments):
        seg_start = i * seg_size
        seg_end = total if i == n_segments - 1 else (i + 1) * seg_size
        # 后续段前加预热
        if i > 0:
            warmup_start = max(0, seg_start - warmup)
            warmup_count = seg_start - warmup_start
        else:
            warmup_start = seg_start
            warmup_count = 0
        segments.append({
            'candles': candles[warmup_start:seg_end],
            'warmup_count': warmup_count,
            'seg_start': seg_start,
            'seg_end': seg_end,
        })
    return segments


def _worker_segment(coin: str, interval: str, strategies: List[str],
                    candles_slice: List[Dict], warmup_count: int,
                    seg_start: int, seg_end: int,
                    mirror: bool = False, db_path: str = None,
                    cache_db_path: str = None,
                    precomputed_indicators: Dict = None) -> Dict:
    """分段 Worker：接收 K 线切片，跑所有策略，返回 paired_trades（不写 DB）。

    与 _worker_coin_interval 类似，但：
    - 不自己加载 K 线（接收 candles_slice）
    - regime_timeline 用 compute_regime_timeline(candles_slice) 重算
    - paired_trades 的 candle_idx 加 seg_start 偏移转全局
    - 丢弃预热段内的交易（open_candle_idx 切片内 < warmup_count）
    - 不调 save_combo，只返回 paired_trades 列表
    - cache_db_path: 预裁剪的段指标 DB 路径，命中则不重算指标

    Returns:
        {
            'coin': coin, 'interval': interval,
            'seg_start': seg_start, 'seg_end': seg_end,
            'trades_by_strategy': {strategy_name: {...}, ...},
            'elapsed': elapsed_seconds,
        }
    """
    t0 = time.time()

    # 镜像模式：翻转切片
    if mirror:
        candles_slice = mirror_candles(candles_slice)

    bars_per_day = _BARS_PER_DAY_MAP.get(interval, 24)

    # regime_timeline 从切片重算（不从 DB 读，不污染原始 regime）
    regime_timeline = compute_regime_timeline(candles_slice, interval, 0)

    # 指标缓存：优先用预裁剪的段 DB（命中快），否则用纯内存（重算慢但安全）
    _cache_path = cache_db_path if cache_db_path and os.path.exists(cache_db_path) else ':memory:'
    _init_indicator_cache(coin, interval, candles_slice, db_path=_cache_path)

    # 预算指标：主进程传入切片后的指标数据，填入内存缓存避免重算
    if precomputed_indicators:
        from core.indicator_cache import _memory_caches
        _memory_caches['normal'].update(precomputed_indicators)

    trades_by_strategy = {}

    for strategy_name in strategies:
        db_name = strategy_name + "_mirror" if mirror else strategy_name

        # 跳过已完成的 combo
        if _worker_completed_set and (db_name, coin, interval) in _worker_completed_set:
            continue

        try:
            engine = BacktestEngine(
                coin=coin, interval=interval, days=DAYS,
                initial_capital=INITIAL_CAPITAL, enable_ttp=ENABLE_TTP,
                ttp_highlow=TTP_HIGHLOW,
                stop_loss_pct=STOP_LOSS_PCT, leverage=LEVERAGE,
                enable_withdraw=False, fixed_bet=FIXED_BET,
                candles=candles_slice, fixed_bet_amount=FIXED_BET_AMOUNT,
                fee_rate=FEE_RATE, slippage_pct=SLIPPAGE_PCT,
                funding_rate_8h=FUNDING_RATE_8H,
                margin_mode=MARGIN_MODE)
            result = engine.run_backtest(strategy_name)

            if result is None:
                trades_by_strategy[db_name] = {'formal': [], 'warmup': []}
                continue

            paired_raw = pair_trades(
                engine.trades, engine.trade_candle_indices,
                regime_timeline, LEVERAGE,
                candles=engine.candles,
                bars_per_funding=engine._bars_per_funding)

            # 偏移 candle_idx 转全局，分离预热区和正式区交易
            paired_formal = []
            paired_warmup = []
            for p in paired_raw:
                local_open = p['open_candle_idx']
                local_close = p['close_candle_idx']
                # 转全局索引
                p = dict(p)
                if local_open is not None:
                    p['open_candle_idx'] = (local_open - warmup_count) + seg_start
                if local_close is not None:
                    p['close_candle_idx'] = (local_close - warmup_count) + seg_start
                # 分流：预热区 vs 正式区
                if local_open is not None and local_open < warmup_count:
                    paired_warmup.append(p)
                else:
                    paired_formal.append(p)

            trades_by_strategy[db_name] = {
                'formal': paired_formal,
                'warmup': paired_warmup,
            }

        except Exception as e:
            trades_by_strategy[db_name] = {'formal': [], 'warmup': []}

    elapsed = time.time() - t0
    return {
        'coin': coin,
        'interval': interval,
        'seg_start': seg_start,
        'seg_end': seg_end,
        'trades_by_strategy': trades_by_strategy,
        'elapsed': elapsed,
    }


def _merge_segment_trades(segment_results, n_validate=3, fallback_skip=500):
    """合并 4 段的交易结果 + 吻合验证。

    吻合验证原理：
    后段的预热区（2000根）跟前段正式区的尾部有重叠。
    如果两段在重叠区产生了相同的交易 → 指标已收敛 → 安全合并。
    不吻合 → 后段跳过 fallback_skip 根后才取交易。

    Returns:
        {strategy_name: {'trades': [merged list], 'validation': [per-boundary results]}}
    """
    all_strategies = set()
    for seg in segment_results:
        all_strategies.update(seg['trades_by_strategy'].keys())

    merged = {}

    for strategy_name in all_strategies:
        sorted_segs = sorted(segment_results, key=lambda s: s['seg_start'])

        all_trades = []
        validation_log = []

        for seg_idx, seg in enumerate(sorted_segs):
            seg_data = seg['trades_by_strategy'].get(strategy_name, {'formal': [], 'warmup': []})
            formal_trades = seg_data['formal']
            warmup_trades = seg_data['warmup']
            seg_start = seg['seg_start']

            if seg_idx == 0:
                all_trades.extend(formal_trades)
                continue

            # 吻合验证：后段预热区交易 vs 前段同时间范围的交易
            # 预热区交易的全局 candle_idx 在 [seg_start - warmup实际数, seg_start) 范围
            # 前段的正式区交易中，落在这个范围的交易
            if warmup_trades:
                warmup_min_idx = min(t['open_candle_idx'] for t in warmup_trades)
                warmup_max_idx = max(t['open_candle_idx'] for t in warmup_trades)
                # 前段在重叠区的交易
                prev_overlap = [t for t in all_trades
                                if t['open_candle_idx'] is not None
                                and warmup_min_idx <= t['open_candle_idx'] <= warmup_max_idx]
                # 取后 n_validate 笔做对比
                prev_check = prev_overlap[-n_validate:] if prev_overlap else []
                warmup_check = warmup_trades[-n_validate:] if warmup_trades else []

                match_count = 0
                check_count = min(len(prev_check), len(warmup_check))
                for pi, ci in zip(prev_check[-check_count:], warmup_check[-check_count:]):
                    if (pi.get('open_time') == ci.get('open_time') and
                            pi.get('direction') == ci.get('direction') and
                            abs(pi.get('entry_price', 0) - ci.get('entry_price', 0)) < 1e-6):
                        match_count += 1
                matched = match_count == check_count and check_count > 0
            else:
                matched = True  # 无预热交易 = 第一段或空段
                check_count = 0

            if matched:
                # 直接取正式区交易
                all_trades.extend(formal_trades)
                validation_log.append({
                    'boundary': seg_idx, 'status': 'matched',
                    'checked': check_count, 'matched': check_count,
                })
            else:
                # 不吻合：跳过 fallback_skip 根后才取
                skip_until = seg_start + fallback_skip
                filtered = [t for t in formal_trades
                            if t['open_candle_idx'] is not None
                            and t['open_candle_idx'] >= skip_until]
                all_trades.extend(filtered)
                skipped = len(formal_trades) - len(filtered)
                validation_log.append({
                    'boundary': seg_idx, 'status': 'fallback',
                    'checked': check_count, 'matched': match_count,
                    'skipped_trades': skipped,
                })

        all_trades.sort(key=lambda t: t.get('open_candle_idx', 0))
        merged[strategy_name] = {
            'trades': all_trades,
            'validation': validation_log,
        }

    return merged


def _rebuild_combo_summary_from_trades(paired_trades: List[Dict], strategy: str,
                                       coin: str, interval: str,
                                       conn: sqlite3.Connection) -> None:
    """从合并后的 paired_trades 重算 combo_summary 并写入 DB。

    不依赖 BacktestResult 对象，直接从 paired 列表计算所有汇总字段，
    然后 INSERT INTO combo_summary + paired_trades。
    """
    bars_per_day = _BARS_PER_DAY_MAP.get(interval, 24)

    total_trades = len(paired_trades)
    winning_trades = len([t for t in paired_trades if t['pnl'] > 0])
    losing_trades = total_trades - winning_trades
    win_rate = winning_trades / total_trades * 100.0 if total_trades > 0 else 0.0

    # Balance 曲线重建
    sorted_trades = sorted(paired_trades, key=lambda x: x['open_candle_idx'] if x['open_candle_idx'] is not None else 0)
    balance = [INITIAL_CAPITAL]
    for t in sorted_trades:
        balance.append(balance[-1] + t['pnl'])

    total_return = (balance[-1] - INITIAL_CAPITAL) / INITIAL_CAPITAL * 100.0 if INITIAL_CAPITAL > 0 else 0.0
    final_balance = balance[-1]
    max_balance = max(balance)
    min_balance = min(balance)

    # max_drawdown：peak-to-trough
    max_drawdown = 0.0
    peak = balance[0]
    for b in balance:
        if b > peak:
            peak = b
        dd = (peak - b) / peak * 100.0 if peak > 0 else 0.0
        if dd > max_drawdown:
            max_drawdown = dd

    ttp_count = len([t for t in paired_trades if 'TTP' in t.get('close_type', '')])
    signal_close_count = len([t for t in paired_trades
                               if 'CLOSE' in t.get('close_type', '') and 'TTP' not in t.get('close_type', '')])

    winning_pnl = [t['pnl'] for t in paired_trades if t['pnl'] > 0]
    losing_pnl = [t['pnl'] for t in paired_trades if t['pnl'] <= 0]

    avg_win_pct = (sum(winning_pnl) / len(winning_pnl) / INITIAL_CAPITAL * 100.0) if winning_pnl else 0.0
    avg_loss_pct = (sum(abs(p) for p in losing_pnl) / len(losing_pnl) / INITIAL_CAPITAL * 100.0) if losing_pnl else 0.0

    sum_win = sum(winning_pnl)
    sum_loss = abs(sum(losing_pnl))
    profit_factor = sum_win / sum_loss if sum_loss > 0 else 999.0

    max_win = max([t['pnl'] for t in paired_trades]) if paired_trades else 0.0
    max_loss = min([t['pnl'] for t in paired_trades]) if paired_trades else 0.0

    # 翻倍次数
    double_count = 0
    fastest_double_days = 0
    avg_double_days = 0.0
    double_target = INITIAL_CAPITAL * 2.0
    double_times = []
    current_target = double_target
    for i, b in enumerate(balance):
        if b >= current_target:
            double_count += 1
            days_taken = i // bars_per_day if bars_per_day > 0 else 0
            double_times.append(days_taken)
            current_target = b * 2.0
    if double_times:
        fastest_double_days = min(double_times)
        avg_double_days = sum(double_times) / len(double_times)

    # daily_open_positions
    total_candles = len(balance) - 1
    daily_open_positions = total_trades / (total_candles / bars_per_day) if total_candles > 0 and bars_per_day > 0 else 0.0

    # 总手续费
    total_fees = sum(t.get('fee', 0) + t.get('funding_cost', 0) + t.get('slippage_cost', 0) for t in paired_trades)

    # 盈亏比
    avg_win_amt = sum(winning_pnl) / len(winning_pnl) if winning_pnl else 0.0
    avg_loss_amt = sum(abs(p) for p in losing_pnl) / len(losing_pnl) if losing_pnl else 0.0
    reward_risk = avg_win_amt / avg_loss_amt if avg_loss_amt > 0 else 0.0

    # 期望比率
    wr = win_rate / 100.0
    expectancy_ratio = (wr * avg_win_pct / 100.0) - ((1 - wr) * avg_loss_pct / 100.0)

    # 最大连续亏损金额
    max_consec_loss_amt = 0.0
    current_loss_amt = 0.0
    for t in sorted_trades:
        if t['pnl'] < 0:
            current_loss_amt += t['pnl']
            if abs(current_loss_amt) > abs(max_consec_loss_amt):
                max_consec_loss_amt = current_loss_amt
        else:
            current_loss_amt = 0.0

    # 最大单日回撤
    max_daily_dd = 0.0
    daily_pnl = {}
    for t in sorted_trades:
        day = t['close_time'][:10] if t.get('close_time') else ''
        if day:
            daily_pnl[day] = daily_pnl.get(day, 0.0) + t['pnl']
    if daily_pnl:
        max_daily_dd = min(daily_pnl.values())

    # 最长连胜/连亏
    longest_win_streak = 0
    longest_loss_streak = 0
    cur_win = 0
    cur_loss = 0
    for t in sorted_trades:
        if t['pnl'] > 0:
            cur_win += 1
            cur_loss = 0
            longest_win_streak = max(longest_win_streak, cur_win)
        else:
            cur_loss += 1
            cur_win = 0
            longest_loss_streak = max(longest_loss_streak, cur_loss)

    # CAGR（设为 0，后续可优化）
    cagr = 0.0
    sharpe_ratio = 0.0
    sortino_ratio = 0.0
    calmar_ratio = 0.0

    cur = conn.execute(
        "INSERT INTO combo_summary "
        "(strategy, coin, interval, total_return, final_balance, "
        "max_drawdown, sharpe_ratio, sortino_ratio, calmar_ratio, "
        "total_trades, winning_trades, losing_trades, win_rate, "
        "avg_win_pct, avg_loss_pct, profit_factor, ttp_count, "
        "double_count, fastest_double_days, avg_double_days, daily_open_positions, "
        "cagr, max_daily_dd, reward_risk, max_consec_loss_amt, total_fees, "
        "max_balance, min_balance, max_win, max_loss, "
        "expectancy_ratio, longest_win_streak, longest_loss_streak, signal_close_count, "
        "backtest_time) "
        "VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
        (strategy, coin, interval,
         total_return, final_balance,
         max_drawdown, sharpe_ratio, sortino_ratio, calmar_ratio,
         total_trades, winning_trades, losing_trades, win_rate,
         avg_win_pct, avg_loss_pct, profit_factor, ttp_count,
         double_count, fastest_double_days, avg_double_days, daily_open_positions,
         cagr, max_daily_dd, reward_risk, max_consec_loss_amt, total_fees,
         max_balance, min_balance, max_win, max_loss,
         expectancy_ratio, longest_win_streak, longest_loss_streak, signal_close_count,
         datetime.now().strftime('%Y-%m-%d %H:%M'))
    )
    combo_id = cur.lastrowid

    if paired_trades:
        conn.executemany(
            "INSERT INTO paired_trades "
            "(combo_id, open_candle_idx, close_candle_idx, open_time, close_time, "
            "holding_bars, direction, entry_price, exit_price, capital, position_size, "
            "pnl, r_value, balance_after, close_type, regime_at_open, "
            "fee, funding_cost, slippage_cost, mfe, mae, open_atr_pct, open_volume, funding_count) "
            "VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
            [(combo_id, p['open_candle_idx'], p['close_candle_idx'],
              p['open_time'], p['close_time'], p['holding_bars'],
              p['direction'], p['entry_price'], p['exit_price'],
              p['capital'], p['position_size'], p['pnl'], p['r_value'],
              p['balance_after'], p['close_type'], p['regime_at_open'],
              p['fee'], p['funding_cost'], p['slippage_cost'],
              p['mfe'], p['mae'], p['open_atr_pct'], p['open_volume'], p['funding_count'])
             for p in paired_trades]
        )


def _prepare_segment_indicator_caches(coin, interval, segments, full_candle_count):
    """预裁剪指标缓存：从完整 indicator_cache.db 读指标，切片写入临时段 DB。

    每段的临时 DB 路径：reports/indicator_cache_seg_{n}.db
    Worker 启动时 init_cache 指向对应临时 DB → candle_count 匹配 → cache 命中。

    Returns: list of temp DB paths (跑完后要删)
    """
    import zlib

    src_db = os.path.join(REPORT_DIR, 'indicator_cache.db')
    if not os.path.exists(src_db):
        print("  ⚠️ indicator_cache.db 不存在，跳过指标预裁剪")
        return []

    src_conn = sqlite3.connect(src_db)
    # 读该 coin/interval 的所有完整指标（只取 candle_count 匹配的）
    rows = src_conn.execute(
        "SELECT indicator, params, data, candle_count FROM indicator_cache "
        "WHERE coin=? AND interval=? AND candle_count=?",
        (coin, interval, full_candle_count)
    ).fetchall()
    src_conn.close()

    if not rows:
        print("  ⚠️ indicator_cache.db 无 %s/%s 完整指标，跳过预裁剪" % (coin, interval))
        return []

    print("  📐 指标预裁剪: %d 条指标 × %d 段" % (len(rows), len(segments)))

    temp_dbs = []
    for seg_idx, seg in enumerate(segments):
        seg_start = seg['seg_start']
        seg_end = seg['seg_end']
        warmup_start = seg_start - seg['warmup_count']
        # 切片范围（含预热）
        slice_start = warmup_start
        slice_end = seg_end
        slice_len = slice_end - slice_start

        temp_path = os.path.join(REPORT_DIR, 'indicator_cache_seg_%d.db' % seg_idx)
        temp_conn = sqlite3.connect(temp_path)
        temp_conn.execute("""
            CREATE TABLE IF NOT EXISTS indicator_cache (
                coin TEXT, interval TEXT, indicator TEXT, params TEXT,
                data BLOB, candle_count INTEGER,
                PRIMARY KEY (coin, interval, indicator, params)
            )
        """)

        for indicator, params, data_blob, cc in rows:
            # 解压完整指标
            raw = json.loads(zlib.decompress(data_blob).decode())

            # 切片
            if isinstance(raw, dict):
                # 多值指标（如 MACD: {macd: [...], signal: [...], histogram: [...]}）
                sliced = {k: v[slice_start:slice_end] for k, v in raw.items()}
            elif isinstance(raw, list):
                # 单值指标
                sliced = raw[slice_start:slice_end]
            else:
                continue

            # 压缩写入
            sliced_blob = zlib.compress(json.dumps(sliced).encode())
            temp_conn.execute(
                "INSERT OR REPLACE INTO indicator_cache "
                "(coin, interval, indicator, params, data, candle_count) "
                "VALUES (?, ?, ?, ?, ?, ?)",
                (coin, interval, indicator, params, sliced_blob, slice_len)
            )

        temp_conn.commit()
        temp_conn.close()
        temp_dbs.append(temp_path)

    return temp_dbs


def _run_1m_segmented(tasks_1m, strategies, mirror, n_workers, completed_set, worker_config):
    """1m 周期分段并行处理

    对每个 coin：
    1. 加载完整 K 线 → 拆 4 段（各 ~52.5 万根，预热 2000 根）
    2. 4 个 worker 并行跑 4 段
    3. 合并 + 吻合验证
    4. 从 trades 重算 combo_summary + 写入主库
    """
    total_completed = 0
    total_skipped = 0
    total_failed = 0

    for coin, iv in tasks_1m:
        print("  ⚡ [%s/1m] 分段并行开始..." % coin)
        t0 = time.time()

        # 加载完整 K 线
        all_candles = load_candles(coin, iv)
        if not all_candles or len(all_candles) < MIN_KLINES:
            print("  ⏭️  [%s/1m] K线不足，跳过" % coin)
            total_skipped += len(strategies)
            continue

        # 镜像翻转
        if mirror:
            all_candles = mirror_candles(all_candles)

        # 检查哪些策略已完成（断点续传）
        remaining = []
        for s in strategies:
            db_name = s + "_mirror" if mirror else s
            if (db_name, coin, iv) in completed_set:
                total_skipped += 1
            else:
                remaining.append(s)

        if not remaining:
            print("  ⏭️  [%s/1m] 全部已完成，跳过" % coin)
            continue

        # 拆成 4 段
        segments = _split_candles(all_candles, n_segments=n_workers, warmup=2000)

        # 预裁剪指标缓存
        full_candle_count = len(all_candles)
        cache_namespace = 'flipped' if mirror else 'normal'
        temp_cache_dbs = _prepare_segment_indicator_caches(
            coin, iv, segments, full_candle_count)

        # 4 段并行跑
        with ProcessPoolExecutor(max_workers=n_workers,
                                 initializer=_init_worker,
                                 initargs=(worker_config,)) as executor:
            futures = {}
            for seg_idx, seg in enumerate(segments):
                # 传临时 cache DB 路径给 worker
                cache_db = temp_cache_dbs[seg_idx] if seg_idx < len(temp_cache_dbs) else None
                future = executor.submit(
                    _worker_segment, coin, iv, remaining,
                    seg['candles'], seg['warmup_count'],
                    seg['seg_start'], seg['seg_end'],
                    mirror=False,  # 已经在主进程翻转过了
                    cache_db_path=cache_db
                )
                futures[future] = seg_idx

            # 等全部完成
            seg_results = [None] * len(segments)
            for future in futures:
                seg_idx = futures[future]
                try:
                    seg_results[seg_idx] = future.result()
                except Exception as e:
                    print("  ❌ [%s/1m] 段 %d 异常: %s" % (coin, seg_idx, e))

        # 过滤掉失败的段
        seg_results = [r for r in seg_results if r is not None]
        if not seg_results:
            total_failed += len(remaining)
            continue

        # 合并 + 吻合验证
        merged = _merge_segment_trades(seg_results)

        # 写入主库
        conn = init_db(DB_PATH)
        for strategy_name in remaining:
            db_name = strategy_name + "_mirror" if mirror else strategy_name
            if (db_name, coin, iv) in completed_set:
                continue

            merge_data = merged.get(db_name, {'trades': [], 'validation': []})
            trades = merge_data['trades']
            validation = merge_data['validation']

            if not trades:
                total_failed += 1
                continue

            # 打印吻合验证结果
            for v in validation:
                if v['status'] == 'fallback':
                    print("  ⚠️  [%s/1m] %s 段 %d 不吻合，跳过 %d 笔" % (
                        coin, db_name, v['boundary'], v.get('skipped_trades', 0)))

            # 从 trades 重算 combo_summary + 写入
            _rebuild_combo_summary_from_trades(trades, db_name, coin, iv, conn)
            total_completed += 1

            ret = (trades[-1].get('balance_after', 0) - INITIAL_CAPITAL) / INITIAL_CAPITAL * 100 if trades else 0
            print("  [%s/1m] %-22s -> %.1f%% | %d笔" % (coin, db_name, ret, len(trades)))

        conn.commit()
        conn.close()

        # 清理临时指标 DB
        for tmp_db in temp_cache_dbs:
            if os.path.exists(tmp_db):
                os.remove(tmp_db)

        elapsed = time.time() - t0
        print("  ⚡ [%s/1m] 完成 (%.1fs, %d新)\n" % (coin, elapsed, len(remaining)))

    return total_completed, total_skipped, total_failed


def _init_worker(config):
    """ProcessPoolExecutor initializer — 在每个 worker 进程里设置全局变量"""
    global ENABLE_TTP, TTP_HIGHLOW, DAYS, INITIAL_CAPITAL, LEVERAGE, STOP_LOSS_PCT
    global FIXED_BET, FIXED_BET_AMOUNT, FEE_RATE, SLIPPAGE_PCT
    global FUNDING_RATE_8H, MIN_KLINES, DATA_DIR, _worker_completed_set, MARGIN_MODE
    ENABLE_TTP = config['enable_ttp']
    TTP_HIGHLOW = config.get('ttp_highlow', True)
    DAYS = config['days']
    INITIAL_CAPITAL = config['initial_capital']
    LEVERAGE = config['leverage']
    STOP_LOSS_PCT = config['stop_loss_pct']
    FIXED_BET = config['fixed_bet']
    FIXED_BET_AMOUNT = config['fixed_bet_amount']
    FEE_RATE = config['fee_rate']
    SLIPPAGE_PCT = config['slippage_pct']
    FUNDING_RATE_8H = config['funding_rate_8h']
    MIN_KLINES = config['min_klines']
    DATA_DIR = config['data_dir']
    _worker_completed_set = config.get('completed_set', set())
    MARGIN_MODE = config.get('margin_mode', 'linear')


def merge_worker_db(main_db_path: str, temp_db_path: str) -> Tuple[int, int]:
    """合并 worker 临时 DB 到主库。

    逐条搬运 combo_summary + paired_trades（ID 重映射），
    regime_timeline 用 INSERT OR IGNORE 天然去重。

    Returns: (merged_count, skipped_count)
    """
    if not os.path.exists(temp_db_path):
        return 0, 0

    conn = sqlite3.connect(main_db_path)
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("PRAGMA busy_timeout=120000")
    conn.execute("PRAGMA synchronous=NORMAL")
    conn.execute("ATTACH DATABASE ? AS tmp", (temp_db_path,))

    # 读临时库所有 combo
    combos = conn.execute(
        "SELECT id, strategy, coin, interval, total_return, final_balance, "
        "max_drawdown, sharpe_ratio, sortino_ratio, calmar_ratio, "
        "total_trades, winning_trades, losing_trades, win_rate, "
        "avg_win_pct, avg_loss_pct, profit_factor, ttp_count, "
        "double_count, fastest_double_days, avg_double_days, daily_open_positions, "
        "cagr, max_daily_dd, reward_risk, max_consec_loss_amt, total_fees, "
        "max_balance, min_balance, max_win, max_loss, "
        "expectancy_ratio, longest_win_streak, longest_loss_streak, signal_close_count, "
        "backtest_time FROM tmp.combo_summary"
    ).fetchall()

    merged = 0
    skipped = 0

    for combo in combos:
        old_id = combo[0]
        strategy, coin, interval = combo[1], combo[2], combo[3]

        # 断点恢复：主库已有就跳过
        if conn.execute(
            "SELECT 1 FROM combo_summary WHERE strategy=? AND coin=? AND interval=?",
            (strategy, coin, interval)
        ).fetchone():
            skipped += 1
            continue

        # 插入 combo（去掉 old_id，让主库 autoincrement）
        cur = conn.execute(
            "INSERT INTO combo_summary "
            "(strategy, coin, interval, total_return, final_balance, "
            "max_drawdown, sharpe_ratio, sortino_ratio, calmar_ratio, "
            "total_trades, winning_trades, losing_trades, win_rate, "
            "avg_win_pct, avg_loss_pct, profit_factor, ttp_count, "
            "double_count, fastest_double_days, avg_double_days, daily_open_positions, "
            "cagr, max_daily_dd, reward_risk, max_consec_loss_amt, total_fees, "
            "max_balance, min_balance, max_win, max_loss, "
            "expectancy_ratio, longest_win_streak, longest_loss_streak, signal_close_count, "
            "backtest_time) "
            "VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
            combo[1:]
        )
        new_id = cur.lastrowid

        # 搬 paired_trades（combo_id 从 old_id 映射到 new_id）
        conn.execute(
            "INSERT INTO paired_trades "
            "(combo_id, open_candle_idx, close_candle_idx, open_time, close_time, "
            "holding_bars, direction, entry_price, exit_price, capital, position_size, "
            "pnl, r_value, balance_after, close_type, regime_at_open, "
            "fee, funding_cost, slippage_cost, mfe, mae, open_atr_pct, open_volume, funding_count) "
            "SELECT ?, open_candle_idx, close_candle_idx, open_time, close_time, "
            "holding_bars, direction, entry_price, exit_price, capital, position_size, "
            "pnl, r_value, balance_after, close_type, regime_at_open, "
            "fee, funding_cost, slippage_cost, mfe, mae, open_atr_pct, open_volume, funding_count "
            "FROM tmp.paired_trades WHERE combo_id=?",
            (new_id, old_id)
        )
        merged += 1

    # regime_timeline：UNIQUE INDEX 天然去重
    conn.execute(
        "INSERT OR IGNORE INTO regime_timeline "
        "SELECT * FROM tmp.regime_timeline"
    )

    conn.commit()
    conn.execute("DETACH DATABASE tmp")
    conn.close()

    # 合并完删临时文件
    try:
        os.remove(temp_db_path)
        wal = temp_db_path + '-wal'
        shm = temp_db_path + '-shm'
        if os.path.exists(wal):
            os.remove(wal)
        if os.path.exists(shm):
            os.remove(shm)
    except OSError:
        pass

    return merged, skipped


def _recover_orphaned_temps(main_db_path: str, temp_dir: str) -> int:
    """恢复上次崩溃遗留的临时 DB — 合并后删除"""
    if not os.path.isdir(temp_dir):
        return 0
    recovered = 0
    for f in sorted(os.listdir(temp_dir)):
        if f.startswith('seed_tmp_') and f.endswith('.db'):
            temp_path = os.path.join(temp_dir, f)
            m, s = merge_worker_db(main_db_path, temp_path)
            if m > 0:
                print("  ♻️  恢复临时文件 %s: %d 组合并" % (f, m))
                recovered += m
    return recovered


def _run_seed_parallel(args, coins, intervals, strategies, all_coins, all_intervals,
                       mirror=False, n_workers=4):
    """并行执行种子生成（分库写 → 合并）"""
    total = len(strategies) * len(coins) * len(intervals)
    n_regime = len(coins) * len(intervals)
    phase = "🪞镜像" if mirror else "普通"

    print("=" * 90)
    print("  种子报告生成器 — %s（%d 并行）" % (phase, n_workers))
    print("  检测到: %d 币种 %d 周期 | 本次运行: %d 币种 %d 周期" % (
        len(all_coins), len(all_intervals), len(coins), len(intervals)))
    print("  币种: %s" % ", ".join(coins))
    print("  周期: %s" % ", ".join(intervals))
    print("  %d 策略 × %d 币种 × %d 周期 = %d 组回测" % (
        len(strategies), len(coins), len(intervals), total))
    print("  + %d 组 regime 时间线" % n_regime)
    days_str = "全量数据" if DAYS == 0 else "%d天" % DAYS
    mirror_str = " · 🪞镜像模式" if mirror else ""
    print("  参数：%s · $%d · %.0fx · 止损%.0f%% · TTP%s · 固定注码$%d%s" % (
        days_str, INITIAL_CAPITAL, LEVERAGE, STOP_LOSS_PCT * 100,
        '开' if ENABLE_TTP else '关', FIXED_BET_AMOUNT, mirror_str))
    print("  成本：手续费%.3f%%/侧 · 滑点%.2f%%/侧 · 资金费%.2f%%/8h" % (
        FEE_RATE * 100, SLIPPAGE_PCT * 100, FUNDING_RATE_8H * 100))
    print("  输出：%s" % DB_PATH)
    print("  内存上限：%d MB | 1m 最多同时 1 个" % _MEM_LIMIT_MB)
    print("=" * 90)
    print()

    # 初始化主库
    conn = init_db(DB_PATH)

    # 保存运行元数据
    meta_key_prefix = "mirror_" if mirror else ""
    save_metadata(conn, {
        'days': DAYS, 'initial_capital': INITIAL_CAPITAL,
        'leverage': LEVERAGE, 'stop_loss_pct': STOP_LOSS_PCT,
        'enable_ttp': ENABLE_TTP, 'fixed_bet': FIXED_BET,
        'fixed_bet_amount': FIXED_BET_AMOUNT, 'fee_rate': FEE_RATE,
        'slippage_pct': SLIPPAGE_PCT, 'funding_rate_8h': FUNDING_RATE_8H,
        'coins': coins, 'intervals': intervals, 'strategies': strategies,
        'total_combos': total,
        '%sstart_time' % meta_key_prefix: datetime.now().isoformat(),
        'schema_version': 'v2',
    })

    # 读取主库已完成的 combo（断点恢复用）
    completed_set = set()
    for row in conn.execute("SELECT strategy, coin, interval FROM combo_summary"):
        completed_set.add((row[0], row[1], row[2]))
    if completed_set:
        print("  📋 主库已有 %d 组（断点恢复跳过）" % len(completed_set))

    conn.close()

    # 恢复上次崩溃遗留的临时 DB
    temp_dir = os.path.join(os.path.dirname(DB_PATH), 'seed_tmp')
    os.makedirs(temp_dir, exist_ok=True)
    recovered = _recover_orphaned_temps(DB_PATH, temp_dir)
    if recovered > 0:
        # 恢复后重新读取已完成集合
        conn = sqlite3.connect(DB_PATH)
        completed_set = set()
        for row in conn.execute("SELECT strategy, coin, interval FROM combo_summary"):
            completed_set.add((row[0], row[1], row[2]))
        conn.close()

    # Worker 初始化配置
    worker_config = {
        'enable_ttp': ENABLE_TTP, 'ttp_highlow': TTP_HIGHLOW,
        'days': DAYS,
        'initial_capital': INITIAL_CAPITAL, 'leverage': LEVERAGE,
        'stop_loss_pct': STOP_LOSS_PCT, 'fixed_bet': FIXED_BET,
        'fixed_bet_amount': FIXED_BET_AMOUNT, 'fee_rate': FEE_RATE,
        'slippage_pct': SLIPPAGE_PCT, 'funding_rate_8h': FUNDING_RATE_8H,
        'min_klines': MIN_KLINES, 'data_dir': DATA_DIR,
        'completed_set': completed_set,
    }

    # 构建任务列表（小周期优先，跑完快释放内存）
    # 预过滤：跳过所有策略都已完成的 coin/interval，避免白白加载K线
    interval_order = ['1d', '12h', '8h', '4h', '2h', '1h', '30m', '15m', '5m', '1m']
    task_list = []
    pre_skipped = 0
    for iv in interval_order:
        if iv in intervals:
            for coin in coins:
                # 检查该 coin/interval 下是否所有策略都已跑完
                all_done = all(
                    (s + ("_mirror" if mirror else ""), coin, iv) in completed_set
                    for s in strategies
                )
                if all_done:
                    pre_skipped += len(strategies)
                else:
                    task_list.append((coin, iv))
    if pre_skipped:
        print("  ⏭️  预过滤跳过 %d 组（coin/interval 全部已完成）" % pre_skipped)

    # ── 分离 1m 任务（分段并行处理） ──
    tasks_1m = [(c, iv) for c, iv in task_list if iv == '1m']
    task_list = [(c, iv) for c, iv in task_list if iv != '1m']

    n_tasks = len(task_list)
    start_all = time.time()
    total_completed = 0
    total_skipped = pre_skipped
    total_failed = 0
    done_count = 0

    # ── 先跑 1m 分段并行 ──
    if tasks_1m:
        print("\n  ⚡ 1m 时间段拆分并行: %d 个币种 × 4 段" % len(tasks_1m))
        seg_completed, seg_skipped, seg_failed = _run_1m_segmented(
            tasks_1m, strategies, mirror, n_workers, completed_set, worker_config)
        total_completed += seg_completed
        total_skipped += seg_skipped
        total_failed += seg_failed
        done_count += len(tasks_1m)
        print("  ⚡ 1m 完成: %d新 %d跳 %d败\n" % (seg_completed, seg_skipped, seg_failed))

    if not task_list:
        # 只有 1m 任务
        elapsed_all = time.time() - start_all
        meta_key_prefix = "mirror_" if mirror else ""
        meta_conn = init_db(DB_PATH)
        save_metadata(meta_conn, {
            '%send_time' % meta_key_prefix: datetime.now().isoformat(),
            '%selapsed_minutes' % meta_key_prefix: round(elapsed_all / 60, 1),
        })
        meta_conn.close()
        print("\n" + "=" * 90)
        print("  %s 完成 (耗时 %.1f 分钟)" % (("🪞镜像" if mirror else "普通"), elapsed_all / 60))
        print("  新增: %d | 跳过(已有): %d | 失败: %d" % (
            total_completed, total_skipped, total_failed))
        print("=" * 90)
        return total_completed, total_skipped, total_failed

    with ProcessPoolExecutor(max_workers=n_workers,
                             initializer=_init_worker,
                             initargs=(worker_config,)) as executor:
        pending = list(task_list)
        active = {}  # future -> (coin, iv, temp_db, mem_mb)

        while pending or active:
            # 提交新任务（检查内存+1m限制）
            submitted = True
            while submitted and pending and len(active) < n_workers:
                submitted = False
                current_mem = sum(m for _, _, _, m in active.values())
                has_1m = any(i == '1m' for _, i, _, _ in active.values())

                for idx, (coin, iv) in enumerate(pending):
                    mem = _MEM_ESTIMATE.get(iv, 100)

                    # 内存超限
                    if current_mem + mem > _MEM_LIMIT_MB and active:
                        continue
                    # 不允许同时跑 2 个 1m
                    if iv == '1m' and has_1m:
                        continue

                    # 提交任务
                    pending.pop(idx)
                    temp_db = os.path.join(
                        temp_dir,
                        'seed_tmp_%s_%s%s.db' % (coin, iv, '_mirror' if mirror else '')
                    )
                    future = executor.submit(
                        _worker_coin_interval, coin, iv, strategies,
                        mirror, temp_db
                    )
                    active[future] = (coin, iv, temp_db, mem)
                    submitted = True
                    print("  🚀 %s/%s (~%dMB) 开始" % (coin, iv, mem))
                    break

            # 等待任意一个完成
            if not active:
                break

            done_futures = [f for f in active if f.done()]
            if not done_futures:
                time.sleep(0.5)
                continue

            for future in done_futures:
                coin, iv, temp_db, mem = active.pop(future)
                try:
                    result = future.result()
                except Exception as e:
                    print("  ❌ %s/%s 进程异常: %s" % (coin, iv, e))
                    total_failed += len(strategies)
                    done_count += 1
                    continue

                if result.get('msg'):
                    print("  [!] %s/%s: %s，跳过" % (coin, iv, result['msg']))
                else:
                    # 打印各策略结果
                    for sname, status, ret, n_paired in result['details']:
                        symbol = "+" if ret > 0 else ""
                        if status == 'OK':
                            print("  [%s/%s] %-22s -> %s%.1f%% | %d笔" % (
                                coin, iv, sname, symbol, ret, n_paired))
                        else:
                            print("  [%s/%s] %-22s -> %s" % (coin, iv, sname, status))

                # 合并到主库
                if os.path.exists(temp_db):
                    m, s = merge_worker_db(DB_PATH, temp_db)
                    result['merged'] = m

                comp = result['completed']
                skip = result['skipped']
                fail = result['failed']
                total_completed += comp
                total_skipped += skip
                total_failed += fail
                done_count += 1

                elapsed = time.time() - start_all
                if done_count > 0:
                    avg = elapsed / done_count
                    eta = avg * (n_tasks - done_count)
                    active_str = ", ".join("%s/%s" % (c, i)
                                          for _, (c, i, _, _) in
                                          [(0, v) for v in active.values()])
                    print("    → %s/%s 完成 (%d新 %d跳过) %.1fs | "
                          "进度 %d/%d | ETA %.0fmin | 并行: [%s]" % (
                              coin, iv, comp, skip,
                              result.get('elapsed', 0),
                              done_count, n_tasks, eta / 60,
                              active_str))
                    print()

    elapsed_all = time.time() - start_all

    # 保存结束元数据
    meta_conn = init_db(DB_PATH)
    save_metadata(meta_conn, {
        '%send_time' % meta_key_prefix: datetime.now().isoformat(),
        '%selapsed_minutes' % meta_key_prefix: round(elapsed_all / 60, 1),
    })
    meta_conn.close()

    print("\n" + "=" * 90)
    print("  %s 完成 (耗时 %.1f 分钟, %d 并行)" % (phase, elapsed_all / 60, n_workers))
    print("  新增: %d | 跳过(已有): %d | 失败: %d" % (
        total_completed, total_skipped, total_failed))
    print("=" * 90)

    return total_completed, total_skipped, total_failed


def _run_seed(args, coins, intervals, strategies, all_coins, all_intervals, mirror=False):
    """执行一轮种子生成（普通或镜像）"""
    total = len(strategies) * len(coins) * len(intervals)
    n_regime = len(coins) * len(intervals)

    phase = "🪞镜像" if mirror else "普通"
    print("=" * 90)
    print("  种子报告生成器 — %s" % phase)
    print("  检测到: %d 币种 %d 周期 | 本次运行: %d 币种 %d 周期" % (
        len(all_coins), len(all_intervals), len(coins), len(intervals)))
    print("  币种: %s" % ", ".join(coins))
    print("  周期: %s" % ", ".join(intervals))
    print("  %d 策略 × %d 币种 × %d 周期 = %d 组回测" % (
        len(strategies), len(coins), len(intervals), total))
    print("  + %d 组 regime 时间线" % n_regime)
    days_str = "全量数据" if DAYS == 0 else "%d天" % DAYS
    mirror_str = " · 🪞镜像模式" if mirror else ""
    print("  参数：%s · $%d · %.0fx · 止损%.0f%% · TTP%s · 固定注码$%d%s" % (
        days_str, INITIAL_CAPITAL, LEVERAGE, STOP_LOSS_PCT * 100,
        '开' if ENABLE_TTP else '关', FIXED_BET_AMOUNT, mirror_str))
    print("  成本：手续费%.3f%%/侧 · 滑点%.2f%%/侧 · 资金费%.2f%%/8h" % (
        FEE_RATE * 100, SLIPPAGE_PCT * 100, FUNDING_RATE_8H * 100))
    print("  输出：%s" % DB_PATH)
    print("=" * 90)
    print()

    conn = init_db(DB_PATH)

    # --strategy 指定策略时，先清除旧数据（重跑用）
    if args.strategy:
        for s in strategies:
            db_s = s + "_mirror" if mirror else s
            combo_ids = [r[0] for r in conn.execute(
                "SELECT id FROM combo_summary WHERE strategy=?", (db_s,)).fetchall()]
            if combo_ids:
                placeholders = ','.join('?' * len(combo_ids))
                conn.execute(
                    "DELETE FROM paired_trades WHERE combo_id IN (%s)" % placeholders,
                    combo_ids)
                conn.execute("DELETE FROM combo_summary WHERE strategy=?", (db_s,))
                conn.commit()
                print("  🗑  清除旧数据: %s (%d 组)" % (db_s, len(combo_ids)))

    # 保存运行元数据
    meta_key_prefix = "mirror_" if mirror else ""
    save_metadata(conn, {
        'days': DAYS,
        'initial_capital': INITIAL_CAPITAL,
        'leverage': LEVERAGE,
        'stop_loss_pct': STOP_LOSS_PCT,
        'enable_ttp': ENABLE_TTP,
        'fixed_bet': FIXED_BET,
        'fixed_bet_amount': FIXED_BET_AMOUNT,
        'fee_rate': FEE_RATE,
        'slippage_pct': SLIPPAGE_PCT,
        'funding_rate_8h': FUNDING_RATE_8H,
        'coins': coins,
        'intervals': intervals,
        'strategies': strategies,
        'total_combos': total,
        '%sstart_time' % meta_key_prefix: datetime.now().isoformat(),
        'schema_version': 'v2',
    })
    # 读取已完成集合，用于预过滤
    completed_set = set()
    conn2 = sqlite3.connect(DB_PATH)
    for row in conn2.execute("SELECT strategy, coin, interval FROM combo_summary"):
        completed_set.add((row[0], row[1], row[2]))
    conn2.close()

    # 预过滤：跳过所有策略都已完成的 coin/interval
    task_list = []
    pre_skipped = 0
    for coin in coins:
        for iv in intervals:
            all_done = all(
                (s + ("_mirror" if mirror else ""), coin, iv) in completed_set
                for s in strategies
            )
            if all_done:
                pre_skipped += len(strategies)
            else:
                task_list.append((coin, iv))
    if pre_skipped:
        print("  ⏭️  预过滤跳过 %d 组（coin/interval 全部已完成）" % pre_skipped)

    n_tasks = len(task_list)

    start_all = time.time()
    total_completed = 0
    total_skipped = pre_skipped
    total_failed = 0

    for i, (coin, iv) in enumerate(task_list):
        result = _worker_coin_interval(coin, iv, strategies, mirror=mirror)

        if result.get('msg'):
            print("  [!] %s/%s: %s，跳过" % (coin, iv, result['msg']))
        else:
            for sname, status, ret, n_paired in result['details']:
                symbol = "+" if ret > 0 else ""
                if status == 'OK':
                    print("  [%s/%s] %-22s -> %s%.1f%% | %d笔" % (
                        coin, iv, sname, symbol, ret, n_paired))
                else:
                    print("  [%s/%s] %-22s -> %s" % (coin, iv, sname, status))

        total_completed += result['completed']
        total_skipped += result['skipped']
        total_failed += result['failed']

        done = i + 1
        elapsed = time.time() - start_all
        if total_completed > 0:
            avg_per_group = elapsed / done
            eta = avg_per_group * (n_tasks - done)
            print("    → %s/%s 完成 (%d新 %d跳过) %.1fs | ETA %.0fmin\n" % (
                coin, iv, result['completed'], result['skipped'],
                result.get('elapsed', 0), eta / 60))

    elapsed_all = time.time() - start_all

    meta_conn = init_db(DB_PATH)
    save_metadata(meta_conn, {
        '%send_time' % meta_key_prefix: datetime.now().isoformat(),
        '%selapsed_minutes' % meta_key_prefix: round(elapsed_all / 60, 1),
    })

    print("\n" + "=" * 90)
    print("  %s 完成 (耗时 %.1f 分钟)" % (phase, elapsed_all / 60))
    print("  新增: %d | 跳过(已有): %d | 失败: %d" % (total_completed, total_skipped, total_failed))
    print("=" * 90)

    meta_conn.close()
    return total_completed, total_skipped, total_failed


_parquet_mod = None  # 缓存，避免每次重新加载

def _convert_to_parquet(db_path):
    """SQLite → Parquet 自动转换（每个种子跑完后调用）"""
    global _parquet_mod
    try:
        db_name = os.path.splitext(os.path.basename(db_path))[0]
        parquet_dir = os.path.join(REPORT_DIR, 'parquet', db_name)
        print("\n" + "=" * 60)
        print("  SQLite → Parquet 转换: %s" % db_name)
        print("=" * 60)

        if _parquet_mod is None:
            import importlib.util
            spec = importlib.util.spec_from_file_location(
                "sqlite_to_parquet",
                os.path.join(PROJECT_ROOT, "sqlite_to_parquet.py")
            )
            if spec is None:
                print("  ⚠️ sqlite_to_parquet.py 未找到，跳过 Parquet 转换")
                return
            mod = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(mod)
            _parquet_mod = mod

        _parquet_mod.convert(db_path, parquet_dir)
    except Exception as e:
        print("  ⚠️ Parquet 转换失败: %s" % e)


_gate_runner_mod = None  # 缓存

def _run_gate_for_seed(seed_db_path, report_dir):
    """对一个种子库跑 Gate 管线（调用 gate_runner.py）"""
    global _gate_runner_mod
    if _gate_runner_mod is None:
