def _generate_comparison_report(all_results):
    """DuckDB 三种子对比报告（矩阵结束后调用）"""
    gate_reports = [(r['name'], r.get('gate_report'))
                    for r in all_results if r.get('gate_report')]
    if len(gate_reports) < 2:
        print("\n  ⚠️ Gate 报告不足 2 个，跳过对比")
        return

    try:
        import duckdb
    except ImportError:
        print("\n  ⚠️ duckdb 未安装，跳过对比报告")
        return

    print("\n" + "═" * 90)
    print("  DuckDB 三种子对比报告")
    print("═" * 90)

    try:
        con = duckdb.connect()
        # 合并各种子的 champions 表
        unions = []
        for name, report_db in gate_reports:
            unions.append(
                "SELECT *, '%s' AS ttp_mode FROM sqlite_scan('%s', 'champions')"
                % (name, report_db)
            )
        sql = " UNION ALL ".join(unions)

        # 按策略+币种+周期分组，横向展示三种模式
        pivot_sql = """
        WITH combined AS (%s)
        SELECT
            strategy, coin, interval, team,
            MAX(CASE WHEN ttp_mode='纯信号' THEN all_pnl END) AS "纯信号_PnL",
            MAX(CASE WHEN ttp_mode='TTP Close' THEN all_pnl END) AS "TTP_Close_PnL",
            MAX(CASE WHEN ttp_mode='TTP High/Low' THEN all_pnl END) AS "TTP_HL_PnL",
            MAX(CASE WHEN ttp_mode='纯信号' THEN double_rate END) AS "纯信号_翻倍",
            MAX(CASE WHEN ttp_mode='TTP Close' THEN double_rate END) AS "TTP_Close_翻倍",
            MAX(CASE WHEN ttp_mode='TTP High/Low' THEN double_rate END) AS "TTP_HL_翻倍"
        FROM combined
        GROUP BY strategy, coin, interval, team
        ORDER BY "TTP_HL_PnL" DESC NULLS LAST
        LIMIT 50
        """ % sql

        df = con.execute(pivot_sql).fetchdf()
        if len(df) > 0:
            print("\n  Top 50 策略对比（按 TTP High/Low PnL 排序）:\n")
            print(df.to_string(index=False))

        # 汇总统计
        summary_sql = """
        WITH combined AS (%s)
        SELECT
            ttp_mode,
            COUNT(*) AS 冠军数,
            ROUND(AVG(all_pnl), 1) AS 平均PnL,
            ROUND(AVG(double_rate), 1) AS 平均翻倍率,
            ROUND(AVG(max_dd_p95), 1) AS 平均最大回撤
        FROM combined
        GROUP BY ttp_mode
        ORDER BY ttp_mode
        """ % sql

        summary = con.execute(summary_sql).fetchdf()
        print("\n  汇总:\n")
        print(summary.to_string(index=False))

        # 保存到 Parquet
        parquet_path = os.path.join(REPORT_DIR, 'parquet', 'gate_comparison.parquet')
        os.makedirs(os.path.dirname(parquet_path), exist_ok=True)
        full_sql = "SELECT * FROM (%s) ORDER BY strategy, coin, interval" % sql
        con.execute(
            "COPY (%s) TO '%s' (FORMAT PARQUET)" % (full_sql, parquet_path)
        )
        print("\n  对比报告: %s" % parquet_path)
        con.close()
    except Exception as e:
        print("  ⚠️ 对比报告失败: %s" % e)

    print("═" * 90)


def _print_seed_stats(db_path, label=""):
