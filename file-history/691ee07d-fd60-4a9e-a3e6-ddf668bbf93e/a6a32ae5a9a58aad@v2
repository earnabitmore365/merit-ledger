#!/usr/bin/env python3
"""
AD Strategy - Accumulation/Distribution Line（真正的A/D指标）

用 Money Flow Multiplier (MFM) 计算资金流向：
  MFM = ((close - low) - (high - close)) / (high - low)
  AD = cumulative sum of (MFM × volume)

MFM 范围 -1 到 +1：
  收盘价靠近最高价 → MFM 接近 +1（买方主导）
  收盘价靠近最低价 → MFM 接近 -1（卖方主导）

信号：AD 上穿零轴 → BUY，下穿零轴 → SELL
"""

from typing import Dict, List, Optional
from dataclasses import dataclass

from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class ADConfig:
    """A/D configuration"""
    period: int = 20


class AD(Strategy):
    """Accumulation/Distribution trading strategy"""

    def __init__(self, exchange=None, config: Optional[ADConfig] = None):
        self.exchange = exchange
        self.config = config or ADConfig()

    @property
    def name(self) -> str:
        return "ad"

    def calculate_ad(self, klines: List[Dict]) -> List[float]:
        """计算 A/D Line（累积）"""
        ad_values = []
        ad_cum = 0.0

        for k in klines:
            high = k["high"]
            low = k["low"]
            close = k["close"]
            volume = k.get("volume", 1000)

            hl_range = high - low
            if hl_range > 0:
                mfm = ((close - low) - (high - close)) / hl_range
            else:
                mfm = 0.0

            ad_cum += mfm * volume
            ad_values.append(ad_cum)

        return ad_values

    def generate_signal(
        self, coin: str, klines: List[Dict] = None
    ) -> TradingSignal:
        min_required = self.config.period + 1
        if not klines or len(klines) < min_required:
            return TradingSignal(
                signal=Signal.HOLD,
                confidence=0.0,
                coin=coin,
                timestamp=klines[-1]["time"] if klines else 0,
                metadata={"reason": "Insufficient klines"},
            )

        ad_values = self.calculate_ad(klines[-(self.config.period + 1):])
        ad_current = ad_values[-1]
        ad_prev = ad_values[-2]

        # 零轴穿越
        if ad_prev <= 0 and ad_current > 0:
            signal = Signal.BUY
            trend = "accumulation"
        elif ad_prev >= 0 and ad_current < 0:
            signal = Signal.SELL
            trend = "distribution"
        elif ad_current > 0:
            signal = Signal.BUY
            trend = "accumulation"
        elif ad_current < 0:
            signal = Signal.SELL
            trend = "distribution"
        else:
            signal = Signal.HOLD
            trend = "neutral"

        return TradingSignal(
            signal=signal,
            confidence=0.6,
            coin=coin,
            timestamp=klines[-1]["time"],
            metadata={"ad": ad_current, "trend": trend},
        )
