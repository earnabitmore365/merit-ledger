"""Macross Slow — MA(20/50)交叉策略（原名SMC，实际是MA交叉）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class MacrossSlowConfig:
    short_ma: int = 20
    long_ma: int = 50


class MacrossSlow(Strategy):
    def __init__(self, exchange=None, config: Optional[MacrossSlowConfig] = None):
        self.exchange = exchange
        self.config = config or MacrossSlowConfig()

    @property
    def name(self) -> str:
        return "macross_slow"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        min_required = self.config.long_ma + 1
        if not klines or len(klines) < min_required:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0,
                                 metadata={"reason": "Insufficient klines"})

        closes = [k["close"] for k in klines]
        ma_s = sum(closes[-self.config.short_ma:]) / self.config.short_ma
        ma_l = sum(closes[-self.config.long_ma:]) / self.config.long_ma
        prev_closes = closes[:-1]
        prev_ma_s = sum(prev_closes[-self.config.short_ma:]) / self.config.short_ma
        prev_ma_l = sum(prev_closes[-self.config.long_ma:]) / self.config.long_ma

        if prev_ma_s <= prev_ma_l and ma_s > ma_l:
            signal = Signal.BUY
        elif prev_ma_s >= prev_ma_l and ma_s < ma_l:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=0.6,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"ma_short": ma_s, "ma_long": ma_l})
