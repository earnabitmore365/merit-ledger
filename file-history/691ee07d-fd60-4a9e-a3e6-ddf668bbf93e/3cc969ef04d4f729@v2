"""Break of Structure (BOS) — 结构破坏策略

市场结构 = 高点和低点的排列方式：
- 上升结构：更高的高点(HH) + 更高的低点(HL)
- 下降结构：更低的低点(LL) + 更低的高点(LH)

结构破坏 = 价格突破了前一个关键高/低点，趋势方向改变：
- 看涨BOS：下降结构中，价格突破前一个更低的高点(LH) → 做多
- 看跌BOS：上升结构中，价格跌破前一个更高的低点(HL) → 做空

用 swing high/low 识别关键点（左右各N根K线都比中间低/高）。
天生多空双向，signal close 正常触发。
"""
from typing import Dict, List, Optional
from dataclasses import dataclass

from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class BreakOfStructureConfig:
    swing_len: int = 5       # swing point 左右各看几根K线
    lookback: int = 50       # 回看窗口找 swing points


class BreakOfStructure(Strategy):
    def __init__(self, exchange=None, config: Optional[BreakOfStructureConfig] = None):
        self.exchange = exchange
        self.config = config or BreakOfStructureConfig()

    @property
    def name(self) -> str:
        return "breakofstructure"

    def _find_swing_points(self, klines: List[Dict], end_idx: int) -> tuple:
        """找出回看窗口内的 swing highs 和 swing lows"""
        n = self.config.swing_len
        start = max(0, end_idx - self.config.lookback)
        swing_highs = []  # (index, price)
        swing_lows = []

        for i in range(start + n, end_idx - n):
            high_i = klines[i]["high"]
            low_i = klines[i]["low"]

            # swing high: 左右各n根的high都比当前低
            is_swing_high = True
            for j in range(1, n + 1):
                if klines[i - j]["high"] >= high_i or klines[i + j]["high"] >= high_i:
                    is_swing_high = False
                    break
            if is_swing_high:
                swing_highs.append((i, high_i))

            # swing low: 左右各n根的low都比当前高
            is_swing_low = True
            for j in range(1, n + 1):
                if klines[i - j]["low"] <= low_i or klines[i + j]["low"] <= low_i:
                    is_swing_low = False
                    break
            if is_swing_low:
                swing_lows.append((i, low_i))

        return swing_highs, swing_lows

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        min_required = self.config.lookback + self.config.swing_len * 2
        if not klines or len(klines) < min_required:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0,
                                 metadata={"reason": "Insufficient klines"})

        end_idx = len(klines) - 1
        swing_highs, swing_lows = self._find_swing_points(klines, end_idx)

        if len(swing_highs) < 2 or len(swing_lows) < 2:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"],
                                 metadata={"reason": "Not enough swing points"})

        # 取最近的两个 swing high 和 swing low
        sh1_idx, sh1 = swing_highs[-1]  # 最近
        sh2_idx, sh2 = swing_highs[-2]  # 次近
        sl1_idx, sl1 = swing_lows[-1]
        sl2_idx, sl2 = swing_lows[-2]

        current_price = klines[-1]["close"]
        prev_price = klines[-2]["close"]

        signal = Signal.HOLD
        confidence = 0.0
        metadata = {"swing_highs": len(swing_highs), "swing_lows": len(swing_lows)}

        # 判断当前结构
        # 下降结构：最近的 swing high < 之前的 swing high (LH)
        is_downtrend = sh1 < sh2 and sl1 < sl2

        # 上升结构：最近的 swing high > 之前的 swing high (HH)
        is_uptrend = sh1 > sh2 and sl1 > sl2

        # 看涨BOS：下降结构中，当前价格突破最近的 swing high (LH)
        if is_downtrend and current_price > sh1 and prev_price <= sh1:
            signal = Signal.BUY
            confidence = min(1.0, (current_price - sh1) / sh1 * 100) if sh1 > 0 else 0.5
            metadata.update({"bos_type": "bullish", "broken_level": sh1,
                           "structure": "downtrend_broken"})

        # 看跌BOS：上升结构中，当前价格跌破最近的 swing low (HL)
        elif is_uptrend and current_price < sl1 and prev_price >= sl1:
            signal = Signal.SELL
            confidence = min(1.0, (sl1 - current_price) / sl1 * 100) if sl1 > 0 else 0.5
            metadata.update({"bos_type": "bearish", "broken_level": sl1,
                           "structure": "uptrend_broken"})

        return TradingSignal(signal=signal, confidence=confidence,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata=metadata)
