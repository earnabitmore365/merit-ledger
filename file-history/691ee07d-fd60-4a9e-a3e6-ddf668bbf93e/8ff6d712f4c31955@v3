"""Volume-Price（量价关系）— 放量确认趋势策略

核心逻辑：
- 价格方向 + 成交量配合 = 判断真假突破
- 放量上涨（价涨+量>均量×倍数）→ 真涨 → 做多
- 放量下跌（价跌+量>均量×倍数）→ 真跌 → 做空
- 缩量波动 → 假信号 → 不动

量比 = 当前成交量 / 近N根K线平均成交量
量比 > threshold 才算"放量"，过滤掉噪音。
"""
from typing import Dict, List, Optional
from dataclasses import dataclass

from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class VolumePriceConfig:
    vol_period: int = 20       # 均量计算周期
    vol_threshold: float = 1.5 # 量比阈值（1.5倍均量算放量）
    price_period: int = 3      # 价格方向看几根K线
    min_price_pct: float = 0.002  # 最小价格变动（0.2%，过滤横盘噪音）


class VolumePrice(Strategy):
    def __init__(self, exchange=None, config: Optional[VolumePriceConfig] = None):
        self.exchange = exchange
        self.config = config or VolumePriceConfig()

    @property
    def name(self) -> str:
        return "volume_price"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        min_required = self.config.vol_period + self.config.price_period
        if not klines or len(klines) < min_required:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0,
                                 metadata={"reason": "Insufficient klines"})

        # 当前成交量
        current_vol = klines[-1].get("volume", 0)

        # 均量（不含当前K线）
        vol_window = [k.get("volume", 0) for k in klines[-(self.config.vol_period + 1):-1]]
        avg_vol = sum(vol_window) / len(vol_window) if vol_window else 1

        # 量比
        vol_ratio = current_vol / avg_vol if avg_vol > 0 else 0

        # 价格方向：最近N根K线的涨跌
        price_now = klines[-1]["close"]
        price_before = klines[-(self.config.price_period + 1)]["close"]
        price_change_pct = (price_now - price_before) / price_before if price_before > 0 else 0

        # 判断信号
        signal = Signal.HOLD
        confidence = 0.0
        is_high_volume = vol_ratio >= self.config.vol_threshold

        if is_high_volume and price_change_pct >= self.config.min_price_pct:
            signal = Signal.BUY
            confidence = min(1.0, vol_ratio / (self.config.vol_threshold * 2))
        elif is_high_volume and price_change_pct <= -self.config.min_price_pct:
            signal = Signal.SELL
            confidence = min(1.0, vol_ratio / (self.config.vol_threshold * 2))

        return TradingSignal(signal=signal, confidence=confidence,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={
                                 "vol_ratio": round(vol_ratio, 2),
                                 "price_change_pct": round(price_change_pct, 4),
                                 "avg_vol": round(avg_vol, 0),
                                 "is_high_volume": is_high_volume
                             })
