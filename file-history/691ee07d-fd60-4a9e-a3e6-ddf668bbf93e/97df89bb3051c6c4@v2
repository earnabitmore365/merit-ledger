#!/usr/bin/env python3
"""
Demand Index — 只做多版本

DI 从负转正时做多，从正转负时 CLOSE 平仓（不做空）。
适合牛市 / 震荡上行行情。
"""

from typing import Dict, List, Optional
from core.strategy import Strategy, Signal, TradingSignal
from core.strategy.strategy_demand_index_echo import DemandIndex as _Base, DemandIndexConfig


class DemandIndexLong(Strategy):
    """Demand Index — Long Only"""

    def __init__(self, exchange=None, config: Optional[DemandIndexConfig] = None):
        self.exchange = exchange
        self._base = _Base(exchange, config)

    @property
    def name(self) -> str:
        return "demandindex_long"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        sig = self._base.generate_signal(coin, klines)
        if sig.signal == Signal.SELL:
            return TradingSignal(
                signal=Signal.CLOSE, confidence=sig.confidence, coin=coin,
                timestamp=sig.timestamp, metadata=sig.metadata)
        return sig
