#!/usr/bin/env python3
"""
Pivot Points Strategy — 标准实现

用前一根K线的 HLC 算出 Pivot + S1/S2/R1/R2 五条线。
价格从下方突破 Pivot → BUY，从上方跌破 Pivot → SELL。
S1/R1 作为止盈/确认层级。

标准公式：
  Pivot = (H + L + C) / 3
  R1 = 2 × Pivot - L
  S1 = 2 × Pivot - H
  R2 = Pivot + (H - L)
  S2 = Pivot - (H - L)
"""

from typing import Dict, List, Optional
from dataclasses import dataclass

from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class PivotPointsConfig:
    """Pivot Points configuration"""
    confirmation_bars: int = 2  # 需要连续几根在pivot同侧才确认


class PivotPoints(Strategy):
    """Standard Pivot Points trading strategy"""

    def __init__(self, exchange=None, config: Optional[PivotPointsConfig] = None):
        self.exchange = exchange
        self.config = config or PivotPointsConfig()

    @property
    def name(self) -> str:
        return "pivot_points"

    def _calc_levels(self, prev_candle: Dict) -> dict:
        """用前一根K线算标准 Pivot 五条线"""
        h = prev_candle["high"]
        l = prev_candle["low"]
        c = prev_candle["close"]
        pivot = (h + l + c) / 3
        return {
            "pivot": pivot,
            "r1": 2 * pivot - l,
            "s1": 2 * pivot - h,
            "r2": pivot + (h - l),
            "s2": pivot - (h - l),
        }

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        min_required = self.config.confirmation_bars + 2
        if not klines or len(klines) < min_required:
            return TradingSignal(
                signal=Signal.HOLD, confidence=0.0, coin=coin,
                timestamp=klines[-1]["time"] if klines else 0,
                metadata={"reason": "Insufficient klines"},
            )

        # 用前一根K线算levels
        levels = self._calc_levels(klines[-2])
        pivot = levels["pivot"]
        current = klines[-1]["close"]

        # 确认：最近 confirmation_bars 根都在同侧
        cb = self.config.confirmation_bars
        recent_closes = [k["close"] for k in klines[-(cb + 1):-1]]

        all_above = all(c > pivot for c in recent_closes)
        all_below = all(c < pivot for c in recent_closes)

        if current > pivot and all_above:
            signal = Signal.BUY
            # 接近R1给更高confidence
            if current > levels["r1"]:
                confidence = 0.8
            else:
                confidence = 0.6
        elif current < pivot and all_below:
            signal = Signal.SELL
            if current < levels["s1"]:
                confidence = 0.8
            else:
                confidence = 0.6
        else:
            signal = Signal.HOLD
            confidence = 0.0

        return TradingSignal(
            signal=signal,
            confidence=confidence,
            coin=coin,
            timestamp=klines[-1]["time"],
            metadata=levels | {"current": current},
        )
