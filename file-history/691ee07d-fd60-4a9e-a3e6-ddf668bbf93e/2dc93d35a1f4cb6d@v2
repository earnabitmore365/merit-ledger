#!/usr/bin/env python3
"""
Always Long Strategy - 永远做多

无条件做多策略。不判断市场方向，永远发出BUY信号。
牛市死多头 — 在牛市里"永远做多"本来就是正确答案。

来源：原 accumulationdistribution 策略的代码逻辑（典型价×成交量永远为正，
等价于无条件做多）。发现后保留为独立策略，用于牛市猴子班。
"""

from typing import Dict, List, Optional
from dataclasses import dataclass

from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class AlwaysLongConfig:
    """Always Long configuration"""
    period: int = 20


class AlwaysLong(Strategy):
    """Always Long trading strategy — 永远做多"""

    def __init__(self, exchange=None, config: Optional[AlwaysLongConfig] = None):
        self.exchange = exchange
        self.config = config or AlwaysLongConfig()

    @property
    def name(self) -> str:
        return "always_long"

    def generate_signal(
        self, coin: str, klines: List[Dict] = None
    ) -> TradingSignal:
        min_required = self.config.period
        if not klines or len(klines) < min_required:
            return TradingSignal(
                signal=Signal.HOLD,
                confidence=0.0,
                coin=coin,
                timestamp=klines[-1]["time"] if klines else 0,
                metadata={"reason": "Insufficient klines"},
            )

        return TradingSignal(
            signal=Signal.BUY,
            confidence=0.6,
            coin=coin,
            timestamp=klines[-1]["time"],
            metadata={"trend": "always_long"},
        )
