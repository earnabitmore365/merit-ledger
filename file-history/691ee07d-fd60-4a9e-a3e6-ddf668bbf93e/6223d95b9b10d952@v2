"""Elder-Ray — EMA方向 + Bull/Bear Power交叉（正统逻辑）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class ElderRayConfig:
    ema_period: int = 13


class ElderRay(Strategy):
    def __init__(self, exchange=None, config: Optional[ElderRayConfig] = None):
        self.exchange = exchange
        self.config = config or ElderRayConfig()

    @property
    def name(self) -> str:
        return "elder_ray"

    def _calc_ema(self, closes: List[float]) -> float:
        period = self.config.ema_period
        if len(closes) < period:
            return sum(closes) / len(closes) if closes else 0.0
        k = 2 / (period + 1)
        ema = sum(closes[:period]) / period
        for price in closes[period:]:
            ema = price * k + ema * (1 - k)
        return ema

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        min_required = self.config.ema_period + 1
        if not klines or len(klines) < min_required:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0,
                                 metadata={"reason": "Insufficient klines"})

        closes = [c["close"] for c in klines]
        ema = self._calc_ema(closes)
        ema_prev = self._calc_ema(closes[:-1])
        ema_rising = ema > ema_prev

        bull_power = klines[-1]["high"] - ema
        bear_power = klines[-1]["low"] - ema
        prev_bull = klines[-2]["high"] - ema_prev
        prev_bear = klines[-2]["low"] - ema_prev

        # 正统Elder-Ray：EMA上升 + bear power从负转正向改善 → BUY
        if ema_rising and bear_power < 0 and bear_power > prev_bear:
            signal = Signal.BUY
        elif not ema_rising and bull_power > 0 and bull_power < prev_bull:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=0.6,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"ema": ema, "bull_power": bull_power,
                                        "bear_power": bear_power})
