"""StdDev v2 — 1.5σ突破 + 量确认"""
from typing import Dict, List, Optional
from dataclasses import dataclass
import statistics
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class StdDevV2Config:
    period: int = 20
    multiplier: float = 1.5
    vol_ratio: float = 1.2  # 量需超过均量的1.2倍


class StdDevV2(Strategy):
    def __init__(self, exchange=None, config: Optional[StdDevV2Config] = None):
        self.exchange = exchange
        self.config = config or StdDevV2Config()

    @property
    def name(self) -> str:
        return "stddev_v2"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        p = self.config.period
        if not klines or len(klines) < p + 1:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0,
                                 metadata={"reason": "Insufficient klines"})

        closes = [c["close"] for c in klines]
        recent = closes[-p:]
        ma = sum(recent) / p
        std = statistics.stdev(recent) if len(recent) > 1 else 0.0
        upper = ma + self.config.multiplier * std
        lower = ma - self.config.multiplier * std
        current = closes[-1]

        # 量确认
        volumes = [c.get("volume", 1000) for c in klines[-p:]]
        avg_vol = sum(volumes) / len(volumes)
        curr_vol = klines[-1].get("volume", 1000)
        vol_ok = curr_vol >= avg_vol * self.config.vol_ratio

        if current > upper and vol_ok:
            signal = Signal.BUY
        elif current < lower and vol_ok:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=0.6,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"ma": ma, "std": std, "upper": upper,
                                        "lower": lower, "vol_ok": vol_ok})
