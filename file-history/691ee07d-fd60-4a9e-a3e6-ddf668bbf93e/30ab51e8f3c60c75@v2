"""SuperTrend — 标准参数版（period=10, multiplier=3.0）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class SuperTrendConfig:
    period: int = 10
    multiplier: float = 3.0


class SuperTrend(Strategy):
    def __init__(self, exchange=None, config: Optional[SuperTrendConfig] = None):
        self.exchange = exchange
        self.config = config or SuperTrendConfig()

    @property
    def name(self) -> str:
        return "supertrend"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        p = self.config.period
        if not klines or len(klines) < p + 2:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        direction, prev_direction = self._supertrend(klines, p, self.config.multiplier)

        if direction == 1 and prev_direction == -1:
            signal = Signal.BUY
        elif direction == -1 and prev_direction == 1:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=0.7,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"direction": direction})

    def _supertrend(self, klines, period, mult):
        trs = []
        for i in range(1, len(klines)):
            hl = klines[i]["high"] - klines[i]["low"]
            hc = abs(klines[i]["high"] - klines[i - 1]["close"])
            lc = abs(klines[i]["low"] - klines[i - 1]["close"])
            trs.append(max(hl, hc, lc))

        if len(trs) < period:
            return 1, 1

        upper_bands = []
        lower_bands = []
        directions = []

        for i in range(len(trs)):
            if i < period - 1:
                upper_bands.append(0)
                lower_bands.append(0)
                directions.append(1)
                continue

            atr = sum(trs[i - period + 1:i + 1]) / period
            hl2 = (klines[i + 1]["high"] + klines[i + 1]["low"]) / 2
            basic_upper = hl2 + mult * atr
            basic_lower = hl2 - mult * atr

            if i > period - 1:
                prev_upper = upper_bands[-1]
                prev_lower = lower_bands[-1]
                final_upper = basic_upper if basic_upper < prev_upper or klines[i]["close"] > prev_upper else prev_upper
                final_lower = basic_lower if basic_lower > prev_lower or klines[i]["close"] < prev_lower else prev_lower
            else:
                final_upper = basic_upper
                final_lower = basic_lower

            upper_bands.append(final_upper)
            lower_bands.append(final_lower)

            close = klines[i + 1]["close"]
            prev_dir = directions[-1]
            if prev_dir == 1:
                d = -1 if close < final_lower else 1
            else:
                d = 1 if close > final_upper else -1
            directions.append(d)

        return directions[-1], directions[-2] if len(directions) >= 2 else directions[-1]
