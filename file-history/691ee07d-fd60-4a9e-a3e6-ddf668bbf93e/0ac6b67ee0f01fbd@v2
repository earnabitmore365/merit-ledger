"""RSI Reversal v2 — Wilder RSI(14) + MA方向过滤"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class RSIReversalV2Config:
    rsi_period: int = 14
    ma_period: int = 20
    overbought: float = 70.0
    oversold: float = 30.0


class RSIReversalV2(Strategy):
    def __init__(self, exchange=None, config: Optional[RSIReversalV2Config] = None):
        self.exchange = exchange
        self.config = config or RSIReversalV2Config()

    @property
    def name(self) -> str:
        return "rsi_reversal_v2"

    def _wilder_rsi(self, closes: List[float]) -> float:
        period = self.config.rsi_period
        if len(closes) < period + 1:
            return 50.0
        gains = losses = 0.0
        for i in range(1, period + 1):
            d = closes[i] - closes[i - 1]
            if d > 0:
                gains += d
            else:
                losses += abs(d)
        avg_gain = gains / period
        avg_loss = losses / period
        for i in range(period + 1, len(closes)):
            d = closes[i] - closes[i - 1]
            g = d if d > 0 else 0.0
            l = abs(d) if d < 0 else 0.0
            avg_gain = (avg_gain * (period - 1) + g) / period
            avg_loss = (avg_loss * (period - 1) + l) / period
        if avg_loss == 0:
            return 100.0
        return 100 - 100 / (1 + avg_gain / avg_loss)

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        min_required = max(self.config.rsi_period + 2, self.config.ma_period + 1)
        if not klines or len(klines) < min_required:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        closes = [c["close"] for c in klines]
        rsi = self._wilder_rsi(closes)
        prev_rsi = self._wilder_rsi(closes[:-1])
        ma = sum(closes[-self.config.ma_period:]) / self.config.ma_period
        trend_up = closes[-1] > ma

        # RSI穿越 + MA方向过滤
        if rsi < self.config.oversold and prev_rsi >= self.config.oversold and trend_up:
            signal = Signal.BUY
        elif rsi > self.config.overbought and prev_rsi <= self.config.overbought and not trend_up:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=abs(rsi - 50) / 50,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"rsi": rsi, "ma": ma, "trend_up": trend_up})
