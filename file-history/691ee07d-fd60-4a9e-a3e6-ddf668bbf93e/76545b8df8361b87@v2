"""Heikin Ashi — 平均K线策略（4根连续确认+影线过滤）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class HeikinAshiConfig:
    min_klines: int = 5


class HeikinAshi(Strategy):
    def __init__(self, exchange=None, config: Optional[HeikinAshiConfig] = None):
        self.exchange = exchange
        self.config = config or HeikinAshiConfig()

    @property
    def name(self) -> str:
        return "heikin_ashi"

    def _calc_ha(self, klines: List[Dict]) -> List[Dict]:
        if not klines or len(klines) < 2:
            return []
        ha = []
        prev_open = prev_close = None
        for i, c in enumerate(klines):
            ha_close = (c["open"] + c["high"] + c["low"] + c["close"]) / 4
            ha_open = (c["open"] + c["close"]) / 2 if i == 0 else (prev_open + prev_close) / 2
            ha.append({
                "open": ha_open,
                "high": max(c["high"], ha_open, ha_close),
                "low": min(c["low"], ha_open, ha_close),
                "close": ha_close,
                "time": c["time"],
            })
            prev_open, prev_close = ha_open, ha_close
        return ha

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        if not klines or len(klines) < self.config.min_klines:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0,
                                 metadata={"reason": "Insufficient klines"})

        ha = self._calc_ha(klines)
        if len(ha) < 4:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"])

        # 4根连续确认
        all_bull = all(ha[-i]["close"] > ha[-i]["open"] for i in range(1, 5))
        all_bear = all(ha[-i]["close"] < ha[-i]["open"] for i in range(1, 5))
        last = ha[-1]
        rng = last["high"] - last["low"]

        # 影线过滤：强势阳线无下影线，强势阴线无上影线
        no_lower = last["open"] <= last["low"] + rng * 0.05 if rng > 0 else False
        no_upper = last["close"] >= last["high"] - rng * 0.05 if rng > 0 else False

        if all_bull and no_lower:
            signal, confidence, trend = Signal.BUY, 0.75, "strong_uptrend"
        elif all_bear and no_upper:
            signal, confidence, trend = Signal.SELL, 0.75, "strong_downtrend"
        elif all_bull:
            signal, confidence, trend = Signal.BUY, 0.55, "uptrend"
        elif all_bear:
            signal, confidence, trend = Signal.SELL, 0.55, "downtrend"
        else:
            signal, confidence, trend = Signal.HOLD, 0.1, "consolidation"

        return TradingSignal(signal=signal, confidence=confidence,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"trend": trend})
