"""VPT Strategy — Volume Price Trend，VPT穿越SMA交叉信号"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class VPTConfig:
    period: int = 20
    sma_period: int = 10


class VPT(Strategy):
    def __init__(self, exchange=None, config: Optional[VPTConfig] = None):
        self.exchange = exchange
        self.config = config or VPTConfig()

    @property
    def name(self) -> str:
        return "vpt"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        min_required = self.config.period + self.config.sma_period
        if not klines or len(klines) < min_required:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0,
                                 metadata={"reason": "Insufficient klines"})

        # 只用最近 period 根算 VPT（不累积全历史）
        def _calc_vpt(bars):
            vpt = 0.0
            for i in range(1, len(bars)):
                if bars[i - 1]["close"] == 0:
                    continue
                pct = (bars[i]["close"] - bars[i - 1]["close"]) / bars[i - 1]["close"]
                vpt += pct * bars[i].get("volume", 1000)
            return vpt

        # 算 VPT 序列用于 SMA
        sma_len = self.config.sma_period
        p = self.config.period
        vpt_series = []
        for end in range(p, len(klines) + 1):
            vpt_series.append(_calc_vpt(klines[end - p:end]))

        if len(vpt_series) < sma_len + 1:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"])

        vpt_now = vpt_series[-1]
        vpt_sma = sum(vpt_series[-sma_len:]) / sma_len
        prev_vpt = vpt_series[-2]
        prev_sma = sum(vpt_series[-sma_len - 1:-1]) / sma_len

        if prev_vpt <= prev_sma and vpt_now > vpt_sma:
            signal = Signal.BUY
        elif prev_vpt >= prev_sma and vpt_now < vpt_sma:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=0.6,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"vpt": vpt_now, "vpt_sma": vpt_sma})
