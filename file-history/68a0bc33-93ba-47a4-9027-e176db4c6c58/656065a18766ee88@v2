#!/usr/bin/env python3
"""选人补充筛选：区分"等得起"(A型) vs "等不起"(B型)

对v4推荐组合的45个策略，补充日均开仓/最大连亏/HOLD占比，标记风险。

用法: cd auto-trading && python3 lab/team_filter.py
"""

import os
import sqlite3
import time
from collections import defaultdict

SEED_DB = os.path.join(os.path.dirname(__file__), 'reports', 'seed_v3_ttp.db')

# v4 推荐组合（从 team_selection_v4.txt 提取）
TEAMS = {
    'BTC': [
        ('bb_squeeze_mirror', '30m'), ('fvg_mirror', '1h'),
        ('order_block_mirror', '1h'), ('rsi_reversal_mirror', '1h'),
        ('renko_mirror', '1h'),
    ],
    'ETH': [
        ('mean_reversion_mirror', '1m'), ('advanced_kline_echo_mirror', '1h'),
        ('cci_extreme_mirror', '1h'), ('donchian_mirror', '30m'),
        ('proc_mirror', '30m'),
    ],
    'XRP': [
        ('rsi_reversal_mirror', '1h'), ('mean_reversion_mirror', '1m'),
        ('proc_mirror', '1h'), ('ma_mirror', '1h'),
        ('volume_momentum_mirror', '30m'),
    ],
    'BNB': [
        ('mean_reversion_mirror', '30m'), ('renko_mirror', '1m'),
        ('order_block_mirror', '5m'), ('rsi_reversal_v2_mirror', '5m'),
        ('hma_mirror', '15m'),
    ],
    'SOL': [
        ('mean_reversion_mirror', '1m'), ('bb_squeeze', '1h'),
        ('williams_fast_mirror', '1h'), ('ultimate_oscillator_2yi_mirror', '1h'),
        ('aroon_mirror', '1h'),
    ],
    'ADA': [
        ('mean_reversion_mirror', '5m'), ('mean_reversion_mirror', '1h'),
        ('coppock_mirror', '1h'), ('ma_mirror', '1h'),
        ('matriple_mirror', '15m'),
    ],
    'AVAX': [
        ('mean_reversion_mirror', '1m'), ('bb_squeeze', '1h'),
        ('smc_real', '1h'), ('rsi_divergence_mirror', '1h'),
        ('aroon_mirror', '15m'),
    ],
    'LINK': [
        ('mean_reversion_mirror', '15m'), ('bb_squeeze', '1h'),
        ('order_block_mirror', '5m'), ('ultimate_oscillator_2yi', '1h'),
        ('trix_mirror', '15m'),
    ],
    'DOT': [
        ('bb_squeeze_mirror', '30m'), ('bb_squeeze_mirror', '5m'),
        ('bb_squeeze', '1h'), ('matriple_long', '1h'),
        ('momentum_slope', '1h'),
    ],
}

# K线数量（估算用于HOLD占比，从combo_summary的数据推算）
INTERVAL_BARS_PER_DAY = {'1m': 1440, '5m': 288, '15m': 96, '30m': 48, '1h': 24}


def run():
    print("=" * 100)
    print("选人补充筛选：A型（等得起）vs B型（等不起）")
    print("=" * 100)

    conn = sqlite3.connect(SEED_DB)
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("PRAGMA cache_size=-500000")

    print(f"\n{'币种':<5} {'策略':<30} {'周期':<5} {'PnL':>7} {'笔数':>6} {'日均开仓':>8} "
          f"{'最大连亏$':>9} {'连亏笔':>6} {'最大单赚':>8} {'HOLD%':>6} {'类型':>5}")
    print("-" * 105)

    for coin in ['BTC', 'ETH', 'XRP', 'BNB', 'SOL', 'ADA', 'AVAX', 'LINK', 'DOT']:
        team = TEAMS.get(coin, [])
        for strat, iv in team:
            # 拿combo基础数据
            row = conn.execute("""
                SELECT id, total_return, total_trades, max_drawdown,
                       max_win, max_consec_loss_amt, longest_loss_streak
                FROM combo_summary
                WHERE strategy = ? AND coin = ? AND interval = ?
            """, (strat, coin, iv)).fetchone()

            if not row:
                print(f"{coin:<5} {strat:<30} {iv:<5} (未找到)")
                continue

            cid, pnl, trades, mdd, max_win, max_consec_loss, longest_loss = row

            # 算日均开仓：总笔数 / 总天数
            # 总天数从K线数据推算
            kline_count = conn.execute("""
                SELECT MAX(close_candle_idx) - MIN(open_candle_idx)
                FROM paired_trades WHERE combo_id = ?
            """, (cid,)).fetchone()[0] or 1

            bars_per_day = INTERVAL_BARS_PER_DAY.get(iv, 24)
            total_days = kline_count / bars_per_day
            daily_opens = trades / total_days if total_days > 0 else 0

            # HOLD占比：没持仓的K线数 / 总K线数
            # 持仓K线数 = SUM(holding_bars)
            holding = conn.execute("""
                SELECT COALESCE(SUM(holding_bars), 0) FROM paired_trades WHERE combo_id = ?
            """, (cid,)).fetchone()[0]
            hold_pct = (1 - holding / kline_count) * 100 if kline_count > 0 else 100

            # 标记风险
            flags = []
            if max_consec_loss and abs(max_consec_loss) > abs(pnl) * 0.5:
                flags.append('⚠️连亏')
            if daily_opens > 5:
                flags.append('⚠️高频')

            if len(flags) == 2:
                type_label = 'B型❌'
            elif len(flags) == 1:
                type_label = '⚠️'
            else:
                type_label = 'A型✅'

            print(f"{coin:<5} {strat:<30} {iv:<5} {pnl:>+7.1f} {trades:>6} {daily_opens:>8.2f} "
                  f"{max_consec_loss:>+9.1f} {longest_loss:>6} {max_win:>+8.1f} {hold_pct:>5.1f}% {type_label:>5}")

        print()  # 币种分隔

    conn.close()
    print("=" * 100)
    print("筛选完成")


if __name__ == '__main__':
    run()
