#!/usr/bin/env python3
"""四维战队验证（先跑两维：动量+波动率）

验证"按市场状态切换策略组合"到底比"全程跑一个策略"更好吗？
用现有种子库 + K线数据直接回答，不写新系统。

维度B: 动量方向（上层TF: 1m→15m, lookback=5, ±1%）
维度C: 波动率状态（ATR(14)/close / SMA(ATR%,50), 阈值0.7/1.5）

用法: cd auto-trading && python3 lab/team_validation.py
"""

import json
import os
import sqlite3
import time
from collections import defaultdict
from datetime import datetime, timezone

# === 配置 ===
LAB = os.path.dirname(__file__)
SEED_DB = os.path.join(LAB, 'reports', 'seed_v3_ttp.db')
DATA_DIR = os.path.join(LAB, 'src', 'backtest', 'data', 'historical')
COINS = ['SOL', 'ETH', 'XRP']
INTERVAL = '1m'
UPPER_TF = '15m'       # 1m → 15m
MOM_LOOKBACK = 5        # 15m lookback
FEE_RATE = 0.00035 * 2  # 双向手续费 0.035%×2


def load_upper_klines(coin: str) -> dict:
    """加载上层TF K线，返回 {timestamp_ms: {high,low,close,volume}}"""
    # 1m 的上层TF是 15m，但我们只有 1h 数据
    # 用 1h 替代（更保守的动量判断，频率更低）
    path = os.path.join(DATA_DIR, coin, '1h.json')
    with open(path) as f:
        data = json.load(f)

    result = {}
    for k in data:
        ts = k.get('time', k.get('open_time', k.get('timestamp', 0)))
        result[ts] = k
    return result


def compute_labels(klines_by_ts: dict) -> dict:
    """对每根上层K线算动量+波动率标签，返回 {timestamp_ms: (momentum_label, vol_label)}"""
    sorted_ts = sorted(klines_by_ts.keys())
    closes = []
    highs = []
    lows = []

    labels = {}
    atr_pcts = []

    for i, ts in enumerate(sorted_ts):
        k = klines_by_ts[ts]
        c = k['close']
        h = k['high']
        l = k['low']
        closes.append(c)
        highs.append(h)
        lows.append(l)

        # 动量（lookback=5根上层TF）
        if i >= MOM_LOOKBACK and closes[i - MOM_LOOKBACK] > 0:
            mom = (c - closes[i - MOM_LOOKBACK]) / closes[i - MOM_LOOKBACK]
            if mom > 0.01:
                mom_label = 'up'
            elif mom < -0.01:
                mom_label = 'down'
            else:
                mom_label = 'flat'
        else:
            mom_label = 'flat'

        # 波动率（ATR14 / close）
        if i >= 14:
            atr_sum = 0
            for j in range(i - 13, i + 1):
                tr = max(
                    highs[j] - lows[j],
                    abs(highs[j] - closes[j - 1]) if j > 0 else 0,
                    abs(lows[j] - closes[j - 1]) if j > 0 else 0,
                )
                atr_sum += tr
            atr = atr_sum / 14
            atr_pct = atr / c if c > 0 else 0
            atr_pcts.append(atr_pct)

            # SMA(atr_pct, 50)
            if len(atr_pcts) >= 50:
                atr_mean = sum(atr_pcts[-50:]) / 50
                atr_ratio = atr_pct / atr_mean if atr_mean > 0 else 1.0
                if atr_ratio > 1.5:
                    vol_label = 'high'
                elif atr_ratio < 0.7:
                    vol_label = 'low'
                else:
                    vol_label = 'normal'
            else:
                vol_label = 'normal'
        else:
            vol_label = 'normal'

        labels[ts] = (mom_label, vol_label)

    return labels


def ts_to_hour_ms(open_time_str: str) -> int:
    """把 paired_trades 的 open_time (YYYY-MM-DD HH:MM) 转成对应的 1h timestamp_ms"""
    try:
        dt = datetime.strptime(open_time_str[:16], '%Y-%m-%d %H:%M')
        dt = dt.replace(minute=0, second=0)
        return int(dt.replace(tzinfo=timezone.utc).timestamp() * 1000)
    except:
        return 0


def run_validation():
    print("=" * 70)
    print("四维战队验证（两维先行：动量 + 波动率）")
    print("=" * 70)

    conn = sqlite3.connect(SEED_DB)
    conn.execute("PRAGMA journal_mode=WAL")

    for coin in COINS:
        print(f"\n{'=' * 60}")
        print(f"币种: {coin} / {INTERVAL}")
        print(f"{'=' * 60}")

        # Step 1: 计算上层TF的动量+波动率标签
        t0 = time.time()
        upper_klines = load_upper_klines(coin)
        labels = compute_labels(upper_klines)
        print(f"标签计算: {len(labels)} 根上层K线, {time.time()-t0:.1f}s")

        # 标签分布
        label_dist = defaultdict(int)
        for mom, vol in labels.values():
            label_dist[f"{mom}_{vol}"] += 1
        print(f"标签分布:")
        for k, v in sorted(label_dist.items(), key=lambda x: -x[1]):
            pct = v / len(labels) * 100
            print(f"  {k:<15} {v:>6} ({pct:.1f}%)")

        # Step 2: 拉该币种1m的所有交易 + 打标签
        t0 = time.time()
        trades = conn.execute("""
            SELECT cs.strategy, pt.r_value, pt.open_time, pt.direction,
                   pt.capital
            FROM combo_summary cs
            JOIN paired_trades pt ON pt.combo_id = cs.id
            WHERE cs.coin = ? AND cs.interval = ?
        """, (coin, INTERVAL)).fetchall()
        print(f"交易数据: {len(trades):,} 笔, {time.time()-t0:.1f}s")

        # 给每笔交易打标签
        labeled_trades = defaultdict(lambda: defaultdict(list))  # {label: {strategy: [pnl,...]}}
        all_trades_by_strategy = defaultdict(list)  # 对照组

        sorted_ts_list = sorted(labels.keys())

        for strategy, r_value, open_time, direction, capital in trades:
            hour_ms = ts_to_hour_ms(open_time)

            # 二分查找最近的标签
            # 简化：直接用 hour_ms 查
            label_data = labels.get(hour_ms)
            if not label_data:
                # 找最近的
                import bisect
                idx = bisect.bisect_right(sorted_ts_list, hour_ms) - 1
                if 0 <= idx < len(sorted_ts_list):
                    nearest_ts = sorted_ts_list[idx]
                    label_data = labels.get(nearest_ts, ('flat', 'normal'))
                else:
                    label_data = ('flat', 'normal')

            mom_label, vol_label = label_data
            combo_label = f"{mom_label}_{vol_label}"

            labeled_trades[combo_label][strategy].append(r_value)
            all_trades_by_strategy[strategy].append(r_value)

        # Step 3: 找每种组合下TOP策略
        print(f"\n--- 每种2D组合下的TOP3策略 ---\n")
        team_config = {}  # {label: [top strategies]}

        for label in sorted(labeled_trades.keys()):
            strats = labeled_trades[label]
            ranked = []
            for strat, pnls in strats.items():
                if len(pnls) >= 30:
                    total = sum(pnls)
                    if total > 0:
                        ranked.append((strat, total, len(pnls),
                                       sum(1 for p in pnls if p > 0) / len(pnls)))

            ranked.sort(key=lambda x: -x[1])
            top3 = ranked[:3]
            team_config[label] = [r[0] for r in top3]

            print(f"  {label}:")
            if not top3:
                print(f"    (无符合条件的策略)")
            for strat, pnl, n, wr in top3:
                print(f"    {strat:<28} PnL={pnl:>+8.1f} 笔数={n:>5} 胜率={wr:.1%}")

        # Step 4: 对比验证
        print(f"\n--- 对比：切换 vs 不切换 ---\n")

        # 对照组：全程最优单策略
        best_single = None
        best_single_pnl = float('-inf')
        for strat, pnls in all_trades_by_strategy.items():
            total = sum(pnls)
            if total > best_single_pnl:
                best_single_pnl = total
                best_single = strat

        # 实验组：按标签选TOP1策略的PnL之和
        switching_pnl = 0
        switch_count = 0
        prev_team = None
        for label, strats in labeled_trades.items():
            if label in team_config and team_config[label]:
                top_strat = team_config[label][0]
                if top_strat in strats:
                    switching_pnl += sum(strats[top_strat])
                    if prev_team != top_strat:
                        switch_count += 1
                        prev_team = top_strat

        # 扣除切换成本（估算：每次切换 = 平仓+开仓的双向手续费 × 名义敞口$100）
        switch_cost = switch_count * 100 * FEE_RATE
        switching_pnl_net = switching_pnl - switch_cost

        print(f"对照组（全程最优单策略）: {best_single} → PnL = {best_single_pnl:+.1f}")
        print(f"实验组（2D切换TOP1）:    PnL = {switching_pnl:+.1f} (切换{switch_count}次, 成本{switch_cost:.1f})")
        print(f"实验组（扣成本后）:      PnL = {switching_pnl_net:+.1f}")
        diff = switching_pnl_net - best_single_pnl
        better = "✅ 切换更好" if diff > 0 else "❌ 不切换更好"
        print(f"差值: {diff:+.1f} → {better}")

    conn.close()
    print(f"\n{'=' * 70}")
    print("验证完成")
    print(f"{'=' * 70}")


if __name__ == '__main__':
    run_validation()
