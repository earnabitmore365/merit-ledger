#!/usr/bin/env python3
"""SQLite → Parquet 转换脚本

将 seed_v3_ttp.db（或 seed_v3.db）的各表导出为 Parquet 文件。
Parquet 是列式存储格式，DuckDB 读取聚合查询比 SQLite 快 7-131 倍。

用法:
  python3 lab/sqlite_to_parquet.py                          # 默认转 seed_v3_ttp.db
  python3 lab/sqlite_to_parquet.py --db seed_v3.db          # 转纯信号种子库
  python3 lab/sqlite_to_parquet.py --tables paired_trades   # 只转指定表

输出: lab/reports/parquet/{db_name}/{table_name}.parquet
"""

import argparse
import os
import time

import duckdb


def convert(db_path: str, output_dir: str, tables: list = None):
    """SQLite → Parquet 转换"""

    if not os.path.exists(db_path):
        print(f"错误: {db_path} 不存在")
        return

    db_size = os.path.getsize(db_path) / (1024 ** 3)
    print(f"源数据库: {db_path} ({db_size:.1f} GB)")
    print(f"输出目录: {output_dir}")
    print()

    os.makedirs(output_dir, exist_ok=True)

    # DuckDB 直接用 SQL 从 SQLite 读并写 Parquet，不经过 Python 内存
    conn = duckdb.connect()
    conn.execute("INSTALL sqlite; LOAD sqlite;")
    conn.execute(f"ATTACH '{db_path}' AS src (TYPE sqlite)")

    # 获取所有表名（用 SQLite 原生连接查 schema）
    import sqlite3
    tmp_conn = sqlite3.connect(db_path)
    all_tables = [r[0] for r in tmp_conn.execute(
        "SELECT name FROM sqlite_master WHERE type='table' ORDER BY name"
    ).fetchall()]
    tmp_conn.close()

    if tables:
        # 只转指定表
        to_convert = [t for t in tables if t in all_tables]
        skipped = [t for t in tables if t not in all_tables]
        if skipped:
            print(f"跳过不存在的表: {skipped}")
    else:
        to_convert = all_tables

    print(f"待转换: {len(to_convert)} 张表 — {to_convert}")
    print()

    total_t0 = time.time()
    results = []

    for table in to_convert:
        parquet_path = os.path.join(output_dir, f"{table}.parquet")
        print(f"转换: {table}")

        # 获取行数
        count = conn.execute(f"SELECT COUNT(*) FROM src.{table}").fetchone()[0]
        print(f"  行数: {count:,}")

        t0 = time.time()
        conn.execute(f"""
            COPY (SELECT * FROM src.{table})
            TO '{parquet_path}'
            (FORMAT PARQUET, COMPRESSION ZSTD, ROW_GROUP_SIZE 1000000)
        """)
        elapsed = time.time() - t0

        pq_size = os.path.getsize(parquet_path) / (1024 ** 3)
        compression = (1 - pq_size / db_size) * 100 if db_size > 0 else 0

        print(f"  耗时: {elapsed:.1f}s")
        print(f"  大小: {pq_size:.2f} GB")
        print()

        results.append((table, count, elapsed, pq_size))

    total_elapsed = time.time() - total_t0
    total_pq_size = sum(r[3] for r in results)

    conn.close()

    # 汇总
    print("=" * 60)
    print("转换完成")
    print("=" * 60)
    print(f"{'表':<25} {'行数':>15} {'耗时':>8} {'Parquet':>10}")
    print("-" * 60)
    for table, count, elapsed, pq_size in results:
        print(f"{table:<25} {count:>15,} {elapsed:>7.1f}s {pq_size:>9.2f}GB")
    print("-" * 60)
    print(f"{'合计':<25} {'':>15} {total_elapsed:>7.1f}s {total_pq_size:>9.2f}GB")
    print(f"\nSQLite: {db_size:.1f} GB → Parquet: {total_pq_size:.1f} GB "
          f"(压缩 {(1 - total_pq_size / db_size) * 100:.0f}%)")
    print(f"输出目录: {output_dir}")


def main():
    parser = argparse.ArgumentParser(description='SQLite → Parquet 转换')
    parser.add_argument('--db', default='seed_v3_ttp.db',
                        help='数据库文件名（在 lab/reports/ 下）')
    parser.add_argument('--tables', nargs='+',
                        help='只转换指定表（默认全部）')
    args = parser.parse_args()

    lab_dir = os.path.dirname(__file__)
    db_path = os.path.join(lab_dir, 'reports', args.db)
    db_name = os.path.splitext(args.db)[0]
    output_dir = os.path.join(lab_dir, 'reports', 'parquet', db_name)

    convert(db_path, output_dir, args.tables)


if __name__ == '__main__':
    main()
