### 脚本逻辑

```python
import duckdb, sqlite3, time

DB_PATH = 'lab/reports/seed_v3_ttp.db'

# SQLite 跑一遍
conn_sqlite = sqlite3.connect(DB_PATH)
for query in QUERIES:
    t0 = time.time()
    conn_sqlite.execute(query).fetchall()
    sqlite_time = time.time() - t0

# DuckDB ATTACH 同一个文件跑一遍
conn_duck = duckdb.connect()
conn_duck.execute(f"ATTACH '{DB_PATH}' AS db (TYPE sqlite)")
for query in QUERIES:
    t0 = time.time()
    conn_duck.execute(f"SELECT ... FROM db.paired_trades ...").fetchall()
    duck_time = time.time() - t0

# 输出对比表
```

