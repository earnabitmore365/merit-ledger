#!/usr/bin/env python3
"""Regime Detector 全面审计脚本

对 SOL/ETH/XRP 的 1h K 线跑 RegimeDetector，输出：
- 2.1 时间分布表
- 2.2 转换频率 + 抖动统计
- 2.3 准确率（regime vs 实际涨跌）
- 2.4 切换延迟（价格极值 vs 切换时间）

用法: cd auto-trading && python3 lab/regime_audit.py

@see lab/live_regime/regime_detector.py — RegimeDetector 状态机
@see lab/live_regime/swing_tracker.py — 摆动追踪 + 打分
@see lab/live_regime/validity_checker.py — 有效性检测
"""

import json
import os
import sys
import time
from collections import defaultdict
from datetime import datetime, timezone

sys.path.insert(0, os.path.join(os.path.dirname(__file__)))
from live_regime.regime_detector import RegimeDetector

DATA_DIR = os.path.join(os.path.dirname(__file__), 'src', 'backtest', 'data', 'historical')
COINS = ['SOL', 'ETH', 'XRP']


def load_klines(coin: str) -> list:
    path = os.path.join(DATA_DIR, coin, '1h.json')
    with open(path) as f:
        data = json.load(f)
    return data


def run_detector(coin: str, klines: list) -> tuple:
    """跑 RegimeDetector，返回 (regime_segments, transitions)"""
    detector = RegimeDetector(initial_regime='盘整')

    segments = []  # [{regime, start_idx, end_idx, start_time, end_time, start_price, end_price}]
    transitions = []  # [{from, to, idx, time, price}]

    current_regime = '盘整'
    seg_start_idx = 0
    seg_start_time = klines[0].get('open_time', klines[0].get('timestamp', 0))
    seg_start_price = klines[0]['close']

    for i, k in enumerate(klines):
        h = k['high']
        l = k['low']
        c = k['close']
        v = k.get('volume', 0)
        t = k.get('open_time', k.get('timestamp', 0))

        # 每4根聚合一次4h bar
        bar_4h = None
        if i >= 3 and i % 4 == 3:
            slice_4 = klines[i - 3:i + 1]
            bar_4h = {
                'high': max(x['high'] for x in slice_4),
                'low': min(x['low'] for x in slice_4),
                'close': slice_4[-1]['close'],
                'volume': sum(x.get('volume', 0) for x in slice_4),
            }

        result = detector.update(i, h, l, c, v, t, bar_4h)
        new_regime = result['regime']

        if new_regime != current_regime:
            # 结束上一段
            segments.append({
                'regime': current_regime,
                'start_idx': seg_start_idx,
                'end_idx': i - 1,
                'start_time': seg_start_time,
                'end_time': klines[i - 1].get('open_time', klines[i - 1].get('timestamp', 0)),
                'start_price': seg_start_price,
                'end_price': klines[i - 1]['close'],
            })
            transitions.append({
                'from': current_regime,
                'to': new_regime,
                'idx': i,
                'time': t,
                'price': c,
            })
            current_regime = new_regime
            seg_start_idx = i
            seg_start_time = t
            seg_start_price = c

    # 最后一段
    last_k = klines[-1]
    segments.append({
        'regime': current_regime,
        'start_idx': seg_start_idx,
        'end_idx': len(klines) - 1,
        'start_time': seg_start_time,
        'end_time': last_k.get('open_time', last_k.get('timestamp', 0)),
        'start_price': seg_start_price,
        'end_price': last_k['close'],
    })

    return segments, transitions


def ms_to_str(ms):
    if ms > 1e12:
        return datetime.fromtimestamp(ms / 1000, tz=timezone.utc).strftime('%Y-%m-%d %H:%M')
    elif ms > 1e9:
        return datetime.fromtimestamp(ms, tz=timezone.utc).strftime('%Y-%m-%d %H:%M')
    return str(ms)


def hours_between(ms1, ms2):
    if ms1 > 1e12:
        ms1, ms2 = ms1 / 1000, ms2 / 1000
    return abs(ms2 - ms1) / 3600


def print_section_21(coin, segments):
    """2.1 时间分布"""
    print(f"\n### 2.1 Regime 时间分布 — {coin}\n")

    stats = defaultdict(lambda: {'hours': 0, 'count': 0, 'durations': []})
    for seg in segments:
        r = seg['regime']
        dur_h = (seg['end_idx'] - seg['start_idx'] + 1)  # 1h bars = hours
        stats[r]['hours'] += dur_h
        stats[r]['count'] += 1
        stats[r]['durations'].append(dur_h)

    total_h = sum(s['hours'] for s in stats.values())

    print(f"{'Regime':<8} {'总时长(天)':>10} {'占比':>6} {'出现次数':>8} {'平均(天)':>8} {'最短(天)':>8} {'最长(天)':>8}")
    print('-' * 65)
    for regime in ['牛', '初牛', '盘整', '初熊', '熊']:
        s = stats.get(regime)
        if not s or s['count'] == 0:
            print(f"{regime:<8} {'0':>10} {'0%':>6} {'0':>8} {'-':>8} {'-':>8} {'-':>8}")
            continue
        days = s['hours'] / 24
        pct = s['hours'] / total_h * 100
        avg_d = days / s['count']
        min_d = min(s['durations']) / 24
        max_d = max(s['durations']) / 24
        print(f"{regime:<8} {days:>10.1f} {pct:>5.1f}% {s['count']:>8} {avg_d:>8.1f} {min_d:>8.1f} {max_d:>8.1f}")


def print_section_22(coin, transitions, segments):
    """2.2 转换频率 + 抖动"""
    print(f"\n### 2.2 状态转换频率 — {coin}\n")

    path_counts = defaultdict(int)
    for t in transitions:
        key = f"{t['from']} → {t['to']}"
        path_counts[key] += 1

    total = len(transitions)
    print(f"{'转换路径':<20} {'次数':>6} {'占比':>6}")
    print('-' * 35)
    for path, cnt in sorted(path_counts.items(), key=lambda x: -x[1]):
        pct = cnt / total * 100 if total > 0 else 0
        print(f"{path:<20} {cnt:>6} {pct:>5.1f}%")

    # 抖动检测（24h内 A→B→A）
    jitters = 0
    jitter_details = []
    for i in range(len(transitions) - 1):
        t1, t2 = transitions[i], transitions[i + 1]
        if t1['from'] == t2['to']:  # A→B→A
            gap_h = hours_between(t1['time'], t2['time'])
            if gap_h <= 24:
                jitters += 1
                jitter_details.append(
                    f"  {ms_to_str(t1['time'])} {t1['from']}→{t1['to']}→{t2['to']} ({gap_h:.0f}h)")

    total_months = sum(s['end_idx'] - s['start_idx'] + 1 for s in segments) / 24 / 30
    jitters_per_month = jitters / total_months if total_months > 0 else 0

    print(f"\n抖动统计（24h内 A→B→A）：{jitters} 次（{jitters_per_month:.1f}次/月）")
    if jitter_details:
        for d in jitter_details[:10]:
            print(d)
        if len(jitter_details) > 10:
            print(f"  ... 共 {len(jitter_details)} 次")


def print_section_23(coin, segments):
    """2.3 准确率"""
    print(f"\n### 2.3 Regime 判断准确率 — {coin}\n")

    regime_stats = defaultdict(lambda: {'total': 0, 'correct': 0, 'wrong': 0, 'details': []})

    for seg in segments:
        r = seg['regime']
        sp = seg['start_price']
        ep = seg['end_price']
        if sp == 0:
            continue
        change_pct = (ep - sp) / sp * 100
        dur_h = seg['end_idx'] - seg['start_idx'] + 1

        # 判断是否正确
        if r in ('牛', '初牛'):
            correct = change_pct > 2
        elif r in ('熊', '初熊'):
            correct = change_pct < -2
        elif r == '盘整':
            correct = -5 <= change_pct <= 5
        else:
            correct = False

        regime_stats[r]['total'] += 1
        if correct:
            regime_stats[r]['correct'] += 1
        else:
            regime_stats[r]['wrong'] += 1

        regime_stats[r]['details'].append({
            'start': ms_to_str(seg['start_time']),
            'end': ms_to_str(seg['end_time']),
            'dur_days': dur_h / 24,
            'change': change_pct,
            'correct': correct,
        })

    print(f"{'Regime':<8} {'总段数':>6} {'正确':>6} {'错误':>6} {'准确率':>8}")
    print('-' * 40)
    total_t, total_c, total_w = 0, 0, 0
    for regime in ['牛', '初牛', '盘整', '初熊', '熊']:
        s = regime_stats.get(regime, {'total': 0, 'correct': 0, 'wrong': 0})
        acc = s['correct'] / s['total'] * 100 if s['total'] > 0 else 0
        print(f"{regime:<8} {s['total']:>6} {s['correct']:>6} {s['wrong']:>6} {acc:>7.1f}%")
        total_t += s['total']
        total_c += s['correct']
        total_w += s['wrong']
    overall = total_c / total_t * 100 if total_t > 0 else 0
    print(f"{'总计':<8} {total_t:>6} {total_c:>6} {total_w:>6} {overall:>7.1f}%")

    # 输出错误案例
    print(f"\n错误案例（判断方向与实际涨跌不符）：")
    wrong_count = 0
    for regime in ['牛', '初牛', '盘整', '初熊', '熊']:
        for d in regime_stats.get(regime, {'details': []})['details']:
            if not d['correct']:
                mark = "❌"
                print(f"  {mark} {regime:<5} {d['start']} ~ {d['end']} ({d['dur_days']:.1f}天) 涨跌={d['change']:+.1f}%")
                wrong_count += 1
                if wrong_count >= 20:
                    break
        if wrong_count >= 20:
            print(f"  ... 更多错误案例省略")
            break


def print_section_24(coin, segments, klines):
    """2.4 切换延迟（简化版：找每段趋势的极值点）"""
    print(f"\n### 2.4 切换延迟 — {coin}\n")

    print(f"{'事件':<18} {'价格极值时间':<18} {'Detector切换':<18} {'延迟(h)':>8} {'延迟涨跌':>8}")
    print('-' * 75)

    for i, seg in enumerate(segments):
        if seg['regime'] in ('牛', '初牛'):
            # 牛市结束 → 找期间最高价及其时间
            si, ei = seg['start_idx'], seg['end_idx']
            if ei >= len(klines) or si >= len(klines):
                continue
            max_price = 0
            max_idx = si
            for j in range(si, min(ei + 1, len(klines))):
                if klines[j]['high'] > max_price:
                    max_price = klines[j]['high']
                    max_idx = j

            # 切换时间 = 下一段的开始
            if i + 1 < len(segments):
                next_seg = segments[i + 1]
                switch_idx = next_seg['start_idx']
                delay_h = switch_idx - max_idx
                if delay_h > 0 and delay_h < 200:
                    peak_time = klines[max_idx].get('open_time', klines[max_idx].get('timestamp', 0))
                    switch_time = klines[min(switch_idx, len(klines) - 1)].get('open_time', 0)
                    delay_change = (klines[min(switch_idx, len(klines) - 1)]['close'] - max_price) / max_price * 100
                    event = f"{seg['regime']}→{next_seg['regime']}"
                    print(f"{event:<18} {ms_to_str(peak_time):<18} {ms_to_str(switch_time):<18} {delay_h:>7}h {delay_change:>+7.1f}%")

        elif seg['regime'] in ('熊', '初熊'):
            # 熊市结束 → 找期间最低价
            si, ei = seg['start_idx'], seg['end_idx']
            if ei >= len(klines) or si >= len(klines):
                continue
            min_price = float('inf')
            min_idx = si
            for j in range(si, min(ei + 1, len(klines))):
                if klines[j]['low'] < min_price:
                    min_price = klines[j]['low']
                    min_idx = j

            if i + 1 < len(segments):
                next_seg = segments[i + 1]
                switch_idx = next_seg['start_idx']
                delay_h = switch_idx - min_idx
                if delay_h > 0 and delay_h < 200:
                    trough_time = klines[min_idx].get('open_time', klines[min_idx].get('timestamp', 0))
                    switch_time = klines[min(switch_idx, len(klines) - 1)].get('open_time', 0)
                    delay_change = (klines[min(switch_idx, len(klines) - 1)]['close'] - min_price) / min_price * 100
                    event = f"{seg['regime']}→{next_seg['regime']}"
                    print(f"{event:<18} {ms_to_str(trough_time):<18} {ms_to_str(switch_time):<18} {delay_h:>7}h {delay_change:>+7.1f}%")


def main():
    print("=" * 70)
    print("Regime Detector 全面审计 — Part 2 历史性能报告")
    print("=" * 70)

    for coin in COINS:
        print(f"\n{'=' * 70}")
        print(f"币种: {coin}")
        print(f"{'=' * 70}")

        t0 = time.time()
        klines = load_klines(coin)
        print(f"K线数据: {len(klines):,} 根 1h")

        segments, transitions = run_detector(coin, klines)
        elapsed = time.time() - t0
        print(f"Detector 跑完: {len(segments)} 段 regime, {len(transitions)} 次切换, {elapsed:.1f}s")

        print_section_21(coin, segments)
        print_section_22(coin, transitions, segments)
        print_section_23(coin, segments)
        print_section_24(coin, segments, klines)

    print(f"\n{'=' * 70}")
    print("审计完成")
    print(f"{'=' * 70}")


if __name__ == '__main__':
    main()
