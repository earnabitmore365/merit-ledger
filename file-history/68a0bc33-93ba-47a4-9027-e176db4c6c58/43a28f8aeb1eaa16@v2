#!/usr/bin/env python3
"""DuckDB vs SQLite Benchmark v2

策略：先把 SQLite 数据导入 DuckDB 内存（一次性成本），
然后在 DuckDB 原生格式上跑同样的查询对比耗时。
ATTACH 模式已证实更慢（行式读取无列式优势），不再测试。

用法: python3 lab/duckdb_benchmark.py
"""

import sqlite3
import time
import os

import duckdb

# === 配置 ===
DB_PATH = os.path.join(os.path.dirname(__file__), 'reports', 'seed_v3_ttp.db')
# 采样限制（避免内存爆炸，先测 500万行子集）
SAMPLE_LIMIT = 5_000_000


def run_benchmark():
    print("=" * 65)
    print("DuckDB vs SQLite Benchmark v2（原生格式对比）")
    print("=" * 65)

    db_size = os.path.getsize(DB_PATH) / (1024 ** 3)
    print(f"数据库: {os.path.basename(DB_PATH)} ({db_size:.1f} GB)")

    # === 阶段0：从 SQLite 导入数据到 DuckDB 内存 ===
    print(f"\n--- 阶段0：导入前 {SAMPLE_LIMIT:,} 行到 DuckDB 内存 ---")

    conn_sqlite = sqlite3.connect(DB_PATH)
    conn_sqlite.execute("PRAGMA journal_mode=WAL")
    conn_sqlite.execute("PRAGMA cache_size=-500000")

    conn_duck = duckdb.connect()

    # 导入 combo_summary（全量，只有 25K 行）
    t0 = time.time()
    rows = conn_sqlite.execute("SELECT * FROM combo_summary").fetchall()
    cols = [d[0] for d in conn_sqlite.execute("SELECT * FROM combo_summary LIMIT 0").description]
    col_defs = ', '.join(f'"{c}" TEXT' for c in cols)
    conn_duck.execute(f"CREATE TABLE combo_summary ({col_defs})")
    if rows:
        placeholders = ', '.join(['?'] * len(cols))
        conn_duck.executemany(f"INSERT INTO combo_summary VALUES ({placeholders})", rows)
    t_cs = time.time() - t0
    print(f"  combo_summary: {len(rows):,} 行 ({t_cs:.1f}s)")

    # 导入 paired_trades（采样前 N 行）
    t0 = time.time()
    pt_cols = [d[0] for d in conn_sqlite.execute("SELECT * FROM paired_trades LIMIT 0").description]
    pt_col_defs = ', '.join(f'"{c}" TEXT' for c in pt_cols)
    conn_duck.execute(f"CREATE TABLE paired_trades ({pt_col_defs})")

    cursor = conn_sqlite.execute(f"SELECT * FROM paired_trades LIMIT {SAMPLE_LIMIT}")
    batch_size = 100_000
    total_imported = 0
    pt_placeholders = ', '.join(['?'] * len(pt_cols))
    while True:
        batch = cursor.fetchmany(batch_size)
        if not batch:
            break
        conn_duck.executemany(f"INSERT INTO paired_trades VALUES ({pt_placeholders})", batch)
        total_imported += len(batch)
        print(f"    导入中... {total_imported:,} 行", end='\r')
    t_pt = time.time() - t0
    print(f"  paired_trades: {total_imported:,} 行 ({t_pt:.1f}s)       ")

    # 导入 regime_fact_labels（对应 paired_trades 的 trade_id）
    t0 = time.time()
    rfl_cols = [d[0] for d in conn_sqlite.execute("SELECT * FROM regime_fact_labels LIMIT 0").description]
    rfl_col_defs = ', '.join(f'"{c}" TEXT' for c in rfl_cols)
    conn_duck.execute(f"CREATE TABLE regime_fact_labels ({rfl_col_defs})")

    cursor = conn_sqlite.execute(f"SELECT * FROM regime_fact_labels LIMIT {SAMPLE_LIMIT}")
    total_rfl = 0
    rfl_placeholders = ', '.join(['?'] * len(rfl_cols))
    while True:
        batch = cursor.fetchmany(batch_size)
        if not batch:
            break
        conn_duck.executemany(f"INSERT INTO regime_fact_labels VALUES ({rfl_placeholders})", batch)
        total_rfl += len(batch)
        print(f"    导入中... {total_rfl:,} 行", end='\r')
    t_rfl = time.time() - t0
    print(f"  regime_fact_labels: {total_rfl:,} 行 ({t_rfl:.1f}s)       ")

    print(f"\n  总导入时间: {t_cs + t_pt + t_rfl:.1f}s")

    # 拿 combo_ids
    combo_ids = [r[0] for r in conn_sqlite.execute("SELECT id FROM combo_summary LIMIT 100").fetchall()]
    ids_str = ','.join(str(i) for i in combo_ids)

    # === 定义查询 ===
    queries = [
        (
            "Gate全程统计(100 combo)",
            f"""SELECT combo_id, SUM(CAST(r_value AS REAL)) as total_pnl,
                   COUNT(*) as trade_count,
                   AVG(CASE WHEN CAST(r_value AS REAL) > 0 THEN 1.0 ELSE 0.0 END) as win_rate
            FROM paired_trades WHERE CAST(combo_id AS INTEGER) IN ({ids_str})
            GROUP BY combo_id""",
            # SQLite 版（原始类型不需要 CAST）
            f"""SELECT combo_id, SUM(r_value) as total_pnl, COUNT(*) as trade_count,
                   AVG(CASE WHEN r_value > 0 THEN 1.0 ELSE 0.0 END) as win_rate
            FROM paired_trades WHERE combo_id IN ({ids_str}) GROUP BY combo_id""",
        ),

        (
            "Regime维度JOIN(牛)",
            f"""SELECT pt.combo_id, SUM(CAST(pt.r_value AS REAL)) as total_pnl, COUNT(*) as cnt
            FROM paired_trades pt
            JOIN regime_fact_labels rfl ON CAST(pt.id AS INTEGER) = CAST(rfl.trade_id AS INTEGER)
            WHERE CAST(pt.combo_id AS INTEGER) IN ({ids_str}) AND rfl.regime_fact = '牛'
            GROUP BY pt.combo_id""",
            f"""SELECT pt.combo_id, SUM(pt.r_value) as total_pnl, COUNT(*) as cnt
            FROM paired_trades pt
            JOIN regime_fact_labels rfl ON pt.id = rfl.trade_id
            WHERE pt.combo_id IN ({ids_str}) AND rfl.regime_fact = '牛'
            GROUP BY pt.combo_id""",
        ),

        (
            "断点反演(MAX+JOIN)",
            """SELECT pt.combo_id, pt.direction, pt.balance_after
            FROM paired_trades pt
            INNER JOIN (
                SELECT combo_id, MAX(CAST(id AS INTEGER)) as max_id
                FROM paired_trades GROUP BY combo_id
            ) latest ON CAST(pt.id AS INTEGER) = latest.max_id""",
            """SELECT pt.combo_id, pt.direction, pt.balance_after
            FROM paired_trades pt
            INNER JOIN (
                SELECT combo_id, MAX(id) as max_id
                FROM paired_trades GROUP BY combo_id
            ) latest ON pt.id = latest.max_id""",
        ),

        (
            "简单COUNT+GROUP BY",
            "SELECT close_type, COUNT(*) FROM paired_trades GROUP BY close_type ORDER BY close_type",
            "SELECT close_type, COUNT(*) FROM paired_trades GROUP BY close_type ORDER BY close_type",
        ),
    ]

    # === 阶段1：对比查询 ===
    print(f"\n--- 阶段1：查询对比（{total_imported:,} 行子集）---\n")

    # SQLite 也限制到同样的子集
    conn_sqlite_sub = sqlite3.connect(":memory:")
    conn_sqlite_sub.execute("PRAGMA journal_mode=WAL")

    # 创建 SQLite 内存子集
    print("准备 SQLite 内存子集...")
    t0 = time.time()
    conn_sqlite.execute(f"ATTACH ':memory:' AS mem")
    conn_sqlite.execute(f"""CREATE TABLE mem.paired_trades AS
        SELECT * FROM paired_trades LIMIT {SAMPLE_LIMIT}""")
    conn_sqlite.execute(f"""CREATE TABLE mem.combo_summary AS
        SELECT * FROM combo_summary""")
    conn_sqlite.execute(f"""CREATE TABLE mem.regime_fact_labels AS
        SELECT * FROM regime_fact_labels LIMIT {SAMPLE_LIMIT}""")
    t_sqlite_prep = time.time() - t0
    print(f"  SQLite 内存子集准备: {t_sqlite_prep:.1f}s\n")

    results = []

    for name, duck_sql, sqlite_sql in queries:
        print(f"测试: {name}")

        # SQLite（内存子集）
        sqlite_sql_mem = sqlite_sql.replace("paired_trades", "mem.paired_trades")
        sqlite_sql_mem = sqlite_sql_mem.replace("combo_summary", "mem.combo_summary")
        sqlite_sql_mem = sqlite_sql_mem.replace("regime_fact_labels", "mem.regime_fact_labels")

        t0 = time.time()
        try:
            rows_s = conn_sqlite.execute(sqlite_sql_mem).fetchall()
            t_sqlite = time.time() - t0
            print(f"  SQLite:  {t_sqlite:.3f}s ({len(rows_s)} 行)")
        except Exception as e:
            t_sqlite = -1
            rows_s = []
            print(f"  SQLite:  错误 - {e}")

        # DuckDB（原生内存）
        t0 = time.time()
        try:
            rows_d = conn_duck.execute(duck_sql).fetchall()
            t_duck = time.time() - t0
            print(f"  DuckDB:  {t_duck:.3f}s ({len(rows_d)} 行)")
        except Exception as e:
            t_duck = -1
            rows_d = []
            print(f"  DuckDB:  错误 - {e}")

        if t_sqlite > 0 and t_duck > 0:
            speedup = t_sqlite / t_duck
            print(f"  加速:    {speedup:.1f}x")
        else:
            speedup = 0
        print()

        results.append((name, t_sqlite, t_duck, speedup, len(rows_s), len(rows_d)))

    # === 阶段2：全量磁盘 SQLite 对比（不走内存）===
    print(f"\n--- 阶段2：全量磁盘 SQLite（{SAMPLE_LIMIT:,} 行，对比磁盘读取差异）---\n")

    disk_results = []

    # 只跑最快的两个查询（全量太慢）
    disk_queries = [
        (
            "简单COUNT(磁盘)",
            "SELECT close_type, COUNT(*) FROM paired_trades GROUP BY close_type ORDER BY close_type",
        ),
        (
            "Gate统计(磁盘,100combo)",
            f"""SELECT combo_id, SUM(r_value) as total_pnl, COUNT(*) as trade_count
            FROM paired_trades WHERE combo_id IN ({ids_str}) GROUP BY combo_id""",
        ),
    ]

    for name, sql in disk_queries:
        print(f"测试: {name}")
        t0 = time.time()
        rows = conn_sqlite.execute(sql).fetchall()
        t_disk = time.time() - t0
        print(f"  SQLite磁盘全量: {t_disk:.2f}s ({len(rows)} 行)")
        disk_results.append((name, t_disk, len(rows)))

    conn_sqlite.close()
    conn_duck.close()

    # === 汇总 ===
    print("\n" + "=" * 70)
    print("汇总（内存对比，同样数据量）")
    print("=" * 70)
    print(f"数据量: {total_imported:,} 行 paired_trades")
    print(f"{'查询':<25} {'SQLite':>10} {'DuckDB':>10} {'加速':>8}")
    print("-" * 70)
    for name, t_s, t_d, sp, rs, rd in results:
        s_str = f"{t_s:.3f}s" if t_s > 0 else "错误"
        d_str = f"{t_d:.3f}s" if t_d > 0 else "错误"
        sp_str = f"{sp:.1f}x" if sp > 0 else "N/A"
        print(f"{name:<25} {s_str:>10} {d_str:>10} {sp_str:>8}")
    print("=" * 70)

    valid = [r for r in results if r[3] > 0]
    if valid:
        avg_speedup = sum(r[3] for r in valid) / len(valid)
        print(f"\n平均加速: {avg_speedup:.1f}x（{len(valid)}个有效查询）")

    if disk_results:
        print(f"\n磁盘全量参考（SQLite，185M行）:")
        for name, t, cnt in disk_results:
            print(f"  {name}: {t:.2f}s ({cnt} 行)")

    print("\n结论：")
    print("  - ATTACH 模式（直读SQLite）：比 SQLite 更慢（已测试，179s vs 1.2s）")
    print("  - 原生格式：见上方对比表")
    print("  - 如果原生格式加速明显，下一步是将种子库转换为 Parquet 格式")


if __name__ == '__main__':
    run_benchmark()
