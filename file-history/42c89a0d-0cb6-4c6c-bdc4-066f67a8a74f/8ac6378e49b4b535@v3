#!/usr/bin/env python3
"""
Gate v4 组考（组队）— 全选正R（regime only）
输入: gate_v3/gate_v3_report.db (gate2)
输出: gate_v3/gate_v3_report.db (gate3_short / gate3_mid / gate3_long)

选人规则：all_pnl > 0 全部入选，同(策略,币种)只留最优周期
老板决策："不要top。除了不赚钱的和WF筛掉的都全部上"
"""
import sqlite3
import os

REPORT_PATH = os.path.join(os.path.dirname(__file__), 'results', 'gate_v3', 'gate_v3_report.db')

TEAMS = {
    'short': ['1m', '5m', '15m', '30m'],
    'mid':   ['1h', '2h', '4h'],
    'long':  ['8h', '12h', '1d'],
}


def main():
    print("=" * 60)
    print("Gate v4 组考（组队）— 全选正R")
    print("=" * 60)

    rpt = sqlite3.connect(REPORT_PATH)
    rpt.row_factory = sqlite3.Row

    for team_name, intervals in TEAMS.items():
        rpt.execute(f"DROP TABLE IF EXISTS gate3_{team_name}")
        rpt.execute(f'''CREATE TABLE gate3_{team_name} (
            combo_id INTEGER PRIMARY KEY,
            strategy TEXT, coin TEXT, interval TEXT,
            all_pnl REAL,
            selected INTEGER, selected_dimensions TEXT, reason TEXT
        )''')

        all_candidates = []
        for iv in intervals:
            rows = rpt.execute(f"SELECT * FROM gate2_{iv}").fetchall()
            all_candidates.extend(rows)

        if not all_candidates:
            print(f"组考 {team_name}队: 0 个候选，跳过")
            continue

        print(f"组考 {team_name}队: {len(all_candidates)} 个候选...", end=' ', flush=True)

        # 筛选: all_pnl > 0
        positive_combos = {}
        for r in all_candidates:
            pnl = r['all_pnl'] or 0
            if pnl > 0:
                positive_combos[r['combo_id']] = r

        # 去重：同(strategy, coin)只留 all_pnl 最高的周期
        by_strat_coin = {}
        for cid, r in positive_combos.items():
            key = (r['strategy'], r['coin'])
            pnl = r['all_pnl'] or 0
            if key not in by_strat_coin or pnl > by_strat_coin[key][1]:
                by_strat_coin[key] = (cid, pnl)

        final_selected = {v[0] for v in by_strat_coin.values()}

        batch = []
        seen = set()
        for r in all_candidates:
            cid = r['combo_id']
            if cid in seen:
                continue
            seen.add(cid)

            pnl = r['all_pnl'] or 0
            if cid in final_selected:
                batch.append((
                    cid, r['strategy'], r['coin'], r['interval'],
                    pnl,
                    1, '',
                    f"入选: all_pnl={pnl:+.1f}R > 0"
                ))
            else:
                if pnl <= 0:
                    reason = f"未入选: all_pnl={pnl:+.1f}R <= 0"
                else:
                    reason = "未入选: 同(策略,币种)有更优周期"
                batch.append((
                    cid, r['strategy'], r['coin'], r['interval'],
                    pnl,
                    0, '', reason
                ))

        rpt.executemany(f"INSERT OR REPLACE INTO gate3_{team_name} VALUES (?,?,?,?,?,?,?,?)", batch)
        rpt.commit()

        n_selected = sum(1 for b in batch if b[5] == 1)
        n_positive = sum(1 for _, r in positive_combos.items())
        n_deduped = n_positive - n_selected
        print(f"{n_selected} 入选 / {n_positive} 正R / {len(all_candidates)} 总候选 (去重{n_deduped})")

        # 打印入选名单（按PnL降序，只打前20个+省略）
        selected_rows = [(b[1], b[2], b[3], b[4]) for b in batch if b[5] == 1]
        selected_rows.sort(key=lambda x: x[3], reverse=True)
        for i, (s, c, iv, pnl) in enumerate(selected_rows):
            if i < 20:
                print(f"    {s:<25} {c:<8} {iv:<4} {pnl:>+8.1f}R")
            elif i == 20:
                print(f"    ... 还有 {len(selected_rows) - 20} 个")
                break

    rpt.close()
    print(f"\n✅ 组考完成，存入 {REPORT_PATH}")


if __name__ == '__main__':
    main()
