"""CCI Extreme — CCI极值均值回归（短周期专用）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class CCIExtremeConfig:
    period: int = 7
    upper: float = 200.0
    lower: float = -200.0


class CCIExtreme(Strategy):
    def __init__(self, exchange=None, config: Optional[CCIExtremeConfig] = None):
        self.exchange = exchange
        self.config = config or CCIExtremeConfig()

    @property
    def name(self) -> str:
        return "cciextreme"

    def _cci(self, klines, period):
        if len(klines) < period:
            return 0.0
        window = klines[-period:]
        tps = [(c["high"] + c["low"] + c["close"]) / 3 for c in window]
        mean_tp = sum(tps) / len(tps)
        mad = sum(abs(tp - mean_tp) for tp in tps) / len(tps)
        if mad == 0:
            return 0.0
        return (tps[-1] - mean_tp) / (0.015 * mad)

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        p = self.config.period
        if not klines or len(klines) < p + 1:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        cci = self._cci(klines, p)
        prev_cci = self._cci(klines[:-1], p)

        if cci < self.config.lower and prev_cci >= self.config.lower:
            signal = Signal.BUY
        elif cci > self.config.upper and prev_cci <= self.config.upper:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=min(abs(cci) / 300, 1.0),
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"cci": cci, "prev_cci": prev_cci})
