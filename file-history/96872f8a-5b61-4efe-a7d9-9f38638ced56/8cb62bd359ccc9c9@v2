"""Stochastic Fast — 快速随机指标（短周期专用）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class StochasticFastConfig:
    k_period: int = 5
    d_period: int = 3
    overbought: float = 90.0
    oversold: float = 10.0


class StochasticFast(Strategy):
    def __init__(self, exchange=None, config: Optional[StochasticFastConfig] = None):
        self.exchange = exchange
        self.config = config or StochasticFastConfig()

    @property
    def name(self) -> str:
        return "stochasticfast"

    def _stoch_k(self, klines, k_period):
        window = klines[-k_period:]
        highest = max(c["high"] for c in window)
        lowest = min(c["low"] for c in window)
        close = klines[-1]["close"]
        if highest == lowest:
            return 50.0
        return (close - lowest) / (highest - lowest) * 100

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        need = self.config.k_period + self.config.d_period + 1
        if not klines or len(klines) < need:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        k_values = []
        for i in range(self.config.d_period + 1):
            offset = self.config.d_period - i
            end = len(klines) - offset if offset > 0 else len(klines)
            k_values.append(self._stoch_k(klines[:end], self.config.k_period))

        d = sum(k_values[-self.config.d_period:]) / self.config.d_period
        prev_d = sum(k_values[-(self.config.d_period + 1):-1]) / self.config.d_period
        k = k_values[-1]
        prev_k = k_values[-2]

        if k < self.config.oversold and prev_k >= self.config.oversold:
            signal = Signal.BUY
        elif k > self.config.overbought and prev_k <= self.config.overbought:
            signal = Signal.SELL
        elif k > d and prev_k <= prev_d and k < 50:
            signal = Signal.BUY
        elif k < d and prev_k >= prev_d and k > 50:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=abs(k - 50) / 50,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"k": k, "d": d, "prev_k": prev_k})
