#!/usr/bin/env python3
"""
路A Walk-Forward 验证 — SOL/1h

前 80% 数据：重新选 Top 策略（确认是否与全量一致）
后 20% 数据：新旧配置对比（d2d / CAGR / max_dd）
"""

import sqlite3
import os
import math
import statistics
import json
from datetime import datetime

DB_PATH = os.path.join(
    os.path.dirname(os.path.abspath(__file__)), '..', 'reports', 'seed_report.db'
)

INITIAL_BALANCE = 500.0
POSITION_PCT = 0.1

OLD_CONFIG = {
    "name": "旧配置 (cmo / meanreversion / bbsqueeze)",
    "regime_map": {"bull": "cmo", "ranging": "meanreversion", "bear": "bbsqueeze"},
}

NEW_CONFIG = {
    "name": "新配置 (vpt / accumulationdistribution / renko)",
    "regime_map": {"bull": "vpt", "ranging": "accumulationdistribution", "bear": "renko"},
}


# ── 数据查询 ──

def get_candle_range(db_path):
    conn = sqlite3.connect(db_path)
    row = conn.execute("""
        SELECT MIN(candle_idx), MAX(candle_idx)
        FROM regime_timeline WHERE coin = 'SOL' AND interval = '1h'
    """).fetchone()
    conn.close()
    return row[0], row[1]


def get_regime_stats(db_path, idx_start, idx_end):
    """前 80% 策略排名（trades ≥ 200, 按 total_r DESC）"""
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    rows = conn.execute("""
        SELECT
            cs.strategy,
            pt.regime_at_open AS regime,
            COUNT(*) AS trades,
            ROUND(AVG(pt.r_value), 4) AS avg_r,
            ROUND(SUM(pt.r_value), 2) AS total_r,
            ROUND(
                SUM(CASE WHEN pt.close_type = 'liquidation' THEN 1 ELSE 0 END)
                * 100.0 / COUNT(*), 2
            ) AS liq_rate
        FROM paired_trades pt
        JOIN combo_summary cs ON pt.combo_id = cs.id
        WHERE cs.coin = 'SOL' AND cs.interval = '1h'
            AND pt.regime_at_open IN ('bull', 'bear', 'ranging')
            AND pt.open_candle_idx >= ? AND pt.open_candle_idx <= ?
        GROUP BY cs.strategy, pt.regime_at_open
        HAVING COUNT(*) >= 30
        ORDER BY pt.regime_at_open, total_r DESC
    """, (idx_start, idx_end)).fetchall()
    conn.close()
    return rows


def get_trades(db_path, regime_map, idx_start, idx_end):
    """提取指定范围内的自动切换交易"""
    conn = sqlite3.connect(db_path)
    all_trades = []
    for regime, strategy in regime_map.items():
        rows = conn.execute("""
            SELECT pt.open_candle_idx, pt.close_candle_idx, pt.r_value,
                   pt.close_type, pt.direction
            FROM paired_trades pt
            JOIN combo_summary cs ON pt.combo_id = cs.id
            WHERE cs.coin = 'SOL' AND cs.interval = '1h'
                AND cs.strategy = ? AND pt.regime_at_open = ?
                AND pt.open_candle_idx >= ? AND pt.open_candle_idx <= ?
            ORDER BY pt.open_candle_idx
        """, (strategy, regime, idx_start, idx_end)).fetchall()
        for r in rows:
            all_trades.append({
                'open_idx': r[0], 'close_idx': r[1], 'r_value': r[2],
                'close_type': r[3], 'direction': r[4],
            })
    conn.close()
    all_trades.sort(key=lambda x: x['open_idx'])
    return all_trades


# ── 模拟 ──

def simulate(trades, total_days):
    """复利模拟（与 route_a_backtest.py 一致）"""
    balance = INITIAL_BALANCE
    peak = balance
    max_dd = 0.0
    last_close_idx = -1

    doubles = []
    next_double_target = INITIAL_BALANCE * 2
    start_idx = trades[0]['open_idx'] if trades else 0

    daily_pnl = {}
    executed = 0
    skipped = 0
    wins = 0
    losses = 0

    for t in trades:
        if t['open_idx'] < last_close_idx:
            skipped += 1
            continue

        pnl = t['r_value'] * balance * POSITION_PCT
        balance += pnl
        executed += 1

        if t['r_value'] > 0:
            wins += 1
        elif t['r_value'] < 0:
            losses += 1

        if balance <= 0:
            balance = 0
            break

        if balance > peak:
            peak = balance
        dd = (peak - balance) / peak
        if dd > max_dd:
            max_dd = dd

        if balance >= next_double_target:
            day = (t['close_idx'] - start_idx) / 24.0
            doubles.append(day)
            next_double_target *= 2

        day_key = (t['close_idx'] - start_idx) // 24
        daily_pnl[day_key] = daily_pnl.get(day_key, 0.0) + pnl
        last_close_idx = t['close_idx']

    # Sharpe
    int_days = max(int(total_days), 1)
    all_daily = [daily_pnl.get(d, 0.0) for d in range(int_days)]
    if len(all_daily) > 1 and balance > 0:
        avg_ret = statistics.mean(all_daily)
        std_ret = statistics.stdev(all_daily)
        sharpe = (avg_ret / std_ret) * math.sqrt(365) if std_ret > 0 else 0
    else:
        sharpe = 0

    # d2d
    d2d_intervals = []
    for i, day in enumerate(doubles):
        prev = doubles[i - 1] if i > 0 else 0
        d2d_intervals.append(day - prev)

    years = total_days / 365.25
    cagr = ((balance / INITIAL_BALANCE) ** (1 / years) - 1) if years > 0 and balance > 0 else 0

    return {
        'final_balance': round(balance, 2),
        'total_return_pct': round((balance - INITIAL_BALANCE) / INITIAL_BALANCE * 100, 1),
        'cagr_pct': round(cagr * 100, 1),
        'max_dd_pct': round(max_dd * 100, 1),
        'sharpe': round(sharpe, 2),
        'doubles': len(doubles),
        'd2d_first': round(doubles[0], 1) if doubles else None,
        'd2d_avg': round(statistics.mean(d2d_intervals), 1) if d2d_intervals else None,
        'executed': executed,
        'skipped': skipped,
        'win_rate_pct': round(wins / executed * 100, 1) if executed > 0 else 0,
    }


# ── 输出 ──

def print_regime_top(rows, regime_name, top_n=5):
    """打印前 N 策略"""
    filtered = [r for r in rows if r['regime'] == regime_name]
    print(f"\n  {regime_name.upper()} Top {top_n}（trades ≥ 30）:")
    print(f"  {'策略':<28} {'trades':>6} {'avg_r':>8} {'total_r':>9}")
    print(f"  {'-'*28} {'-'*6} {'-'*8} {'-'*9}")
    for r in filtered[:top_n]:
        marker = " ←" if r['trades'] >= 200 else " (trades<200)"
        print(f"  {r['strategy']:<28} {r['trades']:>6} {r['avg_r']:>8.4f} {r['total_r']:>9.2f}{marker}")


def print_comparison(old_r, new_r, label):
    """打印对比表"""
    def fmt(v, s=''):
        return 'N/A' if v is None else f"{v}{s}"

    rows = [
        ('最终余额', f"${old_r['final_balance']:,.2f}", f"${new_r['final_balance']:,.2f}"),
        ('CAGR', fmt(old_r['cagr_pct'], '%'), fmt(new_r['cagr_pct'], '%')),
        ('最大回撤', fmt(old_r['max_dd_pct'], '%'), fmt(new_r['max_dd_pct'], '%')),
        ('Sharpe', fmt(old_r['sharpe']), fmt(new_r['sharpe'])),
        ('翻倍次数', str(old_r['doubles']), str(new_r['doubles'])),
        ('首次翻倍(天)', fmt(old_r['d2d_first']), fmt(new_r['d2d_first'])),
        ('平均翻倍(天)', fmt(old_r['d2d_avg']), fmt(new_r['d2d_avg'])),
        ('执行交易', str(old_r['executed']), str(new_r['executed'])),
        ('胜率', fmt(old_r['win_rate_pct'], '%'), fmt(new_r['win_rate_pct'], '%')),
    ]

    print(f"\n{'='*70}")
    print(f"  {label}")
    print(f"  初始: ${INITIAL_BALANCE}  |  仓位: {POSITION_PCT*100:.0f}%  |  复利")
    print(f"{'='*70}")
    print(f"  {'指标':<16} {'旧配置':>20} {'新配置':>20}")
    print(f"  {'-'*16} {'-'*20} {'-'*20}")
    for name, ov, nv in rows:
        print(f"  {name:<16} {ov:>20} {nv:>20}")
    print(f"{'='*70}")


def main():
    if not os.path.exists(DB_PATH):
        print(f"数据库不存在: {DB_PATH}")
        return

    # 1. 确定分割点
    min_idx, max_idx = get_candle_range(DB_PATH)
    total_candles = max_idx - min_idx + 1
    split_idx = min_idx + int(total_candles * 0.8)

    train_days = (split_idx - min_idx) / 24.0
    test_days = (max_idx - split_idx + 1) / 24.0

    print(f"数据库: {DB_PATH}")
    print(f"SOL/1h 总 K 线: {total_candles}")
    print(f"分割点: candle_idx = {split_idx}")
    print(f"  前 80% (训练): idx {min_idx}~{split_idx - 1} = {train_days:.0f} 天")
    print(f"  后 20% (测试): idx {split_idx}~{max_idx} = {test_days:.0f} 天")

    # ── Phase 1: 前 80% 选策略 ──

    print(f"\n{'#'*70}")
    print(f"  Phase 1: 前 80% 策略排名（验证选择是否一致）")
    print(f"{'#'*70}")

    train_stats = get_regime_stats(DB_PATH, min_idx, split_idx - 1)
    for regime in ['bull', 'ranging', 'bear']:
        print_regime_top(train_stats, regime)

    # 确认前 80% 的 Top 1（trades ≥ 200）
    print(f"\n  --- 前 80% Top 1 确认（trades ≥ 200）---")
    for regime in ['bull', 'ranging', 'bear']:
        filtered = [r for r in train_stats if r['regime'] == regime and r['trades'] >= 200]
        if filtered:
            top = filtered[0]  # 已按 total_r DESC
            print(f"  {regime:>8}: {top['strategy']:<28} total_r={top['total_r']:>8.2f}  trades={top['trades']}")
        else:
            # 放宽到 trades ≥ 30
            relaxed = [r for r in train_stats if r['regime'] == regime]
            if relaxed:
                top = relaxed[0]
                print(f"  {regime:>8}: {top['strategy']:<28} total_r={top['total_r']:>8.2f}  trades={top['trades']} (trades<200, 放宽)")

    # ── Phase 2: 后 20% 对比回测 ──

    print(f"\n{'#'*70}")
    print(f"  Phase 2: 后 20% 对比回测（Out-of-Sample）")
    print(f"{'#'*70}")

    old_trades = get_trades(DB_PATH, OLD_CONFIG['regime_map'], split_idx, max_idx)
    new_trades = get_trades(DB_PATH, NEW_CONFIG['regime_map'], split_idx, max_idx)

    print(f"\n  旧配置提取: {len(old_trades)} 笔")
    print(f"  新配置提取: {len(new_trades)} 笔")

    old_result = simulate(old_trades, test_days)
    new_result = simulate(new_trades, test_days)

    print_comparison(old_result, new_result, "后 20% Out-of-Sample 对比")

    # ── 判定 ──

    print(f"\n{'#'*70}")
    print(f"  判定")
    print(f"{'#'*70}")

    old_return = old_result['total_return_pct']
    new_return = new_result['total_return_pct']

    if old_return > 0:
        improvement = new_return / old_return
        print(f"\n  旧配置收益率: {old_return}%")
        print(f"  新配置收益率: {new_return}%")
        print(f"  提升倍数: {improvement:.1f}x")

        if improvement > 2:
            print(f"\n  ✅ 提升 > 2x，新配置通过 walk-forward 验证")
        else:
            print(f"\n  ❌ 提升 ≤ 2x，新配置未通过阈值")
    else:
        if new_return > 0 and old_return <= 0:
            print(f"\n  旧配置收益率: {old_return}%（负或零）")
            print(f"  新配置收益率: {new_return}%")
            print(f"\n  ✅ 旧配置亏损/持平，新配置盈利，通过")
        else:
            print(f"\n  旧配置收益率: {old_return}%")
            print(f"  新配置收益率: {new_return}%")
            print(f"\n  ⚠️ 两者都不理想")

    # ── 保存报告 ──

    report_dir = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'reports', 'route_a')
    os.makedirs(report_dir, exist_ok=True)

    report = {
        'type': 'walk_forward',
        'split': {
            'train_idx': [min_idx, split_idx - 1],
            'test_idx': [split_idx, max_idx],
            'train_days': round(train_days),
            'test_days': round(test_days),
        },
        'old_config': OLD_CONFIG,
        'new_config': NEW_CONFIG,
        'old_result_oos': old_result,
        'new_result_oos': new_result,
        'parameters': {
            'initial_balance': INITIAL_BALANCE,
            'position_pct': POSITION_PCT,
        },
        'generated_at': datetime.now().isoformat(),
    }

    path = os.path.join(report_dir, 'route_a_walkforward.json')
    with open(path, 'w', encoding='utf-8') as f:
        json.dump(report, f, indent=2, ensure_ascii=False)
    print(f"\n  报告已保存: {path}")


if __name__ == '__main__':
    main()
