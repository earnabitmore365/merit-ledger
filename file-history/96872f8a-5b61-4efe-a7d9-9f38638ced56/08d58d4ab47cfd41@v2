"""Balance of Power — 买卖力量对比"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class BalanceOfPowerConfig:
    smooth_period: int = 14


class BalanceOfPower(Strategy):
    def __init__(self, exchange=None, config: Optional[BalanceOfPowerConfig] = None):
        self.exchange = exchange
        self.config = config or BalanceOfPowerConfig()

    @property
    def name(self) -> str:
        return "balanceofpower"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        p = self.config.smooth_period
        if not klines or len(klines) < p + 2:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        bop_raw = []
        for c in klines:
            hl = c["high"] - c["low"]
            if hl == 0:
                bop_raw.append(0.0)
            else:
                bop_raw.append((c["close"] - c["open"]) / hl)

        bop = sum(bop_raw[-p:]) / p
        prev_bop = sum(bop_raw[-(p + 1):-1]) / p

        if bop > 0 and prev_bop <= 0:
            signal = Signal.BUY
        elif bop < 0 and prev_bop >= 0:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=abs(bop),
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"bop": bop, "prev_bop": prev_bop})
