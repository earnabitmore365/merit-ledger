"""Vortex Indicator — VI+ / VI- 交叉"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class VortexConfig:
    period: int = 14


class Vortex(Strategy):
    def __init__(self, exchange=None, config: Optional[VortexConfig] = None):
        self.exchange = exchange
        self.config = config or VortexConfig()

    @property
    def name(self) -> str:
        return "vortex"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        p = self.config.period
        if not klines or len(klines) < p + 2:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        vi_plus, vi_minus = self._vortex(klines, p)
        prev_plus, prev_minus = self._vortex(klines[:-1], p)

        if vi_plus > vi_minus and prev_plus <= prev_minus:
            signal = Signal.BUY
        elif vi_minus > vi_plus and prev_minus <= prev_plus:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=abs(vi_plus - vi_minus),
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"vi_plus": vi_plus, "vi_minus": vi_minus})

    def _vortex(self, klines, period):
        vm_plus = vm_minus = tr_sum = 0.0
        for i in range(len(klines) - period, len(klines)):
            vm_plus += abs(klines[i]["high"] - klines[i - 1]["low"])
            vm_minus += abs(klines[i]["low"] - klines[i - 1]["high"])
            hl = klines[i]["high"] - klines[i]["low"]
            hc = abs(klines[i]["high"] - klines[i - 1]["close"])
            lc = abs(klines[i]["low"] - klines[i - 1]["close"])
            tr_sum += max(hl, hc, lc)
        if tr_sum == 0:
            return 1.0, 1.0
        return vm_plus / tr_sum, vm_minus / tr_sum
