"""Chandelier Exit — ATR动态追踪止损线换向"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class ChandelierConfig:
    atr_period: int = 10
    multiplier: float = 2.0


class Chandelier(Strategy):
    def __init__(self, exchange=None, config: Optional[ChandelierConfig] = None):
        self.exchange = exchange
        self.config = config or ChandelierConfig()

    @property
    def name(self) -> str:
        return "chandelier"

    def _atr(self, klines, period):
        trs = []
        for i in range(1, len(klines)):
            hl = klines[i]["high"] - klines[i]["low"]
            hc = abs(klines[i]["high"] - klines[i - 1]["close"])
            lc = abs(klines[i]["low"] - klines[i - 1]["close"])
            trs.append(max(hl, hc, lc))
        if len(trs) < period:
            return sum(trs) / len(trs) if trs else 0
        return sum(trs[-period:]) / period

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        p = self.config.atr_period
        if not klines or len(klines) < p + 2:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        atr = self._atr(klines[:-1], p)
        prev_atr = self._atr(klines[:-2], p)

        window = klines[-p:]
        highest = max(c["high"] for c in window)
        lowest = min(c["low"] for c in window)

        prev_window = klines[-(p + 1):-1]
        prev_highest = max(c["high"] for c in prev_window)
        prev_lowest = min(c["low"] for c in prev_window)

        long_stop = highest - self.config.multiplier * atr
        short_stop = lowest + self.config.multiplier * atr
        prev_long_stop = prev_highest - self.config.multiplier * prev_atr
        prev_short_stop = prev_lowest + self.config.multiplier * prev_atr

        close = klines[-1]["close"]
        prev_close = klines[-2]["close"]

        if close > short_stop and prev_close <= prev_short_stop:
            signal = Signal.BUY
        elif close < long_stop and prev_close >= prev_long_stop:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=0.7,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"long_stop": long_stop, "short_stop": short_stop,
                                        "atr": atr, "close": close})
