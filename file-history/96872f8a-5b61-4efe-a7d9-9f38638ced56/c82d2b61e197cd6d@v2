"""Aroon Fast — 快速Aroon交叉（短周期专用）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class AroonFastConfig:
    period: int = 7


class AroonFast(Strategy):
    def __init__(self, exchange=None, config: Optional[AroonFastConfig] = None):
        self.exchange = exchange
        self.config = config or AroonFastConfig()

    @property
    def name(self) -> str:
        return "aroonfast"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        p = self.config.period
        if not klines or len(klines) < p + 2:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        aroon_up, aroon_down = self._aroon(klines, p)
        prev_up, prev_down = self._aroon(klines[:-1], p)

        if aroon_up > aroon_down and prev_up <= prev_down:
            signal = Signal.BUY
        elif aroon_down > aroon_up and prev_down <= prev_up:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=abs(aroon_up - aroon_down) / 100,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"aroon_up": aroon_up, "aroon_down": aroon_down})

    def _aroon(self, klines, period):
        window = klines[-period - 1:]
        highs = [c["high"] for c in window]
        lows = [c["low"] for c in window]
        days_since_high = period - highs.index(max(highs))
        days_since_low = period - lows.index(min(lows))
        aroon_up = days_since_high / period * 100
        aroon_down = days_since_low / period * 100
        return aroon_up, aroon_down
