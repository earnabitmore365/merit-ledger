"""Chaikin Oscillator — AD线的快慢EMA差值"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class ChaikinOscillatorConfig:
    fast_period: int = 3
    slow_period: int = 10


class ChaikinOscillator(Strategy):
    def __init__(self, exchange=None, config: Optional[ChaikinOscillatorConfig] = None):
        self.exchange = exchange
        self.config = config or ChaikinOscillatorConfig()

    @property
    def name(self) -> str:
        return "chaikinoscillator"

    def _ad_line(self, klines):
        ad = []
        cumulative = 0.0
        for c in klines:
            hl = c["high"] - c["low"]
            if hl == 0:
                mfm = 0.0
            else:
                mfm = ((c["close"] - c["low"]) - (c["high"] - c["close"])) / hl
            mfv = mfm * c["volume"]
            cumulative += mfv
            ad.append(cumulative)
        return ad

    def _ema(self, values, period):
        if len(values) < period:
            return values[-1] if values else 0
        k = 2 / (period + 1)
        ema = sum(values[:period]) / period
        for v in values[period:]:
            ema = v * k + ema * (1 - k)
        return ema

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        need = self.config.slow_period + 3
        if not klines or len(klines) < need:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        ad = self._ad_line(klines)
        fast = self._ema(ad, self.config.fast_period)
        slow = self._ema(ad, self.config.slow_period)
        co = fast - slow

        ad_prev = self._ad_line(klines[:-1])
        fast_prev = self._ema(ad_prev, self.config.fast_period)
        slow_prev = self._ema(ad_prev, self.config.slow_period)
        co_prev = fast_prev - slow_prev

        if co > 0 and co_prev <= 0:
            signal = Signal.BUY
        elif co < 0 and co_prev >= 0:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=0.6,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"chaikin_osc": co, "prev_co": co_prev})
