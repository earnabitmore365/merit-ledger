def print_regime_map(regime_map_all):
    """打印映射表"""
    print(f"\n{'='*80}")
    print(f"  Regime → Top 策略映射表（训练期，trades≥100, liq<5%）")
    print(f"{'='*80}")
    print(f"  {'币种':<12} {'Bull':<28} {'Ranging':<28} {'Bear':<28}")
    print(f"  {'-'*12} {'-'*28} {'-'*28} {'-'*28}")

    for coin in ALL_COINS:
        cm = regime_map_all.get(coin, {})
        parts = []
        for regime in ['bull', 'ranging', 'bear']:
            entry = cm.get(regime)
            if entry is None:
                parts.append('— (空仓)')
            else:
                parts.append(f"{entry['strategy'][:20]} ({entry['total_r']:.0f}R)")
        print(f"  {coin:<12} {parts[0]:<28} {parts[1]:<28} {parts[2]:<28}")


def print_comparison(sol_r, rot_r, label):
    """打印对比"""
    def fmt(v, s=''):
        return 'N/A' if v is None else f"{v}{s}"

    rows = [
        ('最终余额', f"${sol_r['final_balance']:,.2f}", f"${rot_r['final_balance']:,.2f}"),
        ('CAGR', fmt(sol_r['cagr_pct'], '%'), fmt(rot_r['cagr_pct'], '%')),
        ('最大回撤', fmt(sol_r['max_dd_pct'], '%'), fmt(rot_r['max_dd_pct'], '%')),
        ('Sharpe', fmt(sol_r['sharpe']), fmt(rot_r['sharpe'])),
        ('翻倍次数', str(sol_r['doubles']), str(rot_r['doubles'])),
        ('首次翻倍(天)', fmt(sol_r['d2d_first']), fmt(rot_r['d2d_first'])),
        ('平均翻倍(天)', fmt(sol_r['d2d_avg']), fmt(rot_r['d2d_avg'])),
        ('执行交易', str(sol_r['executed']), str(rot_r['executed'])),
        ('胜率', fmt(sol_r['win_rate_pct'], '%'), fmt(rot_r['win_rate_pct'], '%')),
    ]

    if 'switches' in rot_r:
        rows.append(('币种切换', '—', str(rot_r['switches'])))
    if 'coins_used' in rot_r:
        rows.append(('使用币种', 'SOL', ', '.join(rot_r['coins_used'])))

    print(f"\n{'='*70}")
    print(f"  {label}")
    print(f"  初始: ${INITIAL_BALANCE}  |  仓位: {POSITION_PCT*100:.0f}%  |  复利  |  切换成本: {SWITCH_COST_PCT*100:.2f}%")
    print(f"{'='*70}")
    print(f"  {'指标':<16} {'SOL单币基准':>20} {'多币轮动':>20}")
    print(f"  {'-'*16} {'-'*20} {'-'*20}")
    for name, sv, rv in rows:
        print(f"  {name:<16} {sv:>20} {rv:>20}")
    print(f"{'='*70}")


def main():
    if not os.path.exists(DB_PATH):
        print(f"数据库不存在: {DB_PATH}")
        return

    # 用 SOL 的 K 线范围作为基准
    conn = sqlite3.connect(DB_PATH)
    row = conn.execute("""
        SELECT MIN(candle_idx), MAX(candle_idx)
        FROM regime_timeline WHERE coin = 'SOL' AND interval = '1h'
    """).fetchone()
    conn.close()

    min_idx, max_idx = row[0], row[1]
    total_candles = max_idx - min_idx + 1
    split_idx = min_idx + int(total_candles * 0.8)

    train_days = (split_idx - min_idx) / 24.0
    test_days = (max_idx - split_idx + 1) / 24.0
    full_days = total_candles / 24.0

    print(f"数据库: {DB_PATH}")
    print(f"基准 K 线范围 (SOL/1h): {min_idx}~{max_idx} ({total_candles} 根)")
    print(f"分割: 前80% = {train_days:.0f}天, 后20% = {test_days:.0f}天")

    # ── Step 1: 训练期建映射表 ──

    print(f"\n{'#'*80}")
    print(f"  Step 1: 训练期映射表（前 80%）")
    print(f"{'#'*80}")

    regime_map_train = build_regime_map(DB_PATH, ALL_COINS, min_idx, split_idx - 1)
    print_regime_map(regime_map_train)

    # 统计有多少币种在各 regime 有可用策略
    for regime in ['bull', 'ranging', 'bear']:
        available = sum(1 for c in ALL_COINS if regime_map_train[c].get(regime) is not None)
        print(f"  {regime}: {available}/{len(ALL_COINS)} 币种有可用策略")

    # ── Step 2a: 全量对比 ──

    print(f"\n{'#'*80}")
    print(f"  Step 2a: 全量对比（{full_days:.0f} 天）")
    print(f"{'#'*80}")

    # 全量映射表
    regime_map_full = build_regime_map(DB_PATH, ALL_COINS, min_idx, max_idx)

    sol_full = simulate_sol_baseline(DB_PATH, min_idx, max_idx, full_days)
    rot_full = simulate_rotation(DB_PATH, regime_map_full, min_idx, max_idx, full_days)
    print_comparison(sol_full, rot_full, f"全量对比（{full_days:.0f} 天）")

    # ── Step 2b: OOS 对比（后 20%，用训练期映射表） ──

    print(f"\n{'#'*80}")
    print(f"  Step 2b: OOS 对比（后 20%，{test_days:.0f} 天）— 用训练期映射表")
    print(f"{'#'*80}")

    sol_oos = simulate_sol_baseline(DB_PATH, split_idx, max_idx, test_days)
    rot_oos = simulate_rotation(DB_PATH, regime_map_train, split_idx, max_idx, test_days)
    print_comparison(sol_oos, rot_oos, f"OOS 对比（后 20%，{test_days:.0f} 天）— 训练期映射表")

    # ── Step 3: 判定 ──

    print(f"\n{'#'*80}")
    print(f"  Step 3: 判定")
    print(f"{'#'*80}")

    print(f"\n  === 全量 ===")
    if sol_full['d2d_avg'] and rot_full['d2d_avg'] and rot_full['d2d_avg'] > 0:
        improvement = sol_full['d2d_avg'] / rot_full['d2d_avg']
        print(f"  d2d 提升: SOL {sol_full['d2d_avg']}天 → 轮动 {rot_full['d2d_avg']}天 ({improvement:.1f}x 快)")
    else:
        print(f"  d2d: SOL={sol_full['d2d_avg']}, 轮动={rot_full['d2d_avg']}")

    print(f"\n  === OOS（关键）===")
    sol_oos_ret = sol_oos['total_return_pct']
    rot_oos_ret = rot_oos['total_return_pct']
    print(f"  SOL 基准: {sol_oos_ret}%")
    print(f"  多币轮动: {rot_oos_ret}%")

    if sol_oos_ret > 0 and rot_oos_ret > 0:
        oos_ratio = rot_oos_ret / sol_oos_ret
        print(f"  OOS 收益比: {oos_ratio:.1f}x")

        # d2d 对比
        if sol_oos['d2d_avg'] and rot_oos['d2d_avg'] and rot_oos['d2d_avg'] > 0:
            d2d_improve = (sol_oos['d2d_avg'] - rot_oos['d2d_avg']) / sol_oos['d2d_avg'] * 100
            print(f"  OOS d2d 提升: {d2d_improve:.0f}%")
            if d2d_improve > 15:
                print(f"\n  ✅ d2d 提升 > 15%，轮动方案通过 OOS 验证")
            else:
                print(f"\n  ❌ d2d 提升 ≤ 15%，轮动方案未达阈值")
        else:
            print(f"  OOS d2d: SOL={sol_oos['d2d_avg']}, 轮动={rot_oos['d2d_avg']}")
    elif rot_oos_ret > 0 and sol_oos_ret <= 0:
        print(f"\n  ✅ SOL 亏损，轮动盈利，通过")
    else:
        print(f"\n  ⚠️ 需要综合判断")

    # Sharpe 对比
    print(f"\n  Sharpe: SOL={sol_oos['sharpe']}, 轮动={rot_oos['sharpe']}")
    if rot_oos['sharpe'] >= sol_oos['sharpe']:
        print(f"  ✅ 轮动 Sharpe 不低于 SOL")
    else:
        print(f"  ⚠️ 轮动 Sharpe 低于 SOL（{rot_oos['sharpe']} < {sol_oos['sharpe']}）")

    # ── 保存报告 ──

    report_dir = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'reports', 'route_b')
    os.makedirs(report_dir, exist_ok=True)

    report = {
        'type': 'rotation_walkforward',
        'coins': ALL_COINS,
        'split': {
            'train_idx': [min_idx, split_idx - 1],
            'test_idx': [split_idx, max_idx],
            'train_days': round(train_days),
            'test_days': round(test_days),
        },
        'regime_map_train': {
            coin: {r: (v['strategy'] if v else None) for r, v in cmap.items()}
            for coin, cmap in regime_map_train.items()
        },
        'full': {'sol': sol_full, 'rotation': rot_full},
        'oos': {'sol': sol_oos, 'rotation': rot_oos},
        'parameters': {
            'initial_balance': INITIAL_BALANCE,
            'position_pct': POSITION_PCT,
            'switch_cost_pct': SWITCH_COST_PCT,
        },
        'generated_at': datetime.now().isoformat(),
    }

    path = os.path.join(report_dir, 'rotation_walkforward.json')
    with open(path, 'w', encoding='utf-8') as f:
        json.dump(report, f, indent=2, ensure_ascii=False)
    print(f"\n  报告已保存: {path}")


if __name__ == '__main__':
    main()
