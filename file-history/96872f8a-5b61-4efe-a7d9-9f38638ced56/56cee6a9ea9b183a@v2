#!/usr/bin/env python3
"""
路B — 多币种 Regime 轮动模拟

Step 1: 建 13币×1h Regime→Top策略 映射表（前80%训练期选策略）
Step 2: 轮动模拟（后20%测试期 + 全量期）
Step 3: 对比 SOL 单币基准 vs 多币轮动

Walk-forward: 前80%建表，后20%验证
切换成本: 0.12%/次（平仓+开仓手续费）
Bear 空仓阈值: avg_r < 0.1 或 trades < 100
"""

import sqlite3
import os
import math
import statistics
import json
from datetime import datetime
from collections import defaultdict

DB_PATH = os.path.join(
    os.path.dirname(os.path.abspath(__file__)), '..', 'reports', 'seed_report.db'
)

INITIAL_BALANCE = 500.0
POSITION_PCT = 0.1
SWITCH_COST_PCT = 0.0012  # 0.12% 切换成本

ALL_COINS = [
    'BTC', 'ETH', 'XRP', 'BNB', 'SOL', 'ADA', 'TRX', 'AVAX', 'LINK', 'DOT',
    'BTC_COIN', 'ETH_COIN', 'BNB_COIN',
]

SOL_BASELINE = {
    "regime_map": {"bull": "cmo", "ranging": "meanreversion", "bear": "bbsqueeze"},
}


# ══════════════════════════════════════════════════════════════
#  Step 1: 建映射表
# ══════════════════════════════════════════════════════════════

def build_regime_map(db_path, coins, idx_start, idx_end):
    """
    对每个币种×每个 regime，选 total_r 最高的策略。
    筛选: trades ≥ 100, liq_rate < 5%
    Bear 空仓: avg_r < 0.1 或 trades < 100 → None
    """
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row

    regime_map = {}  # {coin: {regime: strategy_name or None}}

    for coin in coins:
        rows = conn.execute("""
            SELECT
                cs.strategy,
                pt.regime_at_open AS regime,
                COUNT(*) AS trades,
                ROUND(AVG(pt.r_value), 4) AS avg_r,
                ROUND(SUM(pt.r_value), 2) AS total_r,
                ROUND(
                    SUM(CASE WHEN pt.close_type = 'liquidation' THEN 1 ELSE 0 END)
                    * 100.0 / COUNT(*), 2
                ) AS liq_rate
            FROM paired_trades pt
            JOIN combo_summary cs ON pt.combo_id = cs.id
            WHERE cs.coin = ? AND cs.interval = '1h'
                AND pt.regime_at_open IN ('bull', 'bear', 'ranging')
                AND pt.open_candle_idx >= ? AND pt.open_candle_idx <= ?
            GROUP BY cs.strategy, pt.regime_at_open
            HAVING COUNT(*) >= 100
            ORDER BY pt.regime_at_open, total_r DESC
        """, (coin, idx_start, idx_end)).fetchall()

        coin_map = {}
        for regime in ['bull', 'ranging', 'bear']:
            candidates = [r for r in rows
                          if r['regime'] == regime and r['liq_rate'] < 5.0]

            if regime == 'bear':
                # 空仓阈值: avg_r < 0.1 或 trades < 100 → 空仓
                candidates = [c for c in candidates if c['avg_r'] >= 0.1]

            if candidates:
                top = candidates[0]  # 已按 total_r DESC
                coin_map[regime] = {
                    'strategy': top['strategy'],
                    'avg_r': top['avg_r'],
                    'total_r': top['total_r'],
                    'trades': top['trades'],
                }
            else:
                coin_map[regime] = None  # 空仓

        regime_map[coin] = coin_map

    conn.close()
    return regime_map


# ══════════════════════════════════════════════════════════════
#  Step 2: 轮动模拟
# ══════════════════════════════════════════════════════════════

def get_regime_timeline(db_path, coin, idx_start, idx_end):
    """获取币种的 regime 时间线（每根 K 线的 regime）"""
    conn = sqlite3.connect(db_path)
    rows = conn.execute("""
        SELECT candle_idx, regime
        FROM regime_timeline
        WHERE coin = ? AND interval = '1h'
            AND candle_idx >= ? AND candle_idx <= ?
        ORDER BY candle_idx
    """, (coin, idx_start, idx_end)).fetchall()
    conn.close()
    return rows


def get_trades_for_coin(db_path, coin, strategy, regime, idx_start, idx_end):
    """提取特定币种+策略+regime 的交易"""
    conn = sqlite3.connect(db_path)
    rows = conn.execute("""
        SELECT pt.open_candle_idx, pt.close_candle_idx, pt.r_value,
               pt.close_type, pt.direction
        FROM paired_trades pt
        JOIN combo_summary cs ON pt.combo_id = cs.id
        WHERE cs.coin = ? AND cs.interval = '1h'
            AND cs.strategy = ? AND pt.regime_at_open = ?
            AND pt.open_candle_idx >= ? AND pt.open_candle_idx <= ?
        ORDER BY pt.open_candle_idx
    """, (coin, strategy, regime, idx_start, idx_end)).fetchall()
    conn.close()
    return [{'open_idx': r[0], 'close_idx': r[1], 'r_value': r[2],
             'close_type': r[3], 'direction': r[4]} for r in rows]


def simulate_rotation(db_path, regime_map_all, idx_start, idx_end, total_days):
    """
    多币种轮动模拟：
    - 每个 regime 段，选该 regime 下 total_r 最高的币种
    - 同一时间只持一个仓位
    - 切换币种/策略时扣 0.12% 成本
    """
    # 1. 收集所有币种的 regime 时间线，找共同 regime 段
    #    用 SOL 的 regime 时间线作为基准（所有币种 regime 由各自 ADX 计算，时间线不同）
    #    更好的做法：对每个币种独立检测 regime，选当前 regime 下该币种最优策略

    # 简化方案：遍历所有币种，提取所有可用交易，标记（coin, regime, strategy）
    # 按 open_candle_idx 排序，贪心选择：不重叠 + 优先 r_value 高的

    # 实际方案：按时间段，每个 regime 选最优币种+策略的交易
    # 为简化实现，对每个币种独立建交易流，然后合并所有交易按 open_idx 排序

    all_trades = []
    for coin, coin_map in regime_map_all.items():
        for regime in ['bull', 'ranging', 'bear']:
            entry = coin_map.get(regime)
            if entry is None:
                continue
            strategy = entry['strategy']
            trades = get_trades_for_coin(
                db_path, coin, strategy, regime, idx_start, idx_end
            )
            for t in trades:
                t['coin'] = coin
                t['regime'] = regime
                t['strategy'] = strategy
                t['score'] = entry['total_r']  # 用训练期 total_r 作为优先级
            all_trades.extend(trades)

    # 按 open_idx 排序，相同 idx 按 score 降序（优先选表现好的）
    all_trades.sort(key=lambda x: (x['open_idx'], -x['score']))

    # 贪心模拟：依次执行不重叠的交易
    balance = INITIAL_BALANCE
    peak = balance
    max_dd = 0.0
    last_close_idx = -1
    last_coin = None

    doubles = []
    next_double_target = INITIAL_BALANCE * 2
    start_idx = idx_start

    daily_pnl = {}
    executed = 0
    skipped = 0
    switches = 0
    wins = 0
    losses = 0
    coins_used = set()

    for t in all_trades:
        if t['open_idx'] < last_close_idx:
            skipped += 1
            continue

        # 切换成本
        if last_coin is not None and t['coin'] != last_coin:
            cost = balance * SWITCH_COST_PCT
            balance -= cost
            switches += 1
            if balance <= 0:
                balance = 0
                break

        pnl = t['r_value'] * balance * POSITION_PCT
        balance += pnl
        executed += 1
        coins_used.add(t['coin'])

        if t['r_value'] > 0:
            wins += 1
        elif t['r_value'] < 0:
            losses += 1

        if balance <= 0:
            balance = 0
            break

        if balance > peak:
            peak = balance
        dd = (peak - balance) / peak
        if dd > max_dd:
            max_dd = dd

        if balance >= next_double_target:
            day = (t['close_idx'] - start_idx) / 24.0
            doubles.append(day)
            next_double_target *= 2

        day_key = (t['close_idx'] - start_idx) // 24
        daily_pnl[day_key] = daily_pnl.get(day_key, 0.0) + pnl

        last_close_idx = t['close_idx']
        last_coin = t['coin']

    # Sharpe
    int_days = max(int(total_days), 1)
    all_daily = [daily_pnl.get(d, 0.0) for d in range(int_days)]
    if len(all_daily) > 1 and balance > 0:
        avg_ret = statistics.mean(all_daily)
        std_ret = statistics.stdev(all_daily)
        sharpe = (avg_ret / std_ret) * math.sqrt(365) if std_ret > 0 else 0
    else:
        sharpe = 0

    # d2d
    d2d_intervals = []
    for i, day in enumerate(doubles):
        prev = doubles[i - 1] if i > 0 else 0
        d2d_intervals.append(day - prev)

    years = total_days / 365.25
    cagr = ((balance / INITIAL_BALANCE) ** (1 / years) - 1) if years > 0 and balance > 0 else 0

    return {
        'final_balance': round(balance, 2),
        'total_return_pct': round((balance - INITIAL_BALANCE) / INITIAL_BALANCE * 100, 1),
        'cagr_pct': round(cagr * 100, 1),
        'max_dd_pct': round(max_dd * 100, 1),
        'sharpe': round(sharpe, 2),
        'doubles': len(doubles),
        'd2d_first': round(doubles[0], 1) if doubles else None,
        'd2d_avg': round(statistics.mean(d2d_intervals), 1) if d2d_intervals else None,
        'executed': executed,
        'skipped': skipped,
        'switches': switches,
        'coins_used': sorted(coins_used),
        'win_rate_pct': round(wins / executed * 100, 1) if executed > 0 else 0,
    }


def simulate_sol_baseline(db_path, idx_start, idx_end, total_days):
    """SOL 单币基准（原 Phase 1 配置）"""
    all_trades = []
    for regime, strategy in SOL_BASELINE['regime_map'].items():
        trades = get_trades_for_coin(
            db_path, 'SOL', strategy, regime, idx_start, idx_end
        )
        for t in trades:
            t['coin'] = 'SOL'
            t['regime'] = regime
            t['strategy'] = strategy
            t['score'] = 0
        all_trades.extend(trades)

    all_trades.sort(key=lambda x: x['open_idx'])

    # 复用同样的模拟逻辑（无切换成本，因为单币）
    balance = INITIAL_BALANCE
    peak = balance
    max_dd = 0.0
    last_close_idx = -1

