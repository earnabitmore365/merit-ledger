#!/usr/bin/env python3
"""
pull_indicators_history.py — 拉12个指标的历史原始分数
存进 reports/seed_report.db 的 indicator_daily 表

12张椅子：有数据存，没数据跳过，空椅子不投票
  本地计算：AHR999, Pi Cycle Top (BTC 1h K线)
  API拉取：Fear & Greed, Stablecoin Supply, Funding Rate, OI,
           MVRV, NUPL, Puell, Exchange Netflow, BTC.D

用法：python3 lab/pull_indicators_history.py
"""

import json
import math
import sqlite3
import time
import urllib.request
import urllib.error
from collections import OrderedDict
from datetime import datetime, timezone
from pathlib import Path

# === 路径 ===
PROJECT = Path(__file__).parent.parent
DB_PATH = PROJECT / "reports" / "seed_report.db"
BTC_1H_PATH = PROJECT / "src" / "backtest" / "data" / "historical" / "BTC" / "1h.json"
BTC_GENESIS = datetime(2009, 1, 3, tzinfo=timezone.utc)


# ============================================================
# Helpers
# ============================================================

def _aggregate_daily(klines):
    """1h K线聚合日线（每天最后一根收盘价）"""
    daily = OrderedDict()
    for k in klines:
        dt = datetime.fromtimestamp(k['time'] / 1000, tz=timezone.utc)
        day = dt.strftime('%Y-%m-%d')
        daily[day] = k
    return [
        {'time': v['time'], 'close': v['close'], 'date': d}
        for d, v in daily.items()
    ]


def fetch_json(url, retries=3, delay=5):
    """GET JSON，含重试和429处理"""
    for attempt in range(retries):
        try:
            req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
            with urllib.request.urlopen(req, timeout=60) as resp:
                return json.loads(resp.read())
        except urllib.error.HTTPError as e:
            if e.code == 429:
                wait = 60
                print(f"    ⚠️ 限速 (429)，等待{wait}秒...")
                time.sleep(wait)
            elif attempt < retries - 1:
                print(f"    重试 {attempt+1}/{retries}: HTTP {e.code}")
                time.sleep(delay)
            else:
                print(f"    ❌ 请求失败: HTTP {e.code}")
                return None
        except Exception as e:
            if attempt < retries - 1:
                print(f"    重试 {attempt+1}/{retries}: {e}")
                time.sleep(delay)
            else:
                print(f"    ❌ 请求失败: {e}")
                return None
    return None


def create_table(conn):
    conn.execute("""
        CREATE TABLE IF NOT EXISTS indicator_daily (
            date TEXT,
            indicator TEXT,
            value REAL,
            PRIMARY KEY (date, indicator)
        )
    """)
    conn.commit()


def insert_rows(conn, indicator_name, rows):
    """rows = list of (date_str, value)"""
    if not rows:
        return
    conn.executemany(
        "INSERT OR REPLACE INTO indicator_daily (date, indicator, value) VALUES (?, ?, ?)",
        [(d, indicator_name, v) for d, v in rows]
    )
    conn.commit()


# BGeometrics 记录里的非数值字段
_SKIP_KEYS = {"d", "date", "unixTs", "unix_ts", "timestamp", "time", "t"}


def _extract_value_from_record(record):
    """从 BGeometrics 记录 dict 中提取数值字段（自动检测）"""
    if not isinstance(record, dict):
        return None
    for k, v in record.items():
        if k in _SKIP_KEYS:
            continue
        try:
            return float(v)
        except (ValueError, TypeError):
            continue
    return None


# ============================================================
# 本地计算指标
# ============================================================

def pull_ahr999(conn):
    """AHR999 九神指标
    公式: (price / MA200) × (price / 对数增长估值)
    对数增长: 10^(5.84 × log10(距创世天数) - 17.01)
    """
    klines = json.load(open(BTC_1H_PATH))
    daily = _aggregate_daily(klines)

    if len(daily) < 200:
        print(f"    ⚠️ 需要200天数据，只有{len(daily)}天")
        return 0

    closes = [d['close'] for d in daily]
    rows = []

    for i in range(199, len(daily)):
        price = closes[i]
        ma200 = sum(closes[i-199:i+1]) / 200

        dt = datetime.fromtimestamp(daily[i]['time'] / 1000, tz=timezone.utc)
        days = (dt - BTC_GENESIS).days
        if days <= 0:
            continue

        log_value = 10 ** (5.84 * math.log10(days) - 17.01)
        if log_value <= 0:
            continue

        ahr999 = (price / ma200) * (price / log_value)
        rows.append((daily[i]['date'], round(ahr999, 6)))

    insert_rows(conn, 'ahr999', rows)
    return len(rows)


def pull_pi_cycle(conn):
    """Pi Cycle Top
    gap_pct = (sma350×2 - sma111) / sma350×2 × 100
    正值=安全（111日线在下方），负值=接近或越过顶部
    """
    klines = json.load(open(BTC_1H_PATH))
    daily = _aggregate_daily(klines)

    if len(daily) < 350:
        print(f"    ⚠️ 需要350天数据，只有{len(daily)}天")
        return 0

    closes = [d['close'] for d in daily]
    rows = []

    for i in range(349, len(daily)):
        sma111 = sum(closes[i-110:i+1]) / 111
        sma350x2 = sum(closes[i-349:i+1]) / 350 * 2
        if sma350x2 == 0:
            continue
        gap_pct = (sma350x2 - sma111) / sma350x2 * 100
        rows.append((daily[i]['date'], round(gap_pct, 4)))

    insert_rows(conn, 'pi_cycle_top', rows)
    return len(rows)


# ============================================================
# API 指标
# ============================================================

def pull_fear_greed(conn):
    """Fear & Greed Index (alternative.me) — 全量历史 ~2018起"""
    data = fetch_json("https://api.alternative.me/fng/?limit=0&format=json")
    if not data or 'data' not in data:
        return 0

    rows = []
    for item in data['data']:
        ts = int(item['timestamp'])
        dt = datetime.fromtimestamp(ts, tz=timezone.utc)
        date_str = dt.strftime('%Y-%m-%d')
        value = float(item['value'])
        rows.append((date_str, value))

    insert_rows(conn, 'fear_greed', rows)
    return len(rows)


def pull_stablecoin_supply(conn):
    """Stablecoin Supply (DefiLlama) — USDT 流通量 ~2017起"""
    data = fetch_json("https://stablecoins.llama.fi/stablecoincharts/all?stablecoin=1")
    if not data or not isinstance(data, list):
        return 0

    rows = []
    for item in data:
        ts = int(item['date'])
        dt = datetime.fromtimestamp(ts, tz=timezone.utc)
        date_str = dt.strftime('%Y-%m-%d')
        circ = item.get('totalCirculatingUSD', {}).get('peggedUSD')
        if circ is not None:
            rows.append((date_str, float(circ)))

    insert_rows(conn, 'stablecoin_supply', rows)
    return len(rows)


def pull_funding_rate(conn):
    """Binance BTCUSDT Funding Rate — 分页拉全量 ~2019-09起，每天取平均"""
    all_rates = []
    start_time = 1568764800000  # 2019-09-18 00:00:00 UTC

    print("    分页拉取中...", end="", flush=True)
    pages = 0
    while True:
        url = (
            f"https://fapi.binance.com/fapi/v1/fundingRate"
            f"?symbol=BTCUSDT&startTime={start_time}&limit=1000"
        )
        data = fetch_json(url, retries=3, delay=2)
        if not data or len(data) == 0:
            break

        all_rates.extend(data)
        pages += 1
        if pages % 5 == 0:
            print(f" {pages}页", end="", flush=True)

        last_time = data[-1]['fundingTime']
        start_time = last_time + 1
        if len(data) < 1000:
            break
        time.sleep(0.2)

    print(f" 共{pages}页/{len(all_rates)}条")

    if not all_rates:
        return 0

    # 聚合成每天平均
    daily = {}
    for item in all_rates:
        dt = datetime.fromtimestamp(item['fundingTime'] / 1000, tz=timezone.utc)
        date_str = dt.strftime('%Y-%m-%d')
        rate = float(item['fundingRate'])
        if date_str not in daily:
            daily[date_str] = []
        daily[date_str].append(rate)

    rows = [(d, sum(rates) / len(rates)) for d, rates in daily.items()]
    insert_rows(conn, 'funding_rate', rows)
    return len(rows)


def pull_oi(conn):
    """Binance OI History — 只有~30天，API硬限制"""
    url = (
        "https://fapi.binance.com/futures/data/openInterestHist"
        "?symbol=BTCUSDT&period=1d&limit=500"
    )
    data = fetch_json(url)
    if not data or not isinstance(data, list):
        return 0

    rows = []
    for item in data:
        dt = datetime.fromtimestamp(item['timestamp'] / 1000, tz=timezone.utc)
        date_str = dt.strftime('%Y-%m-%d')
        value = float(item['sumOpenInterestValue'])
        rows.append((date_str, value))

    insert_rows(conn, 'oi', rows)
    return len(rows)


def pull_bgeometrics(conn, endpoint, indicator_name):
    """BGeometrics 链上指标 — 去掉/last拉全量历史"""
    url = f"https://bitcoin-data.com/api/v1/{endpoint}"
    data = fetch_json(url)
    if not data or not isinstance(data, list):
        return 0

    rows = []
    for item in data:
        date_str = item.get('d')
        value = _extract_value_from_record(item)
        if date_str and value is not None:
            rows.append((date_str, value))

    insert_rows(conn, indicator_name, rows)
    return len(rows)


def pull_btc_dominance(conn):
    """BTC.D — CoinGecko 免费API无历史，只有当天"""
    data = fetch_json("https://api.coingecko.com/api/v3/global")
    if not data or 'data' not in data:
        return 0

    btcd = data['data'].get('market_cap_percentage', {}).get('btc')
    if btcd is None:
        return 0

    today = datetime.now(timezone.utc).strftime('%Y-%m-%d')
    insert_rows(conn, 'btc_dominance', [(today, round(btcd, 2))])
    return 1


# ============================================================
# Main
# ============================================================

def main():
    print("=" * 60)
    print("pull_indicators_history.py — 拉12指标历史数据")
    print(f"DB: {DB_PATH}")
    print("=" * 60)

    conn = sqlite3.connect(str(DB_PATH))
    create_table(conn)

    results = {}

    # ---- 1. 本地计算（快，不联网）----
    print("\n📊 本地计算指标（BTC 1h K线 → 日线）...")

    print("  [1/12] AHR999...")
    results['ahr999'] = pull_ahr999(conn)
    print(f"    ✅ {results['ahr999']:,} 天")

    print("  [2/12] Pi Cycle Top...")
    results['pi_cycle_top'] = pull_pi_cycle(conn)
    print(f"    ✅ {results['pi_cycle_top']:,} 天")

    # ---- 2. 免费 API（无限速风险）----
    print("\n🌐 免费 API 指标...")

    print("  [3/12] Fear & Greed Index (alternative.me)...")
    results['fear_greed'] = pull_fear_greed(conn)
    print(f"    ✅ {results['fear_greed']:,} 天")

    print("  [4/12] Stablecoin Supply (DefiLlama)...")
    results['stablecoin_supply'] = pull_stablecoin_supply(conn)
    print(f"    ✅ {results['stablecoin_supply']:,} 天")

    # ---- 3. Binance 衍生品（分页/浅历史）----
    print("\n📈 Binance 衍生品指标...")

    print("  [5/12] Funding Rate (BTCUSDT)...")
    results['funding_rate'] = pull_funding_rate(conn)
    print(f"    ✅ {results['funding_rate']:,} 天")

    print("  [6/12] Open Interest (BTCUSDT)...")
    results['oi'] = pull_oi(conn)
    print(f"    ✅ {results['oi']} 天（仅近30天，Binance API限制）")

    # ---- 4. BGeometrics 链上（8次/小时限速）----
    print("\n🔗 BGeometrics 链上指标（限速8次/小时，每个间隔45秒）...")

    bge_list = [
        ('mvrv',                  'mvrv',             7),
        ('nupl',                  'nupl',             8),
        ('puell-multiple',        'puell',            9),
        ('exchange-netflow-btc',  'exchange_netflow', 10),
    ]

    for i, (endpoint, name, seq) in enumerate(bge_list):
        if i > 0:
            wait = 45
            print(f"    ⏳ 等待{wait}秒（限速保护）...")
            time.sleep(wait)
        print(f"  [{seq}/12] {name}...")
        results[name] = pull_bgeometrics(conn, endpoint, name)
        count = results[name]
        print(f"    ✅ {count:,} 天" if count > 0 else f"    ❌ 缺席")

    # ---- 5. CoinGecko（免费API无历史BTC.D）----
    print("\n🌍 CoinGecko...")

    print("  [11/12] BTC Dominance...")
    results['btc_dominance'] = pull_btc_dominance(conn)
    if results['btc_dominance'] > 0:
        print(f"    ✅ {results['btc_dominance']} 天（免费API无历史，仅当天）")
    else:
        print(f"    ❌ 缺席")

    # [12/12] = Pi Cycle Top（已在第2个算完）
    print(f"\n  [12/12] = Pi Cycle Top（已完成，见上方）")

    # ---- 汇总 ----
    conn.close()

    print("\n" + "=" * 60)
    print("📋 汇总")
    print("=" * 60)

    # 12个指标（Pi Cycle 在本地已算，不重复列）
    all_indicators = [
        'ahr999', 'pi_cycle_top', 'fear_greed', 'stablecoin_supply',
        'funding_rate', 'oi', 'mvrv', 'nupl', 'puell', 'exchange_netflow',
        'btc_dominance'
    ]

    present = 0
    absent = 0
    total_rows = 0

    for name in all_indicators:
        count = results.get(name, 0)
        total_rows += count
        if count > 0:
            present += 1
            print(f"  ✅ {name:<22s} {count:>6,} 天")
        else:
            absent += 1
            print(f"  ❌ {name:<22s} 缺席")

    # OI 算"在但数据少"不算缺席
    print(f"\n  📊 {present}个有数据，{absent}个缺席")
    print(f"  💾 总计 {total_rows:,} 条记录存入 indicator_daily 表")
    print("=" * 60)


if __name__ == '__main__':
    main()
