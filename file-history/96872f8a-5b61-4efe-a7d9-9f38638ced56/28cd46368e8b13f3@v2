"""DEMA-TEMA Cross — 双重/三重指数均线交叉"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class DemaTemaConfig:
    dema_period: int = 5
    tema_period: int = 8


class DemaTema(Strategy):
    def __init__(self, exchange=None, config: Optional[DemaTemaConfig] = None):
        self.exchange = exchange
        self.config = config or DemaTemaConfig()

    @property
    def name(self) -> str:
        return "dematema"

    def _ema(self, prices, period):
        if len(prices) < period:
            return prices[-1] if prices else 0
        k = 2 / (period + 1)
        ema = sum(prices[:period]) / period
        for p in prices[period:]:
            ema = p * k + ema * (1 - k)
        return ema

    def _ema_series(self, prices, period):
        if len(prices) < period:
            return list(prices)
        k = 2 / (period + 1)
        ema = sum(prices[:period]) / period
        result = [ema]
        for p in prices[period:]:
            ema = p * k + ema * (1 - k)
            result.append(ema)
        return result

    def _dema(self, prices, period):
        ema1 = self._ema(prices, period)
        ema_s = self._ema_series(prices, period)
        ema2 = self._ema(ema_s, period)
        return 2 * ema1 - ema2

    def _tema(self, prices, period):
        ema1_s = self._ema_series(prices, period)
        ema2_s = self._ema_series(ema1_s, period)
        ema3 = self._ema(ema2_s, period)
        ema1 = ema1_s[-1]
        ema2 = ema2_s[-1]
        return 3 * ema1 - 3 * ema2 + ema3

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        need = max(self.config.dema_period, self.config.tema_period) * 3 + 2
        if not klines or len(klines) < need:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        closes = [c["close"] for c in klines]
        dema = self._dema(closes, self.config.dema_period)
        tema = self._tema(closes, self.config.tema_period)
        prev_dema = self._dema(closes[:-1], self.config.dema_period)
        prev_tema = self._tema(closes[:-1], self.config.tema_period)

        if dema > tema and prev_dema <= prev_tema:
            signal = Signal.BUY
        elif dema < tema and prev_dema >= prev_tema:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        spread = (dema - tema) / tema * 100 if tema != 0 else 0
        return TradingSignal(signal=signal, confidence=min(abs(spread) / 0.3, 1.0),
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"dema": dema, "tema": tema, "spread_pct": spread})
