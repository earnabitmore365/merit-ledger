"""Donchian Break — 快速唐奇安通道突破（短周期专用）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class DonchianBreakConfig:
    period: int = 10


class DonchianBreak(Strategy):
    def __init__(self, exchange=None, config: Optional[DonchianBreakConfig] = None):
        self.exchange = exchange
        self.config = config or DonchianBreakConfig()

    @property
    def name(self) -> str:
        return "donchianbreak"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        p = self.config.period
        if not klines or len(klines) < p + 1:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        lookback = klines[-(p + 1):-1]
        highest = max(c["high"] for c in lookback)
        lowest = min(c["low"] for c in lookback)
        close = klines[-1]["close"]
        prev_close = klines[-2]["close"]

        if close > highest and prev_close <= highest:
            signal = Signal.BUY
        elif close < lowest and prev_close >= lowest:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        mid = (highest + lowest) / 2
        width = (highest - lowest) / mid * 100 if mid != 0 else 0
        return TradingSignal(signal=signal, confidence=min(width / 5, 1.0),
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"highest": highest, "lowest": lowest,
                                        "close": close, "width_pct": width})
