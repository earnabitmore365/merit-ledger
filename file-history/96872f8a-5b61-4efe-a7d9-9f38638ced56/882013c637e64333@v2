"""Bollinger Deviation — 布林带偏离度均值回归（短周期专用）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
import math
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class BollingerDeviationConfig:
    period: int = 10
    num_std: float = 1.5


class BollingerDeviation(Strategy):
    def __init__(self, exchange=None, config: Optional[BollingerDeviationConfig] = None):
        self.exchange = exchange
        self.config = config or BollingerDeviationConfig()

    @property
    def name(self) -> str:
        return "bollingerdeviation"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        p = self.config.period
        if not klines or len(klines) < p + 1:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        closes = [c["close"] for c in klines[-p:]]
        mean = sum(closes) / len(closes)
        std = math.sqrt(sum((x - mean) ** 2 for x in closes) / len(closes))
        if std == 0:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"])

        upper = mean + self.config.num_std * std
        lower = mean - self.config.num_std * std
        price = closes[-1]
        pct_b = (price - lower) / (upper - lower)

        prev_closes = [c["close"] for c in klines[-(p + 1):-1]]
        prev_mean = sum(prev_closes) / len(prev_closes)
        prev_std = math.sqrt(sum((x - prev_mean) ** 2 for x in prev_closes) / len(prev_closes))
        prev_upper = prev_mean + self.config.num_std * prev_std if prev_std > 0 else prev_mean
        prev_lower = prev_mean - self.config.num_std * prev_std if prev_std > 0 else prev_mean
        prev_price = prev_closes[-1]
        prev_pct_b = (prev_price - prev_lower) / (prev_upper - prev_lower) if prev_upper != prev_lower else 0.5

        if pct_b < 0 and prev_pct_b >= 0:
            signal = Signal.BUY
        elif pct_b > 1 and prev_pct_b <= 1:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=abs(pct_b - 0.5),
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"pct_b": pct_b, "upper": upper, "lower": lower})
