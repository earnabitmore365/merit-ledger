"""MACD Fast — 快速MACD（短周期专用）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class MACDFastConfig:
    fast_period: int = 5
    slow_period: int = 13
    signal_period: int = 4


class MACDFast(Strategy):
    def __init__(self, exchange=None, config: Optional[MACDFastConfig] = None):
        self.exchange = exchange
        self.config = config or MACDFastConfig()

    @property
    def name(self) -> str:
        return "macdfast"

    def _ema(self, prices, period):
        if len(prices) < period:
            return prices[-1] if prices else 0
        k = 2 / (period + 1)
        ema = sum(prices[:period]) / period
        for p in prices[period:]:
            ema = p * k + ema * (1 - k)
        return ema

    def _ema_series(self, prices, period):
        if len(prices) < period:
            return [prices[-1]] if prices else [0]
        k = 2 / (period + 1)
        ema = sum(prices[:period]) / period
        result = [ema]
        for p in prices[period:]:
            ema = p * k + ema * (1 - k)
            result.append(ema)
        return result

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        need = self.config.slow_period + self.config.signal_period + 2
        if not klines or len(klines) < need:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        closes = [c["close"] for c in klines]
        fast_ema = self._ema_series(closes, self.config.fast_period)
        slow_ema = self._ema_series(closes, self.config.slow_period)

        min_len = min(len(fast_ema), len(slow_ema))
        macd_line = [fast_ema[len(fast_ema) - min_len + i] - slow_ema[len(slow_ema) - min_len + i]
                     for i in range(min_len)]

        if len(macd_line) < self.config.signal_period + 1:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"])

        signal_line = self._ema_series(macd_line, self.config.signal_period)
        histogram = macd_line[-1] - signal_line[-1]
        prev_histogram = macd_line[-2] - signal_line[-2] if len(signal_line) >= 2 else 0

        if histogram > 0 and prev_histogram <= 0:
            sig = Signal.BUY
        elif histogram < 0 and prev_histogram >= 0:
            sig = Signal.SELL
        else:
            sig = Signal.HOLD

        return TradingSignal(signal=sig, confidence=min(abs(histogram) / closes[-1] * 1000, 1.0),
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"macd": macd_line[-1], "signal": signal_line[-1],
                                        "histogram": histogram})
