"""PV Divergence — 价量背离检测"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class PVDivergenceConfig:
    period: int = 10


class PVDivergence(Strategy):
    def __init__(self, exchange=None, config: Optional[PVDivergenceConfig] = None):
        self.exchange = exchange
        self.config = config or PVDivergenceConfig()

    @property
    def name(self) -> str:
        return "pvdivergence"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        p = self.config.period
        if not klines or len(klines) < p + 2:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        price_slope = self._slope([c["close"] for c in klines[-p:]])
        vol_slope = self._slope([c["volume"] for c in klines[-p:]])
        prev_price_slope = self._slope([c["close"] for c in klines[-(p + 1):-1]])
        prev_vol_slope = self._slope([c["volume"] for c in klines[-(p + 1):-1]])

        bearish_div = price_slope > 0 and vol_slope < 0
        bullish_div = price_slope < 0 and vol_slope > 0
        prev_bearish = prev_price_slope > 0 and prev_vol_slope < 0
        prev_bullish = prev_price_slope < 0 and prev_vol_slope > 0

        if bullish_div and not prev_bullish:
            signal = Signal.BUY
        elif bearish_div and not prev_bearish:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=0.6,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"price_slope": price_slope, "vol_slope": vol_slope})

    def _slope(self, y):
        n = len(y)
        if n < 2:
            return 0.0
        x_mean = (n - 1) / 2
        y_mean = sum(y) / n
        num = sum((i - x_mean) * (y[i] - y_mean) for i in range(n))
        den = sum((i - x_mean) ** 2 for i in range(n))
        return num / den if den != 0 else 0.0
