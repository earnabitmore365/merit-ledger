"""KAMA — Kaufman Adaptive Moving Average"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class KAMAConfig:
    er_period: int = 10
    fast_sc: int = 2
    slow_sc: int = 30


class KAMA(Strategy):
    def __init__(self, exchange=None, config: Optional[KAMAConfig] = None):
        self.exchange = exchange
        self.config = config or KAMAConfig()

    @property
    def name(self) -> str:
        return "kama"

    def _kama_series(self, closes):
        er_p = self.config.er_period
        fast_k = 2 / (self.config.fast_sc + 1)
        slow_k = 2 / (self.config.slow_sc + 1)

        if len(closes) < er_p + 1:
            return closes[:]

        kama_vals = closes[:er_p]
        kama = closes[er_p - 1]

        for i in range(er_p, len(closes)):
            direction = abs(closes[i] - closes[i - er_p])
            volatility = sum(abs(closes[j] - closes[j - 1]) for j in range(i - er_p + 1, i + 1))

            if volatility == 0:
                er = 0
            else:
                er = direction / volatility

            sc = (er * (fast_k - slow_k) + slow_k) ** 2
            kama = kama + sc * (closes[i] - kama)
            kama_vals.append(kama)

        return kama_vals

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        need = self.config.er_period + 3
        if not klines or len(klines) < need:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        closes = [c["close"] for c in klines]
        kama_vals = self._kama_series(closes)

        if len(kama_vals) < 2:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"])

        price = closes[-1]
        prev_price = closes[-2]
        kama_now = kama_vals[-1]
        kama_prev = kama_vals[-2]

        if price > kama_now and prev_price <= kama_prev:
            signal = Signal.BUY
        elif price < kama_now and prev_price >= kama_prev:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        spread = (price - kama_now) / kama_now * 100 if kama_now != 0 else 0
        return TradingSignal(signal=signal, confidence=min(abs(spread) / 1.0, 1.0),
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"kama": kama_now, "price": price, "spread_pct": spread})
