"""Coppock Curve — WMA(ROC(11)+ROC(14), 10) 零轴交叉"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class CoppockConfig:
    roc_short: int = 11
    roc_long: int = 14
    wma_period: int = 10


class Coppock(Strategy):
    def __init__(self, exchange=None, config: Optional[CoppockConfig] = None):
        self.exchange = exchange
        self.config = config or CoppockConfig()

    @property
    def name(self) -> str:
        return "coppock"

    def _roc(self, closes, period):
        if len(closes) <= period:
            return 0.0
        prev = closes[-period - 1]
        if prev == 0:
            return 0.0
        return (closes[-1] - prev) / prev * 100

    def _wma(self, values, period):
        if len(values) < period:
            return values[-1] if values else 0
        window = values[-period:]
        weight_sum = period * (period + 1) / 2
        return sum(window[i] * (i + 1) for i in range(period)) / weight_sum

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        need = self.config.roc_long + self.config.wma_period + 2
        if not klines or len(klines) < need:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        closes = [c["close"] for c in klines]

        coppock_series = []
        for i in range(self.config.wma_period + 1):
            end = len(closes) - self.config.wma_period + i
            sub = closes[:end]
            roc_s = self._roc(sub, self.config.roc_short)
            roc_l = self._roc(sub, self.config.roc_long)
            coppock_series.append(roc_s + roc_l)

        coppock = self._wma(coppock_series, self.config.wma_period)
        prev_coppock = self._wma(coppock_series[:-1], self.config.wma_period)

        if coppock > 0 and prev_coppock <= 0:
            signal = Signal.BUY
        elif coppock < 0 and prev_coppock >= 0:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=min(abs(coppock) / 10, 1.0),
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"coppock": coppock, "prev_coppock": prev_coppock})
