#!/usr/bin/env python3
"""
路A Step 1 — SOL/1h 各 Regime 策略排名

统计 SOL/1h 在 bull/ranging/bear 三个 regime 下每个策略的表现：
  - avg_r: 平均 R 值
  - trades: 交易笔数
  - total_r: 总 R 值 (avg_r × trades)
  - liq_rate: 爆仓率 (%)

筛选：trades ≥ 30，liq_rate > 5% 排除
额外：bear 段 trix 的 direction 分布（SHORT 占比需 >60%）
"""

import sqlite3
import os

# 数据库路径（从 lab/ 向上找 reports/）
DB_PATH = os.path.join(
    os.path.dirname(os.path.abspath(__file__)), '..', 'reports', 'seed_report.db'
)


def query_regime_stats(db_path: str):
    """统计 SOL/1h 各 regime 下策略表现"""
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row

    sql = """
    SELECT
        cs.strategy,
        pt.regime_at_open AS regime,
        COUNT(*) AS trades,
        ROUND(AVG(pt.r_value), 4) AS avg_r,
        ROUND(SUM(pt.r_value), 2) AS total_r,
        ROUND(
            SUM(CASE WHEN pt.close_type = 'liquidation' THEN 1 ELSE 0 END) * 100.0 / COUNT(*),
            2
        ) AS liq_rate
    FROM paired_trades pt
    JOIN combo_summary cs ON pt.combo_id = cs.id
    WHERE cs.coin = 'SOL' AND cs.interval = '1h'
        AND pt.regime_at_open IN ('bull', 'bear', 'ranging')
    GROUP BY cs.strategy, pt.regime_at_open
    HAVING COUNT(*) >= 30
    ORDER BY pt.regime_at_open, total_r DESC
    """

    rows = conn.execute(sql).fetchall()
    conn.close()
    return rows


def query_trix_bear_direction(db_path: str):
    """bear 段 trix 策略的 direction 分布"""
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row

    sql = """
    SELECT
        pt.direction,
        COUNT(*) AS cnt
    FROM paired_trades pt
    JOIN combo_summary cs ON pt.combo_id = cs.id
    WHERE cs.coin = 'SOL' AND cs.interval = '1h'
        AND cs.strategy = 'trix'
        AND pt.regime_at_open = 'bear'
    GROUP BY pt.direction
    """

    rows = conn.execute(sql).fetchall()
    conn.close()
    return rows


def print_table(title: str, rows: list):
    """打印格式化表格"""
    print(f"\n{'='*70}")
    print(f"  {title}")
    print(f"{'='*70}")
    print(f"  {'策略':<28} {'trades':>6} {'avg_r':>8} {'total_r':>9} {'liq%':>6}")
    print(f"  {'-'*28} {'-'*6} {'-'*8} {'-'*9} {'-'*6}")

    for r in rows:
        liq_marker = " ❌" if r['liq_rate'] > 5.0 else ""
        print(
            f"  {r['strategy']:<28} {r['trades']:>6} {r['avg_r']:>8.4f} "
            f"{r['total_r']:>9.2f} {r['liq_rate']:>5.2f}%{liq_marker}"
        )


def main():
    if not os.path.exists(DB_PATH):
        print(f"数据库不存在: {DB_PATH}")
        return

    print(f"数据库: {DB_PATH}")
    print(f"目标: SOL/1h 各 regime 策略排名")
    print(f"筛选: trades ≥ 30, liq_rate > 5% 标记 ❌ 排除")

    # 1. 主查询
    rows = query_regime_stats(DB_PATH)

    # 按 regime 分组
    regimes = {'bull': [], 'ranging': [], 'bear': []}
    for r in rows:
        regime = r['regime']
        if regime in regimes:
            regimes[regime].append(r)

    # 2. 打印三张表
    for regime_name in ['bull', 'ranging', 'bear']:
        regime_rows = regimes[regime_name]
        # 先显示全部（含 liq > 5% 标记），让用户看到完整数据
        print_table(
            f"{regime_name.upper()} — SOL/1h ({len(regime_rows)} 个策略, trades≥30)",
            regime_rows
        )

        # 统计有效策略数
        valid = [r for r in regime_rows if r['liq_rate'] <= 5.0]
        excluded = len(regime_rows) - len(valid)
        if excluded > 0:
            print(f"  （{excluded} 个策略因 liq_rate > 5% 被排除）")

    # 3. Bear 段 trix direction 分布
    print(f"\n{'='*70}")
    print(f"  BEAR 段 trix — direction 分布")
    print(f"{'='*70}")

    trix_dirs = query_trix_bear_direction(DB_PATH)
    total = sum(r['cnt'] for r in trix_dirs)
    for r in trix_dirs:
        pct = r['cnt'] / total * 100 if total > 0 else 0
        marker = " ✅" if r['direction'] == 'SELL' and pct > 60 else ""
        print(f"  {r['direction']:<8} {r['cnt']:>6} ({pct:.1f}%){marker}")
    print(f"  {'合计':<8} {total:>6}")

    if total == 0:
        print("  ⚠️ 无 trix bear 段交易")


if __name__ == '__main__':
    main()
