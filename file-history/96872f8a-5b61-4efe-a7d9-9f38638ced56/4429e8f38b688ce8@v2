"""OBV Slope — OBV斜率方向"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class OBVSlopeConfig:
    obv_period: int = 20
    slope_period: int = 5


class OBVSlope(Strategy):
    def __init__(self, exchange=None, config: Optional[OBVSlopeConfig] = None):
        self.exchange = exchange
        self.config = config or OBVSlopeConfig()

    @property
    def name(self) -> str:
        return "obvslope"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        need = self.config.obv_period + self.config.slope_period + 2
        if not klines or len(klines) < need:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        obv_series = self._obv(klines)
        sp = self.config.slope_period
        slope = self._linreg_slope(obv_series[-sp:])
        prev_slope = self._linreg_slope(obv_series[-(sp + 1):-1])

        if slope > 0 and prev_slope <= 0:
            signal = Signal.BUY
        elif slope < 0 and prev_slope >= 0:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=0.6,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"obv_slope": slope, "prev_slope": prev_slope})

    def _obv(self, klines):
        obv = [0.0]
        for i in range(1, len(klines)):
            if klines[i]["close"] > klines[i - 1]["close"]:
                obv.append(obv[-1] + klines[i]["volume"])
            elif klines[i]["close"] < klines[i - 1]["close"]:
                obv.append(obv[-1] - klines[i]["volume"])
            else:
                obv.append(obv[-1])
        return obv

    def _linreg_slope(self, y):
        n = len(y)
        if n < 2:
            return 0.0
        x_mean = (n - 1) / 2
        y_mean = sum(y) / n
        num = sum((i - x_mean) * (y[i] - y_mean) for i in range(n))
        den = sum((i - x_mean) ** 2 for i in range(n))
        return num / den if den != 0 else 0.0
