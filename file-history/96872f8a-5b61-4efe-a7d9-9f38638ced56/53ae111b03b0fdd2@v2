"""ORB — Opening Range Breakout（开盘区间突破）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class ORBConfig:
    range_bars: int = 12


class ORB(Strategy):
    def __init__(self, exchange=None, config: Optional[ORBConfig] = None):
        self.exchange = exchange
        self.config = config or ORBConfig()

    @property
    def name(self) -> str:
        return "orb"

    def _utc_day(self, ts_ms):
        return ts_ms // 86400000

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        rb = self.config.range_bars
        if not klines or len(klines) < rb + 2:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        current_day = self._utc_day(klines[-1]["time"])

        today_bars = []
        for c in klines:
            if self._utc_day(c["time"]) == current_day:
                today_bars.append(c)

        if len(today_bars) <= rb:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"],
                                 metadata={"reason": "still_in_range_period"})

        range_bars = today_bars[:rb]
        orb_high = max(c["high"] for c in range_bars)
        orb_low = min(c["low"] for c in range_bars)

        close = klines[-1]["close"]
        prev_close = klines[-2]["close"]

        if close > orb_high and prev_close <= orb_high:
            signal = Signal.BUY
        elif close < orb_low and prev_close >= orb_low:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        orb_width = (orb_high - orb_low) / orb_low * 100 if orb_low != 0 else 0
        return TradingSignal(signal=signal, confidence=min(orb_width / 3, 1.0),
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"orb_high": orb_high, "orb_low": orb_low,
                                        "close": close, "today_bar_count": len(today_bars)})
