#!/usr/bin/env python3
"""
路A Step 3 — SOL/1h 新旧配置对比回测

从种子数据库提取交易，按 regime_map 模拟自动切换复利资金曲线。
对比旧配置和新配置的 d2d / total_return / max_dd / Sharpe。
"""

import sqlite3
import os
import math
import statistics
import json
from datetime import datetime

DB_PATH = os.path.join(
    os.path.dirname(os.path.abspath(__file__)), '..', 'reports', 'seed_report.db'
)

INITIAL_BALANCE = 500.0
POSITION_PCT = 0.1   # 每次投入 10% 资金

OLD_CONFIG = {
    "name": "旧配置 (cmo / meanreversion / bbsqueeze)",
    "regime_map": {"bull": "cmo", "ranging": "meanreversion", "bear": "bbsqueeze"},
}

NEW_CONFIG = {
    "name": "新配置 (vpt / accumulationdistribution / renko)",
    "regime_map": {"bull": "vpt", "ranging": "accumulationdistribution", "bear": "renko"},
}


def get_trades(db_path, regime_map):
    """从种子数据库提取自动切换交易"""
    conn = sqlite3.connect(db_path)

    all_trades = []
    for regime, strategy in regime_map.items():
        rows = conn.execute("""
            SELECT pt.open_candle_idx, pt.close_candle_idx, pt.r_value,
                   pt.close_type, pt.direction
            FROM paired_trades pt
            JOIN combo_summary cs ON pt.combo_id = cs.id
            WHERE cs.coin = 'SOL' AND cs.interval = '1h'
                AND cs.strategy = ?
                AND pt.regime_at_open = ?
            ORDER BY pt.open_candle_idx
        """, (strategy, regime)).fetchall()

        for r in rows:
            all_trades.append({
                'open_idx': r[0], 'close_idx': r[1], 'r_value': r[2],
                'close_type': r[3], 'direction': r[4],
                'regime': regime, 'strategy': strategy,
            })

    conn.close()
    all_trades.sort(key=lambda x: x['open_idx'])
    return all_trades


def get_time_span(db_path):
    """获取 SOL/1h K 线时间跨度"""
    conn = sqlite3.connect(db_path)
    row = conn.execute("""
        SELECT MIN(candle_idx), MAX(candle_idx)
        FROM regime_timeline
        WHERE coin = 'SOL' AND interval = '1h'
    """).fetchone()
    conn.close()
    total_candles = row[1] - row[0] + 1
    return {
        'min_idx': row[0],
        'max_idx': row[1],
        'total_candles': total_candles,
        'total_days': total_candles / 24.0,
    }


def simulate(trades, time_span, initial_balance=INITIAL_BALANCE, position_pct=POSITION_PCT):
    """模拟复利资金曲线（不重叠交易）"""
    balance = initial_balance
    peak = balance
    max_dd = 0.0
    last_close_idx = -1

    # 翻倍追踪
    doubles = []
    next_double_target = initial_balance * 2
    start_idx = time_span['min_idx']

    # 每日 PnL（用于 Sharpe）
    daily_pnl = {}
    total_days = int(time_span['total_days'])

    # 统计
    executed_trades = 0
    skipped_trades = 0
    wins = 0
    losses = 0

    for t in trades:
        # 跳过重叠交易（同一时间只能持一个仓位）
        if t['open_idx'] < last_close_idx:
            skipped_trades += 1
            continue

        pnl = t['r_value'] * balance * position_pct
        balance += pnl
        executed_trades += 1

        if t['r_value'] > 0:
            wins += 1
        elif t['r_value'] < 0:
            losses += 1

        if balance <= 0:
            balance = 0
            break

        # Max drawdown
        if balance > peak:
            peak = balance
        dd = (peak - balance) / peak
        if dd > max_dd:
            max_dd = dd

        # 翻倍检测
        if balance >= next_double_target:
            day = (t['close_idx'] - start_idx) / 24.0
            doubles.append(day)
            next_double_target *= 2

        # 每日 PnL
        day_key = (t['close_idx'] - start_idx) // 24
        daily_pnl[day_key] = daily_pnl.get(day_key, 0.0) + pnl

        last_close_idx = t['close_idx']

    # Sharpe（包含无交易日为 0）
    all_daily_returns = []
    for d in range(total_days):
        all_daily_returns.append(daily_pnl.get(d, 0.0))

    if len(all_daily_returns) > 1 and balance > 0:
        avg_ret = statistics.mean(all_daily_returns)
        std_ret = statistics.stdev(all_daily_returns)
        sharpe = (avg_ret / std_ret) * math.sqrt(365) if std_ret > 0 else 0
    else:
        sharpe = 0

    # d2d 计算
    d2d_intervals = []
    for i, day in enumerate(doubles):
        prev = doubles[i - 1] if i > 0 else 0
        d2d_intervals.append(day - prev)

    total_return_pct = (balance - initial_balance) / initial_balance * 100

    # CAGR
    years = time_span['total_days'] / 365.25
    if years > 0 and balance > 0:
        cagr = (balance / initial_balance) ** (1 / years) - 1
    else:
        cagr = 0

    return {
        'final_balance': round(balance, 2),
        'total_return_pct': round(total_return_pct, 1),
        'max_dd_pct': round(max_dd * 100, 1),
        'sharpe': round(sharpe, 2),
        'cagr_pct': round(cagr * 100, 1),
        'executed_trades': executed_trades,
        'skipped_trades': skipped_trades,
        'win_rate_pct': round(wins / executed_trades * 100, 1) if executed_trades > 0 else 0,
        'doubles': len(doubles),
        'd2d_first': round(doubles[0], 1) if doubles else None,
        'd2d_avg': round(statistics.mean(d2d_intervals), 1) if d2d_intervals else None,
        'total_days': round(time_span['total_days'], 0),
    }


def print_comparison(old_result, new_result, old_name, new_name):
    """打印对比表"""
    def fmt(val, suffix=''):
        if val is None:
            return 'N/A'
        return f"{val}{suffix}"

    rows = [
        ('最终余额', f"${old_result['final_balance']:,.2f}", f"${new_result['final_balance']:,.2f}"),
        ('总收益率', fmt(old_result['total_return_pct'], '%'), fmt(new_result['total_return_pct'], '%')),
        ('CAGR', fmt(old_result['cagr_pct'], '%'), fmt(new_result['cagr_pct'], '%')),
        ('最大回撤', fmt(old_result['max_dd_pct'], '%'), fmt(new_result['max_dd_pct'], '%')),
        ('Sharpe', fmt(old_result['sharpe']), fmt(new_result['sharpe'])),
        ('翻倍次数', str(old_result['doubles']), str(new_result['doubles'])),
        ('首次翻倍(天)', fmt(old_result['d2d_first']), fmt(new_result['d2d_first'])),
        ('平均翻倍(天)', fmt(old_result['d2d_avg']), fmt(new_result['d2d_avg'])),
        ('执行交易数', str(old_result['executed_trades']), str(new_result['executed_trades'])),
        ('跳过(重叠)', str(old_result['skipped_trades']), str(new_result['skipped_trades'])),
        ('胜率', fmt(old_result['win_rate_pct'], '%'), fmt(new_result['win_rate_pct'], '%')),
        ('数据天数', fmt(old_result['total_days']), fmt(new_result['total_days'])),
    ]

    print(f"\n{'='*70}")
    print(f"  SOL/1h 自动切换 — 新旧配置对比")
    print(f"  初始资金: ${INITIAL_BALANCE}  |  仓位: {POSITION_PCT*100:.0f}%  |  复利模式")
    print(f"{'='*70}")
    print(f"  {'指标':<16} {'旧配置':>20} {'新配置':>20}")
    print(f"  {'-'*16} {'-'*20} {'-'*20}")

    for label, old_val, new_val in rows:
        print(f"  {label:<16} {old_val:>20} {new_val:>20}")

    print(f"\n  旧: {old_name}")
    print(f"  新: {new_name}")
    print(f"{'='*70}")


def save_report(result, config, time_span, output_dir):
    """保存报告 JSON"""
    os.makedirs(output_dir, exist_ok=True)
    report = {
        'config': config,
        'result': result,
        'time_span': time_span,
        'parameters': {
            'initial_balance': INITIAL_BALANCE,
            'position_pct': POSITION_PCT,
            'mode': 'compound',
        },
        'generated_at': datetime.now().isoformat(),
    }
    safe_name = config['name'].replace('/', '_').replace(' ', '_')
    path = os.path.join(output_dir, f"route_a_{safe_name}.json")
    with open(path, 'w', encoding='utf-8') as f:
        json.dump(report, f, indent=2, ensure_ascii=False)
    print(f"  报告已保存: {path}")


def main():
    if not os.path.exists(DB_PATH):
        print(f"数据库不存在: {DB_PATH}")
        return

    print(f"数据库: {DB_PATH}")
    print(f"目标: SOL/1h 新旧配置对比回测")

    # 时间跨度
    time_span = get_time_span(DB_PATH)
    print(f"数据跨度: {time_span['total_candles']} 根 K 线 = {time_span['total_days']:.0f} 天")

    # 旧配置
    print(f"\n--- 旧配置: {OLD_CONFIG['name']} ---")
    old_trades = get_trades(DB_PATH, OLD_CONFIG['regime_map'])
    print(f"  提取交易: {len(old_trades)} 笔")
    old_result = simulate(old_trades, time_span)

    # 新配置
    print(f"\n--- 新配置: {NEW_CONFIG['name']} ---")
    new_trades = get_trades(DB_PATH, NEW_CONFIG['regime_map'])
    print(f"  提取交易: {len(new_trades)} 笔")
    new_result = simulate(new_trades, time_span)

    # 对比
    print_comparison(old_result, new_result, OLD_CONFIG['name'], NEW_CONFIG['name'])

    # 保存报告
    report_dir = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'reports', 'route_a')
    save_report(old_result, OLD_CONFIG, time_span, report_dir)
    save_report(new_result, NEW_CONFIG, time_span, report_dir)


if __name__ == '__main__':
    main()
