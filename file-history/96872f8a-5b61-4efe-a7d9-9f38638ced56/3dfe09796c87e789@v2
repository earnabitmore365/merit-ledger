"""RSI Reversal — 快速RSI极值反转（短周期专用）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class RSIReversalConfig:
    period: int = 5
    overbought: float = 85.0
    oversold: float = 15.0


class RSIReversal(Strategy):
    def __init__(self, exchange=None, config: Optional[RSIReversalConfig] = None):
        self.exchange = exchange
        self.config = config or RSIReversalConfig()

    @property
    def name(self) -> str:
        return "rsireversal"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        if not klines or len(klines) < self.config.period + 2:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        closes = [c["close"] for c in klines]
        rsi = self._rsi(closes, self.config.period)
        prev_rsi = self._rsi(closes[:-1], self.config.period)

        if rsi < self.config.oversold and prev_rsi >= self.config.oversold:
            signal = Signal.BUY
        elif rsi > self.config.overbought and prev_rsi <= self.config.overbought:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=abs(rsi - 50) / 50,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"rsi": rsi, "prev_rsi": prev_rsi})

    def _rsi(self, prices, period):
        if len(prices) < period + 1:
            return 50.0
        gains = losses = 0.0
        for i in range(len(prices) - period, len(prices)):
            d = prices[i] - prices[i - 1]
            if d > 0:
                gains += d
            else:
                losses -= d
        if losses == 0:
            return 100.0
        rs = gains / losses
        return 100 - 100 / (1 + rs)
