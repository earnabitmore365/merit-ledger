"""Z-Score — 价格标准差偏离均值回归"""
from typing import Dict, List, Optional
from dataclasses import dataclass
import math
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class ZScoreConfig:
    period: int = 14
    threshold: float = 2.5


class ZScore(Strategy):
    def __init__(self, exchange=None, config: Optional[ZScoreConfig] = None):
        self.exchange = exchange
        self.config = config or ZScoreConfig()

    @property
    def name(self) -> str:
        return "zscore"

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        p = self.config.period
        if not klines or len(klines) < p + 1:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        closes = [c["close"] for c in klines[-p:]]
        mean = sum(closes) / len(closes)
        std = math.sqrt(sum((x - mean) ** 2 for x in closes) / len(closes))
        if std == 0:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"])

        z = (closes[-1] - mean) / std

        prev_closes = [c["close"] for c in klines[-(p + 1):-1]]
        prev_mean = sum(prev_closes) / len(prev_closes)
        prev_std = math.sqrt(sum((x - prev_mean) ** 2 for x in prev_closes) / len(prev_closes))
        prev_z = (prev_closes[-1] - prev_mean) / prev_std if prev_std > 0 else 0

        if z < -self.config.threshold and prev_z >= -self.config.threshold:
            signal = Signal.BUY
        elif z > self.config.threshold and prev_z <= self.config.threshold:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=min(abs(z) / 3, 1.0),
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"zscore": z, "prev_z": prev_z, "mean": mean, "std": std})
