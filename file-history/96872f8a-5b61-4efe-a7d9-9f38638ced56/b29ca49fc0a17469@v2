"""Connors RSI — 三合一复合RSI（RSI(2) + 连涨跌天数 + 百分位排名）"""
from typing import Dict, List, Optional
from dataclasses import dataclass
from core.strategy import Strategy, Signal, TradingSignal


@dataclass
class ConnorsRSIConfig:
    rsi_period: int = 2
    streak_rsi_period: int = 3
    percentile_period: int = 100
    overbought: float = 90.0
    oversold: float = 10.0


class ConnorsRSI(Strategy):
    def __init__(self, exchange=None, config: Optional[ConnorsRSIConfig] = None):
        self.exchange = exchange
        self.config = config or ConnorsRSIConfig()

    @property
    def name(self) -> str:
        return "connorsrsi"

    def _rsi(self, values, period):
        if len(values) < period + 1:
            return 50.0
        gains = losses = 0.0
        for i in range(len(values) - period, len(values)):
            d = values[i] - values[i - 1]
            if d > 0:
                gains += d
            else:
                losses -= d
        if losses == 0:
            return 100.0
        rs = gains / losses
        return 100 - 100 / (1 + rs)

    def _streak(self, closes):
        streak = 0
        for i in range(len(closes) - 1, 0, -1):
            if closes[i] > closes[i - 1]:
                if streak >= 0:
                    streak += 1
                else:
                    break
            elif closes[i] < closes[i - 1]:
                if streak <= 0:
                    streak -= 1
                else:
                    break
            else:
                break
        return streak

    def _streak_series(self, closes):
        series = [0]
        streak = 0
        for i in range(1, len(closes)):
            if closes[i] > closes[i - 1]:
                streak = streak + 1 if streak >= 0 else 1
            elif closes[i] < closes[i - 1]:
                streak = streak - 1 if streak <= 0 else -1
            else:
                streak = 0
            series.append(streak)
        return series

    def _percentile_rank(self, closes, period):
        if len(closes) < period + 1:
            return 50.0
        current = closes[-1]
        prev_close = closes[-2]
        pct_change = (current - prev_close) / prev_close * 100 if prev_close != 0 else 0
        changes = []
        for i in range(max(1, len(closes) - period), len(closes)):
            c = (closes[i] - closes[i - 1]) / closes[i - 1] * 100 if closes[i - 1] != 0 else 0
            changes.append(c)
        if not changes:
            return 50.0
        count_below = sum(1 for c in changes if c < pct_change)
        return count_below / len(changes) * 100

    def generate_signal(self, coin: str, klines: List[Dict] = None) -> TradingSignal:
        need = self.config.percentile_period + 5
        if not klines or len(klines) < need:
            return TradingSignal(signal=Signal.HOLD, confidence=0.0, coin=coin,
                                 timestamp=klines[-1]["time"] if klines else 0)

        closes = [c["close"] for c in klines]

        rsi_val = self._rsi(closes, self.config.rsi_period)
        streak_series = self._streak_series(closes)
        streak_rsi = self._rsi(streak_series, self.config.streak_rsi_period)
        pct_rank = self._percentile_rank(closes, self.config.percentile_period)

        crsi = (rsi_val + streak_rsi + pct_rank) / 3

        prev_closes = closes[:-1]
        prev_rsi = self._rsi(prev_closes, self.config.rsi_period)
        prev_streak_series = self._streak_series(prev_closes)
        prev_streak_rsi = self._rsi(prev_streak_series, self.config.streak_rsi_period)
        prev_pct_rank = self._percentile_rank(prev_closes, self.config.percentile_period)
        prev_crsi = (prev_rsi + prev_streak_rsi + prev_pct_rank) / 3

        if crsi < self.config.oversold and prev_crsi >= self.config.oversold:
            signal = Signal.BUY
        elif crsi > self.config.overbought and prev_crsi <= self.config.overbought:
            signal = Signal.SELL
        else:
            signal = Signal.HOLD

        return TradingSignal(signal=signal, confidence=abs(crsi - 50) / 50,
                             coin=coin, timestamp=klines[-1]["time"],
                             metadata={"crsi": crsi, "rsi2": rsi_val,
                                        "streak_rsi": streak_rsi, "pct_rank": pct_rank})
