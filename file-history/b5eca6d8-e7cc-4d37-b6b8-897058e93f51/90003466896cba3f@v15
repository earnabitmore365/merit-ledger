# 队伍划分
TEAMS = {
    'short': ['1m', '5m', '15m', '30m'],
    'mid':   ['1h', '2h', '4h'],
    'long':  ['8h', '12h', '1d'],
}

TOP_N = 5  # 每维度取前5名

# 核心选人逻辑（gate3v41_team.py:51-68）
for dim in ALL_DIMS:   # 13个维度（6 regime + 7 sub_phase）
    pnl_key = f'{dim}_pnl'
    insuf_key = f'{dim}_insufficient' if dim != 'all' else None

    eligible = []
    for r in all_candidates:
        if insuf_key and r[insuf_key]:       # 交易<10笔的跳过
            continue
        pnl = r[pnl_key] if r[pnl_key] is not None else 0
        eligible.append((r, pnl))

    eligible.sort(key=lambda x: x[1], reverse=True)   # 按 PnL 排

    for r, pnl in eligible[:TOP_N]:          # 取前5
        cid = r['combo_id']
        if cid not in selected_combos:
            selected_combos[cid] = set()
        selected_combos[cid].add(dim)        # 记录在哪些维度入选

# 去重：同(strategy, coin)只留 all_pnl 最高的周期
by_strat_coin = {}
for cid, dims in selected_combos.items():
    r = next(x for x in all_candidates if x['combo_id'] == cid)
    key = (r['strategy'], r['coin'])
    pnl = r['all_pnl'] or 0
    if key not in by_strat_coin or pnl > by_strat_coin[key][1]:
        by_strat_coin[key] = (cid, pnl, dims)
```

**选人标准：13 维度 × TOP 5 PnL → 去重 → 进入 MC**

