for c in combos:
    interval = c['interval']
    coin = c['coin']
    trades = c['total_trades']
    klines = kline_counts.get((coin, interval), 0)
    x = X_MAP[interval]
    threshold = klines // x                    # 门槛 = K线数 / X值
    is_pass = trades >= threshold              # 交易数 >= 门槛

