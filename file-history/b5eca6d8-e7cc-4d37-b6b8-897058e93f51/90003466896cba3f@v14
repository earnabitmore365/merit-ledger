## 六、实盘策略代码

### mean_reversion（完整）

```python
# strategy_mean_reversion.py
class MeanReversion(Strategy):
    REQUIRES = ['sma']
    # config: period=20, buy_threshold=0.995, sell_threshold=1.005

    def generate_signal(self, coin, klines=None):
        current = klines[-1]["close"]
        sma_series = get_indicator('sma', period=20)
        ma = sma_series[self.current_idx]

        if current < ma * 0.995:     # 价格低于SMA 0.5%
            return Signal.BUY
        elif current > ma * 1.005:   # 价格高于SMA 0.5%
            return Signal.SELL
        else:
            return Signal.HOLD
```

### MirrorStrategy v2.1（完整）

```python
# mirror.py — SMA(200) 翻转
class MirrorStrategy(Strategy):
    def _mirror_klines(self, klines):
        closes = [k['close'] for k in klines]
        sma200 = sum(closes[-200:]) / min(200, len(closes))
        mirrored = []
        for k in klines:
            m = dict(k)
            m['open']  = 2 * sma200 - k['open']
            m['close'] = 2 * sma200 - k['close']
            m['high']  = 2 * sma200 - k['low']     # swap
            m['low']   = 2 * sma200 - k['high']    # swap
            mirrored.append(m)
        return mirrored

    def generate_signal(self, coin, klines=None):
        mirrored = self._mirror_klines(klines)
        init_cache(coin, self._interval, mirrored, db_path=':memory:')
        self._inner.current_idx = len(mirrored) - 1
        return self._inner.generate_signal(coin, mirrored)   # 信号不翻转
```

