paired_trades: id, combo_id, open_candle_idx, close_candle_idx,
    open_time, close_time, holding_bars, direction,
    entry_price, exit_price, capital, position_size,
    pnl, r_value, balance_after, close_type, regime_at_open,
    fee, funding_cost, slippage_cost, mfe, mae,
    open_atr_pct, open_volume, funding_count

-- Regime 时间线
regime_timeline: coin, interval, candle_idx, candle_time_ms, regime, adx, sma_direction

-- 运行元数据
run_metadata: key, value
```

