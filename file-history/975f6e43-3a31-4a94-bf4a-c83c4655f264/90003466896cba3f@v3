# ==================== FlipKlinesStrategy ====================

class FlipKlinesStrategy:
    """翻转K线但不翻转信号的包装策略

    跟 MirrorStrategy 的区别：Mirror 翻转K线且翻转信号，这个只翻转K线。
    效果：均值回归策略看到翻转的数据 → "以为在抄底" → 实际在追涨 → 变成趋势跟踪。
    """

    def __init__(self, inner_strategy, interval='30m'):
        self._inner = inner_strategy
        self._interval = interval

    @property
    def name(self):
        return self._inner.name + '_flip'

    @name.setter
    def name(self, value):
        pass

    @property
    def current_idx(self):
        return getattr(self._inner, 'current_idx', 0)

    @current_idx.setter
    def current_idx(self, value):
        self._inner.current_idx = value

    def _flip_klines(self, klines):
        """翻转 OHLCV — 复用 mirror.py 的逻辑"""
        if not klines:
            return klines
        max_price = max(k['high'] for k in klines)
        flipped = []
        for k in klines:
            m = dict(k)
            m['open'] = max_price - k['open']
            m['close'] = max_price - k['close']
            m['high'] = max_price - k['low']
            m['low'] = max_price - k['high']
            flipped.append(m)
        return flipped

    def generate_signal(self, coin, klines=None):
        """翻转K线 → 跑策略 → 信号不翻转"""
        if not klines:
            from core.strategy.base import Signal, TradingSignal
            return TradingSignal(signal=Signal.HOLD, coin=coin)

        # 1. 翻转K线
        flipped = self._flip_klines(klines)

        # 2. 用翻转数据初始化 indicator_cache
        try:
            from core.indicator_cache import init_cache
            init_cache(coin, self._interval, flipped)
        except Exception:
            pass

        # 3. 设置 current_idx
        self._inner.current_idx = len(flipped) - 1

        # 4. 跑策略，信号不翻转
        return self._inner.generate_signal(coin, flipped)


