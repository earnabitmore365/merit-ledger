    def register(cls, name: str, manager_class: type):
        """注册风险管理类
        
        Args:
            name: 名称
            manager_class: 管理类
        """
        cls._managers[name.lower()] = manager_class
    
    @classmethod
    def create(cls, name: str, config: RiskConfig = None) -> RiskManager:
        """创建风险管理实例
        
        Args:
            name: 风险管理类型
            config: 配置
        
        Returns:
            RiskManager: 风险管理实例
        """
        name_lower = name.lower()
        if name_lower in cls._managers:
            return cls._managers[name_lower](config)
        raise ValueError(f"Unknown risk manager: {name}")
    
    @classmethod
    def list_managers(cls) -> List[str]:
        """列出所有可用的风险管理类型"""
        return list(cls._managers.keys())


