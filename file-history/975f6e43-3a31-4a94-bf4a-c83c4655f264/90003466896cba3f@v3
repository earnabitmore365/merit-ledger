            self._ws.subscribe_private()
            self._connected = True
            logger.info(f"BitMEX 已连接 ({'测试网' if self.testnet else '主网'})")
        else:
            # WebSocket 失败不阻塞，REST 仍可用
            self._connected = True
            logger.warning("WebSocket 连接失败，仅使用 REST API")

        return self._connected

