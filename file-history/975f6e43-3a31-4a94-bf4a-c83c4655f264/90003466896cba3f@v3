    # ═══════════════════════════════════════════════
    # REST API 基础
    # ═══════════════════════════════════════════════

    def _request(self, verb: str, path: str, data: dict = None,
                 query: dict = None, retries: int = 5) -> dict:
        """发送 REST 请求（网络错误 + 可重试HTTP错误 自动重试）

        重试策略：
          - 网络超时/连接断开：重试，指数退避 2/4/8/16/32 秒
          - HTTP 429（限速）：重试，等 Retry-After 或 5 秒
          - HTTP 503（过载）：重试，等 5 秒
          - HTTP 4xx 其他：不重试（客户端错误）
          - HTTP 5xx 其他：重试（服务器临时故障）

        Args:
            verb: HTTP 方法（GET/POST/PUT/DELETE）
            path: API 路径（不含 base URL，如 /api/v1/order）
            data: POST/PUT 请求体
            query: GET 查询参数
            retries: 最大重试次数（默认5）

        Returns:
            dict: 响应 JSON
        """
        raw_path = path
        url = self.base_url + path

        # 查询参数
        if query:
            qs = urllib.parse.urlencode(query)
            path = f"{path}?{qs}"
            url = f"{url}?{qs}"

        # 请求体
        body_str = ''
        body_bytes = None
        if data:
            body_str = json.dumps(data, separators=(',', ':'))
            body_bytes = body_str.encode('utf-8')

        for attempt in range(retries + 1):
            # 每次重试重新签名（nonce 会变）
            headers = auth_headers(self.api_key, self.api_secret,
                                   verb.upper(), path, body_str)
            req = urllib.request.Request(
                url, data=body_bytes, headers=headers,
                method=verb.upper(),
            )
            try:
                with urllib.request.urlopen(req, timeout=20) as resp:
                    return json.loads(resp.read().decode('utf-8'))
            except urllib.error.HTTPError as e:
                error_body = e.read().decode('utf-8') if e.fp else ''
                code = e.code

                # 可重试的 HTTP 错误
                if code == 429:
                    # 限速：读 Retry-After，没有就等 5 秒
                    retry_after = int(e.headers.get('Retry-After', 5))
                    wait = min(retry_after, 30)
                    if attempt < retries:
                        logger.warning(f"HTTP 429 限速 {verb} {raw_path}，等{wait}s重试({attempt+1}/{retries})")
                        time.sleep(wait)
                        continue
                elif code == 503 or code >= 500:
                    # 服务器过载/错误：重试
                    if attempt < retries:
                        wait = min(2 ** attempt + 1, 30)
                        logger.warning(f"HTTP {code} {verb} {raw_path}，{wait}s后重试({attempt+1}/{retries})")
                        time.sleep(wait)
                        continue

                # 不可重试或重试次数用完
                logger.error(f"HTTP {code} {verb} {raw_path}: {error_body}")
                try:
                    return {'error': json.loads(error_body)}
                except Exception:
                    return {'error': {'message': error_body}}
            except Exception as e:
                if attempt < retries:
                    wait = min(2 ** attempt + 1, 30)  # 3s, 5s, 9s, 17s, 33s
                    logger.warning(f"请求失败 {verb} {raw_path}: {e}，{wait}s后重试({attempt+1}/{retries})")
                    time.sleep(wait)
                else:
                    logger.error(f"请求失败 {verb} {raw_path}: {e}（已重试{retries}次）")
                    return {'error': {'message': str(e)}}

    def _get(self, path: str, query: dict = None) -> dict:
        return self._request('GET', path, query=query)

    def _post(self, path: str, data: dict = None) -> dict:
        return self._request('POST', path, data=data)

    def _put(self, path: str, data: dict = None) -> dict:
        return self._request('PUT', path, data=data)

    def _delete(self, path: str, data: dict = None) -> dict:
