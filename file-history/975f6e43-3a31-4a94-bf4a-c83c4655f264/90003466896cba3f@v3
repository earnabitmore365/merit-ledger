class PaperWrapper:
    """Paper Trade 包装器 — 真实行情 + 虚拟记账

    包装 BitMEXAdapter：行情透传，交易虚拟执行。
    """

    def __init__(self, real_adapter, initial_balance=500.0, leverage=10):
        self._real = real_adapter
        self._balance = initial_balance
        self._available = initial_balance
        self._leverage = leverage
        self._position = None  # {'side': 'LONG'/'SHORT', 'size': int, 'entry_price': float, 'coin': str}
        self._trades = []  # 交易记录
        self._logger = logging.getLogger('paper')
        self._logger.info(f"Paper Trade 启动: 余额=${initial_balance:.2f}, 杠杆={leverage}x")

    # === 行情透传 ===
    def connect(self):
        return self._real.connect()

    def disconnect(self):
        return self._real.disconnect()

    def get_price(self, coin):
        return self._real.get_price(coin)

    def get_klines(self, coin, interval='1h', limit=200):
        return self._real.get_klines(coin, interval, limit)

    def get_orderbook(self, coin, depth=25):
        return self._real.get_orderbook(coin, depth)

    def get_best_bid_ask(self, coin):
        return self._real.get_best_bid_ask(coin)

    def get_funding_rate(self, coin):
        return self._real.get_funding_rate(coin)

    def get_instrument_info(self, coin):
        return self._real.get_instrument_info(coin)

    def health_check(self):
        return self._real.health_check()

    def get_exchange_name(self):
        return 'BitMEX-Paper'

    @property
    def testnet(self):
        return getattr(self._real, 'testnet', False)

    # === 虚拟交易 ===
    def get_balance(self, currency='USDt'):
        unrealized = self._calc_unrealized_pnl()
        return {
            'usdc': self._balance,
            'available': self._available,
            'unrealized_pnl': unrealized,
        }

    def _calc_unrealized_pnl(self):
        if not self._position:
            return 0.0
        try:
            current_price = self._real.get_price(self._position['coin'])
            qty_in_coin = self._position['size'] / self._real._get_u2p(self._position['coin'])
            if self._position['side'] == 'LONG':
                return (current_price - self._position['entry_price']) * qty_in_coin
            else:
                return (self._position['entry_price'] - current_price) * qty_in_coin
        except Exception:
            return 0.0

    def get_positions(self):
        if self._position:
            from exchange.base import Position
            unrealized = self._calc_unrealized_pnl()
            return [Position(
                coin=self._position['coin'],
                side='LONG' if self._position['side'] == 'LONG' else 'SHORT',
                size=self._position['size'],
                entry_price=self._position['entry_price'],
                unrealized_pnl=unrealized,
                leverage=self._leverage,
            )]
        return []

    def get_position(self, coin):
        positions = self.get_positions()
        for p in positions:
            if p.coin == coin:
                return p
        return None

    def set_leverage(self, coin, leverage):
        self._leverage = leverage
        return True

    def coin_to_contracts(self, coin, coin_qty):
        return self._real.coin_to_contracts(coin, coin_qty)

    def place_order(self, order):
        """虚拟下单"""
        from exchange.base import OrderResult
        price = self._real.get_price(order.coin)
        contracts = order.quantity

        self._logger.info(
            f"[PAPER] {order.side} {order.coin} qty={contracts} @ ${price:.4f}"
        )

        # 记录交易
        self._trades.append({
            'time': datetime.now().isoformat(),
            'coin': order.coin,
            'side': order.side,
            'quantity': contracts,
            'price': price,
        })

        # 更新持仓
        side = 'LONG' if order.side == 'BUY' else 'SHORT'
        self._position = {
            'coin': order.coin,
            'side': side,
            'size': contracts,
            'entry_price': price,
        }

        # 更新保证金
        u2p = self._real._get_u2p(order.coin)
        notional = (contracts / u2p) * price
        margin = notional / self._leverage
        self._available = self._balance - margin

        return OrderResult(
            success=True,
            order_id=f'paper_{len(self._trades)}',
            filled_price=price,
            filled_qty=contracts,
            message='Paper trade executed',
        )

    def close_position(self, coin):
        """虚拟平仓"""
        from exchange.base import OrderResult
        if not self._position or self._position['coin'] != coin:
            return OrderResult(success=False, message='No position')

        price = self._real.get_price(coin)
        pnl = self._calc_unrealized_pnl()
        self._balance += pnl
        self._available = self._balance

        self._logger.info(
            f"[PAPER] CLOSE {self._position['side']} {coin} @ ${price:.4f} PnL=${pnl:+.4f} "
            f"余额=${self._balance:.2f}"
        )

        self._trades.append({
            'time': datetime.now().isoformat(),
            'coin': coin,
            'side': 'CLOSE',
            'price': price,
            'pnl': pnl,
            'balance': self._balance,
        })

        self._position = None
        return OrderResult(success=True, filled_price=price, message=f'Paper close, PnL={pnl:+.4f}')

    def reverse_position(self, coin):
        """虚拟反手"""
        self.close_position(coin)
        # reverse 后要在 TradingSystem 里重新 place_order
        from exchange.base import OrderResult
        return OrderResult(success=True, message='Paper reverse (close side done)')

    def cancel_all_orders(self, coin=None):
        return True

    def place_stop_loss(self, coin, stop_price, quantity=None, side=None):
        return {'success': True}

    def place_take_profit(self, coin, tp_price, quantity=None, side=None):
        return {'success': True}

    def _get_u2p(self, coin):
        return self._real._get_u2p(coin)

    def _to_symbol(self, coin):
        return self._real._to_symbol(coin)


