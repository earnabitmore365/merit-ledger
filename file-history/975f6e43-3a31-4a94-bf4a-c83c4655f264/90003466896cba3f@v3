def wait_for_next_kline(interval: str, logger):
    """K 线整点对齐：sleep 到下一根 K 线收盘 + 10 秒"""
    import math
    interval_sec = INTERVAL_SECONDS.get(interval, 1800)
    now = time.time()
    next_close = math.ceil(now / interval_sec) * interval_sec
    wait = next_close - now + 10  # 多等 10 秒让数据稳定

    if wait > 0:
        logger.info(f"等待下一根 {interval} K 线: {wait:.0f}s")
        end_time = time.time() + wait
        while time.time() < end_time:
            time.sleep(min(5.0, end_time - time.time()))


