    replay_start = args.replay_start or '2026-03-14 00:00:00'
    start_dt = datetime.strptime(replay_start, '%Y-%m-%d %H:%M:%S')
    start_ms = int(start_dt.timestamp() * 1000)
    end_ms = start_ms + replay_hours * 3600 * 1000

    # 加载本地K线
    data_dir = os.path.join(os.path.dirname(__file__), 'src', 'backtest', 'data', 'historical')
    kline_path = os.path.join(data_dir, args.coin, f'{args.interval}.json')
    if not os.path.exists(kline_path):
        # 尝试从更小周期聚合
        for base in ['5m', '1m']:
            alt = os.path.join(data_dir, args.coin, f'{base}.json')
            if os.path.exists(alt):
                kline_path = alt
                break

    # 尝试加载目标周期，不存在则从 5m 聚合
    logger.info(f"[REPLAY] 尝试加载: {kline_path}")
    if os.path.exists(kline_path):
        with open(kline_path) as f:
            all_klines = _json.load(f)
        file_interval = args.interval
    else:
        # 从 5m 聚合
        alt_path = os.path.join(data_dir, args.coin, '5m.json')
        if not os.path.exists(alt_path):
            logger.error(f"[REPLAY] 找不到 {kline_path} 和 {alt_path}")
            return
        logger.info(f"[REPLAY] {args.interval}.json 不存在，从 5m 聚合")
        with open(alt_path) as f:
            all_klines = _json.load(f)
        file_interval = '5m'

    # 过滤时间范围（预留200根预热）
    interval_ms = INTERVAL_SECONDS.get(args.interval, 1800) * 1000
    warmup_bars = 200
    warmup_start = start_ms - warmup_bars * interval_ms

    # 如果K线周期不匹配，做聚合
    if file_interval != args.interval:
        from exchange.bitmex.adapter import BitMEXAdapter
        factor = INTERVAL_SECONDS[args.interval] // INTERVAL_SECONDS[file_interval]
        all_klines = BitMEXAdapter._aggregate_klines(all_klines, factor, args.interval)
        logger.info(f"[REPLAY] 聚合 {file_interval} → {args.interval}，{len(all_klines)} 根")

    # 筛选范围
    replay_klines = [k for k in all_klines if k['time'] >= warmup_start and k['time'] <= end_ms]
    logger.info(f"[REPLAY] 范围: {len(replay_klines)} 根 K 线（含 {warmup_bars} 根预热）")

    if len(replay_klines) < warmup_bars + 10:
        logger.error(f"[REPLAY] K 线不足！需要至少 {warmup_bars + 10} 根")
        return

    # 模拟交易状态
    balance = args.balance
    position = 'NO_POSITION'  # BUY / SELL / NO_POSITION
    entry_price = 0.0
    trades = []
    max_balance = balance
    max_drawdown = 0.0

    print(f"\n{'='*60}")
    print(f"  [REPLAY] 72 小时历史回放")
    print(f"  币种: {args.coin} / {args.interval}")
    print(f"  时间: {replay_start} → +{replay_hours}h")
    print(f"  K线: {len(replay_klines)} 根")
    print(f"  初始余额: ${balance:.2f}")
    print(f"{'='*60}\n")

    # 预热 RegimeDetector（用前200根K线建立摆动追踪）
    if regime_router is not None:
        warmup_data = replay_klines[:warmup_bars]
        regime_router.warmup(warmup_data)
        logger.info(f"[REPLAY] RegimeDetector 预热完成，regime={regime_router._detector.regime}")

    # 逐根喂
    for i in range(warmup_bars, len(replay_klines)):
        window = replay_klines[max(0, i - warmup_bars + 1):i + 1]
        current = replay_klines[i]
        ts = datetime.fromtimestamp(current['time'] / 1000).strftime('%m-%d %H:%M')

        # 双缓存初始化
        if regime_router is not None:
            flipped = regime_router.flip_klines(window)
            init_cache(args.coin, args.interval, window, namespace='normal')
            init_cache(args.coin, args.interval, flipped, namespace='flipped')

        # 生成信号
        try:
            signal_result = strategy.generate_signal(args.coin, window)
            signal = signal_result.signal.name if hasattr(signal_result.signal, 'name') else str(signal_result.signal)
            metadata = getattr(signal_result, 'metadata', {}) or {}
            regime = metadata.get('regime', '?')
            mode = metadata.get('mode', '?')
            fused = metadata.get('fused', False)
        except Exception as e:
            logger.error(f"[REPLAY] {ts} 信号异常: {e}")
            continue

        # 模拟交易
        price = current['close']
        action = 'NONE'

        if signal == 'BUY' and position == 'NO_POSITION':
            position = 'BUY'
            entry_price = price
            action = 'OPEN_LONG'
        elif signal == 'SELL' and position == 'NO_POSITION':
            position = 'SELL'
            entry_price = price
            action = 'OPEN_SHORT'
        elif signal == 'BUY' and position == 'SELL':
            # 平空 + 开多
            pnl = (entry_price - price) * (args.min_bet / entry_price) * args.leverage
            balance += pnl
            trades.append({'time': ts, 'side': 'SHORT', 'entry': entry_price, 'exit': price, 'pnl': pnl, 'regime': regime, 'mode': mode})
            position = 'BUY'
            entry_price = price
            action = f'REVERSE_LONG (pnl={pnl:+.2f})'
        elif signal == 'SELL' and position == 'BUY':
            # 平多 + 开空
            pnl = (price - entry_price) * (args.min_bet / entry_price) * args.leverage
            balance += pnl
            trades.append({'time': ts, 'side': 'LONG', 'entry': entry_price, 'exit': price, 'pnl': pnl, 'regime': regime, 'mode': mode})
            position = 'SELL'
            entry_price = price
            action = f'REVERSE_SHORT (pnl={pnl:+.2f})'
        elif signal == 'CLOSE' and position != 'NO_POSITION':
            if position == 'BUY':
                pnl = (price - entry_price) * (args.min_bet / entry_price) * args.leverage
            else:
                pnl = (entry_price - price) * (args.min_bet / entry_price) * args.leverage
            balance += pnl
            trades.append({'time': ts, 'side': position, 'entry': entry_price, 'exit': price, 'pnl': pnl, 'regime': regime, 'mode': mode})
            position = 'NO_POSITION'
            entry_price = 0.0
            action = f'CLOSE (pnl={pnl:+.2f})'

        # 更新回撤
        if balance > max_balance:
            max_balance = balance
        dd = (max_balance - balance) / max_balance * 100 if max_balance > 0 else 0
        if dd > max_drawdown:
            max_drawdown = dd

        # 打印（只打有动作的 + 每小时打一次状态）
        if action != 'NONE' or i % (3600 // INTERVAL_SECONDS.get(args.interval, 1800)) == 0:
            logger.info(
                f"[REPLAY] {ts} | regime={regime:4s} mode={mode:7s} "
                f"signal={signal:5s} action={action:20s} "
                f"pos={position:4s} bal=${balance:.2f} "
                f"{'[FUSE]' if fused else ''}"
            )

    # 汇总
    total_pnl = balance - args.balance
    wins = sum(1 for t in trades if t['pnl'] > 0)
    losses = sum(1 for t in trades if t['pnl'] <= 0)
    wr = wins / len(trades) * 100 if trades else 0

    print(f"\n{'='*60}")
    print(f"  [REPLAY] 回放完成")
    print(f"  交易数: {len(trades)} (赢{wins}/亏{losses}, WR={wr:.0f}%)")
    print(f"  总 PnL: ${total_pnl:+.2f}")
    print(f"  最终余额: ${balance:.2f}")
    print(f"  最大回撤: {max_drawdown:.1f}%")
    print(f"{'='*60}")

    # 打印每笔交易
    print(f"\n  交易明细:")
    for t in trades:
        print(f"  {t['time']} | {t['side']:5s} | ${t['entry']:.4f}→${t['exit']:.4f} | PnL=${t['pnl']:+.2f} | {t['regime']}/{t['mode']}")


if __name__ == '__main__':
    main()
