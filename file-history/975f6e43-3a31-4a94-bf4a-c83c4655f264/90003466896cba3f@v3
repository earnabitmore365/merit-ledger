class FixedPercentSizing:
    """固定百分比仓位管理 — 老板的标准开仓规则

    规则（不变的）：
    - 本金 $500
    - 每笔 10% 本金
    - 最低 $100 保证金
    - 10x 杠杆，逐仓
    - 不设止损（让强平兜底）
    """

    def __init__(self, balance=500, bet_pct=0.10, min_bet=100, leverage=10):
        """
        Args:
            balance: 初始本金（仅作默认参考，实际以 current_balance 为准）
            bet_pct: 每笔下注占本金比例
            min_bet: 最低保证金
            leverage: 杠杆倍数
        """
        self.default_balance = balance
        self.bet_pct = bet_pct
        self.min_bet = min_bet
        self.leverage = leverage

    def calc_position_size(self, current_balance: float) -> dict:
        """计算开仓参数

        Args:
            current_balance: 当前可用余额

        Returns:
            dict: {
                'margin': 保证金（美元），
                'notional': 名义价值（保证金 × 杠杆），
                'leverage': 杠杆倍数,
                'isolated': True = 逐仓,
                'stop_loss': False = 不设止损（强平兜底）,
            }
        """
        margin = max(current_balance * self.bet_pct, self.min_bet)
        margin = min(margin, current_balance)  # 不能超过余额
        return {
            'margin': round(margin, 2),
            'notional': round(margin * self.leverage, 2),
            'leverage': self.leverage,
            'isolated': True,
            'stop_loss': False,
        }

    def __repr__(self) -> str:
        return (
            f"<FixedPercentSizing: {self.bet_pct:.0%} bet, "
            f"min=${self.min_bet}, {self.leverage}x leverage>"
        )
