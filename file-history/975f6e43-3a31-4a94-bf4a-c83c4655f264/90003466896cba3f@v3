        if self._ws and self._ws.is_connected():
            price = self._ws.get_last_price(symbol)
            if price and price > 0:
                return price

        # REST fallback
        result = self._get(f'{API_BASE}/instrument', query={
            'symbol': symbol,
            'columns': 'lastPrice',
        })

        if isinstance(result, list) and result:
            return float(result[0].get('lastPrice', 0))
        return 0.0

    def get_orderbook(self, coin: str, depth: int = 25) -> dict:
        """获取 orderbook

        Returns:
            dict: {'bids': [{'price': ..., 'size': ...}],
                   'asks': [{'price': ..., 'size': ...}]}
        """
        symbol = self._to_symbol(coin)

        # 先试 WebSocket
        if self._ws and self._ws.is_connected():
            bid = self._ws.get_best_bid(symbol)
            ask = self._ws.get_best_ask(symbol)
            if bid and ask:
                return {
                    'bids': [{'price': bid}],
                    'asks': [{'price': ask}],
                }

        # REST
        result = self._get(f'{API_BASE}/orderBook/L2', query={
            'symbol': symbol,
            'depth': depth,
        })

        if isinstance(result, list):
            bids = [{'price': r['price'], 'size': r['size']}
                    for r in result if r.get('side') == 'Buy']
            asks = [{'price': r['price'], 'size': r['size']}
                    for r in result if r.get('side') == 'Sell']
            return {'bids': bids, 'asks': asks}
        return {'bids': [], 'asks': []}

    def get_best_bid_ask(self, coin: str) -> tuple:
        """获取最优买卖价 (bid, ask)"""
        book = self.get_orderbook(coin, depth=1)
        bid = book['bids'][0]['price'] if book['bids'] else 0
        ask = book['asks'][0]['price'] if book['asks'] else 0
        return bid, ask

    @staticmethod
    def _aggregate_klines(klines_base: List[Dict], factor: int,
                          target_minutes: int, base_minutes: int) -> List[Dict]:
        """将小周期 K 线聚合成大周期

        ⚠️ BitMEX timestamp 是收盘时间（"end of the period"），
        必须先减去 base_interval 转为开盘时间再做边界对齐。

        Args:
            klines_base: 基础周期 K 线（时间正序）
            factor: 聚合倍数（3=15m, 6=30m）
            target_minutes: 目标周期分钟数（15 或 30）
            base_minutes: 基础周期分钟数（5）
        """
        if not klines_base:
            return []

        interval_ms = target_minutes * 60 * 1000
        base_ms = base_minutes * 60 * 1000

        # 按时间边界分组（用开盘时间对齐）
        groups = {}
        for k in klines_base:
            ts = k['timestamp']
            open_time = ts - base_ms  # 收盘时间 → 开盘时间
            boundary = (open_time // interval_ms) * interval_ms
            if boundary not in groups:
                groups[boundary] = []
            groups[boundary].append(k)

        # 聚合每组
        result = []
        for boundary_ts in sorted(groups.keys()):
            group = groups[boundary_ts]
            if len(group) < factor:
                continue  # 不完整的组丢弃
            group = sorted(group, key=lambda x: x['timestamp'])[:factor]
            result.append({
                'timestamp': group[-1]['timestamp'],
                'time': group[-1]['time'],
                'open': group[0]['open'],
                'high': max(k['high'] for k in group),
                'low': min(k['low'] for k in group),
                'close': group[-1]['close'],
                'volume': sum(k['volume'] for k in group),
            })
        return result

    def get_klines(self, coin: str, interval: str = '1h',
                   limit: int = 100) -> List[Dict]:
        """获取 K 线数据（支持 15m/30m 本地聚合）

        Args:
            coin: 币种
            interval: K线周期（1m, 5m, 15m, 30m, 1h, 1d）
            limit: 获取数量（最大 1000）

        Returns:
            List[Dict]: K 线列表
        """
        # 15m/30m 走本地聚合路径
        if interval in AGGREGATE_MAP:
            base_interval, factor = AGGREGATE_MAP[interval]
            target_minutes = int(interval.replace('m', ''))
            base_minutes = int(base_interval.replace('m', ''))
            raw_limit = min(limit * factor + factor, 1000)
            raw_klines = self.get_klines(coin, base_interval, raw_limit)
            aggregated = self._aggregate_klines(
                raw_klines, factor, target_minutes, base_minutes)
            return aggregated[-limit:] if len(aggregated) > limit else aggregated

        symbol = self._to_symbol(coin)
        bin_size = INTERVAL_MAP.get(interval, interval)

        result = self._get(f'{API_BASE}/trade/bucketed', query={
            'binSize': bin_size,
            'symbol': symbol,
            'count': min(limit, 1000),
            'reverse': 'true',  # 最新在前
            'partial': 'false',
        })

        if not isinstance(result, list):
            return []

        klines = []
        for r in reversed(result):  # 反转为时间正序
            ts = r.get('timestamp', '')
            try:
                dt = datetime.fromisoformat(ts.replace('Z', '+00:00'))
                ts_ms = int(dt.timestamp() * 1000)
            except Exception:
                ts_ms = 0

            klines.append({
                'timestamp': ts_ms,
                'time': ts_ms,
                'open': float(r.get('open', 0)),
                'high': float(r.get('high', 0)),
                'low': float(r.get('low', 0)),
                'close': float(r.get('close', 0)),
                'volume': float(r.get('volume', 0)),
            })
        return klines

    # ═══════════════════════════════════════════════
    # 订单操作
    # ═══════════════════════════════════════════════

    def place_order(self, order: OrderRequest) -> OrderResult:
        """下单

        MARKET → Taker 市价单
        LIMIT  → Maker postOnly 限价单（自动追价）

        size 单位：外部传入的是**币数量**（如 706 XRP），
        adapter 自动转成 BitMEX 的合约数量（如 70600 合约）。

        Args:
            order: 订单请求（size = 币数量）

        Returns:
            OrderResult: 订单结果
        """
        symbol = self._to_symbol(order.coin)

        # 确保杠杆已设置
        self._ensure_leverage(symbol)

        # 币数量 → 合约数量
        contracts = self.coin_to_contracts(order.coin, order.size)
        if contracts <= 0:
            return OrderResult(
                success=False,
                message=f"下单量太小: {order.size} {order.coin} → {contracts} 合约",
            )

        # 用合约数量替换
        from dataclasses import replace
        order_with_contracts = replace(order, size=contracts)

        logger.info(f"下单: {order.coin} {order.size:.4f}币 → {contracts}合约")

        if order.order_type == OrderType.MARKET:
            return self._place_market_order(symbol, order_with_contracts)
        else:
            return self._place_maker_order(symbol, order_with_contracts)

    def _place_market_order(self, symbol: str, order: OrderRequest) -> OrderResult:
        """市价单（Taker）"""
        side = 'Buy' if order.side == OrderSide.BUY else 'Sell'

        data = {
            'symbol': symbol,
            'side': side,
            'orderQty': order.size,
            'ordType': 'Market',
        }

        if order.reduce_only:
            data['execInst'] = 'ReduceOnly'

        result = self._post(f'{API_BASE}/order', data=data)

        if 'error' in result:
            msg = result['error'].get('message', str(result['error']))
            return OrderResult(success=False, message=f"下单失败: {msg}")

        return OrderResult(
            success=True,
            order_id=result.get('orderID', ''),
            filled_price=float(result.get('avgPx', 0) or 0),
            filled_size=float(result.get('cumQty', 0) or 0),
            message=f"市价单成交: {result.get('ordStatus', '')}",
        )

    def _place_maker_order(self, symbol: str, order: OrderRequest) -> OrderResult:
        """Maker 限价单（postOnly + 追价）

        1. 挂 postOnly 限价单（买挂 best_bid，卖挂 best_ask）
        2. 每隔 chase_interval 秒检查：
           - 已成交 → 返回
           - 未成交 → 取消，重新挂到最新价
        3. 超过 chase_timeout → 可选转市价单兜底
        """
        side = 'Buy' if order.side == OrderSide.BUY else 'Sell'
        start_time = time.time()

        while True:
            elapsed = time.time() - start_time

            # 超时处理
            if elapsed >= self.chase_timeout:
                if self.fallback_taker:
                    logger.warning(f"Maker 超时 {elapsed:.0f}s，转市价单")
                    return self._place_market_order(symbol, order)
                else:
                    return OrderResult(
                        success=False,
                        message=f"Maker 超时 {elapsed:.0f}s，放弃",
                    )

            # 获取最新 bid/ask
            bid, ask = self.get_best_bid_ask(order.coin)
            if bid <= 0 or ask <= 0:
                time.sleep(1)
                continue

            # 挂单价格：买挂 bid，卖挂 ask
            price = bid if order.side == OrderSide.BUY else ask

            # 如果指定了价格，用指定价格
            if order.price and order.price > 0:
                price = order.price

            data = {
                'symbol': symbol,
                'side': side,
                'orderQty': order.size,
                'price': price,
                'ordType': 'Limit',
                'execInst': 'ParticipateDoNotInitiate',  # postOnly
            }

            if order.reduce_only:
                data['execInst'] += ',ReduceOnly'

            result = self._post(f'{API_BASE}/order', data=data)

            if 'error' in result:
                msg = result['error'].get('message', str(result['error']))
                # postOnly 被拒（价格会变成 Taker）→ 重试
                if 'ParticipateDoNotInitiate' in msg or 'would execute' in msg.lower():
                    logger.debug(f"postOnly 被拒，{self.chase_interval}s 后重试")
                    time.sleep(self.chase_interval)
                    continue
                return OrderResult(success=False, message=f"下单失败: {msg}")

            order_id = result.get('orderID', '')
            status = result.get('ordStatus', '')

            # 立即成交
            if status == 'Filled':
                return OrderResult(
                    success=True,
                    order_id=order_id,
                    filled_price=float(result.get('avgPx', 0) or 0),
                    filled_size=float(result.get('cumQty', 0) or 0),
                    message="Maker 成交",
                )

            # 等待成交
            time.sleep(self.chase_interval)

            # 检查订单状态
            order_status = self.get_order_status(order_id)
            current_status = order_status.get('ordStatus', '')

            if current_status == 'Filled':
                return OrderResult(
                    success=True,
                    order_id=order_id,
                    filled_price=float(order_status.get('avgPx', 0) or 0),
                    filled_size=float(order_status.get('cumQty', 0) or 0),
                    message="Maker 成交",
                )

            if current_status in ('PartiallyFilled',):
                # 部分成交：取消剩余，返回已成交部分
                self.cancel_order(order_id)
                filled = float(order_status.get('cumQty', 0) or 0)
                if filled > 0:
                    return OrderResult(
                        success=True,
                        order_id=order_id,
                        filled_price=float(order_status.get('avgPx', 0) or 0),
                        filled_size=filled,
                        message=f"Maker 部分成交 ({filled}/{order.size})",
                    )

            # 未成交：取消，下一轮追价
            self.cancel_order(order_id)
            logger.debug(f"追价: 取消 {order_id}，重新挂单")

    def cancel_order(self, order_id: str) -> bool:
        """取消订单"""
        result = self._delete(f'{API_BASE}/order', data={'orderID': order_id})
        if 'error' in result:
            return False
        return True

    def cancel_all_orders(self, coin: str = None) -> bool:
        """取消所有订单（可指定币种）"""
        data = {}
        if coin:
            data['symbol'] = self._to_symbol(coin)
        result = self._delete(f'{API_BASE}/order/all', data=data)
        if 'error' in result:
            return False
        return True

    def get_order_status(self, order_id: str) -> Dict:
        """查询订单状态"""
        result = self._get(f'{API_BASE}/order', query={
            'filter': json.dumps({'orderID': order_id}),
        })
        if isinstance(result, list) and result:
            return result[0]
        return {}

    # ═══════════════════════════════════════════════
    # 持仓管理
    # ═══════════════════════════════════════════════

    def get_positions(self) -> List[Position]:
        """获取所有持仓

        Returns:
            List[Position]: 持仓列表（size = 币数量，不是合约数）
        """
        result = self._get(f'{API_BASE}/position', query={
            'filter': json.dumps({'isOpen': True}),
        })

        if not isinstance(result, list):
            return []

        positions = []
        for r in result:
            qty = r.get('currentQty', 0)
            if qty == 0:
                continue
            coin = self._from_symbol(r.get('symbol', ''))
            u2p = self._get_u2p(coin)
            positions.append(Position(
                coin=coin,
                side='LONG' if qty > 0 else 'SHORT',
                size=abs(qty) / u2p,  # 合约 → 币
                entry_price=float(r.get('avgEntryPrice', 0) or 0),
                unrealized_pnl=float(r.get('unrealisedPnl', 0) or 0) / 1e6,
            ))
        return positions

    def get_position(self, coin: str) -> Optional[Position]:
        """获取指定币种持仓

        Returns:
            Position: size = 币数量（不是合约数）
        """
        symbol = self._to_symbol(coin)
        result = self._get(f'{API_BASE}/position', query={
            'filter': json.dumps({'symbol': symbol}),
        })

        if isinstance(result, list) and result:
            r = result[0]
            qty = r.get('currentQty', 0)
            if qty != 0:
                u2p = self._get_u2p(coin)
                return Position(
                    coin=coin,
                    side='LONG' if qty > 0 else 'SHORT',
                    size=abs(qty) / u2p,  # 合约 → 币
                    entry_price=float(r.get('avgEntryPrice', 0) or 0),
                    unrealized_pnl=float(r.get('unrealisedPnl', 0) or 0) / 1e6,
                )
        return None

    def reverse_position(self, coin: str) -> OrderResult:
        """反手：平掉当前持仓并反向开仓（市价单）"""
        pos = self.get_position(coin)
        if not pos:
            return OrderResult(success=False, message='无持仓，无法反手')

        # 1. 平仓
        close_result = self.close_position(coin)
        if not close_result.success:
            return OrderResult(success=False,
                               message=f'反手平仓失败: {close_result.message}')

        # 2. 反向开仓（原来 LONG → 开 SHORT，原来 SHORT → 开 LONG）
        new_side = OrderSide.SELL if pos.side == 'LONG' else OrderSide.BUY
        order = OrderRequest(
            coin=coin,
            side=new_side,
            order_type=OrderType.MARKET,
            size=pos.size,
        )
        open_result = self.place_order(order)
        if not open_result.success:
            logger.error(f"反手开仓失败（已平仓）: {open_result.message}")
        return open_result

    def close_position(self, coin: str) -> OrderResult:
        """平仓（市价单 + reduce_only）"""
        pos = self.get_position(coin)
        if not pos:
            return OrderResult(success=False, message='无持仓')

        # 平仓 = 反方向市价单
        close_side = OrderSide.SELL if pos.side == 'LONG' else OrderSide.BUY
        order = OrderRequest(
            coin=coin,
            side=close_side,
            order_type=OrderType.MARKET,
            size=pos.size,
            reduce_only=True,
        )
        return self.place_order(order)

    def close_position_maker(self, coin: str) -> OrderResult:
        """Maker 平仓（postOnly 限价单 + 追价）"""
        pos = self.get_position(coin)
        if not pos:
            return OrderResult(success=False, message='无持仓')

        close_side = OrderSide.SELL if pos.side == 'LONG' else OrderSide.BUY
        order = OrderRequest(
            coin=coin,
            side=close_side,
            order_type=OrderType.LIMIT,
            size=pos.size,
            reduce_only=True,
        )
        return self.place_order(order)

    # ═══════════════════════════════════════════════
    # 账户管理
    # ═══════════════════════════════════════════════

    def get_balance(self, currency: str = 'USDt') -> Dict:
        """获取账户余额

        Args:
            currency: 钱包币种（'USDt' = USDT保证金，'XBt' = BTC保证金）

        Returns:
            dict: {
                'usdc': 总余额（美元）,
                'available': 可用余额,
                'margin_used': 已用保证金,
                'unrealized_pnl': 未实现盈亏,
            }
        """
        result = self._get(f'{API_BASE}/user/margin', query={'currency': currency})

        if 'error' in result:
            return {'usdc': 0, 'available': 0}

        # USDt 单位是 1e6（微美元），XBt 单位是 1e8（聪）
        divisor = 1e6 if currency == 'USDt' else 1e8

        wallet = float(result.get('walletBalance', 0)) / divisor
        available = float(result.get('availableMargin', 0)) / divisor
        margin_used = float(result.get('maintMargin', 0)) / divisor
        unrealized = float(result.get('unrealisedPnl', 0)) / divisor

        return {
            'usdc': wallet,
            'available': available,
            'margin_used': margin_used,
            'unrealized_pnl': unrealized,
        }

    # ═══════════════════════════════════════════════
    # 杠杆管理
    # ═══════════════════════════════════════════════

    def set_leverage(self, coin: str, leverage: float) -> bool:
        """设置杠杆

        Args:
            coin: 币种
            leverage: 杠杆倍数（0 = 全仓模式）
        """
        symbol = self._to_symbol(coin)
        result = self._post(f'{API_BASE}/position/leverage', data={
            'symbol': symbol,
            'leverage': leverage,
        })
        if 'error' in result:
            logger.error(f"设置杠杆失败: {result['error']}")
            return False
        self._leverage_set.add(symbol)
        return True

    def _ensure_leverage(self, symbol: str):
        """确保杠杆已设置（每个品种只设一次）"""
        if symbol not in self._leverage_set:
            coin = self._from_symbol(symbol)
            self.set_leverage(coin, self.default_leverage)

    # ═══════════════════════════════════════════════
    # 条件单（止损/止盈）
    # ═══════════════════════════════════════════════

    def place_stop_loss(self, coin: str, stop_price: float,
                        size: float, side: OrderSide) -> OrderResult:
        """止损单（触发后市价执行）

        Args:
            coin: 币种
            stop_price: 触发价
            size: 数量
            side: 方向（平多仓用 SELL，平空仓用 BUY）
        """
        symbol = self._to_symbol(coin)
        data = {
            'symbol': symbol,
            'side': 'Buy' if side == OrderSide.BUY else 'Sell',
            'orderQty': size,
            'stopPx': stop_price,
            'ordType': 'Stop',
            'execInst': 'ReduceOnly,LastPrice',
        }
        result = self._post(f'{API_BASE}/order', data=data)

        if 'error' in result:
            msg = result['error'].get('message', str(result['error']))
            return OrderResult(success=False, message=f"止损单失败: {msg}")

        return OrderResult(
            success=True,
            order_id=result.get('orderID', ''),
            message="止损单已挂",
        )

    def place_take_profit(self, coin: str, tp_price: float,
                          size: float, side: OrderSide) -> OrderResult:
        """止盈单（触发后限价执行）

        Args:
            coin: 币种
            tp_price: 触发价
            size: 数量
            side: 方向
        """
        symbol = self._to_symbol(coin)
        data = {
            'symbol': symbol,
            'side': 'Buy' if side == OrderSide.BUY else 'Sell',
            'orderQty': size,
            'price': tp_price,
            'stopPx': tp_price,
            'ordType': 'LimitIfTouched',
            'execInst': 'ReduceOnly,LastPrice',
        }
        result = self._post(f'{API_BASE}/order', data=data)

        if 'error' in result:
            msg = result['error'].get('message', str(result['error']))
            return OrderResult(success=False, message=f"止盈单失败: {msg}")

        return OrderResult(
            success=True,
            order_id=result.get('orderID', ''),
            message="止盈单已挂",
        )

    # ═══════════════════════════════════════════════
    # 资金费率
    # ═══════════════════════════════════════════════

    def get_funding_rate(self, coin: str) -> Dict:
        """获取当前资金费率

        Returns:
            dict: {
                'rate': 当前费率,
                'next_time': 下次收取时间,
            }
        """
        symbol = self._to_symbol(coin)
        result = self._get(f'{API_BASE}/instrument', query={
            'symbol': symbol,
            'columns': 'fundingRate,fundingTimestamp',
        })

        if isinstance(result, list) and result:
            return {
                'rate': float(result[0].get('fundingRate', 0) or 0),
                'next_time': result[0].get('fundingTimestamp', ''),
            }
        return {'rate': 0, 'next_time': ''}

    # ═══════════════════════════════════════════════
    # 工具方法
    # ═══════════════════════════════════════════════

    def _from_symbol(self, symbol: str) -> str:
        """BitMEX 合约代码转币种名"""
        for coin, sym in SYMBOL_MAP.items():
            if sym == symbol:
                return coin
        # fallback: 去掉 USD 后缀
        return symbol.replace('USD', '').replace('USDT', '')

    def _get_u2p(self, coin: str) -> int:
        """获取 underlyingToPositionMultiplier（币 → 合约数量的乘数）

        缓存结果，每个品种只查一次。
        例：XRP u2p=100 → 1 XRP = 100 合约
        """
        if not hasattr(self, '_u2p_cache'):
            self._u2p_cache = {}

        if coin not in self._u2p_cache:
            info = self.get_instrument_info(coin)
            self._u2p_cache[coin] = int(info.get('underlyingToPositionMultiplier', 1) or 1)

        return self._u2p_cache[coin]

    def _get_lot_size(self, coin: str) -> int:
        """获取最小下单量（合约数）"""
        if not hasattr(self, '_lot_cache'):
            self._lot_cache = {}

        if coin not in self._lot_cache:
            info = self.get_instrument_info(coin)
            self._lot_cache[coin] = int(info.get('lotSize', 1) or 1)

        return self._lot_cache[coin]

    def coin_to_contracts(self, coin: str, coin_qty: float) -> int:
        """币数量 → 合约数量（向下取整到 lotSize）

        Args:
            coin: 币种
            coin_qty: 币数量（如 706.5 XRP）

        Returns:
            int: 合约数量（如 70600）
        """
        u2p = self._get_u2p(coin)
        lot = self._get_lot_size(coin)
        contracts = int(coin_qty * u2p)
        # 向下取整到 lotSize 的整数倍
        contracts = (contracts // lot) * lot
        return contracts

    def get_instrument_info(self, coin: str) -> Dict:
        """获取合约信息（tick size、lot size 等）"""
        symbol = self._to_symbol(coin)
        result = self._get(f'{API_BASE}/instrument', query={
            'symbol': symbol,
        })
        if isinstance(result, list) and result:
            return result[0]
        return {}
