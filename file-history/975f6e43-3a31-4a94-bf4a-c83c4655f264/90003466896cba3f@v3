"""
Regime Detector — 状态机 + 持久化

核心逻辑（老板定义的两层分工）：
  形态有效性检测 → 守住现有状态（形态没破就不动）
  哨兵 → 形态破了才进来，确认新方向

状态持久化到 JSON，重启后直接读回来继续追踪（断点续传）。
"""
import json
import os
from datetime import datetime, timezone
from .validity_checker import ValidityChecker


# 合法的 regime 转换（不能跳级）
VALID_TRANSITIONS = {
    '牛': ['初熊'],
    '初牛': ['牛', '盘整', '初熊'],
    '盘整': ['初牛', '初熊'],
    '初熊': ['熊', '盘整', '初牛'],
    '熊': ['初牛'],
}


class RegimeDetector:
    """
    Regime 状态机

    维持当前 regime，持续检测有效性。
    有效性失效 → 等哨兵确认方向 → 正式切换。
    """

    def __init__(self, initial_regime: str = '盘整',
                 state_file: str = None):
        """
        Args:
            initial_regime: 初始 regime
            state_file: 状态文件路径（None = 不持久化）
        """
        self.regime = initial_regime
        self.state_file = state_file
        self.checker = ValidityChecker(initial_regime)

        # 4h 聚合器（从 1h 聚合到 4h）
        self._4h_buffer = []
        self._4h_count = 0

        # 历史记录
        self.regime_history = []  # (idx, time_ms, old_regime, new_regime, reason)

        # 尝试加载已有状态
        if state_file and os.path.exists(state_file):
            self._load_state()

    def update(self, idx: int, high: float, low: float, close: float,
               volume: float, time_ms: int = 0,
               bar_4h: dict = None) -> dict:
        """
        每根小周期K线调用一次。

        Args:
            idx: K线索引
            high/low/close/volume: 小周期 OHLCV
            time_ms: 时间戳（毫秒）
            bar_4h: 大周期 bar（可选）
                    {'high': float, 'low': float, 'close': float}
                    有值时才更新大周期追踪

        Returns:
            {
                'regime': str,          # 当前 regime
                'valid': bool,          # 有效性
                'warning': bool,        # 预警
                'invalid': bool,        # 失效（该叫哨兵了）
                'reasons': list[str],   # 原因
            }
        """
        # 更新小周期
        self.checker.update_small_tf(idx, high, low, close, volume, time_ms)

        # 更新大周期（有 bar_4h 时才更新）
        if bar_4h is not None:
            self._4h_count += 1
            self.checker.update_large_tf(
                self._4h_count,
                bar_4h['high'], bar_4h['low'], bar_4h['close'],
                bar_4h.get('volume', 0), time_ms
            )

        # 获取综合状态
        status = self.checker.get_status()

        # 升级信号：趋势确认，自动升级（不需要哨兵）
        if status.get('upgrade'):
            self.confirm_transition(
                status['upgrade'], idx, time_ms,
                f"趋势确认升级: {self.regime}→{status['upgrade']}"
            )

        return {
            'regime': self.regime,
            'valid': status['valid'],
            'warning': status['warning'],
            'invalid': status['invalid'],
            'upgrade': status.get('upgrade'),
            'reasons': status['reasons'],
        }

    def update_with_aggregation(self, idx: int, high: float, low: float,
                                close: float, volume: float,
                                time_ms: int = 0,
                                large_tf_bars: int = 4) -> dict:
        """
        每根小周期K线调用，自动聚合大周期。

        Args:
            large_tf_bars: 几根小周期合成一根大周期（默认4，即1h→4h）
        """
        # 累积到 4h 缓冲
        self._4h_buffer.append({
            'high': high, 'low': low, 'close': close, 'volume': volume,
            'time_ms': time_ms,
        })

        bar_4h = None
        if len(self._4h_buffer) >= large_tf_bars:
            # 聚合
            bar_4h = {
                'high': max(b['high'] for b in self._4h_buffer),
                'low': min(b['low'] for b in self._4h_buffer),
                'close': self._4h_buffer[-1]['close'],
                'volume': sum(b['volume'] for b in self._4h_buffer),
            }
            self._4h_buffer = []

        return self.update(idx, high, low, close, volume, time_ms, bar_4h)

    def confirm_transition(self, new_regime: str, idx: int = 0,
                           time_ms: int = 0, reason: str = '哨兵确认'):
        """
        哨兵确认后，正式切换 regime。

        Args:
            new_regime: 新的 regime
        """
        old = self.regime
        valid_targets = VALID_TRANSITIONS.get(old, [])

        if new_regime not in valid_targets:
            # 允许所有转换（极端行情可能跳级）
            pass

        self.regime = new_regime
        self.checker.set_regime(new_regime)
        self.regime_history.append(
            (idx, time_ms, old, new_regime, reason))

        if self.state_file:
            self._save_state()

    def _save_state(self):
        """保存状态到 JSON"""
        state = {
            'regime': self.regime,
            'regime_history': self.regime_history,
            '4h_count': self._4h_count,
            '4h_buffer': self._4h_buffer,
            'checker': self.checker.get_state(),
            'saved_at': datetime.now(timezone.utc).isoformat(),
        }
        with open(self.state_file, 'w') as f:
            json.dump(state, f, ensure_ascii=False, indent=2)

    def _load_state(self):
        """从 JSON 恢复状态"""
        with open(self.state_file) as f:
            state = json.load(f)
        self.regime = state['regime']
        self.regime_history = state.get('regime_history', [])
        self._4h_count = state.get('4h_count', 0)
        self._4h_buffer = state.get('4h_buffer', [])
