#!/usr/bin/env python3
"""阈值扫描：mean_reversion 原版 + v2.1 mirror（SMA(200)翻转），多阈值对比"""

import sys, os, json
sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), 'src'))

from backtest.backtest import BacktestEngine
from core.strategy.strategy_mean_reversion import MeanReversion, MeanReversionConfig


def mirror_v21(klines):
    """v2.1 SMA(200) 翻转 — 跟实盘 regime_router.flip_klines 完全一致

    flipped_price = 2 × SMA(200) - original_price
    每根K线用当前窗口的 SMA(200) 做翻转轴（滚动窗口）
    """
    if not klines:
        return []

    n = min(len(klines), 200)
    sma = sum(k['close'] for k in klines[-n:]) / n
    pivot = 2 * sma

    flipped = []
    for k in klines:
        m = dict(k)
        m['open'] = pivot - k['open']
        m['close'] = pivot - k['close']
        m['high'] = pivot - k['low']
        m['low'] = pivot - k['high']
        flipped.append(m)
    return flipped


# 测试阈值
thresholds = [
    (0.990, 1.010, '±1.0%'),
    (0.993, 1.007, '±0.7%'),
    (0.995, 1.005, '±0.5%'),
    (0.997, 1.003, '±0.3%'),
    (0.998, 1.002, '±0.2%'),
]

combos = [
    ('ETH', '1m'),
    ('XRP', '5m'),
]

print(f'{"="*95}')
print(f'  mean_reversion 阈值扫描（近60天，原版 + v2.1 SMA(200)翻转）')
print(f'{"="*95}')

for coin, interval in combos:
    print(f'\n{"─"*95}')
    print(f'  {coin} {interval}')
    print(f'{"─"*95}')
    print(f'  {"阈值":<8} {"模式":<12} {"交易数":>6} {"胜率":>8} {"PnL":>10} {"余额":>10} {"Sharpe":>8} {"赢/亏":>8}')
    print(f'  {"─"*85}')

    for buy_th, sell_th, label in thresholds:
        for mode in ['原版', 'v2.1_mirror']:
            engine = BacktestEngine(
                coin=coin,
                interval=interval,
                days=60,
                initial_capital=500,
                enable_ttp=True,
                stop_loss_pct=0.1,
                leverage=10.0,
                enable_withdraw=False,
            )

            if mode == 'v2.1_mirror':
                engine.candles = mirror_v21(engine.candles)

            config = MeanReversionConfig(
                period=20,
                buy_threshold=buy_th,
                sell_threshold=sell_th,
            )
            strategy = MeanReversion(config=config)

            result = engine.run_backtest('mean_reversion', strategy=strategy)

            if result:
                wr = result.win_rate
                if wr > 1:
                    wr = wr / 100
                print(f'  {label:<8} {mode:<12} {result.total_trades:>6} {wr:>7.1%} {result.total_return:>+10.2f} ${result.final_balance:>9.2f} {result.sharpe_ratio:>+8.4f} {result.winning_trades:>3}/{result.losing_trades:<3}')
            else:
                print(f'  {label:<8} {mode:<12}  FAILED')

print(f'\n{"="*95}')
print('v2.1_mirror = 2×SMA(200)-price 翻转（跟实盘 regime_router.flip_klines 一致）')
