#!/usr/bin/env python3
"""快速回测：验证 mean_reversion ±0.2% 新阈值在近60天的表现"""

import sys, os
sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), 'src'))

from backtest.backtest import BacktestEngine

combos = [
    ('ETH', '1m', 'mean_reversion'),
    ('XRP', '5m', 'mean_reversion'),
]

for coin, interval, strategy_name in combos:
    print(f'\n{"="*60}')
    print(f'  {coin} {interval} {strategy_name} (近60天, 新阈值 ±0.2%)')
    print(f'{"="*60}')

    engine = BacktestEngine(
        coin=coin,
        interval=interval,
        days=60,
        initial_capital=500,
        enable_ttp=True,
        stop_loss_pct=0.1,
        leverage=10.0,
        enable_withdraw=False,
    )

    result = engine.run_backtest(strategy_name)

    if result:
        print(f'  交易数: {result.total_trades}')
        print(f'  胜率: {result.win_rate:.1%}')
        print(f'  总PnL: {result.total_return:+.4f} ($1注码)')
        print(f'  最终余额: ${result.final_balance:.2f}')
        print(f'  最大回撤: {result.max_drawdown:.2%}')
        print(f'  Sharpe: {result.sharpe_ratio:.4f}')
        print(f'  赢/亏: {result.winning_trades}/{result.losing_trades}')
        if hasattr(result, 'profit_factor') and result.profit_factor:
            print(f'  盈亏比: {result.profit_factor:.2f}')
    else:
        print('  回测失败！')
